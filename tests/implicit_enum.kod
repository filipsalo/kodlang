type Direction = enum {
	North
	South
	East
	West
}

func classify(anon d: Direction) -> Direction {
	match d {
		Direction.North -> return .South
		Direction.South -> return .North
		Direction.East -> return .West
		Direction.West -> return .East
	}
	return .North
}

func main() -> int64 {
	let d: Direction = .North
	if d == Direction.North {
		print("north")
	}

	let d2: Direction = classify(Direction.East)
	if d2 == Direction.West {
		print("west")
	}

	return 0
}

// expected output:
// north
// west

// expected status:
// 0
