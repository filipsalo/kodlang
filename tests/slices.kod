// Slices on strings and arrays. The `..` separator picks out a
// `[lo, hi)` range. Either endpoint may be omitted: `s[..hi]`
// defaults lo to 0, `s[lo..]` defaults hi to `len(s)`. `s[..]`
// copies the whole thing.
func main() -> int64 {
    // String slices.
    let s: str = "hello world"
    print(s[0..5])
    print(s[6..11])
    print(s[..5])
    print(s[6..])
    print(s[..])

    // Array slices (int64).
    let xs: [int64] = [10, 20, 30, 40, 50]
    let mid: [int64] = xs[1..4]
    for x in mid { print_int(x) }
    print("--")
    let head: [int64] = xs[..3]
    for x in head { print_int(x) }
    print("--")
    let tail: [int64] = xs[2..]
    for x in tail { print_int(x) }
    print("--")

    // Array slices ([str]).
    let names: [str] = ["alpha", "beta", "gamma", "delta"]
    let middle: [str] = names[1..3]
    for n in middle { print(n) }
    return 0
}

// expected output:
// hello
// world
// hello
// world
// hello world
// 20
// 30
// 40
// --
// 10
// 20
// 30
// --
// 30
// 40
// 50
// --
// beta
// gamma
