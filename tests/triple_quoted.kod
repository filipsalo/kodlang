func check(anon name: str, ok: bool) -> none {
    if ok { print(f"ok   {name}") } else { print(f"FAIL {name}") }
}

func main() -> int64 {
    let preamble: str = """
        .text
        .globl _main
        _main:
        """
    check("dedent", ok: preamble == ".text\n.globl _main\n_main:\n")

    let label: str = "$user$main"
    let asm: str = f"""
        bl {label}
        ret
        """
    check("f-string interpolation", ok: asm == "bl $user$main\nret\n")

    // Inner indent (beyond the closing-quote anchor) is preserved.
    let nested: str = """
        outer
            inner
        outer
        """
    check("inner indent preserved", ok: nested == "outer\n    inner\nouter\n")

    // Escape sequences still work inside the body.
    let escapes: str = """
        a\tb
        """
    check("escapes", ok: escapes == "a\tb\n")

    return 0
}

// expected output:
// ok   dedent
// ok   f-string interpolation
// ok   inner indent preserved
// ok   escapes

// expected status:
// 0
