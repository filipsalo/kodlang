// Read every JSON-RPC message from stdin and echo each body back as a
// framed response. Exits cleanly on EOF. Proves the read+write framing
// round-trips an entire message stream without losing or splitting
// anything, which is the foundation an actual LSP server sits on.
import "jsonrpc"

func main() -> int64 {
    for true {
        match jsonrpc.read_message() {
            Some(body) -> jsonrpc.write_message(body)
            none -> return 0
        }
    }
    return 0
}

// expected status:
// 0
