// Unit tests for the codegen's user-facing error messages. Each test
// builds a minimal snippet that triggers the diagnostic and asserts on
// the .message field of the captured Error. New error messages should
// add a test here.

import "kod/codegen"
import "./test_support"

test "unknown function" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func main() -> int64 {
            does_not_exist()
            return 0
        }
        """)
    assert test_support.any_message_contains(errs, needle: "unknown function `does_not_exist`")
}

test "unknown method on a struct receiver" {
    let errs: [codegen.Error] = test_support.try_compile("""
        type Foo = struct { x: int64 }
        func main() -> int64 {
            let f: Foo = Foo(x: 5)
            f.does_not_exist()
            return 0
        }
        """)
    assert test_support.any_message_contains(errs, needle: "unknown method `does_not_exist`")
}

test "unknown implicit variant in call position" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func main() -> int64 {
            .NoSuchVariant()
            return 0
        }
        """)
    assert test_support.any_message_contains(errs, needle: "unknown implicit variant `.NoSuchVariant`")
}

test "struct constructor with wrong field name" {
    let errs: [codegen.Error] = test_support.try_compile("""
        type Foo = struct { x: int64 }
        func main() -> int64 {
            let f: Foo = Foo(y: 5)
            return 0
        }
        """)
    assert test_support.any_message_contains(errs, needle: "struct `Foo` has no field `y`")
}

test "passing label to an anon parameter" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func greet(anon name: str) -> none { print(name) }
        func main() -> int64 {
            greet(name: "alice")
            return 0
        }
        """)
    assert test_support.any_message_contains(errs, needle: "remove label `name`")
}

test "wrong label at call site" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func greet(name: str) -> none { print(name) }
        func main() -> int64 {
            greet(person: "alice")
            return 0
        }
        """)
    assert test_support.any_message_contains(errs, needle: "expected label `name`, got `person`")
}

test "anon parameter cannot follow a labeled parameter" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func bad(label: int64, anon other: int64) -> int64 {
            return label + other
        }
        func main() -> int64 {
            return 0
        }
        """)
    assert test_support.any_message_contains(errs, needle: "anon parameter `other` cannot follow a labeled parameter")
}

test "`is none` on a non-optional value" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func main() -> int64 {
            let n: int64 = 5
            if n is none {
                return 1
            }
            return 0
        }
        """)
    assert test_support.any_message_contains(errs, needle: "requires an optional value")
}

test "len() on a struct without a len method" {
    let errs: [codegen.Error] = test_support.try_compile("""
        type Foo = struct { x: int64 }
        func main() -> int64 {
            let f: Foo = Foo(x: 5)
            return len(f)
        }
        """)
    assert test_support.any_message_contains(errs, needle: "len() not defined for struct `Foo`")
}

test "function call missing a required label" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func greet(name: str) -> none { print(name) }
        func main() -> int64 {
            greet("alice")
            return 0
        }
        """)
    assert test_support.any_message_contains(errs, needle: "requires label `name`")
}

test "function call with too few arguments" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func greet(name: str) -> none { print(name) }
        func main() -> int64 {
            greet()
            return 0
        }
        """)
    assert test_support.any_message_contains(errs, needle: "takes 1 arguments, got 0")
}

test "function call with too many arguments" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func greet(name: str) -> none { print(name) }
        func main() -> int64 {
            greet(name: "alice", "extra")
            return 0
        }
        """)
    assert test_support.any_message_contains(errs, needle: "takes 1 arguments, got 2")
}

test "match with none/Some on a non-optional subject" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func main() -> int64 {
            let n: int64 = 5
            match n {
                Some(v) -> print(v.to_str())
                none -> print("nope")
            }
            return 0
        }
        """)
    assert test_support.any_message_contains(errs, needle: "none/Some requires an optional value")
}

test "comparing a non-optional value with `none`" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func main() -> int64 {
            let n: int64 = 5
            if n == none {
                return 1
            }
            return 0
        }
        """)
    assert test_support.any_message_contains(errs, needle: "cannot compare non-optional value with `none`")
}

test "len() on a primitive" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func main() -> int64 {
            let b: bool = true
            return len(b)
        }
        """)
    assert test_support.any_message_contains(errs, needle: "len() not defined for this type")
}

test "unknown identifier in expression" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func main() -> int64 {
            let x: int64 = 0
            return xy
        }
        """)
    assert test_support.any_message_contains(errs, needle: "unknown name `xy`")
}

test "parse error: missing close paren in call" {
    // `expect(.CloseParen)` after the call args now reports its mismatch
    // instead of advancing silently and feeding a garbage AST to codegen.
    let errs: [codegen.Error] = test_support.try_compile("""
        func main() -> int64 {
            print("hi"
            return 0
        }
        """)
    assert test_support.any_message_contains(errs, needle: "expected `)`")
}

test "parse error: missing `=` after let binding" {
    // The colon and type annotation are optional in `let`, so `let x int64`
    // is read as `let x` with `int64` as the next token — and the
    // subsequent `expect(.Equal)` fires.
    let errs: [codegen.Error] = test_support.try_compile("""
        func main() -> int64 {
            let x int64 = 0
            return x
        }
        """)
    assert test_support.any_message_contains(errs, needle: "expected `=`")
}

test "unknown function suggests a near-match" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func helper() -> int64 { return 0 }
        func main() -> int64 {
            return helprr()
        }
        """)
    assert test_support.any_message_contains(errs, needle: "unknown function `helprr`")
    assert test_support.any_message_contains(errs, needle: "did you mean `helper`")
}

test "unknown name suggests a near-match" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func main() -> int64 {
            let count: int64 = 0
            return coutn
        }
        """)
    assert test_support.any_message_contains(errs, needle: "unknown name `coutn`")
    assert test_support.any_message_contains(errs, needle: "did you mean `count`")
}

test "unknown method suggests a near-match" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func main() -> int64 {
            let s: str = "hi"
            return s.to_strr().hash()
        }
        """)
    assert test_support.any_message_contains(errs, needle: "unknown method `to_strr`")
    assert test_support.any_message_contains(errs, needle: "did you mean `to_str`")
}

test "unknown struct field suggests a near-match" {
    let errs: [codegen.Error] = test_support.try_compile("""
        type Point = struct { x: int64; y: int64 }
        func main() -> int64 {
            let p: Point = Point(xx: 1, y: 2)
            return p.x
        }
        """)
    assert test_support.any_message_contains(errs, needle: "has no field `xx`")
    assert test_support.any_message_contains(errs, needle: "did you mean `x`")
}

test "unknown implicit variant suggests a near-match" {
    let errs: [codegen.Error] = test_support.try_compile("""
        type Color = enum {
            Red
            Green
            Blue
            Custom(r: int64, g: int64, b: int64)
        }
        func main() -> int64 {
            let c: Color = .Greeen
            return 0
        }
        """)
    // `.Greeen` triggers either the call-position branch or the
    // construct-without-args branch depending on shape. Either way
    // the diagnostic should mention the typo, and the close match
    // `Green` should appear in the suggestion.
    assert test_support.any_message_contains(errs, needle: "Greeen")
    assert test_support.any_message_contains(errs, needle: "did you mean `Green`")
}

test "no suggestion when nothing is close" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func helper() -> int64 { return 0 }
        func main() -> int64 {
            return xyzzy()
        }
        """)
    // Identifier far enough from `helper` that no suggestion should appear.
    assert test_support.any_message_contains(errs, needle: "unknown function `xyzzy`")
    assert test_support.any_message_contains(errs, needle: "did you mean") == false
}

test "caret squiggly spans the full offending token" {
    // Before the widening fix, the caret was a single `^` at the
    // token's start column. Now it spans the whole token, so a typo
    // like `helprr` (6 chars) gets `^^^^^^` underneath.
    let errs: [codegen.Error] = test_support.try_compile("""
        func main() -> int64 {
            helprr()
            return 0
        }
        """)
    assert len(errs) > 0
    // Find the error for the typo'd call.
    mut i: int64 = 0
    mut found: bool = false
    for i < len(errs) {
        if errs[i].caret.contains("^^^^^^") {
            found = true
        }
        i = i + 1
    }
    assert found
}

test "parse error: comma-separated struct fields terminate cleanly" {
    // Struct fields are newline-separated, not comma-separated. Putting
    // a comma between them used to send the parser into an infinite
    // loop because error recovery advanced past the EOF token and
    // peek_kind started reading OOB tokens. Now peek/advance clamp at
    // EOF, so the parser records errors and returns.
    let errs: [codegen.Error] = test_support.try_compile("""
        type Box = struct { x: int64, y: int64 }
        func main() -> int64 {
            return 0
        }
        """)
    // The exact error message comes from the recovery cascade; what
    // matters here is "at least one parse error was reported."
    assert len(errs) > 0
}

test "constructing a struct without a non-default field is an error" {
    let errs: [codegen.Error] = test_support.try_compile("""
        type P = struct {
            x: int64
            y: int64
        }
        func main() -> int64 {
            let p: P = P(x: 5)
            return 0
        }
        """)
    assert test_support.any_message_contains(errs, needle: "requires field `y`")
}

test "omitting a defaulted field is not an error" {
    let errs: [codegen.Error] = test_support.try_compile("""
        type Q = struct {
            x: int64
            y: int64 = 0
        }
        func main() -> int64 {
            let q: Q = Q(x: 5)
            return 0
        }
        """)
    assert len(errs) == 0
}
