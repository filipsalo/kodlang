// Stored-only gzip writer — produces a `.gz` blob, writes it through
// `gunzip`, and prints whatever comes back out. A successful
// round-trip means the framing (header + stored block + CRC + ISIZE)
// is well-formed.

import "compress/gzip"
import "io"
import "process"

func roundtrip(anon label: str, anon input: bytes, anon compressed: bytes) -> none {
    let path: str = f"/tmp/kod_gzip_{label}.gz"
    let rc: int64 = io.write_file(path, kod_bytes_to_str(compressed))
    if rc != 0 {
        print(f"{label}: write failed")
        return none
    }
    let r: process.ProcessResult = process.run(["gunzip", "-c", path])
    if r.status != 0 {
        print(f"{label}: gunzip failed")
        return none
    }
    if kod_str_to_bytes(r.stdout) == input {
        print(f"{label}: ok")
    } else {
        print(f"{label}: mismatch")
    }
}

func main() -> int64 {
    let input: bytes = b"The quick brown fox jumps over the lazy dog."
    roundtrip("stored", input, gzip.compress(input))
    roundtrip("fixed", input, gzip.compress_fixed(input))
    roundtrip("lz77", input, gzip.compress_lz77(input))
    return 0
}

// expected output:
// stored: ok
// fixed: ok
// lz77: ok
// expected status:
// 0
// expected mode:
// run
