type Direction = enum {
	North
	South
	East
	West
}

func classify(anon d: Direction) -> Direction {
	match d {
		.North -> return .South
		.South -> return .North
		.East -> return .West
		.West -> return .East
	}
	return .North
}

func main() -> int64 {
	let d: Direction = .North
	if d == .North {
		print("north")
	}

	let d2: Direction = classify(.East)
	if d2 == .West {
		print("west")
	}

	return 0
}

// expected output:
// north
// west

// expected status:
// 0


// expected selfhosted:
// skip
