// Extern functions. `str` in Kod is a `{ buf, len }` struct, so an
// extern's `str` parameter binds to a `KodStr *` on the C side, not
// `char *`. kod_puts (defined in stdlib/runtime.c) accepts the right
// shape and writes both bytes and the length to stdout.
extern func kod_puts(anon s: str) -> int64

func greet(anon name: str) -> none {
	kod_puts(name)
}

func main() -> int64 {
	greet("hello from extern")
	return 0
}

// expected output:
// hello from extern

// expected status:
// 0
