import "process"

func check(anon name: str, ok: bool) -> none {
    if ok {
        print(f"ok   {name}")
    } else {
        print(f"FAIL {name}")
    }
}

func main() -> int64 {
    let r1: process.ProcessResult = process.run(["echo", "hello"])
    check("echo status", ok: r1.status == 0)
    check("echo stdout", ok: r1.stdout == "hello\n")
    check("echo stderr empty", ok: r1.stderr == "")

    // sh -c lets us drive both streams + a non-zero exit code in one shot.
    let r2: process.ProcessResult = process.run(["sh", "-c", "echo out; echo err 1>&2; exit 3"])
    check("sh status", ok: r2.status == 3)
    check("sh stdout", ok: r2.stdout == "out\n")
    check("sh stderr", ok: r2.stderr == "err\n")

    // Non-existent binary -> posix_spawnp ENOENT -> status -1.
    let r3: process.ProcessResult = process.run(["this-binary-does-not-exist-on-purpose"])
    check("missing binary", ok: r3.status == -1)
    return 0
}

// expected output:
// ok   echo status
// ok   echo stdout
// ok   echo stderr empty
// ok   sh status
// ok   sh stdout
// ok   sh stderr
// ok   missing binary

// expected status:
// 0

// expected mode:
// run
