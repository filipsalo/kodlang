type Point = struct {
	x: int64
	y: int64
}

func shift(anon p: Point, anon dx: int64) -> none {
	p.x = p.x + dx
}

func main() -> int64 {
	let p = Point(x: 3, y: 4)
	print_int(p.x)
	shift(p, 10)
	print_int(p.x)
	let q: Point = p
	q.y = 99
	print_int(p.y)
	return 0
}

// expected output:
// 3
// 13
// 99

// expected status:
// 0



// expected selfhosted:
// skip
