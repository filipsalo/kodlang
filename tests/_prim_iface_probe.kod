// Primitives implementing interfaces: pass int64/str/bool where
// the parameter is `Stringable`, dispatch through the vtable.

interface Showable {
	func to_str(self) -> str
}

func show(anon thing: Showable) -> none {
	print(thing.to_str())
}

func main() -> int64 {
	let n: int64 = 42
	let s: str = "hello"
	let b: bool = true
	show(n)
	show(s)
	show(b)
	return 0
}

// expected output:
// 42
// hello
// true
// expected status:
// 0
