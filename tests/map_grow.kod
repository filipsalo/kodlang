// Exercises the Map past its initial-size threshold so the resize path
// runs at least once, plus updating an existing key.

type IntMap = Map[str, int64]

func main() -> int64 {
    let m: IntMap = IntMap(keys: [], values: [], indices: [])
    let keys: [str] = ["a", "b", "c", "d", "e", "f", "g", "h", "i", "j", "k", "l", "m", "n", "o", "p", "q", "r", "s", "t"]
    let i: int64 = 0
    for i < len(keys) {
        m[keys[i]] = i * 10
        i = i + 1
    }
    // Update an existing key — must overwrite, not insert.
    m["a"] = 999

    // Look up every key, summing the values.
    let sum: int64 = 0
    let j: int64 = 0
    for j < len(keys) {
        let value: int64? = m[keys[j]]
        match value {
            Some(value_inner) -> sum = sum + value_inner
            none -> sum = sum - 1
        }
        j = j + 1
    }
    print(sum.to_str())

    // Confirm a missing key is reported as missing.
    let missing: int64? = m["missing"]
    match missing {
        none -> print("missing")
        Some(value) -> print("unexpected")
    }

    return 0
}

// expected output:
// 2899
// missing

// expected status:
// 0
