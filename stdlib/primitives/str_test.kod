test "to_str: identity" {
    assert "".to_str() == ""
    assert "hello".to_str() == "hello"
}

test "hash: deterministic for the same string" {
    assert "".hash() == "".hash()
    assert "a".hash() == "a".hash()
    assert "the quick brown fox".hash() == "the quick brown fox".hash()
}

test "hash: empty string is 5381 (djb2 seed)" {
    // Stable expectation pinned to the documented algorithm in
    // stdlib/primitives/str.kod — guards against accidental seed
    // changes that would silently break every Map[str, V] caller.
    assert "".hash() == 5381
}

test "hash: content equality, not pointer identity" {
    // `b` is allocated separately from `a` (concatenation builds a
    // fresh arena buffer), but the hash function reads bytes so they
    // must agree.
    let a: str = "hello"
    let b: str = "hel" + "lo"
    assert a.hash() == b.hash()
}

test "hash: distinct inputs give distinct outputs (no trivial collisions)" {
    assert "a".hash() != "b".hash()
    assert "ab".hash() != "ba".hash()
    assert "foo".hash() != "bar".hash()
}

test "contains: hit and miss" {
    assert "hello world".contains("world")
    assert "hello world".contains("hello")
    assert "hello world".contains("lo wo")
    assert "hello world".contains("xyz") == false
}

test "contains: edge cases" {
    assert "".contains("")
    assert "anything".contains("")
    assert "".contains("x") == false
    assert "abc".contains("abcd") == false
}

test "concat with +" {
    let a: str = "hello"
    let b: str = " world"
    assert a + b == "hello world"
    assert "" + "x" == "x"
    assert "x" + "" == "x"
}

test "concat with += mutates the binding" {
    let a: str = "hello"
    a += "!"
    assert a == "hello!"
    a += " world"
    assert a == "hello! world"
}

test "indexing returns the byte at the offset" {
    let s: str = "hello, world"
    assert s[0] == 'h'
    assert s[7] == 'w'
    assert s[len(s) - 1] == 'd'
}

test "negative index counts from the end" {
    let s: str = "hello"
    assert s[-1] == 'o'
    assert s[-5] == 'h'
}

test "slicing returns a fresh substring" {
    let s: str = "hello, world"
    assert s[0:5] == "hello"
    assert s[7:12] == "world"
    assert s[0:0] == ""
}

test "equality compares bytes, not pointers" {
    let a: str = "hello"
    let b: str = "hel" + "lo"
    assert a == b
    assert a != "world"
    assert a != "hell"
    assert a != "hellos"
}

test "code_points: ASCII is a 1:1 mapping" {
    let cps: [int64] = "abc".code_points()
    assert len(cps) == 3
    assert cps[0] == 97   // 'a'
    assert cps[1] == 98
    assert cps[2] == 99
}

test "code_points: 2-byte latin-1 supplement" {
    // "é" is U+00E9, encoded as 0xC3 0xA9 in UTF-8 (two bytes).
    let cps: [int64] = "é".code_points()
    assert len(cps) == 1
    assert cps[0] == 233
}

test "code_points: 3-byte CJK" {
    // "中" is U+4E2D (20013), encoded as 0xE4 0xB8 0xAD.
    let cps: [int64] = "中".code_points()
    assert len(cps) == 1
    assert cps[0] == 20013
}

test "code_points: 4-byte supplementary plane" {
    // "🌍" is U+1F30D (127757), encoded as 0xF0 0x9F 0x8C 0x8D.
    let cps: [int64] = "🌍".code_points()
    assert len(cps) == 1
    assert cps[0] == 127757
}

test "code_points: mixed widths in one string" {
    let cps: [int64] = "a中🌍".code_points()
    assert len(cps) == 3
    assert cps[0] == 97       // 'a' (1 byte)
    assert cps[1] == 20013    // '中' (3 bytes)
    assert cps[2] == 127757   // '🌍' (4 bytes)
}

test "code_points: empty string" {
    let cps: [int64] = "".code_points()
    assert len(cps) == 0
}

test "code_points: permissive on invalid bytes" {
    // A continuation byte (0x80) with no leading start byte is invalid.
    // The decoder emits it as a 1-byte code point rather than panicking.
    // Build it via slicing so the literal stays well-formed for editors.
    let bad: str = "中"
    let just_continuation: str = bad[1:3]   // 0xB8 0xAD — both continuation bytes
    let cps: [int64] = just_continuation.code_points()
    assert len(cps) == 2
    assert cps[0] == 184   // 0xB8
    assert cps[1] == 173   // 0xAD
}

test "char_count matches code_points length" {
    assert "".char_count() == 0
    assert "abc".char_count() == 3
    assert "é".char_count() == 1
    assert "中".char_count() == 1
    assert "🌍".char_count() == 1
    assert "a中🌍".char_count() == 3
}

test "char_count differs from len for multi-byte input" {
    // len() stays byte length; char_count() is the code-point count.
    let s: str = "héllo"     // 'h' 'é' 'l' 'l' 'o' — 5 code points, 6 bytes
    assert len(s) == 6
    assert s.char_count() == 5
}
