// Compiler tests for match exhaustiveness. Each test embeds a source
// snippet, runs it through sh_kodc, and asserts on what the codegen
// reported.

import "process"
import "./test_support"

test "match on int64 requires an `else` arm" {
    let r: process.ProcessResult = test_support.compile_source("""
        func main() -> int64 {
            let n: int64 = 1
            match n {
                1 -> print("one")
            }
            return 0
        }
        """)
    assert r.status != 0
    assert r.stderr.contains("match on int64 must include an `else` arm")
}

test "match on str requires an `else` arm" {
    let r: process.ProcessResult = test_support.compile_source("""
        func main() -> int64 {
            let s: str = "hello"
            match s {
                "a" -> print("a")
            }
            return 0
        }
        """)
    assert r.status != 0
    assert r.stderr.contains("match on str must include an `else` arm")
}

test "match on enum: missing variant reported" {
    let r: process.ProcessResult = test_support.compile_source("""
        type Color = enum { Red, Green, Blue }
        func main() -> int64 {
            let c: Color = .Red
            match c {
                .Red -> print("red")
                .Green -> print("green")
            }
            return 0
        }
        """)
    assert r.status != 0
    assert r.stderr.contains("doesn't cover variant `Blue`")
}

test "match with `else` catch-all is accepted" {
    let r: process.ProcessResult = test_support.compile_source("""
        func main() -> int64 {
            let n: int64 = 1
            match n {
                1 -> print("one")
                else -> print("other")
            }
            return 0
        }
        """)
    assert r.status == 0
}
