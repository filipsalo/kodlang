import "kod/map"

type IntMap = map.Map[str, int64]

extern func int_to_str(anon n: int64) -> str

func main() -> int64 {
	let m: IntMap = IntMap(keys: [], values: [])
	m.set("x", 10)
	m.set("y", 20)
	m.set("z", 30)

	let vx: int64? = m.get("x")
	let vy: int64? = m.get("y")
	let vmissing: int64? = m.get("nope")

	match vx {
		none -> print("missing x")
		Some(v) -> print(int_to_str(v))
	}
	match vy {
		none -> print("missing y")
		Some(v) -> print(int_to_str(v))
	}
	match vmissing {
		none -> print("none")
		Some(v) -> print(int_to_str(v))
	}

	if m.contains("z") {
		print("has z")
	}

	return 0
}

// expected output:
// 10
// 20
// none
// has z

// expected status:
// 0

// expected mode:
// interpret
