// Direct in-process tests for `stdlib/io.kod`. Migrated from
// tests/io_read_file.kod — exercising `read_file` here doesn't need
// build_and_run since the test program already has `io` available.
// Fixture path is relative to the project root (where `kod test` runs).

import "io"

test "read_file returns full contents and reports the right length" {
    let s: str = io.read_file("tests/io_fixture.txt")
    assert s == "hello world\n"
    assert len(s) == 12
}
