// `Ok` / `Err` patterns over a `T or Error` result, exercised through both
// `match` and the bare `is` operator. Runs under both frontends.

type IoError = struct {
    message: str
    func to_str(self) -> str { return self.message }
}

func read_size(anon path: str) -> int64 or Error {
    if path == "missing" {
        throw IoError(message: "not found")
    }
    return 42
}

func main() -> int64 {
    match read_size("ok") {
        Ok(n) -> print_int(n)
        Err(e) -> print(e.to_str())
    }
    match read_size("missing") {
        Ok(n) -> print_int(n)
        Err(e) -> print(e.to_str())
    }
    let r = read_size("missing")
    if r is Err(_) {
        print("err")
    }
    if read_size("ok") is Ok(_) {
        print("ok")
    }
    return 0
}

// expected output:
// 42
// not found
// err
// ok
