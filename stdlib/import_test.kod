// Cross-module import behaviour. Migrated from tests/import.kod
// (entry) + tests/import_me.kod (dep). The whole shape — relative
// `./` import, module-prefixed call on the import, both files
// linked together — lives in one kod test now via the MemFs
// + build_and_run_files pipeline.

import "fs"
import "process"
import "kod/test_support"

test "relative `./` import resolves and module-prefixed call works" {
    let files: fs.MemFs = fs.mem_fs()
    files.add("main.kod", """
import "./helper"

func foo() -> none {
    print("foo in main.kod")
}

func main() -> int64 {
    foo()
    helper.foo()
    return 0
}
""")
    files.add("helper.kod", """
func foo() -> none {
    print("foo in helper.kod")
}
""")
    let r: process.ProcessResult = test_support.build_and_run_files(:files, entry: "main.kod")
    assert r.status == 0
    assert r.stdout == "foo in main.kod\nfoo in helper.kod\n"
}
