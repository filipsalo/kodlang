// Generic enum smoke test. `Pair[A, B]` is monomorphised per concrete
// instantiation (Pair[int64, str] is a distinct type from Pair[str, int64]),
// and variant fields carry the substituted kinds so int / str arms compile
// to the right widths.
type Pair[A, B] = enum {
    Both(left: A, right: B)
    OnlyLeft(value: A)
    Empty
}

func describe(anon p: Pair[int64, str]) -> str {
    match p {
        .Both(left, right) -> return f"both {left} {right}"
        .OnlyLeft(value) -> return f"left {value}"
        .Empty -> return "empty"
    }
}

func main() -> int64 {
    let a: Pair[int64, str] = .Both(left: 42, right: "hi")
    let b: Pair[int64, str] = .OnlyLeft(value: 7)
    let c: Pair[int64, str] = .Empty
    print(describe(a))
    print(describe(b))
    print(describe(c))
    return 0
}

// expected output:
// both 42 hi
// left 7
// empty
