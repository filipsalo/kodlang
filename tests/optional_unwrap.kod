// Postfix `?` on `T?`:
//   - `x?`           — extract on Some, panic on none.
//   - `x? or default` — extract on Some, evaluate `default` on none.

func find(anon haystack: str, anon needle: int64) -> int64? {
    mut i: int64 = 0
    for i < len(haystack) {
        if haystack[i] == needle {
            return i
        }
        i = i + 1
    }
    return none
}

func main() -> int64 {
    // Panic form: unwrap a value we know is Some.
    let present: int64? = find("hello", 'l')
    let idx: int64 = present?
    print_int(idx)   // 2

    // Fallback form: substitute a default when the lookup misses.
    let missing: int64? = find("hello", 'z')
    let idx2: int64 = missing? or 99
    print_int(idx2)  // 99

    // Fallback chosen even when the default isn't a literal.
    let backup: int64 = 7
    let idx3: int64 = missing? or backup
    print_int(idx3)  // 7

    // Fallback ignored when the value is present.
    let idx4: int64 = present? or 99
    print_int(idx4)  // 2

    return 0
}

// expected output:
// 2
// 99
// 7
// 2
// expected status:
// 0
