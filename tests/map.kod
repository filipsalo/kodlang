type IntMap = Map[str, int64]

func main() -> int64 {
	let m: IntMap = IntMap(keys: [], values: [], indices: [])
	m["x"] = 10
	m["y"] = 20
	m["z"] = 30

	let vx: int64? = m["x"]
	let vy: int64? = m["y"]
	let vmissing: int64? = m["nope"]

	match vx {
		none -> print("missing x")
		Some(v) -> print(v.to_str())
	}
	match vy {
		none -> print("missing y")
		Some(v) -> print(v.to_str())
	}
	match vmissing {
		none -> print("none")
		Some(v) -> print(v.to_str())
	}

	if m.contains("z") {
		print("has z")
	}

	// Test that key lookup works with a variable, not just same literal pointer
	let k: str = "x"
	let vk: int64? = m[k]
	match vk {
		none -> print("missing via var")
		Some(v) -> print(v.to_str())
	}

	return 0
}

// expected output:
// 10
// 20
// none
// has z
// 10

// expected status:
// 0
