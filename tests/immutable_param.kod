// Parameters are immutable by default; reassigning one is a compile
// error. (Declaring `anon mut x` instead would make this compile.)
func bump(anon x: int64) -> int64 {
    x = x + 1
    return x
}

func main() -> int64 {
    return bump(41)
}

// expected errors:
// 4:5: cannot reassign immutable binding `x`; declare it with `mut`
