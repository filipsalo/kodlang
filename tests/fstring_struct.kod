// Struct with a `to_str` method participating in f-string interpolation.

type Point = struct {
    x: int64
    y: int64
    func to_str(self) -> str {
        return f"({self.x}, {self.y})"
    }
}

func main() -> int64 {
    let p: Point = Point(x: 3, y: 4)
    print(f"point={p}")
    return 0
}

// expected status:
// 0
// expected output:
// point=(3, 4)
