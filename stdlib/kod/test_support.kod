// Helpers for compiler tests written in Kod. Each test that needs to
// assert on compiler diagnostics writes a source snippet (typically as
// a triple-quoted string), passes it to `compile_source`, and inspects
// the captured exit code / stdout / stderr.

import "io"
import "process"

// Write `src` to a scratch file in the project root, invoke sh_kodc on
// it, return the captured process result. The scratch path is the same
// for every call; tests that run in sequence (the default) are fine,
// concurrent test runs would race.
func compile_source(anon src: str) -> process.ProcessResult {
    let scratch: str = ".kod_compile_test.kod"
    io.write_file(scratch, src)
    return process.run(["build/stage1/sh_kodc", scratch])
}
