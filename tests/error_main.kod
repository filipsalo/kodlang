type IoError = struct {
    message: str

    func to_str(self) -> str {
        return self.message
    }
}

func read_size(path: str) -> int64 or Error {
    if path == "missing.txt" {
        throw IoError(message: f"no such file: {path}")
    }
    return 42
}

// main itself returns `int64 or Error`. The runtime wrapper catches
// the Err, prints the message, exits with status 1.
func main() -> int64 or Error {
    let n: int64 = try read_size("missing.txt")
    print(f"got {n}")
    return 0
}

// expected mode:
// run
// expected status:
// 1
// expected stderr:
// panic: no such file: missing.txt
