type Direction = enum {
	North
	South
}

type Message = enum {
	Text(content: str)
	Number(value: int64)
}

func main() -> int64 {
	let d: Direction = Direction.North
	if d == Direction.North {
		print("going north")
	}

	let m: Message = Message.Text(content: "hello")
	match m {
		Message.Text(content) -> print(content)
		Message.Number(value) -> print_int(value)
	}

	let m2: Message = Message.Number(value: 42)
	match m2 {
		Message.Text(content) -> print(content)
		Message.Number(value) -> print_int(value)
	}

	return 0
}

// expected output:
// going north
// hello
// 42

// expected status:
// 0


// expected selfhosted:
// skip
