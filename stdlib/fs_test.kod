import "fs"

test "mem_fs: empty has no paths and read returns ''" {
    let m: fs.MemFs = fs.mem_fs()
    assert len(m.paths()) == 0
    assert m.read_file("anything") == ""
}

test "mem_fs: add + read round-trips" {
    let m: fs.MemFs = fs.mem_fs()
    m.add("a.kod", "hello")
    m.add("dir/b.kod", "world")
    assert m.read_file("a.kod") == "hello"
    assert m.read_file("dir/b.kod") == "world"
    assert m.read_file("missing") == ""
}

test "mem_fs: paths enumerates everything added" {
    let m: fs.MemFs = fs.mem_fs()
    m.add("a", "1")
    m.add("b", "2")
    m.add("c", "3")
    let ps: [str] = m.paths()
    assert len(ps) == 3
    // Map's keys array is insertion-ordered (CPython dict layout).
    assert ps[0] == "a"
    assert ps[1] == "b"
    assert ps[2] == "c"
}

test "disk_fs: reads a real fixture from the project tree" {
    let d: fs.DiskFs = fs.disk_fs()
    assert d.read_file("tests/io_fixture.txt") == "hello world\n"
}

test "disk_fs: paths is empty (no list_dir extern yet)" {
    let d: fs.DiskFs = fs.disk_fs()
    assert len(d.paths()) == 0
}
