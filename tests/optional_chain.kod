// `?.` short-circuit field access and method calls on a `T?` struct.

type Point = struct {
    x: int64
    y: int64

    func magnitude_sq(self) -> int64 {
        return self.x * self.x + self.y * self.y
    }
}

func origin_or(anon mut p: Point?, set: bool) -> Point? {
    if set {
        p = Point(x: 3, y: 4)
    }
    return p
}

func main() -> int64 {
    let present: Point? = origin_or(none, set: true)
    let missing: Point? = origin_or(none, set: false)

    // Present: x?.x is Some(3).
    let xp: int64? = present?.x
    match xp {
        Some(v) -> print_int(v)   // 3
        none -> print("missing")
    }

    // Missing: x?.x is none — the field is never read.
    let xm: int64? = missing?.x
    match xm {
        Some(v) -> print_int(v)
        none -> print("missing")  // missing
    }

    // Unwrap chains compose with postfix `?` for a final default.
    let yp: int64 = present?.y? or -1
    print_int(yp)   // 4

    let ym: int64 = missing?.y? or -1
    print_int(ym)   // -1

    // Method call: present?.magnitude_sq() is Some(25).
    match present?.magnitude_sq() {
        Some(v) -> print_int(v)   // 25
        none -> print("missing")
    }

    // Method call short-circuits on none.
    match missing?.magnitude_sq() {
        Some(v) -> print_int(v)
        none -> print("missing")  // missing
    }

    return 0
}

// expected output:
// 3
// missing
// 4
// -1
// 25
// missing
// expected status:
// 0
