import "kod/ast"
import "kod/parser"
import "kod/lexer"

// ── Type kind (must precede uses in FieldInfo/VarSlot) ───────────────────────

type TypeKind = enum {
    KVoid
    KInt64
    KBool
    KStr
    KArray
    KOptional
    KEnum(idx: int64)
    KStruct(idx: int64)
    KArrayStruct(elem_idx: int64)
    KArrayEnum(elem_idx: int64)
    KArrayStr
}

// ── Type layout structures ────────────────────────────────────────────────────

type VariantInfo = struct {
    name: str
    discriminant: int64
    field_names: [str]
    field_offsets: [int64]
    field_kinds: [TypeKind]
}

type EnumInfo = struct {
    name: str
    variants: [VariantInfo]
    data_width: int64
    // Module prefix used to mangle this enum's method/value labels.
    // Local enums use the current module's prefix; imported ones use
    // the source module's prefix (e.g. "builtins").
    module_prefix: str
}

type FieldInfo = struct {
    name: str
    offset: int64
    kind: TypeKind
}

type StructInfo = struct {
    name: str
    fields: [FieldInfo]
    method_names: [str]
    method_decl_ids: [int64]
    method_return_kinds: [TypeKind]
    data_width: int64
    // See EnumInfo.module_prefix.
    module_prefix: str
    // Parser that owns this struct's method func_decls. Needed to
    // monomorphise the methods into the consuming module's object file
    // when a type alias instantiates a generic struct.
    src_p: parser.Parser
}

// ── Per-variable stack slot ───────────────────────────────────────────────────

type VarSlot = struct {
    name: str
    offset: int64
    kind: TypeKind
}

// ── Expression result (what compile_expr returns) ─────────────────────────────

type Val = enum {
    VReg(name: str)
    VImm(value: int64)
    VStack(offset: int64)
    VStrLbl(page: str)
}

// ── Loop label stack entry ────────────────────────────────────────────────────

type LoopLbl = struct {
    start_lbl: str
    end_lbl: str
    incr_lbl: str
}

// ── Codegen struct ────────────────────────────────────────────────────────────

type Codegen = struct {
    p: parser.Parser
    path_prefix: str

    enums: [EnumInfo]
    structs: [StructInfo]

    // Type-alias maps: `type X = Y` adds an entry pointing X's name to
    // Y's struct/enum index. find_struct_idx / find_enum_idx consult
    // these before searching the main lists.
    struct_alias_name: [str]
    struct_alias_target: [int64]
    enum_alias_name: [str]
    enum_alias_target: [int64]

    import_local: [str]
    import_prefix: [str]

    // Functions exported by imported modules, indexed by parallel arrays.
    // Used to resolve mod.func() calls to their exact labels (extern names
    // get _name, regular functions get $prefix$name).
    import_fn_module: [str]
    import_fn_name: [str]
    import_fn_label: [str]

    vars: [VarSlot]
    frame_slots: int64
    ret_lbl: str
    return_kind: TypeKind

    free_regs: [str]

    loop_stack: [LoopLbl]

    str_labels: [str]
    str_values: [str]

    label_count: int64

    func_names: [str]
    func_labels: [str]


    func itos(self, anon n: int64) -> str {
        return int_to_str(n)
    }

    func fresh(self, anon prefix: str) -> str {
        self.label_count = self.label_count + 1
        return f"{prefix}${self.itos(self.label_count)}"
    }

    func emit(self, anon line: str) -> none {
        print(f"\t{line}")
    }

    func emit_label(self, anon lbl: str) -> none {
        print(f"{lbl}:")
    }

    func emit_globl(self, anon lbl: str) -> none {
        print(f"\t.globl {lbl}")
    }

    func emit_asciz(self, anon value: str) -> none {
        putchar(9)   // \t
        let i = 0
        let prefix = ".asciz "
        for i < len(prefix) {
            putchar(prefix[i])
            i = i + 1
        }
        putchar('"')
        let j = 0
        for j < len(value) {
            let c = value[j]
            let escaped = false
            if c == '\n' {
                putchar('\\')
                putchar('n')
                escaped = true
            }
            if c == '\t' {
                putchar('\\')
                putchar('t')
                escaped = true
            }
            if c == '\r' {
                putchar('\\')
                putchar('r')
                escaped = true
            }
            if c == '\\' {
                putchar('\\')
                putchar('\\')
                escaped = true
            }
            if c == '"' {
                putchar('\\')
                putchar('"')
                escaped = true
            }
            if escaped == false {
                putchar(c)
            }
            j = j + 1
        }
        putchar('"')
        putchar(10)
    }


    func alloc_reg(self) -> str {
        let n = len(self.free_regs)
        let r = self.free_regs[-1]
        let new_regs: [str] = []
        let i = 0
        for i < n - 1 {
            new_regs += [self.free_regs[i]]
            i = i + 1
        }
        self.free_regs = new_regs
        return r
    }

    func free_reg(self, anon r: str) -> none {
        // Only return pool registers (x8-x15, x19-x27) to the free list.
        // Argument registers (x0-x7) hold call results/args and must not be pooled.
        if r == "x0" or r == "x1" or r == "x2" or r == "x3" or r == "x4" or r == "x5" or r == "x6" or r == "x7" {
            return
        }
        self.free_regs += [r]
    }

    func free_val(self, anon v: Val) -> none {
        match v {
            .VReg(name) -> self.free_reg(name)
            else none
        }
    }


    func load(self, anon v: Val) -> str {
        match v {
            .VReg(name) -> return name
            .VImm(value) -> {
                let r = self.alloc_reg()
                self.emit(f"mov {r}, #{self.itos(value)}")
                return r
            }
            .VStack(offset) -> {
                let r = self.alloc_reg()
                self.emit_ldr(r, offset)
                return r
            }
            .VStrLbl(page) -> {
                let r = self.alloc_reg()
                self.emit(f"adrp {r}, {page}@PAGE")
                self.emit(f"add {r}, {r}, {page}@PAGEOFF")
                return r
            }
        }
    }

    func mov_to(self, dest: str, anon v: Val) -> str {
        match v {
            .VReg(name) -> {
                if name != dest {
                    self.emit(f"mov {dest}, {name}")
                    self.free_reg(name)
                }
                return dest
            }
            .VImm(value) -> {
                self.emit(f"mov {dest}, #{self.itos(value)}")
                return dest
            }
            .VStack(offset) -> {
                self.emit_ldr(dest, offset)
                return dest
            }
            .VStrLbl(page) -> {
                self.emit(f"adrp {dest}, {page}@PAGE")
                self.emit(f"add {dest}, {dest}, {page}@PAGEOFF")
                return dest
            }
        }
    }


    func intern_str(self, anon value: str) -> str {
        let i = 0
        for i < len(self.str_values) {
            if self.str_values[i] == value {
                return self.str_labels[i]
            }
            i = i + 1
        }
        let lbl = self.fresh("Lstr")
        self.str_labels += [lbl]
        self.str_values += [value]
        return lbl
    }


    func alloc_var(self, name: str, kind: TypeKind) -> int64 {
        self.frame_slots = self.frame_slots + 1
        let offset = 0 - self.frame_slots * 8
        self.vars += [VarSlot(name: name, offset: offset, kind: kind)]
        return offset
    }

    func find_var_offset(self, anon name: str) -> int64 {
        let i = len(self.vars) - 1
        for i >= 0 {
            if self.vars[i].name == name {
                return self.vars[i].offset
            }
            i = i - 1
        }
        return -9999
    }

    func find_var_kind(self, anon name: str) -> TypeKind {
        let i = len(self.vars) - 1
        for i >= 0 {
            if self.vars[i].name == name {
                return self.vars[i].kind
            }
            i = i - 1
        }
        return .KVoid
    }

    func var_declared(self, anon name: str) -> bool {
        let i = 0
        for i < len(self.vars) {
            if self.vars[i].name == name {
                return true
            }
            i = i + 1
        }
        return false
    }


    func find_enum_idx(self, anon name: str) -> int64 {
        let a = 0
        for a < len(self.enum_alias_name) {
            if self.enum_alias_name[a] == name {
                return self.enum_alias_target[a]
            }
            a = a + 1
        }
        let i = 0
        for i < len(self.enums) {
            if self.enums[i].name == name {
                return i
            }
            i = i + 1
        }
        return -1
    }

    func find_struct_idx(self, anon name: str) -> int64 {
        let a = 0
        for a < len(self.struct_alias_name) {
            if self.struct_alias_name[a] == name {
                return self.struct_alias_target[a]
            }
            a = a + 1
        }
        let i = 0
        for i < len(self.structs) {
            if self.structs[i].name == name {
                return i
            }
            i = i + 1
        }
        return -1
    }

    func find_enum_with_variant(self, anon variant_name: str) -> int64 {
        let i = 0
        for i < len(self.enums) {
            let j = 0
            for j < len(self.enums[i].variants) {
                if self.enums[i].variants[j].name == variant_name {
                    return i
                }
                j = j + 1
            }
            i = i + 1
        }
        return -1
    }

    func find_variant_idx(self, enum_idx: int64, anon variant_name: str) -> int64 {
        let j = 0
        for j < len(self.enums[enum_idx].variants) {
            if self.enums[enum_idx].variants[j].name == variant_name {
                return j
            }
            j = j + 1
        }
        return -1
    }

    func find_field_offset(self, struct_idx: int64, anon field_name: str) -> int64 {
        let j = 0
        for j < len(self.structs[struct_idx].fields) {
            if self.structs[struct_idx].fields[j].name == field_name {
                return self.structs[struct_idx].fields[j].offset
            }
            j = j + 1
        }
        return 0
    }


    func resolve_type(self, anon type_id: int64) -> TypeKind {
        if type_id == 0 {
            return .KVoid
        }
        match self.p.type_exprs[type_id] {
            .Named(name) -> {
                if name == "int64" {
                    return .KInt64
                }
                if name == "bool" {
                    return .KBool
                }
                if name == "str" {
                    return .KStr
                }
                if name == "none" {
                    return .KVoid
                }
                let ei = self.find_enum_idx(name)
                if ei >= 0 {
                    return .KEnum(idx: ei)
                }
                let si = self.find_struct_idx(name)
                if si >= 0 {
                    return .KStruct(idx: si)
                }
                return .KInt64
            }
            .Array(inner) -> {
                let ek = self.resolve_type(inner)
                match ek {
                    .KStruct(si) -> return .KArrayStruct(elem_idx: si)
                    .KEnum(ei) -> return .KArrayEnum(elem_idx: ei)
                    .KStr -> return .KArrayStr
                    else return .KArray
                }
            }
            .Optional(inner) -> return .KOptional
            .Generic(name, arg) -> {
                // Generics are erased at codegen — look up the base type.
                let si = self.find_struct_idx(name)
                if si >= 0 {
                    return .KStruct(idx: si)
                }
                let ei = self.find_enum_idx(name)
                if ei >= 0 {
                    return .KEnum(idx: ei)
                }
                return .KInt64
            }
        }
    }


    func func_label(self, anon name: str) -> str {
        let i = 0
        for i < len(self.func_names) {
            if self.func_names[i] == name {
                return self.func_labels[i]
            }
            i = i + 1
        }
        return f"$builtins${name}"
    }

    func import_func_label(self, local_mod: str, anon func_name: str) -> str {
        // Prefer the exact label recorded by register_import_module
        // (extern names map to _name, regular functions map to $prefix$name).
        let j = 0
        for j < len(self.import_fn_module) {
            if self.import_fn_module[j] == local_mod and self.import_fn_name[j] == func_name {
                return self.import_fn_label[j]
            }
            j = j + 1
        }
        // Fallback: synthesize a label from the registered prefix.
        let i = 0
        for i < len(self.import_local) {
            if self.import_local[i] == local_mod {
                return f"${self.import_prefix[i]}${func_name}"
            }
            i = i + 1
        }
        return f"_{func_name}"
    }


    func emit_ldr(self, reg: str, anon offset: int64) -> none {
        if offset >= 0 {
            self.emit(f"ldr {reg}, [fp]")
            return
        }
        if offset >= -256 {
            self.emit(f"ldr {reg}, [fp, #{self.itos(offset)}]")
            return
        }
        // Out of immediate range — materialise the negative offset first.
        self.emit(f"mov x16, #{self.itos(0 - offset)}")
        self.emit(f"sub x16, fp, x16")
        self.emit(f"ldr {reg}, [x16]")
    }

    func emit_str(self, reg: str, anon offset: int64) -> none {
        if offset >= 0 {
            self.emit(f"str {reg}, [fp]")
            return
        }
        if offset >= -256 {
            self.emit(f"str {reg}, [fp, #{self.itos(offset)}]")
            return
        }
        self.emit(f"mov x16, #{self.itos(0 - offset)}")
        self.emit(f"sub x16, fp, x16")
        self.emit(f"str {reg}, [x16]")
    }


    func register_enum(self, anon decl: ast.Decl, prefix: str, p: parser.Parser) -> none {
        match decl {
            .Enum(name, variants) -> {
                let saved_p = self.p
                self.p = p
                let vinfos: [VariantInfo] = []
                let disc = 0
                let max_payload = 0
                let i = 0
                for i < len(variants) {
                    let v = variants[i]
                    let fnames: [str] = []
                    let foffsets: [int64] = []
                    let fkinds: [TypeKind] = []
                    let j = 0
                    for j < len(v.fields) {
                        fnames += [v.fields[j].name]
                        foffsets += [j * 8]
                        fkinds += [self.resolve_type(v.fields[j].typ)]
                        j = j + 1
                    }
                    let payload = len(v.fields) * 8
                    if payload > max_payload {
                        max_payload = payload
                    }
                    vinfos += [VariantInfo(name: v.name, discriminant: disc, field_names: fnames, field_offsets: foffsets, field_kinds: fkinds)]
                    disc = disc + 1
                    i = i + 1
                }
                self.p = saved_p
                let dw = 8 + max_payload
                self.enums += [EnumInfo(name: name, variants: vinfos, data_width: dw, module_prefix: prefix)]
            }
            else none
        }
    }

    func register_struct(self, anon decl: ast.Decl, prefix: str, p: parser.Parser) -> none {
        match decl {
            .Struct(name, fields, methods) -> {
                let finfos: [FieldInfo] = []
                let offset = 0
                let i = 0
                // Temporarily swap parser so resolve_type reads field type
                // expressions from p (the source module's parser), not self.p.
                let saved_p = self.p
                self.p = p
                for i < len(fields) {
                    let fkind = self.resolve_type(fields[i].typ)
                    finfos += [FieldInfo(name: fields[i].name, offset: offset, kind: fkind)]
                    offset = offset + 8
                    i = i + 1
                }
                let mnames: [str] = []
                let mids: [int64] = []
                let mrets: [TypeKind] = []
                let j = 0
                for j < len(methods) {
                    let fd = p.func_decls[methods[j]]
                    mnames += [fd.name]
                    mids += [methods[j]]
                    mrets += [self.resolve_type(fd.return_typ)]
                    j = j + 1
                }
                self.p = saved_p
                self.structs += [StructInfo(name: name, fields: finfos, method_names: mnames, method_decl_ids: mids, method_return_kinds: mrets, data_width: offset, module_prefix: prefix, src_p: p)]
            }
            else none
        }
    }

    // Register all struct and enum declarations from another module under the
    // given prefix (e.g. "builtins"). Doesn't emit any code for them — just
    // makes their names and methods visible for label resolution.
    func register_module_types(self, anon m: ast.Module, prefix: str, p: parser.Parser) -> none {
        let i = 0
        for i < len(m.decls) {
            self.register_enum(m.decls[i], prefix: prefix, p: p)
            self.register_struct(m.decls[i], prefix: prefix, p: p)
            i = i + 1
        }
    }


    // Walk an expression and allocate stack slots for any bindings that
    // appear in nested match expressions. Without this, 'Some(x) -> x'
    // inside a match expression returns 'x' as an unknown var.
    func collect_expr_vars(self, anon expr_id: int64) -> none {
        match self.p.exprs[expr_id] {
            .Binary(lhs, op, rhs) -> {
                self.collect_expr_vars(lhs)
                self.collect_expr_vars(rhs)
            }
            .Call(callee, args) -> {
                self.collect_expr_vars(callee)
                let i = 0
                for i < len(args) {
                    self.collect_expr_vars(args[i].value)
                    i = i + 1
                }
            }
            .ArrayLit(elements) -> {
                let i = 0
                for i < len(elements) {
                    self.collect_expr_vars(elements[i])
                    i = i + 1
                }
            }
            .Slice(s, lo, hi) -> {
                self.collect_expr_vars(s)
                self.collect_expr_vars(lo)
                if hi != 0 {
                    self.collect_expr_vars(hi)
                }
            }
            .MatchExpr(subject, arms) -> {
                self.collect_expr_vars(subject)
                let i = 0
                for i < len(arms) {
                    let arm = self.p.match_expr_arms[arms[i]]
                    match self.p.patterns[arm.pattern] {
                        .SomePat(binding) -> {
                            if len(binding) > 0 and self.var_declared(binding) == false {
                                self.alloc_var(binding, .KInt64)
                            }
                        }
                        .EnumPat(enum_name, variant_name, bindings) -> {
                            let ei = self.find_enum_idx(enum_name)
                            let vi = -1
                            if ei >= 0 {
                                vi = self.find_variant_idx(ei, variant_name)
                            }
                            let j = 0
                            for j < len(bindings) {
                                if self.var_declared(bindings[j]) == false {
                                    let bkind = .KInt64
                                    if vi >= 0 and j < len(self.enums[ei].variants[vi].field_kinds) {
                                        bkind = self.enums[ei].variants[vi].field_kinds[j]
                                    }
                                    self.alloc_var(bindings[j], bkind)
                                }
                                j = j + 1
                            }
                        }
                        .ImplicitEnumPat(variant_name, bindings) -> {
                            let ei = self.find_enum_with_variant(variant_name)
                            let vi = -1
                            if ei >= 0 {
                                vi = self.find_variant_idx(ei, variant_name)
                            }
                            let j = 0
                            for j < len(bindings) {
                                if self.var_declared(bindings[j]) == false {
                                    let bkind = .KInt64
                                    if vi >= 0 and j < len(self.enums[ei].variants[vi].field_kinds) {
                                        bkind = self.enums[ei].variants[vi].field_kinds[j]
                                    }
                                    self.alloc_var(bindings[j], bkind)
                                }
                                j = j + 1
                            }
                        }
                        else none
                    }
                    self.collect_expr_vars(arm.body)
                    i = i + 1
                }
            }
            else none
        }
    }

    func collect_stmt_vars(self, stmt_id: int64) -> none {
        match self.p.stmts[stmt_id] {
            .Let(name, typ, value) -> {
                if self.var_declared(name) == false {
                    let kind = self.resolve_type(typ)
                    self.alloc_var(name, kind)
                }
                self.collect_expr_vars(value)
            }
            .Assign(lhs, rhs) -> self.collect_expr_vars(rhs)
            .PlusAssign(lhs, rhs) -> self.collect_expr_vars(rhs)
            .Return(value) -> {
                if value != 0 {
                    self.collect_expr_vars(value)
                }
            }
            .ExprStmt(expr) -> self.collect_expr_vars(expr)
            .If(cond, then_body, else_body) -> {
                self.collect_expr_vars(cond)
                let i = 0
                for i < len(then_body) {
                    self.collect_stmt_vars(then_body[i])
                    i = i + 1
                }
                let j = 0
                for j < len(else_body) {
                    self.collect_stmt_vars(else_body[j])
                    j = j + 1
                }
            }
            .For(cond, body) -> {
                let i = 0
                for i < len(body) {
                    self.collect_stmt_vars(body[i])
                    i = i + 1
                }
            }
            .ForEach(name, iter, body) -> {
                if self.var_declared(name) == false {
                    let ekind = .KInt64
                    match self.infer_kind(iter) {
                        .KArrayStruct(elem_idx) -> ekind = .KStruct(idx: elem_idx)
                        .KArrayEnum(elem_idx) -> ekind = .KEnum(idx: elem_idx)
                        .KArrayStr -> ekind = .KStr
                        else none
                    }
                    self.alloc_var(name, ekind)
                }
                let idx_name = f"__fi_{name}"
                if self.var_declared(idx_name) == false {
                    self.alloc_var(idx_name, .KInt64)
                }
                let i = 0
                for i < len(body) {
                    self.collect_stmt_vars(body[i])
                    i = i + 1
                }
            }
            .MatchStmt(subject, arms) -> {
                let i = 0
                for i < len(arms) {
                    let arm = self.p.match_arms[arms[i]]
                    match self.p.patterns[arm.pattern] {
                        .SomePat(binding) -> {
                            if len(binding) > 0 and self.var_declared(binding) == false {
                                self.alloc_var(binding, .KInt64)
                            }
                        }
                        .EnumPat(enum_name, variant_name, bindings) -> {
                            let ei = self.find_enum_idx(enum_name)
                            let vi = -1
                            if ei >= 0 {
                                vi = self.find_variant_idx(ei, variant_name)
                            }
                            let j = 0
                            for j < len(bindings) {
                                if self.var_declared(bindings[j]) == false {
                                    let bkind = .KInt64
                                    if vi >= 0 and j < len(self.enums[ei].variants[vi].field_kinds) {
                                        bkind = self.enums[ei].variants[vi].field_kinds[j]
                                    }
                                    self.alloc_var(bindings[j], bkind)
                                }
                                j = j + 1
                            }
                        }
                        .ImplicitEnumPat(variant_name, bindings) -> {
                            let ei = self.find_enum_with_variant(variant_name)
                            let vi = -1
                            if ei >= 0 {
                                vi = self.find_variant_idx(ei, variant_name)
                            }
                            let j = 0
                            for j < len(bindings) {
                                if self.var_declared(bindings[j]) == false {
                                    let bkind = .KInt64
                                    if vi >= 0 and j < len(self.enums[ei].variants[vi].field_kinds) {
                                        bkind = self.enums[ei].variants[vi].field_kinds[j]
                                    }
                                    self.alloc_var(bindings[j], bkind)
                                }
                                j = j + 1
                            }
                        }
                        else none
                    }
                    let j = 0
                    for j < len(arm.body) {
                        self.collect_stmt_vars(arm.body[j])
                        j = j + 1
                    }
                    i = i + 1
                }
            }
            .LetElse(pattern, value, else_body) -> {
                // Allocate bindings introduced by the pattern (same shape as
                // a match arm) so the rest of the surrounding block can use
                // them.
                match self.p.patterns[pattern] {
                    .EnumPat(enum_name, variant_name, bindings) -> {
                        let ei = self.find_enum_idx(enum_name)
                        let vi = -1
                        if ei >= 0 {
                            vi = self.find_variant_idx(ei, variant_name)
                        }
                        let j = 0
                        for j < len(bindings) {
                            if self.var_declared(bindings[j]) == false {
                                let bkind = .KInt64
                                if vi >= 0 and j < len(self.enums[ei].variants[vi].field_kinds) {
                                    bkind = self.enums[ei].variants[vi].field_kinds[j]
                                }
                                self.alloc_var(bindings[j], bkind)
                            }
                            j = j + 1
                        }
                    }
                    .ImplicitEnumPat(variant_name, bindings) -> {
                        let ei = self.find_enum_with_variant(variant_name)
                        let vi = -1
                        if ei >= 0 {
                            vi = self.find_variant_idx(ei, variant_name)
                        }
                        let j = 0
                        for j < len(bindings) {
                            if self.var_declared(bindings[j]) == false {
                                let bkind = .KInt64
                                if vi >= 0 and j < len(self.enums[ei].variants[vi].field_kinds) {
                                    bkind = self.enums[ei].variants[vi].field_kinds[j]
                                }
                                self.alloc_var(bindings[j], bkind)
                            }
                            j = j + 1
                        }
                    }
                    .SomePat(binding) -> {
                        if len(binding) > 0 and self.var_declared(binding) == false {
                            self.alloc_var(binding, .KInt64)
                        }
                    }
                    else none
                }
                self.collect_expr_vars(value)
                let e = 0
                for e < len(else_body) {
                    self.collect_stmt_vars(else_body[e])
                    e = e + 1
                }
            }
            else none
        }
    }


    func compile_expr(self, anon expr_id: int64) -> Val {
        match self.p.exprs[expr_id] {
            .IntLit(value) -> return .VImm(value: value)
            .BoolLit(value) -> {
                if value {
                    return .VImm(value: 1)
                }
                return .VImm(value: 0)
            }
            .NoneLit -> return .VImm(value: 0)
            .StrLit(value) -> {
                let lbl = self.intern_str(value)
                return .VStrLbl(page: lbl)
            }
            .Ident(name) -> {
                let off = self.find_var_offset(name)
                return .VStack(offset: off)
            }
            .ImplicitVariant(name) -> {
                let ei = self.find_enum_with_variant(name)
                let vi = self.find_variant_idx(ei, name)
                let empty: [ast.CallArg] = []
                return self.compile_enum_construct(ei, vi, empty)
            }
            .Binary(lhs, op, rhs) -> return self.compile_binary(lhs, op, rhs)
            .Call(callee, args) -> return self.compile_call(callee, args)
            .ArrayLit(elements) -> return self.compile_array_lit(elements)
            .MatchExpr(subject, arms) -> return self.compile_match_expr(subject, arms)
            .Slice(s, lo, hi) -> return self.compile_slice(s, lo, hi)
        }
    }

    func compile_binary(self, lhs: int64, op: ast.Op, rhs: int64) -> Val {
        match op {
            .Dot -> return self.compile_dot(lhs, rhs)
            .Index -> return self.compile_index(lhs, rhs)
            .And -> return self.compile_and(lhs, rhs)
            .Or -> return self.compile_or(lhs, rhs)
            .Is -> return self.compile_is(lhs, rhs)
            else return self.compile_arith_cmp(lhs, op, rhs)
        }
    }

    // Try `module.Enum.Variant` — bare three-part unit-variant access.
    // Drops the module qualifier (types are global in the codegen).
    func try_three_part_unit_variant(self, dot_lhs: int64, dot_rhs: int64) -> Val? {
        let .Binary(inner_lhs, inner_op, inner_rhs) = self.p.exprs[dot_lhs] else { return none }
        let .Dot = inner_op else { return none }
        let .Ident(enum_name) = self.p.exprs[inner_rhs] else { return none }
        let .Ident(variant_name) = self.p.exprs[dot_rhs] else { return none }
        let ei3 = self.find_enum_idx(enum_name)
        if ei3 < 0 { return none }
        let vi3 = self.find_variant_idx(ei3, variant_name)
        if vi3 < 0 { return none }
        let empty: [ast.CallArg] = []
        return self.compile_enum_construct(ei3, vi3, empty)
    }

    // Try `EnumName.Variant` — bare two-part unit-variant access.
    func try_two_part_unit_variant(self, dot_lhs: int64, dot_rhs: int64) -> Val? {
        let .Ident(type_name) = self.p.exprs[dot_lhs] else { return none }
        let ei = self.find_enum_idx(type_name)
        if ei < 0 { return none }
        let .Ident(variant_name) = self.p.exprs[dot_rhs] else { return none }
        let vi = self.find_variant_idx(ei, variant_name)
        let empty: [ast.CallArg] = []
        return self.compile_enum_construct(ei, vi, empty)
    }

    func compile_dot(self, lhs: int64, rhs: int64) -> Val {
        match self.try_three_part_unit_variant(lhs, rhs) {
            Some(v) -> return v
            none -> {}
        }
        match self.try_two_part_unit_variant(lhs, rhs) {
            Some(v) -> return v
            none -> {}
        }
        let ptr_v = self.compile_expr(lhs)
        let ptr_r = self.load(ptr_v)
        match self.p.exprs[rhs] {
            .Ident(field_name) -> {
                // Resolve the struct via infer_kind so chained accesses
                // (e.g. obj.field, arr[i].field) work, not just Ident lhs.
                let struct_idx = -1
                match self.infer_kind(lhs) {
                    .KStruct(idx) -> struct_idx = idx
                    else none
                }
                let field_off = 0
                if struct_idx >= 0 {
                    field_off = self.find_field_offset(struct_idx, field_name)
                }
                let result = self.alloc_reg()
                self.emit(f"ldr {result}, [{ptr_r}, #{self.itos(field_off)}]")
                self.free_reg(ptr_r)
                return .VReg(name: result)
            }
            else none
        }
        self.free_reg(ptr_r)
        return .VImm(value: 0)
    }

    func find_var_offset_by_lhs(self, anon expr_id: int64) -> int64 {
        match self.p.exprs[expr_id] {
            .Ident(name) -> return self.find_var_offset(name)
            else return -8
        }
    }

    func compile_index(self, lhs: int64, rhs: int64) -> Val {
        let lhs_kind = self.infer_kind(lhs)
        // Struct with op_index — dispatch as a method call.
        match lhs_kind {
            .KStruct(idx) -> {
                let mi = 0
                let found = false
                for mi < len(self.structs[idx].method_names) {
                    if self.structs[idx].method_names[mi] == "op_index" {
                        found = true
                        mi = len(self.structs[idx].method_names)
                    } else {
                        mi = mi + 1
                    }
                }
                if found {
                    let kv = self.compile_expr(rhs)
                    let kr = self.alloc_reg()
                    self.mov_to(kr, kv)
                    let ov = self.compile_expr(lhs)
                    self.mov_to("x0", ov)
                    self.emit(f"mov x1, {kr}")
                    self.free_reg(kr)
                    let method_lbl = f"${self.structs[idx].module_prefix}${self.structs[idx].name}$op_index"
                    self.emit(f"bl {method_lbl}")
                    return .VReg(name: "x0")
                }
            }
            else none
        }
        let ptr_v = self.compile_expr(lhs)
        let idx_v = self.compile_expr(rhs)
        let ptr_r = self.load(ptr_v)
        let idx_r = self.load(idx_v)
        let result = self.alloc_reg()
        let array_like = false
        match lhs_kind {
            .KArray -> array_like = true
            .KArrayStruct(elem_idx) -> array_like = true
            .KArrayEnum(elem_idx) -> array_like = true
            .KArrayStr -> array_like = true
            else none
        }
        if array_like {
            // Normalise negative index: if idx < 0, idx += len.
            let pos_lbl = self.fresh("Lidx_pos")
            let len_r = self.alloc_reg()
            self.emit(f"ldr {len_r}, [{ptr_r}, #8]")
            self.emit(f"cmp {idx_r}, #0")
            self.emit(f"bge {pos_lbl}")
            self.emit(f"add {idx_r}, {idx_r}, {len_r}")
            self.emit_label(pos_lbl)
            self.free_reg(len_r)

            let hdr = self.alloc_reg()
            self.emit(f"ldr {hdr}, [{ptr_r}]")
            self.emit(f"lsl {idx_r}, {idx_r}, #3")
            self.emit(f"ldr {result}, [{hdr}, {idx_r}]")
            self.free_reg(hdr)
        } else {
            self.emit(f"ldrb w{result[1:len(result)]}, [{ptr_r}, {idx_r}]")
        }
        self.free_reg(ptr_r)
        self.free_reg(idx_r)
        return .VReg(name: result)
    }

    func compile_and(self, lhs: int64, rhs: int64) -> Val {
        let done = self.fresh("Land")
        let result = self.alloc_reg()
        let lv = self.compile_expr(lhs)
        self.mov_to(result, lv)
        self.emit(f"cmp {result}, #0")
        self.emit(f"cset {result}, ne")
        self.emit(f"beq {done}")
        let rv = self.compile_expr(rhs)
        self.mov_to(result, rv)
        self.emit(f"cmp {result}, #0")
        self.emit(f"cset {result}, ne")
        self.emit_label(done)
        return .VReg(name: result)
    }

    func compile_or(self, lhs: int64, rhs: int64) -> Val {
        let done = self.fresh("Lor")
        let result = self.alloc_reg()
        let lv = self.compile_expr(lhs)
        self.mov_to(result, lv)
        self.emit(f"cmp {result}, #0")
        self.emit(f"cset {result}, ne")
        self.emit(f"bne {done}")
        let rv = self.compile_expr(rhs)
        self.mov_to(result, rv)
        self.emit(f"cmp {result}, #0")
        self.emit(f"cset {result}, ne")
        self.emit_label(done)
        return .VReg(name: result)
    }

    func compile_is(self, lhs: int64, rhs: int64) -> Val {
        let ptr_v = self.compile_expr(lhs)
        let r = self.load(ptr_v)
        self.emit(f"cmp {r}, #0")
        match self.p.exprs[rhs] {
            .NoneLit -> self.emit(f"cset {r}, eq")
            else self.emit(f"cset {r}, ne")
        }
        return .VReg(name: r)
    }

    func compile_arith_cmp(self, lhs_id: int64, op: ast.Op, rhs_id: int64) -> Val {
        let lhs_kind = self.infer_kind(lhs_id)
        match lhs_kind {
            .KStr -> {
                match op {
                    .Eq -> return self.compile_str_eq(lhs_id, rhs_id, false)
                    .Ne -> return self.compile_str_eq(lhs_id, rhs_id, true)
                    else none
                }
            }
            else none
        }
        match op {
            .Add -> {
                match lhs_kind {
                    .KStr -> return self.compile_str_concat(lhs_id, rhs_id)
                    .KArray -> return self.compile_arr_concat(lhs_id, rhs_id)
                    .KArrayStruct(elem_idx) -> return self.compile_arr_concat(lhs_id, rhs_id)
                    .KArrayEnum(elem_idx) -> return self.compile_arr_concat(lhs_id, rhs_id)
                    .KArrayStr -> return self.compile_arr_concat(lhs_id, rhs_id)
                    else none
                }
            }
            else none
        }

        // Compile both sides, stashing the lhs on the stack across the rhs
        // compilation so its value survives any bl calls in rhs.
        let lv = self.compile_expr(lhs_id)
        let lv_r = self.load_enum_or_val(lhs_id, lv)
        let lr = self.alloc_reg()
        if lv_r != lr {
            self.emit(f"mov {lr}, {lv_r}")
        }
        self.free_reg(lv_r)
        self.emit("sub sp, sp, #16")
        self.emit(f"str {lr}, [sp]")
        let rv = self.compile_expr(rhs_id)
        let rr = self.load_enum_or_val(rhs_id, rv)
        self.emit(f"ldr {lr}, [sp]")
        self.emit("add sp, sp, #16")
        let result = self.alloc_reg()
        match op {
            .Eq -> {
                self.emit(f"cmp {lr}, {rr}")
                self.emit(f"cset {result}, eq")
            }
            .Ne -> {
                self.emit(f"cmp {lr}, {rr}")
                self.emit(f"cset {result}, ne")
            }
            .Lt -> {
                self.emit(f"cmp {lr}, {rr}")
                self.emit(f"cset {result}, lt")
            }
            .Le -> {
                self.emit(f"cmp {lr}, {rr}")
                self.emit(f"cset {result}, le")
            }
            .Gt -> {
                self.emit(f"cmp {lr}, {rr}")
                self.emit(f"cset {result}, gt")
            }
            .Ge -> {
                self.emit(f"cmp {lr}, {rr}")
                self.emit(f"cset {result}, ge")
            }
            .Add -> {
                self.emit(f"add {result}, {lr}, {rr}")
            }
            .Sub -> {
                self.emit(f"sub {result}, {lr}, {rr}")
            }
            .Mul -> {
                self.emit(f"mul {result}, {lr}, {rr}")
            }
            .Div -> {
                self.emit(f"sdiv {result}, {lr}, {rr}")
            }
            .Mod -> {
                let tmp2 = self.alloc_reg()
                self.emit(f"sdiv {result}, {lr}, {rr}")
                self.emit(f"mul {tmp2}, {result}, {rr}")
                self.emit(f"sub {result}, {lr}, {tmp2}")
                self.free_reg(tmp2)
            }
            else {
                self.emit(f"cmp {lr}, {rr}")
                self.emit(f"cset {result}, eq")
            }
        }
        self.free_reg(lr)
        self.free_reg(rr)
        return .VReg(name: result)
    }

    func load_enum_or_val(self, expr_id: int64, anon v: Val) -> str {
        match self.infer_kind(expr_id) {
            .KEnum(idx) -> {
                let r = self.load(v)
                self.emit(f"ldr {r}, [{r}]")
                return r
            }
            else return self.load(v)
        }
    }

    func compile_str_eq(self, lhs_id: int64, rhs_id: int64, negate: bool) -> Val {
        let rv = self.compile_expr(rhs_id)
        let rr = self.alloc_reg()
        self.mov_to(rr, rv)
        // Stash rhs to the stack so the lhs compilation (which may bl)
        // doesn't clobber rr's pool register.
        self.emit("sub sp, sp, #16")
        self.emit(f"str {rr}, [sp]")
        let lv = self.compile_expr(lhs_id)
        self.mov_to("x0", lv)
        self.emit(f"ldr {rr}, [sp]")
        self.emit("add sp, sp, #16")
        self.emit(f"mov x1, {rr}")
        self.free_reg(rr)
        self.emit("bl _strcmp")
        let result = self.alloc_reg()
        self.emit("cmp x0, #0")
        if negate {
            self.emit(f"cset {result}, ne")
        } else {
            self.emit(f"cset {result}, eq")
        }
        return .VReg(name: result)
    }

    func compile_str_concat(self, lhs_id: int64, rhs_id: int64) -> Val {
        let rv = self.compile_expr(rhs_id)
        let rr = self.alloc_reg()
        self.mov_to(rr, rv)
        // Save rhs to the stack so it survives any bl calls inside lhs
        // compilation (pool registers x8-x15 are caller-saved and would
        // be clobbered by an inner _kod_str_concat for chained concats).
        self.emit("sub sp, sp, #16")
        self.emit(f"str {rr}, [sp]")
        let lv = self.compile_expr(lhs_id)
        self.mov_to("x0", lv)
        self.emit(f"ldr {rr}, [sp]")
        self.emit("add sp, sp, #16")
        self.emit(f"mov x1, {rr}")
        self.free_reg(rr)
        self.emit("bl _kod_str_concat")
        return .VReg(name: "x0")
    }

    func compile_arr_concat(self, lhs_id: int64, rhs_id: int64) -> Val {
        let rv = self.compile_expr(rhs_id)
        let rr = self.load(rv)
        let lv = self.compile_expr(lhs_id)
        self.mov_to("x0", lv)
        self.emit(f"mov x1, {rr}")
        self.free_reg(rr)
        self.emit("bl _kod_array_concat")
        return .VReg(name: "x0")
    }

    func compile_slice(self, s_id: int64, lo_id: int64, hi_id: int64) -> Val {
        // Stash each value on the stack so that compile_expr calls (which can
        // issue bl into len/strlen/etc.) don't clobber prior args still held
        // in caller-saved pool registers or in x0.
        self.emit("sub sp, sp, #32")
        let hi_v = self.compile_expr(hi_id)
        let hi_r = self.load(hi_v)
        self.emit(f"str {hi_r}, [sp, #16]")
        self.free_reg(hi_r)
        let lo_v = self.compile_expr(lo_id)
        let lo_r = self.load(lo_v)
        self.emit(f"str {lo_r}, [sp, #8]")
        self.free_reg(lo_r)
        let sv = self.compile_expr(s_id)
        let s_r = self.load(sv)
        self.emit(f"str {s_r}, [sp]")
        self.free_reg(s_r)
        self.emit("ldr x0, [sp]")
        self.emit("ldr x1, [sp, #8]")
        self.emit("ldr x2, [sp, #16]")
        self.emit("add sp, sp, #32")
        self.emit("bl _kod_str_slice")
        return .VReg(name: "x0")
    }

    func compile_array_lit(self, anon elements: [int64]) -> Val {
        let n = len(elements)
        let item_sz = 8
        // Allocate header (24 bytes) and buf, saving both pointers on
        // the stack so element compilation (which may bl) doesn't
        // clobber them via pool-register reuse.
        self.emit("sub sp, sp, #16")
        self.emit("mov x0, #24")
        self.emit("bl _arena_alloc")
        self.emit("str x0, [sp]")
        let buf_sz = n * item_sz
        if buf_sz < 8 {
            buf_sz = 8
        }
        self.emit(f"mov x0, #{self.itos(buf_sz)}")
        self.emit("bl _arena_alloc")
        self.emit("str x0, [sp, #8]")
        let i = 0
        for i < n {
            let ev = self.compile_expr(elements[i])
            let er = self.load(ev)
            // Reload buf from stack — any bl in compile_expr above would
            // have clobbered a pool-register copy.
            let buf_r = self.alloc_reg()
            self.emit(f"ldr {buf_r}, [sp, #8]")
            self.emit(f"str {er}, [{buf_r}, #{self.itos(i * item_sz)}]")
            self.free_reg(buf_r)
            self.free_reg(er)
            i = i + 1
        }
        let hdr_r = self.alloc_reg()
        let buf_r = self.alloc_reg()
        self.emit(f"ldr {hdr_r}, [sp]")
        self.emit(f"ldr {buf_r}, [sp, #8]")
        self.emit("add sp, sp, #16")
        self.emit(f"str {buf_r}, [{hdr_r}]")
        let len_r = self.alloc_reg()
        self.emit(f"mov {len_r}, #{self.itos(n)}")
        self.emit(f"str {len_r}, [{hdr_r}, #8]")
        self.emit(f"str {len_r}, [{hdr_r}, #16]")
        self.free_reg(len_r)
        self.free_reg(buf_r)
        return .VReg(name: hdr_r)
    }

    // Try `mod.Enum.Variant(args)` — succeed iff the callee shape is
    // Binary(Binary(Ident(mod), Dot, Ident(enum)), Dot, Ident(variant))
    // and Enum/Variant resolve.
    func try_three_part_construct(self, callee_lhs: int64, callee_rhs: int64, anon args: [ast.CallArg]) -> Val? {
        let .Binary(inner_lhs, inner_op, inner_rhs) = self.p.exprs[callee_lhs] else { return none }
        let .Dot = inner_op else { return none }
        let .Ident(mod_name) = self.p.exprs[inner_lhs] else { return none }
        let .Ident(enum_name) = self.p.exprs[inner_rhs] else { return none }
        let .Ident(variant_name) = self.p.exprs[callee_rhs] else { return none }
        let ei = self.find_enum_idx(enum_name)
        if ei < 0 { return none }
        let vi = self.find_variant_idx(ei, variant_name)
        if vi < 0 { return none }
        return self.compile_enum_construct(ei, vi, args)
    }

    // Try `EnumName.Variant(args)` or `module.thing(args)` two-part forms.
    func try_two_part_call(self, callee_lhs: int64, callee_rhs: int64, anon args: [ast.CallArg]) -> Val? {
        let .Ident(mod_or_obj) = self.p.exprs[callee_lhs] else { return none }
        let .Ident(method_name) = self.p.exprs[callee_rhs] else { return none }
        let enum_idx = self.find_enum_idx(mod_or_obj)
        if enum_idx >= 0 {
            let variant_idx = self.find_variant_idx(enum_idx, method_name)
            if variant_idx >= 0 {
                return self.compile_enum_construct(enum_idx, variant_idx, args)
            }
        }
        let is_import = false
        let i = 0
        for i < len(self.import_local) {
            if self.import_local[i] == mod_or_obj {
                is_import = true
                i = len(self.import_local)
            } else {
                i = i + 1
            }
        }
        if is_import {
            let s_idx = self.find_struct_idx(method_name)
            if s_idx >= 0 {
                return self.compile_struct_construct(s_idx, args)
            }
            self.prepare_args(args)
            let lbl = self.import_func_label(mod_or_obj, method_name)
            self.emit(f"bl {lbl}")
            return .VReg(name: "x0")
        }
        return self.compile_method_call(mod_or_obj, method_name, args)
    }

    func compile_call(self, callee_id: int64, anon args: [ast.CallArg]) -> Val {
        match self.p.exprs[callee_id] {
            .Ident(name) -> {
                if name == "len" and len(args) == 1 {
                    return self.compile_len(args[0].value)
                }
                // Struct constructor: StructName(field1: v1, ...)
                let si = self.find_struct_idx(name)
                if si >= 0 {
                    return self.compile_struct_construct(si, args)
                }
                self.prepare_args(args)
                let lbl = self.func_label(name)
                self.emit(f"bl {lbl}")
                return .VReg(name: "x0")
            }
            .Binary(lhs, op, rhs) -> {
                match op {
                    .Dot -> {
                        match self.try_three_part_construct(lhs, rhs, args) {
                            Some(v) -> return v
                            none -> {}
                        }
                        match self.try_two_part_call(lhs, rhs, args) {
                            Some(v) -> return v
                            none -> {}
                        }
                    }
                    else none
                }
                self.prepare_args(args)
                self.emit("bl _unknown")
                return .VReg(name: "x0")
            }
            .ImplicitVariant(variant_name) -> {
                // .Variant(args) constructor — payload form of implicit variant.
                let ei = self.find_enum_with_variant(variant_name)
                if ei >= 0 {
                    let vi = self.find_variant_idx(ei, variant_name)
                    if vi >= 0 {
                        return self.compile_enum_construct(ei, vi, args)
                    }
                }
                self.prepare_args(args)
                self.emit("bl _unknown")
                return .VReg(name: "x0")
            }
            else {
                self.prepare_args(args)
                self.emit("bl _unknown")
                return .VReg(name: "x0")
            }
        }
    }

    func compile_len(self, anon arg_id: int64) -> Val {
        let kind = self.infer_kind(arg_id)
        let av = self.compile_expr(arg_id)
        match kind {
            .KArray -> {
                let r = self.load(av)
                self.emit(f"ldr {r}, [{r}, #8]")
                return .VReg(name: r)
            }
            .KArrayStruct(elem_idx) -> {
                let r = self.load(av)
                self.emit(f"ldr {r}, [{r}, #8]")
                return .VReg(name: r)
            }
            .KArrayEnum(elem_idx) -> {
                let r = self.load(av)
                self.emit(f"ldr {r}, [{r}, #8]")
                return .VReg(name: r)
            }
            .KArrayStr -> {
                let r = self.load(av)
                self.emit(f"ldr {r}, [{r}, #8]")
                return .VReg(name: r)
            }
            .KStr -> {
                self.mov_to("x0", av)
                self.emit("bl _strlen")
                return .VReg(name: "x0")
            }
            else {
                let r = self.load(av)
                self.emit(f"ldr {r}, [{r}, #8]")
                return .VReg(name: r)
            }
        }
    }

    func compile_method_call(self, obj_name: str, method_name: str, anon args: [ast.CallArg]) -> Val {
        let var_kind = self.find_var_kind(obj_name)
        let obj_off = self.find_var_offset(obj_name)

        let method_lbl = "_unknown_method"
        match var_kind {
            .KStruct(idx) -> {
                let mi = 0
                for mi < len(self.structs[idx].method_names) {
                    if self.structs[idx].method_names[mi] == method_name {
                        method_lbl = f"${self.structs[idx].module_prefix}${self.structs[idx].name}${method_name}"
                        mi = len(self.structs[idx].method_names)
                    } else {
                        mi = mi + 1
                    }
                }
            }
            else none
        }

        // Stash self and each compiled arg on the stack so that arg
        // expressions (which may issue bl calls) don't clobber preceding
        // values held in x0..x7.
        let arg_regs: [str] = ["x0", "x1", "x2", "x3", "x4", "x5", "x6", "x7"]
        let n = len(args) + 1
        let padded = n * 8
        if padded % 16 != 0 {
            padded = padded + 8
        }
        self.emit(f"sub sp, sp, #{self.itos(padded)}")
        self.emit_ldr("x0", obj_off)
        self.emit("str x0, [sp]")
        let i = 0
        for i < len(args) {
            let av = self.compile_expr(args[i].value)
            let ar = self.load(av)
            self.emit(f"str {ar}, [sp, #{self.itos((i + 1) * 8)}]")
            self.free_reg(ar)
            i = i + 1
        }
        let k = 0
        for k < n {
            self.emit(f"ldr {arg_regs[k]}, [sp, #{self.itos(k * 8)}]")
            k = k + 1
        }
        self.emit(f"add sp, sp, #{self.itos(padded)}")
        self.emit(f"bl {method_lbl}")
        return .VReg(name: "x0")
    }

    func prepare_args(self, anon args: [ast.CallArg]) -> none {
        let arg_regs: [str] = ["x0", "x1", "x2", "x3", "x4", "x5", "x6", "x7"]
        let n = len(args)
        if n == 0 {
            return none
        }
        // Reserve 16-byte aligned stack space and stash each compiled arg
        // there. Compiling an arg may issue bl calls (e.g. into match
        // expressions, struct/enum construction, array concat) which would
        // clobber any earlier args we'd already placed into x0..x7.
        let padded = n * 8
        if padded % 16 != 0 {
            padded = padded + 8
        }
        self.emit(f"sub sp, sp, #{self.itos(padded)}")
        let i = 0
        for i < n {
            let av = self.compile_expr(args[i].value)
            let ar = self.load(av)
            self.emit(f"str {ar}, [sp, #{self.itos(i * 8)}]")
            self.free_reg(ar)
            i = i + 1
        }
        let k = 0
        for k < n {
            self.emit(f"ldr {arg_regs[k]}, [sp, #{self.itos(k * 8)}]")
            k = k + 1
        }
        self.emit(f"add sp, sp, #{self.itos(padded)}")
    }

    func compile_match_expr(self, subject_id: int64, anon arms: [int64]) -> Val {
        let done_lbl = self.fresh("Lmexpr_done")
        let sv = self.compile_expr(subject_id)
        let sptr_r = self.load(sv)
        let subj_slot = self.alloc_var(self.fresh("__msubj"), .KInt64)
        self.emit_str(sptr_r, subj_slot)
        self.free_reg(sptr_r)
        let dv = .VStack(offset: subj_slot)
        let disc_r = self.load_enum_or_val(subject_id, dv)
        let result_r = self.alloc_reg()
        let i = 0
        for i < len(arms) {
            let arm = self.p.match_expr_arms[arms[i]]
            let skip_lbl = self.fresh("Lmexpr_skip")
            match self.p.patterns[arm.pattern] {
                .Wildcard -> {
                    let bv = self.compile_expr(arm.body)
                    self.mov_to(result_r, bv)
                    self.emit(f"b {done_lbl}")
                }
                .IntPat(value) -> {
                    self.emit(f"cmp {disc_r}, #{self.itos(value)}")
                    self.emit(f"bne {skip_lbl}")
                    let bv = self.compile_expr(arm.body)
                    self.mov_to(result_r, bv)
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .StrPat(value) -> {
                    let slbl = self.intern_str(value)
                    self.emit(f"adrp x0, {slbl}@PAGE")
                    self.emit(f"add x0, x0, {slbl}@PAGEOFF")
                    self.emit(f"mov x1, {disc_r}")
                    self.emit("bl _strcmp")
                    self.emit("cmp x0, #0")
                    self.emit(f"bne {skip_lbl}")
                    let bv = self.compile_expr(arm.body)
                    self.mov_to(result_r, bv)
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .EnumPat(enum_name, variant_name, bindings) -> {
                    let ei = self.find_enum_idx(enum_name)
                    let vi = self.find_variant_idx(ei, variant_name)
                    let disc = self.enums[ei].variants[vi].discriminant
                    self.emit(f"cmp {disc_r}, #{self.itos(disc)}")
                    self.emit(f"bne {skip_lbl}")
                    let bv = self.compile_expr(arm.body)
                    self.mov_to(result_r, bv)
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .ImplicitEnumPat(variant_name, bindings) -> {
                    let ei = self.find_enum_with_variant(variant_name)
                    let vi = self.find_variant_idx(ei, variant_name)
                    let disc = self.enums[ei].variants[vi].discriminant
                    self.emit(f"cmp {disc_r}, #{self.itos(disc)}")
                    self.emit(f"bne {skip_lbl}")
                    let bv = self.compile_expr(arm.body)
                    self.mov_to(result_r, bv)
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .NonePat -> {
                    self.emit(f"cmp {disc_r}, #0")
                    self.emit(f"bne {skip_lbl}")
                    let bv = self.compile_expr(arm.body)
                    self.mov_to(result_r, bv)
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .SomePat(binding) -> {
                    self.emit(f"cmp {disc_r}, #0")
                    self.emit(f"beq {skip_lbl}")
                    if len(binding) > 0 {
                        let boff = self.find_var_offset(binding)
                        let ptr_r = self.alloc_reg()
                        self.emit_ldr(ptr_r, subj_slot)
                        let val_r = self.alloc_reg()
                        self.emit(f"ldr {val_r}, [{ptr_r}]")
                        self.emit_str(val_r, boff)
                        self.free_reg(val_r)
                        self.free_reg(ptr_r)
                    }
                    let bv = self.compile_expr(arm.body)
                    self.mov_to(result_r, bv)
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                else {
                    let bv = self.compile_expr(arm.body)
                    self.mov_to(result_r, bv)
                    self.emit(f"b {done_lbl}")
                }
            }
            i = i + 1
        }
        self.emit_label(done_lbl)
        self.free_reg(disc_r)
        return .VReg(name: result_r)
    }


    // For `obj.method()` where obj is a known struct, return the method's
    // recorded return kind. Returns none if anything about the shape doesn't
    // match (callee not Ident.Ident, obj not a struct, method not found).
    func method_call_return_kind(self, callee_lhs: int64, callee_rhs: int64) -> TypeKind? {
        let .Ident(obj_name) = self.p.exprs[callee_lhs] else { return none }
        let .KStruct(sidx) = self.find_var_kind(obj_name) else { return none }
        let .Ident(method_name) = self.p.exprs[callee_rhs] else { return none }
        let mi = 0
        for mi < len(self.structs[sidx].method_names) {
            if self.structs[sidx].method_names[mi] == method_name {
                return self.structs[sidx].method_return_kinds[mi]
            }
            mi = mi + 1
        }
        return none
    }

    // For an expression of shape `mod.Enum.Variant`, return KEnum(idx).
    func three_part_enum_kind(self, dot_lhs: int64) -> TypeKind? {
        let .Binary(inner_lhs, inner_op, inner_rhs) = self.p.exprs[dot_lhs] else { return none }
        let .Dot = inner_op else { return none }
        let .Ident(enum_name) = self.p.exprs[inner_rhs] else { return none }
        let ei = self.find_enum_idx(enum_name)
        if ei < 0 { return none }
        return .KEnum(idx: ei)
    }

    // For `EnumName.X`, return KEnum(idx). (X is checked at the call site.)
    func two_part_enum_kind(self, dot_lhs: int64) -> TypeKind? {
        let .Ident(type_name) = self.p.exprs[dot_lhs] else { return none }
        let ei = self.find_enum_idx(type_name)
        if ei < 0 { return none }
        return .KEnum(idx: ei)
    }

    // Look up a struct field's kind by name. Returns none if absent.
    func struct_field_kind(self, struct_idx: int64, field_name: str) -> TypeKind? {
        let fi = 0
        for fi < len(self.structs[struct_idx].fields) {
            if self.structs[struct_idx].fields[fi].name == field_name {
                return self.structs[struct_idx].fields[fi].kind
            }
            fi = fi + 1
        }
        return none
    }

    func infer_kind(self, anon expr_id: int64) -> TypeKind {
        match self.p.exprs[expr_id] {
            .IntLit(value) -> return .KInt64
            .BoolLit(value) -> return .KBool
            .StrLit(value) -> return .KStr
            .NoneLit -> return .KOptional
            .Ident(name) -> return self.find_var_kind(name)
            .ArrayLit(elements) -> return .KArray
            .Slice(s, lo, hi) -> return .KStr
            .ImplicitVariant(name) -> {
                let ei = self.find_enum_with_variant(name)
                if ei >= 0 {
                    return .KEnum(idx: ei)
                }
                return .KInt64
            }
            .Call(callee, args) -> {
                match self.p.exprs[callee] {
                    .Ident(name) -> {
                        // Struct or enum constructor: TypeName(...)
                        let si = self.find_struct_idx(name)
                        if si >= 0 {
                            return .KStruct(idx: si)
                        }
                        let ei = self.find_enum_idx(name)
                        if ei >= 0 {
                            return .KEnum(idx: ei)
                        }
                    }
                    .Binary(call_lhs, call_op, call_rhs) -> {
                        let .Dot = call_op else { return .KInt64 }
                        match self.method_call_return_kind(call_lhs, call_rhs) {
                            Some(k) -> return k
                            none -> {}
                        }
                    }
                    .ImplicitVariant(variant_name) -> {
                        // .Variant(args) — constructor for an enum.
                        let ei2 = self.find_enum_with_variant(variant_name)
                        if ei2 >= 0 {
                            return .KEnum(idx: ei2)
                        }
                    }
                    else none
                }
                return .KInt64
            }
            .Binary(lhs, op, rhs) -> {
                match op {
                    .Dot -> {
                        // `mod.Enum.Variant` or `Enum.Variant` — unit-variant ref.
                        match self.three_part_enum_kind(lhs) {
                            Some(k) -> return k
                            none -> {}
                        }
                        match self.two_part_enum_kind(lhs) {
                            Some(k) -> return k
                            none -> {}
                        }
                        // Field access on any struct-valued expression.
                        let .KStruct(si) = self.infer_kind(lhs) else { return .KInt64 }
                        let .Ident(field_name) = self.p.exprs[rhs] else { return .KInt64 }
                        match self.struct_field_kind(si, field_name) {
                            Some(k) -> return k
                            none -> return .KInt64
                        }
                    }
                    .Add -> return self.infer_kind(lhs)
                    .Index -> {
                        match self.infer_kind(lhs) {
                            .KArrayStruct(elem_idx) -> return .KStruct(idx: elem_idx)
                            .KArrayEnum(elem_idx) -> return .KEnum(idx: elem_idx)
                            .KArrayStr -> return .KStr
                            .KStruct(sidx) -> {
                                // Struct with op_index — return its return kind.
                                let mi = 0
                                for mi < len(self.structs[sidx].method_names) {
                                    if self.structs[sidx].method_names[mi] == "op_index" {
                                        return self.structs[sidx].method_return_kinds[mi]
                                    }
                                    mi = mi + 1
                                }
                                return .KInt64
                            }
                            else return .KInt64
                        }
                    }
                    else return .KInt64
                }
            }
            else return .KInt64
        }
    }


    func compile_stmt(self, anon stmt_id: int64) -> none {
        match self.p.stmts[stmt_id] {
            .Let(name, typ, value) -> self.compile_let(name, typ, value)
            .Assign(lhs, rhs) -> self.compile_assign(lhs, rhs)
            .PlusAssign(lhs, rhs) -> self.compile_plus_assign(lhs, rhs)
            .Return(value) -> self.compile_return(value)
            .If(cond, then_body, else_body) -> self.compile_if(cond, then_body, else_body)
            .For(cond, body) -> self.compile_for(cond, body)
            .ForEach(name, iter, body) -> self.compile_foreach(name, iter, body)
            .Break -> self.compile_break()
            .Continue -> self.compile_continue()
            .ExprStmt(expr) -> {
                let v = self.compile_expr(expr)
                self.free_val(v)
            }
            .MatchStmt(subject, arms) -> self.compile_match_stmt(subject, arms)
            .LetElse(pattern, value, else_body) -> self.compile_let_else(pattern, value, else_body)
        }
    }

    func compile_let(self, name: str, typ: int64, value: int64) -> none {
        let off = self.find_var_offset(name)
        let kind = self.resolve_type(typ)
        match kind {
            .KVoid -> kind = self.infer_kind(value)
            else none
        }
        let i = 0
        for i < len(self.vars) {
            if self.vars[i].name == name {
                self.vars[i].kind = kind
                i = len(self.vars)
            } else {
                i = i + 1
            }
        }
        self.compile_store(off, kind, value)
    }

    func compile_store(self, dest_off: int64, kind: TypeKind, value_id: int64) -> none {
        match kind {
            .KEnum(idx) -> {
                self.emit_enum_alloc(idx, value_id, dest_off)
            }
            .KStruct(idx) -> {
                // If the source is a value already producing a struct pointer
                // (variable alias, call result, or constructor expression),
                // just store the pointer — preserve reference semantics.
                let alias = false
                match self.p.exprs[value_id] {
                    .Ident(name) -> {
                        match self.find_var_kind(name) {
                            .KStruct(other) -> alias = true
                            else none
                        }
                    }
                    .Call(callee, args) -> alias = true
                    .Binary(blhs, bop, brhs) -> {
                        match bop {
                            .Index -> alias = true
                            .Dot -> alias = true
                            else none
                        }
                    }
                    else none
                }
                if alias {
                    let v = self.compile_expr(value_id)
                    let r = self.load(v)
                    self.emit_str(r, dest_off)
                    self.free_reg(r)
                } else {
                    self.emit_struct_alloc(idx, value_id, dest_off)
                }
            }
            .KArray -> {
                let v = self.compile_expr(value_id)
                let r = self.load(v)
                self.emit_str(r, dest_off)
                self.free_reg(r)
            }
            .KArrayStruct(elem_idx) -> {
                let v = self.compile_expr(value_id)
                let r = self.load(v)
                self.emit_str(r, dest_off)
                self.free_reg(r)
            }
            .KArrayEnum(elem_idx) -> {
                let v = self.compile_expr(value_id)
                let r = self.load(v)
                self.emit_str(r, dest_off)
                self.free_reg(r)
            }
            .KArrayStr -> {
                let v = self.compile_expr(value_id)
                let r = self.load(v)
                self.emit_str(r, dest_off)
                self.free_reg(r)
            }
            .KOptional -> {
                // Wrap into an Optional cell unless the value is already an
                // Optional (NoneLit, Call return, or an inferred-Optional expr).
                let needs_wrap = true
                match self.p.exprs[value_id] {
                    .NoneLit -> needs_wrap = false
                    .Call(callee, args) -> needs_wrap = false
                    else none
                }
                if needs_wrap {
                    match self.infer_kind(value_id) {
                        .KOptional -> needs_wrap = false
                        else none
                    }
                }
                if needs_wrap == false {
                    let vv = self.compile_expr(value_id)
                    let vr = self.load(vv)
                    self.emit_str(vr, dest_off)
                    self.free_reg(vr)
                } else {
                    let vv = self.compile_expr(value_id)
                    let vr = self.load(vv)
                    self.emit("sub sp, sp, #16")
                    self.emit(f"str {vr}, [sp]")
                    self.free_reg(vr)
                    self.emit("mov x0, #8")
                    self.emit("bl _arena_alloc")
                    let pr = self.alloc_reg()
                    self.emit(f"mov {pr}, x0")
                    self.emit_str(pr, dest_off)
                    let tmp = self.alloc_reg()
                    self.emit(f"ldr {tmp}, [sp]")
                    self.emit("add sp, sp, #16")
                    self.emit(f"str {tmp}, [{pr}]")
                    self.free_reg(tmp)
                    self.free_reg(pr)
                }
            }
            else {
                let v = self.compile_expr(value_id)
                let r = self.load(v)
                self.emit_str(r, dest_off)
                self.free_reg(r)
            }
        }
    }

    // Allocate a struct value on the arena and return its pointer in x0.
    // field_args supplies the labelled field values.
    func compile_struct_construct(self, si: int64, anon field_args: [ast.CallArg]) -> Val {
        let dw = self.structs[si].data_width
        self.emit(f"mov x0, #{self.itos(dw)}")
        self.emit("bl _arena_alloc")
        let ptr_r = self.alloc_reg()
        self.emit(f"mov {ptr_r}, x0")
        let i = 0
        for i < len(field_args) {
            let arg = field_args[i]
            let foff = self.find_field_offset(si, arg.label)
            // Stash ptr_r across the call so it survives any bl in the
            // field expression.
            self.emit("sub sp, sp, #16")
            self.emit(f"str {ptr_r}, [sp]")
            let fv = self.compile_expr(arg.value)
            let fr = self.load(fv)
            self.emit(f"ldr {ptr_r}, [sp]")
            self.emit("add sp, sp, #16")
            self.emit(f"str {fr}, [{ptr_r}, #{self.itos(foff)}]")
            self.free_reg(fr)
            i = i + 1
        }
        self.emit(f"mov x0, {ptr_r}")
        self.free_reg(ptr_r)
        return .VReg(name: "x0")
    }

    // Allocate an enum value on the arena and return its pointer in x0.
    // field_args supplies payload values (empty for unit variants).
    func compile_enum_construct(self, ei: int64, vi: int64, anon field_args: [ast.CallArg]) -> Val {
        let dw = self.enums[ei].data_width
        let disc = self.enums[ei].variants[vi].discriminant
        self.emit(f"mov x0, #{self.itos(dw)}")
        self.emit("bl _arena_alloc")
        let ptr_r = self.alloc_reg()
        self.emit(f"mov {ptr_r}, x0")
        let disc_r = self.alloc_reg()
        self.emit(f"mov {disc_r}, #{self.itos(disc)}")
        self.emit(f"str {disc_r}, [{ptr_r}]")
        self.free_reg(disc_r)
        if len(field_args) > 0 {
            let vinfo = self.enums[ei].variants[vi]
            let i = 0
            for i < len(field_args) {
                let foff = vinfo.field_offsets[i]
                // Stash ptr_r across the call so it survives any bl in the
                // field expression.
                self.emit("sub sp, sp, #16")
                self.emit(f"str {ptr_r}, [sp]")
                let fv = self.compile_expr(field_args[i].value)
                let fr = self.load(fv)
                self.emit(f"ldr {ptr_r}, [sp]")
                self.emit("add sp, sp, #16")
                self.emit(f"str {fr}, [{ptr_r}, #{self.itos(8 + foff)}]")
                self.free_reg(fr)
                i = i + 1
            }
        }
        self.emit(f"mov x0, {ptr_r}")
        self.free_reg(ptr_r)
        return .VReg(name: "x0")
    }

    // For an expression that looks like a dotted variant reference, return
    // the variant name. Handles `.Variant`, `Enum.Variant`, and the Dot side
    // of `Enum.Variant(args)`.
    func dotted_variant_name(self, expr_id: int64) -> str? {
        match self.p.exprs[expr_id] {
            .ImplicitVariant(variant_name) -> return variant_name
            else none
        }
        let .Binary(lhs, op, rhs) = self.p.exprs[expr_id] else { return none }
        let .Dot = op else { return none }
        let .Ident(variant_name) = self.p.exprs[rhs] else { return none }
        return variant_name
    }

    func emit_enum_alloc(self, enum_idx: int64, value_id: int64, dest_off: int64) -> none {
        // Detect direct enum construction patterns and route through
        // compile_enum_construct; otherwise compile the expression and store
        // its (pointer) result.
        let variant_idx = -1
        let field_args: [ast.CallArg] = []
        // Bare-variant cases: .Variant or Enum.Variant
        match self.dotted_variant_name(value_id) {
            Some(name) -> variant_idx = self.find_variant_idx(enum_idx, name)
            none -> {}
        }
        // Variant-with-args case: <dotted>(args)
        match self.p.exprs[value_id] {
            .Call(callee_id, call_args) -> {
                match self.dotted_variant_name(callee_id) {
                    Some(name) -> {
                        variant_idx = self.find_variant_idx(enum_idx, name)
                        field_args = call_args
                    }
                    none -> {}
                }
            }
            else none
        }
        if variant_idx >= 0 {
            let v = self.compile_enum_construct(enum_idx, variant_idx, field_args)
            self.emit_str("x0", dest_off)
        } else {
            let v = self.compile_expr(value_id)
            let r = self.load(v)
            self.emit_str(r, dest_off)
            self.free_reg(r)
        }
    }

    func emit_struct_alloc(self, struct_idx: int64, value_id: int64, dest_off: int64) -> none {
        let dw = self.structs[struct_idx].data_width
        self.emit(f"mov x0, #{self.itos(dw)}")
        self.emit("bl _arena_alloc")
        let ptr_r = self.alloc_reg()
        self.emit(f"mov {ptr_r}, x0")
        self.emit_str(ptr_r, dest_off)
        self.free_reg(ptr_r)
        match self.p.exprs[value_id] {
            .Call(callee_id, args) -> {
                let i = 0
                for i < len(args) {
                    let arg = args[i]
                    let foff = self.find_field_offset(struct_idx, arg.label)
                    let fv = self.compile_expr(arg.value)
                    let fr = self.load(fv)
                    let pr = self.alloc_reg()
                    self.emit_ldr(pr, dest_off)
                    self.emit(f"str {fr}, [{pr}, #{self.itos(foff)}]")
                    self.free_reg(fr)
                    self.free_reg(pr)
                    i = i + 1
                }
            }
            else none
        }
    }

    // Compile `<lhs>.<field> = <rhs>` for any lhs expression that yields a
    // struct pointer.
    func compile_field_assign(self, lhs: int64, rhs: int64, rhs_id: int64) -> none {
        let .Ident(field_name) = self.p.exprs[rhs] else { return }
        let struct_idx = -1
        match self.infer_kind(lhs) {
            .KStruct(idx) -> struct_idx = idx
            else none
        }
        let foff = 0
        if struct_idx >= 0 {
            foff = self.find_field_offset(struct_idx, field_name)
        }
        // Compute rhs first, stash on stack, then compute the lhs pointer.
        let rv = self.compile_expr(rhs_id)
        let rr = self.load(rv)
        self.emit("sub sp, sp, #16")
        self.emit(f"str {rr}, [sp]")
        self.free_reg(rr)
        let pv = self.compile_expr(lhs)
        let pr = self.load(pv)
        let tr = self.alloc_reg()
        self.emit(f"ldr {tr}, [sp]")
        self.emit("add sp, sp, #16")
        self.emit(f"str {tr}, [{pr}, #{self.itos(foff)}]")
        self.free_reg(tr)
        self.free_reg(pr)
    }

    // Look up `op_index_set` on a struct, returning its mangled label.
    func struct_index_setter_label(self, struct_idx: int64) -> str? {
        let mi = 0
        for mi < len(self.structs[struct_idx].method_names) {
            if self.structs[struct_idx].method_names[mi] == "op_index_set" {
                return f"${self.structs[struct_idx].module_prefix}${self.structs[struct_idx].name}$op_index_set"
            }
            mi = mi + 1
        }
        return none
    }

    // Compile `<arr>[<key>] = <rhs>` for Ident-named arr. Dispatches to
    // op_index_set when available; otherwise plain array indexed store.
    func compile_index_assign(self, lhs: int64, rhs: int64, rhs_id: int64) -> none {
        let .Ident(arr_name) = self.p.exprs[lhs] else { return }
        let struct_idx = -1
        match self.find_var_kind(arr_name) {
            .KStruct(si) -> struct_idx = si
            else none
        }
        let setter: str? = none
        if struct_idx >= 0 {
            setter = self.struct_index_setter_label(struct_idx)
        }
        match setter {
            Some(method_lbl) -> {
                // Compile rhs first (clean register state), stash, then key,
                // then load the array and call.
                let rhs_v = self.compile_expr(rhs_id)
                let rhs_r = self.alloc_reg()
                self.mov_to(rhs_r, rhs_v)
                self.emit("sub sp, sp, #16")
                self.emit(f"str {rhs_r}, [sp]")
                self.free_reg(rhs_r)
                let kv = self.compile_expr(rhs)
                let kr = self.alloc_reg()
                self.mov_to(kr, kv)
                let arr_off = self.find_var_offset(arr_name)
                self.emit_ldr("x0", arr_off)
                self.emit(f"mov x1, {kr}")
                self.free_reg(kr)
                self.emit("ldr x2, [sp]")
                self.emit("add sp, sp, #16")
                self.emit(f"bl {method_lbl}")
            }
            none -> {
                let arr_off = self.find_var_offset(arr_name)
                let idx_v = self.compile_expr(rhs)
                let idx_r = self.load(idx_v)
                let rhs_v = self.compile_expr(rhs_id)
                let rhs_r = self.load(rhs_v)
                let ptr_r = self.alloc_reg()
                self.emit_ldr(ptr_r, arr_off)
                self.emit(f"ldr {ptr_r}, [{ptr_r}]")
                self.emit(f"lsl {idx_r}, {idx_r}, #3")
                self.emit(f"str {rhs_r}, [{ptr_r}, {idx_r}]")
                self.free_reg(ptr_r)
                self.free_reg(idx_r)
                self.free_reg(rhs_r)
            }
        }
    }

    func compile_assign(self, lhs_id: int64, rhs_id: int64) -> none {
        match self.p.exprs[lhs_id] {
            .Ident(name) -> {
                let off = self.find_var_offset(name)
                let kind = self.find_var_kind(name)
                self.compile_store(off, kind, rhs_id)
            }
            .Binary(lhs2, op, rhs2) -> {
                match op {
                    .Dot -> self.compile_field_assign(lhs2, rhs2, rhs_id)
                    .Index -> self.compile_index_assign(lhs2, rhs2, rhs_id)
                    else none
                }
            }
            else none
        }
    }

    func find_field_kind(self, struct_idx: int64, anon field_name: str) -> TypeKind {
        let fi = 0
        for fi < len(self.structs[struct_idx].fields) {
            if self.structs[struct_idx].fields[fi].name == field_name {
                return self.structs[struct_idx].fields[fi].kind
            }
            fi = fi + 1
        }
        return .KInt64
    }

    func compile_plus_assign(self, lhs_id: int64, rhs_id: int64) -> none {
        match self.p.exprs[lhs_id] {
            .Binary(lhs2, op, rhs2) -> {
                match op {
                    .Dot -> {
                        match self.p.exprs[lhs2] {
                            .Ident(obj_name) -> {
                                match self.p.exprs[rhs2] {
                                    .Ident(field_name) -> {
                                        let obj_off = self.find_var_offset(obj_name)
                                        let struct_idx = -1
                                        match self.find_var_kind(obj_name) {
                                            .KStruct(idx) -> struct_idx = idx
                                            else none
                                        }
                                        let foff = 0
                                        let fkind = .KInt64
                                        if struct_idx >= 0 {
                                            foff = self.find_field_offset(struct_idx, field_name)
                                            fkind = self.find_field_kind(struct_idx, field_name)
                                        }
                                        let is_arr = false
                                        let is_str = false
                                        match fkind {
                                            .KArray -> is_arr = true
                                            .KArrayStruct(elem_idx) -> is_arr = true
                                            .KArrayEnum(elem_idx) -> is_arr = true
                                            .KArrayStr -> is_arr = true
                                            .KStr -> is_str = true
                                            else none
                                        }
                                        if is_arr {
                                            let rv = self.compile_expr(rhs_id)
                                            let rr = self.load(rv)
                                            self.emit("sub sp, sp, #16")
                                            self.emit(f"str {rr}, [sp]")
                                            self.free_reg(rr)
                                            let pr = self.alloc_reg()
                                            self.emit_ldr(pr, obj_off)
                                            self.emit(f"ldr x0, [{pr}, #{self.itos(foff)}]")
                                            self.emit("ldr x1, [sp]")
                                            self.emit("add sp, sp, #16")
                                            self.emit("bl _kod_array_concat")
                                            self.emit_ldr(pr, obj_off)
                                            self.emit(f"str x0, [{pr}, #{self.itos(foff)}]")
                                            self.free_reg(pr)
                                        } else {
                                            if is_str {
                                                let rv = self.compile_expr(rhs_id)
                                                let rr = self.load(rv)
                                                self.emit("sub sp, sp, #16")
                                                self.emit(f"str {rr}, [sp]")
                                                self.free_reg(rr)
                                                let pr = self.alloc_reg()
                                                self.emit_ldr(pr, obj_off)
                                                self.emit(f"ldr x0, [{pr}, #{self.itos(foff)}]")
                                                self.emit("ldr x1, [sp]")
                                                self.emit("add sp, sp, #16")
                                                self.emit("bl _kod_str_concat")
                                                self.emit_ldr(pr, obj_off)
                                                self.emit(f"str x0, [{pr}, #{self.itos(foff)}]")
                                                self.free_reg(pr)
                                            } else {
                                                let rv = self.compile_expr(rhs_id)
                                                let rr = self.load(rv)
                                                let pr = self.alloc_reg()
                                                self.emit_ldr(pr, obj_off)
                                                let lr = self.alloc_reg()
                                                self.emit(f"ldr {lr}, [{pr}, #{self.itos(foff)}]")
                                                self.emit(f"add {lr}, {lr}, {rr}")
                                                self.emit(f"str {lr}, [{pr}, #{self.itos(foff)}]")
                                                self.free_reg(lr)
                                                self.free_reg(rr)
                                                self.free_reg(pr)
                                            }
                                        }
                                    }
                                    else none
                                }
                            }
                            else none
                        }
                    }
                    else none
                }
            }
            .Ident(name) -> {
                let off = self.find_var_offset(name)
                let kind = self.find_var_kind(name)
                match kind {
                    .KArray -> {
                        let rv = self.compile_expr(rhs_id)
                        let rr = self.load(rv)
                        let lr = self.alloc_reg()
                        self.emit_ldr(lr, off)
                        self.emit(f"mov x0, {lr}")
                        self.emit(f"mov x1, {rr}")
                        self.free_reg(lr)
                        self.free_reg(rr)
                        self.emit("bl _kod_array_concat")
                        self.emit_str("x0", off)
                    }
                    .KArrayStruct(elem_idx) -> {
                        let rv = self.compile_expr(rhs_id)
                        let rr = self.load(rv)
                        let lr = self.alloc_reg()
                        self.emit_ldr(lr, off)
                        self.emit(f"mov x0, {lr}")
                        self.emit(f"mov x1, {rr}")
                        self.free_reg(lr)
                        self.free_reg(rr)
                        self.emit("bl _kod_array_concat")
                        self.emit_str("x0", off)
                    }
                    .KArrayEnum(elem_idx) -> {
                        let rv = self.compile_expr(rhs_id)
                        let rr = self.load(rv)
                        let lr = self.alloc_reg()
                        self.emit_ldr(lr, off)
                        self.emit(f"mov x0, {lr}")
                        self.emit(f"mov x1, {rr}")
                        self.free_reg(lr)
                        self.free_reg(rr)
                        self.emit("bl _kod_array_concat")
                        self.emit_str("x0", off)
                    }
                    .KArrayStr -> {
                        let rv = self.compile_expr(rhs_id)
                        let rr = self.load(rv)
                        let lr = self.alloc_reg()
                        self.emit_ldr(lr, off)
                        self.emit(f"mov x0, {lr}")
                        self.emit(f"mov x1, {rr}")
                        self.free_reg(lr)
                        self.free_reg(rr)
                        self.emit("bl _kod_array_concat")
                        self.emit_str("x0", off)
                    }
                    .KStr -> {
                        let rv = self.compile_expr(rhs_id)
                        let rr = self.load(rv)
                        let lr = self.alloc_reg()
                        self.emit_ldr(lr, off)
                        self.emit(f"mov x0, {lr}")
                        self.emit(f"mov x1, {rr}")
                        self.free_reg(lr)
                        self.free_reg(rr)
                        self.emit("bl _kod_str_concat")
                        self.emit_str("x0", off)
                    }
                    else {
                        let rv = self.compile_expr(rhs_id)
                        let rr = self.load(rv)
                        let lr = self.alloc_reg()
                        self.emit_ldr(lr, off)
                        self.emit(f"add {lr}, {lr}, {rr}")
                        self.emit_str(lr, off)
                        self.free_reg(lr)
                        self.free_reg(rr)
                    }
                }
            }
            else none
        }
    }

    func compile_return(self, anon value_id: int64) -> none {
        if value_id == 0 {
            self.emit("mov x0, #0")
            self.emit(f"b {self.ret_lbl}")
            return
        }
        // If returning into an optional and the value isn't already optional,
        // wrap it in an arena allocation. NoneLit is always Optional. For Call,
        // trust free-function returns (we don't track free-fn return kinds);
        // for method calls, infer_kind looks up the method's return type.
        let needs_wrap = false
        match self.return_kind {
            .KOptional -> {
                let assume_optional = false
                match self.p.exprs[value_id] {
                    .NoneLit -> assume_optional = true
                    .Call(callee, args) -> {
                        match self.p.exprs[callee] {
                            .Ident(name) -> assume_optional = true
                            else none
                        }
                    }
                    else none
                }
                if assume_optional == false {
                    match self.infer_kind(value_id) {
                        .KOptional -> {}
                        else needs_wrap = true
                    }
                }
            }
            else none
        }
        if needs_wrap {
            // Conditional wrap: if the value is 0 (none), return 0 directly;
            // otherwise allocate a cell holding the value. This lets a match
            // expression whose arms include `else none` produce a real none.
            let v = self.compile_expr(value_id)
            let r = self.load(v)
            let skip_lbl = self.fresh("Lwrap_skip")
            let done_lbl = self.fresh("Lwrap_done")
            self.emit(f"cmp {r}, #0")
            self.emit(f"beq {skip_lbl}")
            self.emit("sub sp, sp, #16")
            self.emit(f"str {r}, [sp]")
            self.free_reg(r)
            self.emit("mov x0, #8")
            self.emit("bl _arena_alloc")
            let tmp = self.alloc_reg()
            self.emit(f"ldr {tmp}, [sp]")
            self.emit("add sp, sp, #16")
            self.emit(f"str {tmp}, [x0]")
            self.free_reg(tmp)
            self.emit(f"b {done_lbl}")
            self.emit_label(skip_lbl)
            self.emit("mov x0, #0")
            self.emit_label(done_lbl)
        } else {
            let v = self.compile_expr(value_id)
            self.mov_to("x0", v)
        }
        self.emit(f"b {self.ret_lbl}")
    }

    func compile_if(self, cond_id: int64, then_body: [int64], else_body: [int64]) -> none {
        let lbl = self.fresh("Lif")
        let false_lbl = f"{lbl}_false"
        let end_lbl = f"{lbl}_end"
        let cv = self.compile_expr(cond_id)
        let cr = self.load(cv)
        self.emit(f"cmp {cr}, #0")
        self.free_reg(cr)
        self.emit(f"beq {false_lbl}")
        let i = 0
        for i < len(then_body) {
            self.compile_stmt(then_body[i])
            i = i + 1
        }
        self.emit(f"b {end_lbl}")
        self.emit_label(false_lbl)
        let j = 0
        for j < len(else_body) {
            self.compile_stmt(else_body[j])
            j = j + 1
        }
        self.emit_label(end_lbl)
    }

    func compile_for(self, cond_id: int64, anon body: [int64]) -> none {
        let lbl = self.fresh("Lfor")
        let start_lbl = f"{lbl}_start"
        let end_lbl = f"{lbl}_end"
        self.loop_stack += [LoopLbl(start_lbl: start_lbl, end_lbl: end_lbl, incr_lbl: end_lbl)]
        self.emit_label(start_lbl)
        let cv = self.compile_expr(cond_id)
        let cr = self.load(cv)
        self.emit(f"cmp {cr}, #0")
        self.free_reg(cr)
        self.emit(f"beq {end_lbl}")
        let i = 0
        for i < len(body) {
            self.compile_stmt(body[i])
            i = i + 1
        }
        self.emit(f"b {start_lbl}")
        self.emit_label(end_lbl)
        let n = len(self.loop_stack)
        let new_stack: [LoopLbl] = []
        let j = 0
        for j < n - 1 {
            new_stack += [self.loop_stack[j]]
            j = j + 1
        }
        self.loop_stack = new_stack
    }

    func compile_foreach(self, name: str, iter_id: int64, anon body: [int64]) -> none {
        let lbl = self.fresh("Lfe")
        let start_lbl = f"{lbl}_start"
        let incr_lbl = f"{lbl}_incr"
        let end_lbl = f"{lbl}_end"
        self.loop_stack += [LoopLbl(start_lbl: incr_lbl, end_lbl: end_lbl, incr_lbl: incr_lbl)]

        let idx_name = f"__fi_{name}"
        let idx_off = self.find_var_offset(idx_name)
        let elem_off = self.find_var_offset(name)

        let arr_v = self.compile_expr(iter_id)
        let hdr_r = self.load(arr_v)

        let len_r = self.alloc_reg()
        let ptr_r = self.alloc_reg()
        self.emit(f"ldr {len_r}, [{hdr_r}, #8]")
        self.emit(f"ldr {ptr_r}, [{hdr_r}]")
        self.free_reg(hdr_r)

        let idx_r = self.alloc_reg()
        self.emit(f"mov {idx_r}, #0")
        self.emit_str(idx_r, idx_off)

        self.emit_label(start_lbl)
        self.emit_ldr(idx_r, idx_off)
        self.emit(f"cmp {idx_r}, {len_r}")
        self.emit(f"bge {end_lbl}")

        let elem_r = self.alloc_reg()
        self.emit(f"lsl {elem_r}, {idx_r}, #3")
        self.emit(f"ldr {elem_r}, [{ptr_r}, {elem_r}]")
        self.emit_str(elem_r, elem_off)
        self.free_reg(elem_r)

        let i = 0
        for i < len(body) {
            self.compile_stmt(body[i])
            i = i + 1
        }

        self.emit_label(incr_lbl)
        self.emit_ldr(idx_r, idx_off)
        self.emit(f"add {idx_r}, {idx_r}, #1")
        self.emit_str(idx_r, idx_off)
        self.emit(f"b {start_lbl}")
        self.emit_label(end_lbl)

        self.free_reg(idx_r)
        self.free_reg(len_r)
        self.free_reg(ptr_r)

        let n = len(self.loop_stack)
        let new_stack: [LoopLbl] = []
        let j = 0
        for j < n - 1 {
            new_stack += [self.loop_stack[j]]
            j = j + 1
        }
        self.loop_stack = new_stack
    }

    func compile_break(self) -> none {
        self.emit(f"b {self.loop_stack[-1].end_lbl}")
    }

    func compile_continue(self) -> none {
        self.emit(f"b {self.loop_stack[-1].incr_lbl}")
    }

    // Refutable `let .Pat(...) = expr else { ... }`. On a successful pattern
    // match, the bindings receive the variant's payload fields and execution
    // falls through; on mismatch, the else-block runs (and must diverge).
    func compile_let_else(self, pattern_id: int64, value_id: int64, anon else_body: [int64]) -> none {
        let else_lbl = self.fresh("Llet_else")
        let done_lbl = self.fresh("Llet_done")
        let sv = self.compile_expr(value_id)
        let sptr_r = self.load(sv)
        let subj_slot = self.alloc_var(self.fresh("__lsubj"), .KInt64)
        self.emit_str(sptr_r, subj_slot)
        self.free_reg(sptr_r)
        match self.p.patterns[pattern_id] {
            .EnumPat(enum_name, variant_name, bindings) -> {
                let ei = self.find_enum_idx(enum_name)
                let vi = self.find_variant_idx(ei, variant_name)
                let disc = self.enums[ei].variants[vi].discriminant
                let disc_r = self.alloc_reg()
                let ptr_r = self.alloc_reg()
                self.emit_ldr(ptr_r, subj_slot)
                self.emit(f"ldr {disc_r}, [{ptr_r}]")
                self.emit(f"cmp {disc_r}, #{self.itos(disc)}")
                self.emit(f"bne {else_lbl}")
                self.free_reg(disc_r)
                self.free_reg(ptr_r)
                let vinfo = self.enums[ei].variants[vi]
                let ki = 0
                for ki < len(bindings) {
                    let foff = vinfo.field_offsets[ki]
                    let binding_off = self.find_var_offset(bindings[ki])
                    let ptr_r2 = self.alloc_reg()
                    self.emit_ldr(ptr_r2, subj_slot)
                    let fv_r = self.alloc_reg()
                    self.emit(f"ldr {fv_r}, [{ptr_r2}, #{self.itos(8 + foff)}]")
                    self.emit_str(fv_r, binding_off)
                    self.free_reg(fv_r)
                    self.free_reg(ptr_r2)
                    ki = ki + 1
                }
            }
            .ImplicitEnumPat(variant_name, bindings) -> {
                let ei = self.find_enum_with_variant(variant_name)
                let vi = self.find_variant_idx(ei, variant_name)
                let disc = self.enums[ei].variants[vi].discriminant
                let disc_r = self.alloc_reg()
                let ptr_r = self.alloc_reg()
                self.emit_ldr(ptr_r, subj_slot)
                self.emit(f"ldr {disc_r}, [{ptr_r}]")
                self.emit(f"cmp {disc_r}, #{self.itos(disc)}")
                self.emit(f"bne {else_lbl}")
                self.free_reg(disc_r)
                self.free_reg(ptr_r)
                let vinfo2 = self.enums[ei].variants[vi]
                let ki = 0
                for ki < len(bindings) {
                    let foff = vinfo2.field_offsets[ki]
                    let binding_off = self.find_var_offset(bindings[ki])
                    let ptr_r2 = self.alloc_reg()
                    self.emit_ldr(ptr_r2, subj_slot)
                    let fv_r = self.alloc_reg()
                    self.emit(f"ldr {fv_r}, [{ptr_r2}, #{self.itos(8 + foff)}]")
                    self.emit_str(fv_r, binding_off)
                    self.free_reg(fv_r)
                    self.free_reg(ptr_r2)
                    ki = ki + 1
                }
            }
            .SomePat(binding) -> {
                let disc_r = self.alloc_reg()
                self.emit_ldr(disc_r, subj_slot)
                self.emit(f"cmp {disc_r}, #0")
                self.emit(f"beq {else_lbl}")
                self.free_reg(disc_r)
                if len(binding) > 0 {
                    let boff = self.find_var_offset(binding)
                    let ptr_r = self.alloc_reg()
                    self.emit_ldr(ptr_r, subj_slot)
                    let val_r = self.alloc_reg()
                    self.emit(f"ldr {val_r}, [{ptr_r}]")
                    self.emit_str(val_r, boff)
                    self.free_reg(val_r)
                    self.free_reg(ptr_r)
                }
            }
            .NonePat -> {
                let disc_r = self.alloc_reg()
                self.emit_ldr(disc_r, subj_slot)
                self.emit(f"cmp {disc_r}, #0")
                self.emit(f"bne {else_lbl}")
                self.free_reg(disc_r)
            }
            else {
                // Other patterns are not supported here yet.
                self.emit(f"b {else_lbl}")
            }
        }
        self.emit(f"b {done_lbl}")
        self.emit_label(else_lbl)
        let i = 0
        for i < len(else_body) {
            self.compile_stmt(else_body[i])
            i = i + 1
        }
        self.emit_label(done_lbl)
    }

    func compile_match_stmt(self, subject_id: int64, anon arms: [int64]) -> none {
        let done_lbl = self.fresh("Lmatch_done")
        // Evaluate subject once; stash its pointer on the stack so pattern
        // bindings can read fields off the subject after disc_r is consumed.
        let sv = self.compile_expr(subject_id)
        let sptr_r = self.load(sv)
        let subj_slot = self.alloc_var(self.fresh("__msubj"), .KInt64)
        self.emit_str(sptr_r, subj_slot)
        self.free_reg(sptr_r)
        let dv = .VStack(offset: subj_slot)
        let disc_r = self.load_enum_or_val(subject_id, dv)
        let i = 0
        for i < len(arms) {
            let arm = self.p.match_arms[arms[i]]
            let skip_lbl = self.fresh("Lmatch_skip")
            match self.p.patterns[arm.pattern] {
                .Wildcard -> {
                    let j = 0
                    for j < len(arm.body) {
                        self.compile_stmt(arm.body[j])
                        j = j + 1
                    }
                    self.emit(f"b {done_lbl}")
                }
                .IntPat(value) -> {
                    self.emit(f"cmp {disc_r}, #{self.itos(value)}")
                    self.emit(f"bne {skip_lbl}")
                    let j = 0
                    for j < len(arm.body) {
                        self.compile_stmt(arm.body[j])
                        j = j + 1
                    }
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .StrPat(value) -> {
                    let slbl = self.intern_str(value)
                    self.emit(f"mov x0, {disc_r}")
                    self.emit(f"adrp x1, {slbl}@PAGE")
                    self.emit(f"add x1, x1, {slbl}@PAGEOFF")
                    self.emit("bl _strcmp")
                    self.emit("cmp x0, #0")
                    self.emit(f"bne {skip_lbl}")
                    let j = 0
                    for j < len(arm.body) {
                        self.compile_stmt(arm.body[j])
                        j = j + 1
                    }
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .EnumPat(enum_name, variant_name, bindings) -> {
                    let ei = self.find_enum_idx(enum_name)
                    let vi = self.find_variant_idx(ei, variant_name)
                    let disc = self.enums[ei].variants[vi].discriminant
                    self.emit(f"cmp {disc_r}, #{self.itos(disc)}")
                    self.emit(f"bne {skip_lbl}")
                    let vinfo = self.enums[ei].variants[vi]
                    let ki = 0
                    for ki < len(bindings) {
                        let foff = vinfo.field_offsets[ki]
                        let binding_off = self.find_var_offset(bindings[ki])
                        let ptr_r = self.alloc_reg()
                        self.emit_ldr(ptr_r, subj_slot)
                        let fv_r = self.alloc_reg()
                        self.emit(f"ldr {fv_r}, [{ptr_r}, #{self.itos(8 + foff)}]")
                        self.emit_str(fv_r, binding_off)
                        self.free_reg(fv_r)
                        self.free_reg(ptr_r)
                        ki = ki + 1
                    }
                    let j = 0
                    for j < len(arm.body) {
                        self.compile_stmt(arm.body[j])
                        j = j + 1
                    }
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .ImplicitEnumPat(variant_name, bindings) -> {
                    let ei = self.find_enum_with_variant(variant_name)
                    let vi = self.find_variant_idx(ei, variant_name)
                    let disc = self.enums[ei].variants[vi].discriminant
                    self.emit(f"cmp {disc_r}, #{self.itos(disc)}")
                    self.emit(f"bne {skip_lbl}")
                    let vinfo2 = self.enums[ei].variants[vi]
                    let ki = 0
                    for ki < len(bindings) {
                        let foff = vinfo2.field_offsets[ki]
                        let binding_off = self.find_var_offset(bindings[ki])
                        let ptr_r = self.alloc_reg()
                        self.emit_ldr(ptr_r, subj_slot)
                        let fv_r = self.alloc_reg()
                        self.emit(f"ldr {fv_r}, [{ptr_r}, #{self.itos(8 + foff)}]")
                        self.emit_str(fv_r, binding_off)
                        self.free_reg(fv_r)
                        self.free_reg(ptr_r)
                        ki = ki + 1
                    }
                    let j = 0
                    for j < len(arm.body) {
                        self.compile_stmt(arm.body[j])
                        j = j + 1
                    }
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .NonePat -> {
                    self.emit(f"cmp {disc_r}, #0")
                    self.emit(f"bne {skip_lbl}")
                    let j = 0
                    for j < len(arm.body) {
                        self.compile_stmt(arm.body[j])
                        j = j + 1
                    }
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .SomePat(binding) -> {
                    self.emit(f"cmp {disc_r}, #0")
                    self.emit(f"beq {skip_lbl}")
                    if len(binding) > 0 {
                        let boff = self.find_var_offset(binding)
                        let ptr_r = self.alloc_reg()
                        self.emit_ldr(ptr_r, subj_slot)
                        let val_r = self.alloc_reg()
                        self.emit(f"ldr {val_r}, [{ptr_r}]")
                        self.emit_str(val_r, boff)
                        self.free_reg(val_r)
                        self.free_reg(ptr_r)
                    }
                    let j = 0
                    for j < len(arm.body) {
                        self.compile_stmt(arm.body[j])
                        j = j + 1
                    }
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
            }
            i = i + 1
        }
        self.emit_label(done_lbl)
        self.free_reg(disc_r)
    }


    func compile_func(self, fd_id: int64, struct_name: str) -> none {
        let fd = self.p.func_decls[fd_id]
        self.vars = []
        self.frame_slots = 0
        self.free_regs = ["x27", "x26", "x25", "x24", "x23", "x22", "x21", "x20", "x19", "x15", "x14", "x13", "x12", "x11", "x10", "x9", "x8"]
        self.loop_stack = []

        let i = 0
        for i < len(fd.params) {
            let param = fd.params[i]
            let kind = self.resolve_type(param.typ)
            // The method receiver `self` has no type annotation; give it
            // the kind of the enclosing struct so field/method access works.
            if param.name == "self" and len(struct_name) > 0 {
                let si = self.find_struct_idx(struct_name)
                if si >= 0 {
                    kind = .KStruct(idx: si)
                }
            }
            self.alloc_var(param.name, kind)
            i = i + 1
        }

        let j = 0
        for j < len(fd.body) {
            self.collect_stmt_vars(fd.body[j])
            j = j + 1
        }

        let raw_sz = self.frame_slots * 8
        let aligned = raw_sz + 16 - raw_sz % 16

        let func_lbl = f"${self.path_prefix}${fd.name}"
        if len(struct_name) > 0 {
            func_lbl = f"${self.path_prefix}${struct_name}${fd.name}"
        }
        self.ret_lbl = f"{func_lbl}$end"
        self.return_kind = self.resolve_type(fd.return_typ)

        self.emit_globl(func_lbl)
        self.emit_label(func_lbl)
        self.emit(f"sub sp, sp, #{self.itos(aligned + 16)}")
        self.emit(f"stp fp, lr, [sp, #{self.itos(aligned)}]")
        self.emit(f"add fp, sp, #{self.itos(aligned)}")

        let arg_regs: [str] = ["x0", "x1", "x2", "x3", "x4", "x5", "x6", "x7"]
        let k = 0
        for k < len(fd.params) {
            let off = self.find_var_offset(fd.params[k].name)
            self.emit_str(arg_regs[k], off)
            k = k + 1
        }

        let b = 0
        for b < len(fd.body) {
            self.compile_stmt(fd.body[b])
            b = b + 1
        }

        self.emit("mov x0, #0")

        self.emit_label(self.ret_lbl)
        self.emit(f"ldp fp, lr, [sp, #{self.itos(aligned)}]")
        self.emit(f"add sp, sp, #{self.itos(aligned + 16)}")
        self.emit("ret")
    }


    func compile_module(self, anon m: ast.Module) -> none {
        print("\t.text")

        let i = 0
        for i < len(m.decls) {
            self.register_enum(m.decls[i], prefix: self.path_prefix, p: self.p)
            i = i + 1
        }
        let j = 0
        for j < len(m.decls) {
            self.register_struct(m.decls[j], prefix: self.path_prefix, p: self.p)
            j = j + 1
        }
        // Process type aliases now that base types are registered.
        let a = 0
        for a < len(m.decls) {
            match m.decls[a] {
                .TypeAlias(name, target) -> {
                    let kind = self.resolve_type(target)
                    match kind {
                        .KStruct(idx) -> {
                            self.struct_alias_name += [name]
                            self.struct_alias_target += [idx]
                        }
                        .KEnum(idx) -> {
                            self.enum_alias_name += [name]
                            self.enum_alias_target += [idx]
                        }
                        else none
                    }
                }
                else none
            }
            a = a + 1
        }

        let k = 0
        for k < len(m.decls) {
            match m.decls[k] {
                .Func(decl_id) -> {
                    let fd = self.p.func_decls[decl_id]
                    self.func_names += [fd.name]
                    self.func_labels += [f"${self.path_prefix}${fd.name}"]
                }
                .Extern(name, params, return_typ) -> {
                    self.func_names += [name]
                    self.func_labels += [f"_{name}"]
                }
                else none
            }
            k = k + 1
        }

        let d = 0
        for d < len(m.decls) {
            match m.decls[d] {
                .Func(decl_id) -> self.compile_func(decl_id, "")
                .Struct(name, fields, methods) -> {
                    let mi = 0
                    for mi < len(methods) {
                        self.compile_func(methods[mi], name)
                        mi = mi + 1
                    }
                }
                else none
            }
            d = d + 1
        }

        if len(self.str_labels) > 0 {
            print(".data")
            let si = 0
            for si < len(self.str_labels) {
                print(f"{self.str_labels[si]}:")
                self.emit_asciz(self.str_values[si])
                si = si + 1
            }
        }
    }

    func module_name_to_prefix(self, anon module_name: str) -> str {
        let result = ""
        let i = 0
        for i < len(module_name) {
            if module_name[i] == '/' {
                result = f"{result}$"
            } else {
                result = result + module_name[i:i+1]
            }
            i = i + 1
        }
        return result
    }

    // Register all functions and externs from a dependency module without compiling it.
    // Call this for each imported module (e.g. builtins) before compile_module.
    func register_module_funcs(self, anon m: ast.Module, prefix: str, p: parser.Parser) -> none {
        let k = 0
        for k < len(m.decls) {
            match m.decls[k] {
                .Func(decl_id) -> {
                    let fd = p.func_decls[decl_id]
                    self.func_names += [fd.name]
                    self.func_labels += [f"${prefix}${fd.name}"]
                }
                .Extern(name, params, return_typ) -> {
                    self.func_names += [name]
                    self.func_labels += [f"_{name}"]
                }
                else none
            }
            k = k + 1
        }
    }

    // Register a module that was imported by `import "<module_name>"`.
    // local_mod is the import alias used at call sites (mod.func()).
    // prefix is the codegen path prefix for the imported module.
    // m and p are the parsed module and its parser.
    func register_import_module(self, local_mod: str, prefix: str, anon m: ast.Module, p: parser.Parser) -> none {
        self.import_local += [local_mod]
        self.import_prefix += [prefix]
        let k = 0
        for k < len(m.decls) {
            match m.decls[k] {
                .Func(decl_id) -> {
                    let fd = p.func_decls[decl_id]
                    self.import_fn_module += [local_mod]
                    self.import_fn_name += [fd.name]
                    self.import_fn_label += [f"${prefix}${fd.name}"]
                }
                .Extern(name, params, return_typ) -> {
                    self.import_fn_module += [local_mod]
                    self.import_fn_name += [name]
                    self.import_fn_label += [f"_{name}"]
                }
                else none
            }
            k = k + 1
        }
    }
}

func make_codegen(p: parser.Parser, path_prefix: str) -> Codegen {
    let enums: [EnumInfo] = []
    let structs: [StructInfo] = []
    let struct_alias_name: [str] = []
    let struct_alias_target: [int64] = []
    let enum_alias_name: [str] = []
    let enum_alias_target: [int64] = []
    let import_local: [str] = []
    let import_prefix: [str] = []
    let import_fn_module: [str] = []
    let import_fn_name: [str] = []
    let import_fn_label: [str] = []
    let vars: [VarSlot] = []
    let loop_stack: [LoopLbl] = []
    let str_labels: [str] = []
    let str_values: [str] = []
    let func_names: [str] = []
    let func_labels: [str] = []
    let free_regs: [str] = ["x27", "x26", "x25", "x24", "x23", "x22", "x21", "x20", "x19", "x15", "x14", "x13", "x12", "x11", "x10", "x9", "x8"]
    return Codegen(p: p, path_prefix: path_prefix, enums: enums, structs: structs, struct_alias_name: struct_alias_name, struct_alias_target: struct_alias_target, enum_alias_name: enum_alias_name, enum_alias_target: enum_alias_target, import_local: import_local, import_prefix: import_prefix, import_fn_module: import_fn_module, import_fn_name: import_fn_name, import_fn_label: import_fn_label, vars: vars, frame_slots: 0, ret_lbl: "", return_kind: .KVoid, free_regs: free_regs, loop_stack: loop_stack, str_labels: str_labels, str_values: str_values, label_count: 0, func_names: func_names, func_labels: func_labels)
}
