// Primitive method dispatch via `x.to_str()` — routed through
// stdlib/primitives/<kind>.kod.

func main() -> int64 {
	let n: int64 = 42
	let s: str = "hello"
	let b: bool = true

	print(n.to_str())
	print(s.to_str())
	print(b.to_str())

	let h: int64 = s.hash()
	print(h.to_str())
	return 0
}

// expected output:
// 42
// hello
// true
// 210714636441
// expected status:
// 0
