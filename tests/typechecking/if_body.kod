func other_func(msg: str) -> none {
	print(msg)
}

func main() -> int64 {
	if true {
		other_func()
		other_func("hello", 123)
	} else {
		other_func()
	}
	return 0
}

// expected errors:
// 7:13: error: 'other_func' takes 1 argument, but got 0
// 8:13: error: 'other_func' takes 1 argument, but got 2
// 8:14: error: Expected argument 'msg' to be labeled
// 10:13: error: 'other_func' takes 1 argument, but got 0
