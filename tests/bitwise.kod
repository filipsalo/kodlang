// Bitwise operators on int64: `&`, `|`, `^`, `<<`, `>>`.
//
// Precedence follows C: shifts bind tighter than addition; bitwise
// AND/XOR/OR bind looser than comparison; everything binds tighter
// than boolean `and`/`or`.

func main() -> int64 {
    print_int(0xff & 0x0f)      // 15
    print_int(0xf0 | 0x0f)      // 255
    print_int(0xff ^ 0x0f)      // 240
    print_int(0x100 >> 4)       // 16
    print_int(0x10 << 4)        // 256

    // Precedence: shift > arithmetic > comparison > bitwise > boolean.
    // `1 << 3 + 1` parses as `1 << (3 + 1)` = 16; would be 9 if shifts
    // bound tighter.
    print_int(1 << 3 + 1)       // 16
    // `0x10 | 0x01 << 4` parses as `0x10 | (0x01 << 4)` = 0x10 | 0x10 = 16.
    print_int(0x10 | 0x01 << 4) // 16

    // The canonical CRC32-ish update: combine ldr + shift + xor + and.
    let crc: int64 = 0xfffffff0
    let byte: int64 = 0x0a
    let masked: int64 = (crc ^ byte) & 0xff
    print_int(masked)           // 250

    return 0
}

// expected output:
// 15
// 255
// 240
// 16
// 256
// 16
// 16
// 250
// expected status:
// 0
