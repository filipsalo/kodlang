func digit_name(anon c: int64) -> str {
	return match c {
		'0' -> "zero"
		'1' -> "one"
		'2' -> "two"
		_ -> "other"
	}
}

func main() -> int64 {
	print(digit_name('1'))
	print(digit_name('2'))
	print(digit_name('9'))

	let x: int64 = 42
	let label: str = match x {
		1 -> "one"
		42 -> "forty-two"
		_ -> "other"
	}
	print(label)

	return 0
}

// expected output:
// one
// two
// other
// forty-two

// expected status:
// 0

// expected selfhosted:
// skip
