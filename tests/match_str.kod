func classify(anon s: str) -> str {
	return match s {
		"hello" -> "greeting"
		"bye" -> "farewell"
		else "unknown"
	}
}

func main() -> int64 {
	print(classify("hello"))
	print(classify("bye"))
	print(classify("what"))
	return 0
}

// expected output:
// greeting
// farewell
// unknown

// expected status:
// 0
