func other_func(msg: str) -> none {
	print(msg)
}

func main() -> int64 {
	if true {
		other_func()
		other_func("hello", 123)
	} else {
		other_func()
	}
	return 0
}

// expected errors:
// 7:3: error: `other_func` takes 1 arguments, got 0
// 8:3: error: `other_func` takes 1 arguments, got 2
// 10:3: error: `other_func` takes 1 arguments, got 0
