type TokenKind = enum {
	EOF
	EOL
	Identifier
	IntegerLit
	StringLit
	Comment
	KwImport
	KwLet
	KwExtern
	KwFunc
	KwAnon
	KwReturn
	KwIf
	KwElse
	KwTrue
	KwFalse
	KwFor
	KwIn
	KwBreak
	KwContinue
	KwStruct
	KwType
	KwEnum
	KwMatch
	KwIs
	KwAnd
	KwOr
	KwNone
	OpenParen
	CloseParen
	OpenCurly
	CloseCurly
	OpenBracket
	CloseBracket
	Dot
	Colon
	Comma
	Question
	Equal
	EqualEqual
	NotEqual
	Plus
	PlusEqual
	Minus
	Arrow
	Star
	Slash
	Percent
	LessThan
	LessEqual
	GreaterThan
	GreaterEqual
}

type Token = struct {
	kind: TokenKind
	value: str
	start: int64
	end: int64
}

func is_digit(anon c: int64) -> bool {
	return c >= '0' and c <= '9'
}

func is_alpha(anon c: int64) -> bool {
	return (c >= 'a' and c <= 'z') or (c >= 'A' and c <= 'Z') or c == '_'
}

func is_alnum(anon c: int64) -> bool {
	return is_alpha(c) or is_digit(c)
}

func keyword_kind(anon w: str) -> TokenKind? {
	return match w {
		"import" -> TokenKind.KwImport
		"let" -> TokenKind.KwLet
		"extern" -> TokenKind.KwExtern
		"func" -> TokenKind.KwFunc
		"anon" -> TokenKind.KwAnon
		"return" -> TokenKind.KwReturn
		"if" -> TokenKind.KwIf
		"else" -> TokenKind.KwElse
		"true" -> TokenKind.KwTrue
		"false" -> TokenKind.KwFalse
		"for" -> TokenKind.KwFor
		"in" -> TokenKind.KwIn
		"break" -> TokenKind.KwBreak
		"continue" -> TokenKind.KwContinue
		"struct" -> TokenKind.KwStruct
		"type" -> TokenKind.KwType
		"enum" -> TokenKind.KwEnum
		"match" -> TokenKind.KwMatch
		"is" -> TokenKind.KwIs
		"and" -> TokenKind.KwAnd
		"or" -> TokenKind.KwOr
		"none" -> TokenKind.KwNone
		_ -> none
	}
}

type Lexer = struct {
	source: str
	pos: int64
	start: int64

	func peek(self) -> int64 {
		if self.pos >= len(self.source) {
			return 0
		}
		return self.source[self.pos]
	}

	func eof(self) -> bool {
		return self.pos >= len(self.source)
	}

	func advance(self) -> none {
		self.pos = self.pos + 1
	}

	func skip_whitespace(self) -> none {
		for self.peek() == ' ' or self.peek() == '\t' {
			self.advance()
		}
		self.start = self.pos
	}

	func buffered(self) -> str {
		return self.source[self.start:self.pos]
	}

	func build(self, anon kind: TokenKind) -> Token {
		let t: Token = Token(kind: kind, value: self.source[self.start:self.pos], start: self.start, end: self.pos)
		self.start = self.pos
		return t
	}

	func lex_number(self) -> Token {
		for is_digit(self.peek()) {
			self.advance()
		}
		return self.build(TokenKind.IntegerLit)
	}

	func lex_string(self) -> Token {
		self.advance()
		for self.peek() != '"' and self.peek() != 0 {
			self.advance()
		}
		self.advance()
		return self.build(TokenKind.StringLit)
	}

	func lex_identifier(self) -> Token {
		for is_alnum(self.peek()) {
			self.advance()
		}
		let kw: TokenKind? = keyword_kind(self.buffered())
		return self.build(match kw {
			none -> TokenKind.Identifier
			Some(k) -> k
		})
	}

	func lex_slash_or_comment(self) -> Token {
		self.advance()
		if self.peek() == '/' {
			self.advance()
			for self.peek() == ' ' or self.peek() == '\t' {
				self.advance()
			}
			for self.peek() != '\n' and self.peek() != 0 {
				self.advance()
			}
			return self.build(TokenKind.Comment)
		}
		return self.build(TokenKind.Slash)
	}

	func lex_equals(self) -> Token {
		self.advance()
		if self.peek() == '=' {
			self.advance()
			return self.build(TokenKind.EqualEqual)
		}
		return self.build(TokenKind.Equal)
	}

	func lex_not_equal(self) -> Token {
		self.advance()
		self.advance()
		return self.build(TokenKind.NotEqual)
	}

	func lex_less(self) -> Token {
		self.advance()
		if self.peek() == '=' {
			self.advance()
			return self.build(TokenKind.LessEqual)
		}
		return self.build(TokenKind.LessThan)
	}

	func lex_greater(self) -> Token {
		self.advance()
		if self.peek() == '=' {
			self.advance()
			return self.build(TokenKind.GreaterEqual)
		}
		return self.build(TokenKind.GreaterThan)
	}

	func lex_minus_or_arrow(self) -> Token {
		self.advance()
		if self.peek() == '>' {
			self.advance()
			return self.build(TokenKind.Arrow)
		}
		return self.build(TokenKind.Minus)
	}

	func lex_plus_or_plus_equal(self) -> Token {
		self.advance()
		if self.peek() == '=' {
			self.advance()
			return self.build(TokenKind.PlusEqual)
		}
		return self.build(TokenKind.Plus)
	}

	func lex(self) -> [Token] {
		let tokens: [Token] = []
		for self.peek() != 0 {
			self.skip_whitespace()
			if self.eof() {
				break
			}
			let c: int64 = self.peek()
			match c {
				'\n' -> {
					self.advance()
					tokens += [self.build(TokenKind.EOL)]
				}
				'(' -> {
					self.advance()
					tokens += [self.build(TokenKind.OpenParen)]
				}
				')' -> {
					self.advance()
					tokens += [self.build(TokenKind.CloseParen)]
				}
				'{' -> {
					self.advance()
					tokens += [self.build(TokenKind.OpenCurly)]
				}
				'}' -> {
					self.advance()
					tokens += [self.build(TokenKind.CloseCurly)]
				}
				'[' -> {
					self.advance()
					tokens += [self.build(TokenKind.OpenBracket)]
				}
				']' -> {
					self.advance()
					tokens += [self.build(TokenKind.CloseBracket)]
				}
				'.' -> {
					self.advance()
					tokens += [self.build(TokenKind.Dot)]
				}
				':' -> {
					self.advance()
					tokens += [self.build(TokenKind.Colon)]
				}
				',' -> {
					self.advance()
					tokens += [self.build(TokenKind.Comma)]
				}
				'?' -> {
					self.advance()
					tokens += [self.build(TokenKind.Question)]
				}
				'*' -> {
					self.advance()
					tokens += [self.build(TokenKind.Star)]
				}
				'%' -> {
					self.advance()
					tokens += [self.build(TokenKind.Percent)]
				}
				'=' -> tokens += [self.lex_equals()]
				'!' -> tokens += [self.lex_not_equal()]
				'<' -> tokens += [self.lex_less()]
				'>' -> tokens += [self.lex_greater()]
				'-' -> tokens += [self.lex_minus_or_arrow()]
				'+' -> tokens += [self.lex_plus_or_plus_equal()]
				'/' -> tokens += [self.lex_slash_or_comment()]
				'"' -> tokens += [self.lex_string()]
				_ -> {
					if is_digit(c) {
						tokens += [self.lex_number()]
					}
					if is_alpha(c) {
						tokens += [self.lex_identifier()]
					}
					if is_digit(c) == false and is_alpha(c) == false {
						self.advance()
						self.start = self.pos
					}
				}
			}
		}
		tokens += [Token(kind: TokenKind.EOF, value: "", start: self.pos, end: self.pos)]
		return tokens
	}
}
