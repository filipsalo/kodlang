test "addition works" {
    let n: int64 = 2 + 2
    assert n == 4
}

test "this one fails on purpose (assert)" {
    let n: int64 = 7
    assert n == 4
}

test "this one fails on purpose (fail)" {
    fail("explicit fail() also still works")
}

test "string equality" {
    let s: str = "hello" + " " + "world"
    assert s == "hello world"
}

test "multiple asserts surface multiple errors" {
    let x: int64 = 1
    let y: int64 = 2
    assert x == 100
    assert y == 200
}

