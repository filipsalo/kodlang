// Integer `/` and `%` truncate toward zero (C-style, matching ARM64 sdiv),
// so the remainder takes the dividend's sign. The interpreter previously used
// Python's floor division/modulo and disagreed with compiled code on
// negative operands; this pins both frontends to the same answers.
func main() -> int64 {
    print_int((0 - 7) / 2)        // -3, not -4
    print_int((0 - 7) % 3)        // -1, not 2
    print_int(7 % (0 - 3))        // 1, not -2
    print_int((0 - 7) / (0 - 2))  // 3
    print_int(7 / 2)              // 3
    return 0
}

// expected output:
// -3
// -1
// 1
// 3
// 3
