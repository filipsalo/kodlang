// First-class functions, beyond Slice 1 — function-typed struct
// fields, arrays of function pointers, and general callee
// expressions (call results, indexing, struct-field access).

func double(x: int64) -> int64 { return x * 2 }
func triple(x: int64) -> int64 { return x * 3 }

type Handler = struct {
    fn: func(int64) -> int64
}

func get_doubler() -> func(int64) -> int64 {
    return double
}

func main() -> int64 {
    // Struct field of function-pointer type — `h.fn(7)` resolves
    // to a field load + indirect call (NOT a method call).
    let h: Handler = Handler(fn: triple)
    print_int(h.fn(7))

    // Array of function pointers — index returns a function value;
    // `(...)` after it dispatches indirectly.
    let ops: [func(int64) -> int64] = [double, triple]
    print_int(ops[0](10))
    print_int(ops[1](10))

    // Callee is itself a Call returning a function pointer.
    print_int(get_doubler()(50))

    // for-each over `[func(...) -> R]` gives a function-typed
    // iteration variable.
    for f in ops {
        print_int(f(5))
    }

    return 0
}

// expected output:
// 21
// 20
// 30
// 100
// 10
// 15

// expected status:
// 0
