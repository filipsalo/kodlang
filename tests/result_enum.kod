// Use the stdlib Result[T, E] enum directly (not via `T or Error` sugar).
// Proves the unified enum-shaped Result is constructible, matchable, and
// carries the substituted payload kinds per instantiation.
func divide(anon n: int64, anon d: int64) -> Result[int64, str] {
    if d == 0 {
        return .Err(error: "division by zero")
    }
    return .Ok(value: n / d)
}

func describe(anon r: Result[int64, str]) -> str {
    match r {
        .Ok(value) -> return f"ok {value}"
        .Err(error) -> return f"err {error}"
    }
}

func main() -> int64 {
    print(describe(divide(10, 2)))
    print(describe(divide(7, 0)))
    return 0
}

// expected output:
// ok 5
// err division by zero
