// Regression: cross-module return-kind inference. Before the kodc.kod
// two-pass import walk + the method_call_return_kind import lookup,
// `match json.parse(...)` would treat the subject as int64 (the sig's
// return_kind had been resolved before the json module's Value enum was
// registered, so it fell back to KInt64). The match would then take the
// else branch instead of dereferencing the enum and dispatching on its
// discriminant.
import "json"

func main() -> int64 {
    match json.parse("[1, 2, 3]") {
        .Array(items) -> print_int(len(items))
        else -> print("not Array")
    }
    return 0
}

// expected status:
// 0
// expected output:
// 3
