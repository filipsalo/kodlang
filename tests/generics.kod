type Pair[A, B] = struct {
	first: A
	second: B
}

extern func int_to_str(anon n: int64) -> str

func main() -> int64 {
	let p: Pair[str, int64] = Pair[str, int64](first: "hello", second: 42)
	print(p.first)
	print(int_to_str(p.second))
	return 0
}

// expected output:
// hello
// 42

// expected status:
// 0

// expected mode:
// interpret
