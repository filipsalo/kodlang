// `?.` short-circuit field access on a `T?` struct value.

type Point = struct {
    x: int64
    y: int64
}

func origin_or(anon mut p: Point?, set: bool) -> Point? {
    if set {
        p = Point(x: 3, y: 4)
    }
    return p
}

func main() -> int64 {
    let present: Point? = origin_or(none, set: true)
    let missing: Point? = origin_or(none, set: false)

    // Present: x?.x is Some(3).
    let xp: int64? = present?.x
    match xp {
        Some(v) -> print_int(v)   // 3
        none -> print("missing")
    }

    // Missing: x?.x is none — the field is never read.
    let xm: int64? = missing?.x
    match xm {
        Some(v) -> print_int(v)
        none -> print("missing")  // missing
    }

    // Unwrap chains compose with postfix `?` for a final default.
    let yp: int64 = present?.y? or -1
    print_int(yp)   // 4

    let ym: int64 = missing?.y? or -1
    print_int(ym)   // -1

    return 0
}

// expected output:
// 3
// missing
// 4
// -1
// expected status:
// 0
