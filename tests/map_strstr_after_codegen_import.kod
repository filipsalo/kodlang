// Regression: importing kod/codegen registers `Map[str, int64]` as a
// FuncIdx monomorphisation. Before the resolve_field_kinds fix, the
// later monomorphisation of Map[str, str] re-resolved its `[K]` field
// type without the substitution context, falling back to KArray (no
// elem kind). That made `self.keys[i]` infer as KInt64 inside `probe`,
// so `K == K` lowered to a bit-identical pointer compare instead of
// `$primitives$str$equals` — and `m.get("hel" + "lo")` missed an
// entry inserted under the literal "hello".

import "kod/codegen"

type S2S = Map[str, str]

func main() -> int64 {
	let m: S2S = S2S(keys: [], values: [], indices: [])
	m.set("hello", "world")
	match m.get("hel" + "lo") {
		Some(v) -> print(v)
		none -> print("MISS")
	}
	return 0
}

// expected output:
// world
// expected status:
// 0
