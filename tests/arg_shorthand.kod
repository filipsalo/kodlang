// Shorthand call-arg syntax: `:name` is sugar for `name: name`, making
// "label inferred from variable name" visually distinct from passing an
// anonymous arg. The bare form `name` (no colon) is the legacy shorthand,
// being removed once all call sites are migrated.

func greet(name: str, count: int64) -> none {
	let i = 0
	for i < count {
		print(name)
		i = i + 1
	}
}

func main() -> int64 {
	let name: str = "kod"
	let count: int64 = 2
	// New explicit shorthand:
	greet(:name, :count)
	// Mixed with full labels:
	greet(name: "explicit", :count)
	// Legacy bare-identifier shorthand still works for now:
	greet(name, count)
	return 0
}

// expected output:
// kod
// kod
// explicit
// explicit
// kod
// kod
// expected status:
// 0
