// Shorthand call-arg syntax: passing a bare identifier with the same
// name as the parameter label should be equivalent to `label: value`.

func greet(name: str, count: int64) -> none {
	let i = 0
	for i < count {
		print(name)
		i = i + 1
	}
}

func main() -> int64 {
	let name: str = "kod"
	let count: int64 = 2
	greet(name, count)
	// Still works with explicit labels mixed in:
	greet(name: "explicit", count)
	return 0
}

// expected output:
// kod
// kod
// explicit
// explicit
// expected status:
// 0
