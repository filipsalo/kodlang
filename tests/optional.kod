func main() -> int64 {
	let a: int64? = none
	if a == none {
		print("a is none")
	}

	let b: int64? = 42
	if b != none {
		print("b is not none")
	}

	if a is None {
		print("a is None")
	}

	if b is Some {
		print("b is Some")
	}

	match a {
		None -> print("matched none")
		Some(v) -> print_int(v)
	}

	match b {
		None -> print("matched none")
		Some(v) -> print_int(v)
	}

	return 0
}

// expected output:
// a is none
// b is not none
// a is None
// b is Some
// matched none
// 42

// expected status:
// 0
