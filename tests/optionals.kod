func find(anon haystack: str, anon needle: int64) -> str? {
    mut i: int64 = 0
    for i < len(haystack) {
        if haystack[i] == needle {
            return haystack[i..i+1]
        }
        i = i + 1
    }
    return none
}

func main() -> int64 {
    let result: str? = find("hello", 'e')
    match result {
        none -> print("not found")
        Some(c) -> print(c)
    }
    let missing: str? = find("hello", 'z')
    match missing {
        none -> print("not found")
        Some(c) -> print(c)
    }
    return 0
}

// expected status:
// 0
// expected output:
// e
// not found
