import "time"

test "monotonic_ns: never goes backwards" {
    let a: int64 = time.monotonic_ns()
    let b: int64 = time.monotonic_ns()
    assert b >= a
}

test "monotonic_ns: increases across a small busy wait" {
    // Spin a tiny accumulator to let the clock advance — enough
    // iterations that any reasonable clock_gettime ticks at least
    // once. Asserts a strict increase, which would only fail on a
    // truly broken (frozen) clock.
    let t0: int64 = time.monotonic_ns()
    mut sum: int64 = 0
    mut i: int64 = 0
    for i < 200000 {
        sum = sum + i
        i = i + 1
    }
    let t1: int64 = time.monotonic_ns()
    assert t1 > t0
    // Defeat dead-code elimination of `sum`.
    assert sum != -1
}

test "unix_ns: looks like a real timestamp" {
    // 2020-01-01 UTC == 1577836800 seconds == 1577836800000000000 ns.
    // Any sane wall clock should be past that. Upper bound is the
    // year 2200 — keeps the test from breaking on truly skewed
    // clocks while still catching a hard-zero return.
    let t: int64 = time.unix_ns()
    assert t > 1577836800000000000
    assert t < 7258118400000000000
}
