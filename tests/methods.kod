type Point = struct {
    x: int64
    y: int64
    func sum(self) -> int64 {
        return self.x + self.y
    }
    func scale(self, factor: int64) -> int64 {
        return (self.x + self.y) * factor
    }
}

func main() -> int64 {
    let p: Point = Point(x: 3, y: 4)
    let s: int64 = p.sum()
    print(s.to_str())
    let t: int64 = p.scale(factor: 2)
    print(t.to_str())
    return 0
}

// expected status:
// 0
// expected output:
// 7
// 14
