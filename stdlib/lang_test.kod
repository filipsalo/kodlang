// Language-feature tests that don't have an obvious home in a
// primitive's *_test.kod. Each block here used to be a tests/*.kod
// example with a `// expected output:` block; assertions replace the
// print-and-compare pattern, which is faster (one binary for the
// whole suite instead of one per file) and tighter.

type Point = struct {
    x: int64
    y: int64
    func to_str(self) -> str {
        return f"({self.x}, {self.y})"
    }
}

// `//` comments interleaved with enum variants / struct fields used to
// break the parser. The regression test is the *parse* of these type
// definitions — if the parser regresses, the whole file fails to
// compile and `kod test` surfaces it as a build error before any
// assertion runs. The `Color` / `ColorPoint` test block below is just
// a runtime smoke-check that the types behave normally afterwards.
type Color = enum {
    // primary colors
    Red
    Green
    Blue
    // custom
    Custom(r: int64, g: int64, b: int64)
}

type PointHolder = struct {
    pts: [Point]
}

type Defaulted = struct {
    label: str
    count: int64 = 0
    flag: bool = true
    items: [int64] = []
}

type OptHolder = struct {
    v: int64?
}

interface Greet {
    func hello(self) -> str
}

type Cat = struct {
    func hello(self) -> str {
        return "meow"
    }
}

type Dog = struct {
    func hello(self) -> str {
        return "woof"
    }
}

type GreetHolder = struct {
    g: Greet
}

func _takes_opt(anon v: int64?) -> int64 {
    if v is Some(x) {
        return x
    }
    return -1
}

type OptBox = struct {
    func receive(self, anon v: int64?) -> int64 {
        if v is Some(x) {
            return x
        }
        return -1
    }
}

type PayloadEnum = enum {
    A
    B(payload: int64?)
}

func _make_cat() -> Greet {
    return Cat()
}

type ColorPoint = struct {
    // coordinates
    x: int64
    y: int64
}

test "comparison operators" {
    assert 1 != 2
    assert 2 <= 2
    assert 2 < 3
    assert 3 >= 2
    assert 3 > 2
    assert (1 < 2) == true
    assert (2 < 1) == false
}

test "logical operators short-circuit" {
    assert true and true
    assert (true and false) == false
    assert false or true
    assert (false or false) == false
}

test "arithmetic precedence: * binds tighter than +" {
    assert 1 + 2 * 3 == 7
    assert (1 + 2) * 3 == 9
    assert 10 - 2 - 3 == 5
    assert 10 - (2 - 3) == 11
}

test "negative array indexing" {
    let nums: [int64] = [10, 20, 30, 40, 50]
    assert nums[-1] == 50
    assert nums[-2] == 40
    assert nums[-5] == 10
}

test "f-string interpolates int / bool / str" {
    let n: int64 = 42
    let b: bool = true
    let s: str = "hi"
    assert f"int={n}" == "int=42"
    assert f"bool={b}" == "bool=true"
    assert f"bool={false}" == "bool=false"
    assert f"str={s}" == "str=hi"
    assert f"mix={n} {b} {s}" == "mix=42 true hi"
}

test "f-string concatenation across multiple interpolations" {
    let a: str = "world"
    let b: str = "!"
    assert f"hello {a}{b}" == "hello world!"
}

test "f-string calls user-defined to_str on struct values" {
    let p: Point = Point(x: 3, y: 4)
    assert f"point={p}" == "point=(3, 4)"
}

test "enum-with-comments and struct-with-comments are still usable" {
    // The comment regression is covered by the parse of the module-
    // level type definitions above. This block just confirms the
    // resulting types construct, match, and field-access normally.
    let c: Color = Color.Custom(r: 1, g: 2, b: 3)
    match c {
        .Red -> fail("expected Custom")
        .Green -> fail("expected Custom")
        .Blue -> fail("expected Custom")
        .Custom(r, g, b) -> {
            assert r == 1
            assert g == 2
            assert b == 3
        }
    }
    let pt: ColorPoint = ColorPoint(x: 1, y: 2)
    assert pt.x + pt.y == 3
}

test "two foreach loops sharing an element name pin per-loop kinds" {
    // Regression: reusing the element name `f` across two foreach loops
    // with differently-typed iterators used to leave both bodies seeing
    // the first loop's struct kind, so `f.x` in the second loop read the
    // wrong byte offset.
    let pts: [Point] = [Point(x: 1, y: 2), Point(x: 3, y: 4)]
    let cps: [ColorPoint] = [ColorPoint(x: 10, y: 20)]
    mut total: int64 = 0
    for f in pts {
        total = total + f.x + f.y
    }
    for f in cps {
        total = total + f.x + f.y
    }
    assert total == (1 + 2) + (3 + 4) + (10 + 20)
}

test "foreach over an array literal infers the element struct kind" {
    // Regression: `for p in [pt]` used to fall back to KInt64 for `p`
    // (ArrayLit's infer_kind returned a bare KArray), so `p.x` read
    // from offset 0 of the int64-typed slot.
    let pt: Point = Point(x: 7, y: 9)
    mut sum: int64 = 0
    for p in [pt] {
        sum = sum + p.x + p.y
    }
    assert sum == 16
}

test "non-Ident lhs in indexed assignment stores correctly" {
    // Regression: `obj.field[idx] = expr` (and any other non-Ident
    // array LHS) used to silently emit nothing because
    // compile_index_assign required the LHS to be a bare Ident.
    let outer: PointHolder = PointHolder(pts: [Point(x: 1, y: 2), Point(x: 3, y: 4)])
    outer.pts[0] = Point(x: 99, y: 100)
    assert outer.pts[0].x == 99
    assert outer.pts[0].y == 100
    assert outer.pts[1].x == 3
}

test "+= works for nested-field and indexed lhs" {
    // Regression: `obj.inner.count += 1` and `arr[i] += 1` used to
    // silently do nothing — compile_plus_assign only knew how to
    // handle `name += rhs` and `obj.field += rhs` with `obj` as a
    // bare Ident.
    let xs: [int64] = [10, 20, 30]
    xs[1] += 5
    assert xs[1] == 25

    let h: PointHolder = PointHolder(pts: [Point(x: 1, y: 2)])
    h.pts[0].x += 100
    assert h.pts[0].x == 101
}

test "-= updates var, field, and indexed lhs in place" {
    mut x: int64 = 10
    x -= 3
    assert x == 7

    let xs: [int64] = [10, 20, 30]
    xs[1] -= 5
    assert xs[1] == 15

    let h: PointHolder = PointHolder(pts: [Point(x: 50, y: 2)])
    h.pts[0].x -= 8
    assert h.pts[0].x == 42
}

test "optional struct field wraps int on construct and assign" {
    // Regression: struct constructor and field-assign for an
    // Optional-typed field used to store the raw int64 instead of
    // wrapping it in a `Some(...)` cell — the next read interpreted
    // the int as a pointer and walked random memory.
    let opt_h: OptHolder = OptHolder(v: 42)
    assert opt_h.v is Some(x) and x == 42

    opt_h.v = 99
    assert opt_h.v is Some(y) and y == 99

    opt_h.v = none
    assert opt_h.v is none
}

test "interface-typed struct field boxes a struct value" {
    // Regression: assigning a struct value to an interface-typed
    // struct field used to store the raw struct pointer (no
    // {data, vtable} cell), so the next method dispatch loaded
    // garbage from offset 8.
    let h: GreetHolder = GreetHolder(g: Cat())
    assert h.g.hello() == "meow"
}

test "call argument wraps int into Optional param" {
    // Regression: passing a bare int to a function whose param is
    // declared `int64?` used to drop the int into x0 unwrapped, so
    // the callee's `if v is Some(x)` walked random memory.
    assert _takes_opt(42) == 42
    assert _takes_opt(none) == -1
}

test "method argument wraps int into Optional param" {
    // Same as the free-function case but through compile_method_call
    // (and compile_iface_method_call): both used to do raw arg loads.
    let b: OptBox = OptBox()
    assert b.receive(42) == 42
    assert b.receive(none) == -1
}

test "if X is Pat { ... } else { ... } takes the else branch on non-match" {
    let v: PayloadEnum = PayloadEnum.A
    mut saw: str = ""
    if v is .B(p) {
        saw = f"B({p})"
    } else {
        saw = "not B"
    }
    assert saw == "not B"

    let w: PayloadEnum = PayloadEnum.B(payload: 42)
    if w is .B(p) {
        match p {
            Some(x) -> saw = f"B({x})"
            none -> saw = "B(none)"
        }
    } else {
        saw = "not B"
    }
    assert saw == "B(42)"
}

test "array literal of interface-typed binding boxes each element" {
    // Regression: TypeKind had no KArrayInterface, so `[Greet]`
    // collapsed to KArray and `[Cat(), Dog()]` stored raw struct
    // pointers — the foreach body's method dispatch then walked
    // garbage from offset 8.
    let pets: [Greet] = [Cat(), Dog()]
    mut buf: str = ""
    for p in pets {
        buf = buf + p.hello() + ","
    }
    assert buf == "meow,woof,"
}

test "array literal of optional-typed binding wraps each element" {
    // Regression: TypeKind had no KArrayOptional, so `[int64?]`
    // collapsed to KArray and `[1, 2, none]` stored raw ints —
    // the foreach body's `is Some(x)` then walked random memory.
    let xs: [int64?] = [10, 20, none, 40]
    mut sum: int64 = 0
    mut none_count: int64 = 0
    for x in xs {
        match x {
            Some(v) -> sum = sum + v
            none -> none_count = none_count + 1
        }
    }
    assert sum == 70
    assert none_count == 1
}

test "indexed store wraps the element for optional / interface arrays" {
    // Regression: `xs[i] = v` went through compile_index_assign's
    // plain-array path which stored the rhs raw, ignoring the array's
    // element kind — so an int written into a `[int64?]` slot (or a
    // struct into a `[Greet]` slot) wasn't wrapped/boxed and the next
    // read walked garbage.
    let xs: [int64?] = [none, none]
    xs[0] = 42
    assert xs[0] is Some(v) and v == 42
    assert xs[1] is none

    let pets: [Greet] = [Cat(), Cat()]
    pets[1] = Dog()
    assert pets[0].hello() == "meow"
    assert pets[1].hello() == "woof"
}

test "returning a struct from an interface-returning function boxes it" {
    // Regression: compile_return's else-branch did a raw mov into x0,
    // ignoring the case where return_kind is an interface — the next
    // method dispatch at the call site loaded garbage from offset 8.
    let g: Greet = _make_cat()
    assert g.hello() == "meow"
}

test "enum variant payload wraps int into Optional field" {
    // Regression: compile_enum_construct stored each variant payload
    // value raw, ignoring the declared field kind — so `V.B(payload:
    // 42)` for a variant whose payload is `int64?` stored an
    // unwrapped int and the next read walked random memory.
    let v: PayloadEnum = PayloadEnum.B(payload: 42)
    match v {
        .A -> fail("expected B")
        .B(p) -> {
            match p {
                Some(x) -> assert x == 42
                none -> fail("expected Some")
            }
        }
    }
}

test "struct field defaults fill omitted fields" {
    let d: Defaulted = Defaulted(label: "a")
    assert d.label == "a"
    assert d.count == 0
    assert d.flag == true
    assert len(d.items) == 0
}

test "struct field defaults are overridden when supplied" {
    let d: Defaulted = Defaulted(label: "b", count: 7, flag: false)
    assert d.label == "b"
    assert d.count == 7
    assert d.flag == false
}

test "array-typed default yields a fresh array per construction" {
    let a: Defaulted = Defaulted(label: "x")
    let b: Defaulted = Defaulted(label: "y")
    a.items += [1]
    a.items += [2]
    assert len(a.items) == 2
    // b's default must be its own empty array, not shared with a.
    assert len(b.items) == 0
}

test "Map constructs with no arguments via field defaults" {
    let m: Map[str, int64] = Map[str, int64]()
    m.set("k", 42)
    assert m.get("k") is Some(v) and v == 42
    assert len(m) == 1
}

test "mut bindings reassign; += and -= work on them" {
    // A `let` binding here would be a compile error to reassign — that
    // case is covered by tests/immutable_reassign.kod. This checks the
    // mutable side: plain reassignment plus compound assignment.
    mut n: int64 = 1
    n = n + 40
    n += 2
    n -= 1
    assert n == 42
}
