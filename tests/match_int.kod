func main(argv: [str]) -> int64 {
	let c: int64 = 'B'
	match c {
		'A' -> print("A")
		'B' -> print("B")
		_ -> print("other")
	}
	let n: int64 = 42
	match n {
		1 -> print("one")
		42 -> print("forty-two")
		_ -> print("other")
	}
	return 0
}

// expected output:
// B
// forty-two

// expected status:
// 0

// expected selfhosted:
// skip
