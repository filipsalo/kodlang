// Compiler tests for match exhaustiveness. Each test embeds a source
// snippet and runs it through the in-process dry-run codegen, then
// inspects the returned error list.

import "kod/codegen"
import "./test_support"

test "match on int64 requires an `else` arm" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func main() -> int64 {
            let n: int64 = 1
            match n {
                1 -> print("one")
            }
            return 0
        }
        """)
    assert test_support.any_message_contains(errs, needle: "match on int64 must include an `else` arm")
}

test "match on str requires an `else` arm" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func main() -> int64 {
            let s: str = "hello"
            match s {
                "a" -> print("a")
            }
            return 0
        }
        """)
    assert test_support.any_message_contains(errs, needle: "match on str must include an `else` arm")
}

test "match on enum: missing variant reported" {
    let errs: [codegen.Error] = test_support.try_compile("""
        type Color = enum { Red, Green, Blue }
        func main() -> int64 {
            let c: Color = .Red
            match c {
                .Red -> print("red")
                .Green -> print("green")
            }
            return 0
        }
        """)
    assert test_support.any_message_contains(errs, needle: "doesn't cover variant `Blue`")
}

test "match with `else` catch-all is accepted" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func main() -> int64 {
            let n: int64 = 1
            match n {
                1 -> print("one")
                else -> print("other")
            }
            return 0
        }
        """)
    assert len(errs) == 0
}

test "match on bool: missing `true` reported" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func main() -> int64 {
            let b: bool = false
            match b {
                false -> print("f")
            }
            return 0
        }
        """)
    assert test_support.any_message_contains(errs, needle: "match on bool doesn't cover `true`")
}

test "match on bool: missing `false` reported" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func main() -> int64 {
            let b: bool = true
            match b {
                true -> print("t")
            }
            return 0
        }
        """)
    assert test_support.any_message_contains(errs, needle: "match on bool doesn't cover `false`")
}

test "match on bool covering both arms is accepted" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func main() -> int64 {
            let b: bool = true
            match b {
                true -> print("t")
                false -> print("f")
            }
            return 0
        }
        """)
    assert len(errs) == 0
}

test "match on bool with wildcard `else` is accepted" {
    let errs: [codegen.Error] = test_support.try_compile("""
        func main() -> int64 {
            let b: bool = true
            match b {
                true -> print("t")
                else -> print("other")
            }
            return 0
        }
        """)
    assert len(errs) == 0
}
