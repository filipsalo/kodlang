// Direct in-process tests for `stdlib/process.kod`. Migrated from
// tests/process_run.kod — no build_and_run dance needed since the
// test program can just call `process.run` itself.

import "process"

test "process.run captures stdout and status from echo" {
    let r: process.ProcessResult = process.run(["echo", "hello"])
    assert r.status == 0
    assert r.stdout == "hello\n"
    assert r.stderr == ""
}

test "process.run captures stderr and a non-zero exit" {
    // `sh -c` drives both streams and a chosen exit code in one shot.
    let r: process.ProcessResult = process.run(["sh", "-c", "echo out; echo err 1>&2; exit 3"])
    assert r.status == 3
    assert r.stdout == "out\n"
    assert r.stderr == "err\n"
}

test "process.run reports -1 for a missing binary" {
    // posix_spawnp ENOENT — the runtime maps that to status -1 so
    // callers can distinguish "binary not found" from a real failure.
    let r: process.ProcessResult = process.run(["this-binary-does-not-exist-on-purpose"])
    assert r.status == -1
}
