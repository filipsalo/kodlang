import "sort"

test "sorted_int64: empty" {
    let xs: [int64] = []
    let s: [int64] = sort.sorted_int64(xs)
    assert len(s) == 0
}

test "sorted_int64: already sorted is unchanged" {
    let xs: [int64] = [1, 2, 3, 4, 5]
    let s: [int64] = sort.sorted_int64(xs)
    assert len(s) == 5
    assert s[0] == 1
    assert s[4] == 5
}

test "sorted_int64: reversed input" {
    let xs: [int64] = [5, 4, 3, 2, 1]
    let s: [int64] = sort.sorted_int64(xs)
    assert s[0] == 1
    assert s[1] == 2
    assert s[2] == 3
    assert s[3] == 4
    assert s[4] == 5
}

test "sorted_int64: duplicates preserved" {
    let xs: [int64] = [3, 1, 2, 1, 3]
    let s: [int64] = sort.sorted_int64(xs)
    assert s[0] == 1
    assert s[1] == 1
    assert s[2] == 2
    assert s[3] == 3
    assert s[4] == 3
}

test "sorted_int64: negative values" {
    let xs: [int64] = [3, -5, 0, -1, 7]
    let s: [int64] = sort.sorted_int64(xs)
    assert s[0] == -5
    assert s[1] == -1
    assert s[2] == 0
    assert s[3] == 3
    assert s[4] == 7
}

test "sorted_int64: does not mutate input" {
    let xs: [int64] = [3, 1, 2]
    let _s: [int64] = sort.sorted_int64(xs)
    assert xs[0] == 3
    assert xs[1] == 1
    assert xs[2] == 2
}

test "str_less: byte-lexicographic ordering" {
    assert sort.str_less("a", "b")
    assert sort.str_less("b", "a") == false
    assert sort.str_less("a", "a") == false
    // Shorter is less when one is a prefix of the other.
    assert sort.str_less("ab", "abc")
    assert sort.str_less("abc", "ab") == false
    // Empty sorts first.
    assert sort.str_less("", "x")
    assert sort.str_less("", "") == false
}

test "sorted_str: reversed input" {
    let xs: [str] = ["banana", "apple", "cherry"]
    let s: [str] = sort.sorted_str(xs)
    assert s[0] == "apple"
    assert s[1] == "banana"
    assert s[2] == "cherry"
}

test "sorted_str: empty" {
    let xs: [str] = []
    let s: [str] = sort.sorted_str(xs)
    assert len(s) == 0
}

test "sorted_str: prefix ordering" {
    let xs: [str] = ["abc", "ab", "abcd"]
    let s: [str] = sort.sorted_str(xs)
    assert s[0] == "ab"
    assert s[1] == "abc"
    assert s[2] == "abcd"
}
