type Color = enum {
    // primary colors
    Red
    Green
    Blue
    // custom
    Custom(r: int64, g: int64, b: int64)
}

type Point = struct {
    // coordinates
    x: int64
    y: int64
}

func main() -> int64 {
    let c: Color = Color.Red
    match c {
        Color.Red -> print("red")
        Color.Green -> print("green")
        Color.Blue -> print("blue")
        Color.Custom(r, g, b) -> print("custom")
    }
    let p: Point = Point(x: 1, y: 2)
    print_int(p.x + p.y)
    return 0
}

// expected output:
// red
// 3

// expected status:
// 0


