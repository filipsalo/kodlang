func main() -> int64 {
	let n: int64 = 42
	match n {
		1 -> print("one")
		2 -> print("two")
	}
	let s: str = "hello"
	match s {
		"a" -> print("a")
		"b" -> print("b")
	}
	return 0
}

// expected errors:
// 3:8: error: match on int64 must include a wildcard arm (`_`)
// 8:8: error: match on str must include a wildcard arm (`_`)
