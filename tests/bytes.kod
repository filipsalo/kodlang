// Regression: `bytes` is a distinct type from `str` with the same
// in-memory layout, written as `b"..."`.
func main() -> int64 {
	let raw: bytes = b"hello"
	print_int(len(raw))
	print_int(raw[0])
	print_int(raw[4])

	let zero: bytes = b"\0ok"
	print_int(len(zero))
	print_int(zero[0])
	print_int(zero[1])

	let slice: bytes = raw[1..4]
	print_int(len(slice))

	let cat: bytes = raw + b" world"
	print_int(len(cat))

	if raw == b"hello" {
		print("eq")
	}
	if raw != b"hellO" {
		print("ne")
	}

	return 0
}

// expected output:
// 5
// 104
// 111
// 3
// 0
// 111
// 3
// 11
// eq
// ne

// expected status:
// 0
