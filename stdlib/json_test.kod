import "json"

// The self-recursive enum element kind isn't re-resolved post-registration
// yet (Value's own variant fields like `Array(items: [Value])` capture
// KArray instead of KArrayEnum, because Value isn't in the registry at
// register_enum time), so `items[i]` reads as int64. The typed-local
// pattern (`let it: json.Value = items[i]; match it { ... }`) is a
// workaround. Drop it once register_enum re-resolves variant kinds the
// same way register_struct does for fields.

test "parse: null" {
    match json.parse("null") {
        .Null -> {}
        else -> fail("expected Null")
    }
}

test "parse: true" {
    match json.parse("true") {
        .Bool(b) -> assert b == true
        else -> fail("expected Bool")
    }
}

test "parse: false" {
    match json.parse("false") {
        .Bool(b) -> assert b == false
        else -> fail("expected Bool")
    }
}

test "parse: positive integer" {
    match json.parse("42") {
        .Number(n) -> assert n == 42
        else -> fail("expected Number")
    }
}

test "parse: negative integer" {
    match json.parse("-7") {
        .Number(n) -> assert n == -7
        else -> fail("expected Number")
    }
}

test "parse: zero" {
    match json.parse("0") {
        .Number(n) -> assert n == 0
        else -> fail("expected Number")
    }
}

test "parse: simple string" {
    match json.parse("\"hello\"") {
        .Str(s) -> assert s == "hello"
        else -> fail("expected Str")
    }
}

test "parse: string with escapes" {
    match json.parse("\"a\\nb\\tc\\\"d\"") {
        .Str(s) -> assert s == "a\nb\tc\"d"
        else -> fail("expected Str")
    }
}

test "parse: empty array" {
    match json.parse("[]") {
        .Array(items) -> assert len(items) == 0
        else -> fail("expected Array")
    }
}

test "parse: array of numbers" {
    match json.parse("[1, 2, 3]") {
        .Array(items) -> {
            assert len(items) == 3
            // Typed locals because items[i] currently reads as int64.
            let item0: json.Value = items[0]
            match item0 {
                .Number(n) -> assert n == 1
                else -> fail("expected Number at [0]")
            }
            let item1: json.Value = items[1]
            match item1 {
                .Number(n) -> assert n == 2
                else -> fail("expected Number at [1]")
            }
            let item2: json.Value = items[2]
            match item2 {
                .Number(n) -> assert n == 3
                else -> fail("expected Number at [2]")
            }
        }
        else -> fail("expected Array")
    }
}

test "parse: empty object" {
    match json.parse("{}") {
        .Object(keys, _values) -> assert len(keys) == 0
        else -> fail("expected Object")
    }
}

test "parse: object" {
    let v: json.Value = json.parse("{\"name\": \"alice\", \"age\": 30}")
    match json.get(v, key: "name") {
        .Str(s) -> assert s == "alice"
        else -> fail("expected Str for name")
    }
    match json.get(v, key: "age") {
        .Number(n) -> assert n == 30
        else -> fail("expected Number for age")
    }
    match json.get(v, key: "missing") {
        .Null -> {}
        else -> fail("expected Null for missing key")
    }
}

test "parse: nested" {
    let v: json.Value = json.parse("{\"items\": [1, 2, {\"k\": true}]}")
    match json.get(v, key: "items") {
        .Array(items) -> {
            assert len(items) == 3
            let item0: json.Value = items[0]
            match item0 {
                .Number(n) -> assert n == 1
                else -> fail("expected Number at [0]")
            }
            let item2: json.Value = items[2]
            match json.get(item2, key: "k") {
                .Bool(b) -> assert b == true
                else -> fail("expected Bool for k")
            }
        }
        else -> fail("expected Array")
    }
}

// Accessor coverage — the optional-wrap-on-zero codegen bug used to make
// `Some(0)` and `Some(false)` round-trip to `none`, so these cases stayed
// uncovered until ea0a0e9. The `match … { Some(v) -> …; none -> fail }`
// shape is used instead of `if … is Some(v) { … } else { … }` because the
// parser lowers an `if is` into a one-arm match and doesn't attach the
// trailing `else`.

test "as_int: positive" {
    match json.as_int(json.parse("42")) {
        Some(p) -> assert p == 42
        none -> fail("expected Some")
    }
}

test "as_int: negative" {
    match json.as_int(json.parse("-7")) {
        Some(n) -> assert n == -7
        none -> fail("expected Some")
    }
}

test "as_int: zero (regression: optional-wrap-on-zero)" {
    match json.as_int(json.parse("0")) {
        Some(z) -> assert z == 0
        none -> fail("as_int(0) round-tripped to none")
    }
}

test "as_bool: true" {
    match json.as_bool(json.parse("true")) {
        Some(tv) -> assert tv == true
        none -> fail("expected Some")
    }
}

test "as_bool: false (regression: optional-wrap-on-zero)" {
    match json.as_bool(json.parse("false")) {
        Some(fv) -> assert fv == false
        none -> fail("as_bool(false) round-tripped to none")
    }
}

test "as_int / as_bool: wrong type returns none" {
    assert json.as_int(json.parse("\"hi\"")) is none
    assert json.as_bool(json.parse("0")) is none
}

test "as_str: returns string" {
    match json.as_str(json.parse("\"hi\"")) {
        Some(sv) -> assert sv == "hi"
        none -> fail("expected Some")
    }
}

test "emit: null" {
    assert json.emit(json.Value.Null) == "null"
}

test "emit: true / false" {
    assert json.emit(json.Value.Bool(value: true)) == "true"
    assert json.emit(json.Value.Bool(value: false)) == "false"
}

test "emit: integers" {
    assert json.emit(json.Value.Number(value: 42)) == "42"
    assert json.emit(json.Value.Number(value: -7)) == "-7"
}

test "emit: simple string" {
    assert json.emit(json.Value.Str(value: "hi")) == "\"hi\""
}

test "emit: string escapes" {
    assert json.emit(json.Value.Str(value: "a\nb")) == "\"a\\nb\""
    assert json.emit(json.Value.Str(value: "x\"y")) == "\"x\\\"y\""
}

test "emit: array" {
    let items: [json.Value] = [json.Value.Number(value: 1), json.Value.Number(value: 2)]
    assert json.emit(json.Value.Array(:items)) == "[1,2]"
}

test "emit: object" {
    let keys: [str] = ["a"]
    let values: [json.Value] = [json.Value.Number(value: 1)]
    assert json.emit(json.Value.Object(:keys, :values)) == "{\"a\":1}"
}

test "round-trip: nested structure" {
    let src: str = "{\"name\":\"alice\",\"tags\":[\"a\",\"b\"],\"meta\":{\"n\":42}}"
    assert json.emit(json.parse(src)) == src
}
