type IoError = struct {
    message: str

    func to_str(self) -> str {
        return self.message
    }
}

func read_size(anon path: str) -> int64 or Error {
    throw IoError(message: f"file not found: {path}")
}

func main() -> int64 {
    let n: int64 = must read_size("missing.txt")
    return n
}

// expected mode:
// run
// expected status:
// 1
// expected stderr:
// panic: file not found: missing.txt
