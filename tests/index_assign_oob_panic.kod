// Symmetric to index_oob_panic but for the write path: `arr[i] = v`
// for an out-of-range `i` used to silently write past the buf,
// corrupting whatever lived there. Now it panics through
// `_kod_index_oob` at the assignment.

func main() -> int64 {
	let xs: [int64] = [10, 20, 30]
	xs[5] = 99
	return 0
}

// expected mode:
// run
// expected status:
// 1
// expected stderr:
// panic: index 5 out of bounds for array of length 3
