// Runtime panic-path tests, migrated from tests/{assert,index_oob,
// index_assign_oob,error}_panic.kod. Each one builds a tiny source
// snippet, runs it, and asserts the process exited non-zero with
// the expected `panic: …` message on stderr. Uses the kod-side
// build_and_run pipeline in test_support.

import "kod/test_support"
import "process"

test "assert false panics with the source text" {
    let r: process.ProcessResult = test_support.build_and_run("""
        func main() -> int64 {
            let n: int64 = 7
            assert n == 4
            return 0
        }
    """)
    assert r.status != 0
    assert r.stderr.contains("panic")
    assert r.stderr.contains("assertion failed")
    assert r.stderr.contains("n == 4")
}

test "out-of-bounds array read panics with the index and length" {
    let r: process.ProcessResult = test_support.build_and_run("""
        func main() -> int64 {
            let xs: [int64] = [10, 20, 30]
            return xs[5]
        }
    """)
    assert r.status != 0
    assert r.stderr.contains("panic")
    assert r.stderr.contains("index 5 out of bounds for array of length 3")
}

test "out-of-bounds array write panics with the index and length" {
    let r: process.ProcessResult = test_support.build_and_run("""
        func main() -> int64 {
            let xs: [int64] = [10, 20, 30]
            xs[5] = 99
            return 0
        }
    """)
    assert r.status != 0
    assert r.stderr.contains("panic")
    assert r.stderr.contains("index 5 out of bounds for array of length 3")
}

test "unhandled error from `must` panics with the error's to_str" {
    let r: process.ProcessResult = test_support.build_and_run("""
        type IoError = struct {
            message: str
            func to_str(self) -> str {
                return self.message
            }
        }
        func read_size(anon path: str) -> int64 or Error {
            throw IoError(message: f"file not found: {path}")
        }
        func main() -> int64 {
            let n: int64 = must read_size("missing.txt")
            return n
        }
    """)
    assert r.status != 0
    assert r.stderr.contains("panic")
    assert r.stderr.contains("file not found: missing.txt")
}
