// Slice 2 of first-class functions: anonymous function expressions.
// `func(params) -> R { body }` is a value, callable directly or
// passable as an argument. No captures yet — referencing an
// enclosing-scope local errors out (the body sees only the
// lambda's own params + locals + module-level functions).

func apply(anon f: func(int64) -> int64, anon x: int64) -> int64 {
    return f(x)
}

func main() -> int64 {
    // Bind a lambda to a var, then call indirectly.
    let dbl: func(int64) -> int64 = func(x: int64) -> int64 { return x * 2 }
    print_int(dbl(21))

    // Pass a lambda directly as a callback.
    print_int(apply(func(n: int64) -> int64 { return n + 100 }, 5))

    // Array of lambdas, dispatched in a loop. Multi-line form
    // exercises the EOL-skipping inside `[...]`.
    let ops: [func(int64) -> int64] = [
        func(x: int64) -> int64 { return x + 1 },
        func(x: int64) -> int64 { return x * x },
    ]
    for f in ops {
        print_int(f(4))
    }

    return 0
}

// expected output:
// 42
// 105
// 5
// 16

// expected status:
// 0
