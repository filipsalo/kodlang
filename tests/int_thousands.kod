// Integer literals can be written with `<space><exactly-3-digits>`
// groups as thousands separators: `1 000` == 1000, `1 234 567` == 1234567.
// The lexer enforces strict 3-digit grouping; bare digit runs of any
// length stay valid (`1234567`).
func main() -> int64 {
    let a: int64 = 1 000
    print_int(a)
    let b: int64 = 1 234 567
    print_int(b)
    let c: int64 = 12 345
    print_int(c)
    let d: int64 = 123 456 789
    print_int(d)
    // Bare form still parses unchanged.
    let e: int64 = 1234567
    print_int(e)
    return 0
}

// expected output:
// 1000
// 1234567
// 12345
// 123456789
// 1234567
