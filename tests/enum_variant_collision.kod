// Two enums share a variant name. Implicit `.Foo` patterns in a
// match must dispatch against the SUBJECT'S enum, not the first
// enum in registration order that happens to have a `Foo`.
//
// Pre-fix, `find_enum_with_variant("Foo")` returned the first
// registered enum, so a match on a Tag value with a `.Foo` arm
// would compare against Shape.Foo's discriminant — the arm
// silently never fired.

type Shape = enum {
    Circle
    Square
    Foo
}

type Tag = enum {
    Foo
    Bar
}

func describe(anon t: Tag) -> str {
    match t {
        .Foo -> return "tag-foo"
        .Bar -> return "tag-bar"
    }
}

func main() -> int64 {
    let t: Tag = Tag.Foo
    print(describe(t))
    let t2: Tag = Tag.Bar
    print(describe(t2))
    return 0
}

// expected output:
// tag-foo
// tag-bar

// expected status:
// 0
