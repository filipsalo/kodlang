// Hexadecimal (`0x…`), octal (`0o…`), and binary (`0b…`) integer
// literals. Digits are base-restricted: `0xFF` accepts `0-9 a-f A-F`,
// `0o…` accepts `0-7`, `0b…` accepts `0-1`. No digit separators
// (space-grouping is decimal-only).
func main() -> int64 {
    let h1: int64 = 0xff
    print_int(h1)
    let h2: int64 = 0xDEADBEEF
    print_int(h2)
    let o: int64 = 0o755
    print_int(o)
    let b: int64 = 0b1010
    print_int(b)
    // Mixed bases that compute the same value.
    let same1: int64 = 255
    let same2: int64 = 0xff
    let same3: int64 = 0o377
    let same4: int64 = 0b11111111
    if same1 == same2 and same2 == same3 and same3 == same4 {
        print("all 255")
    }
    return 0
}

// expected output:
// 255
// 3735928559
// 493
// 10
// all 255
