func main() -> int64 {
    let s: str = "hello, world"

    // char literal comparison
    let c: int64 = s[0]
    if c == 'h' {
        print("char ok")
    }

    // slicing
    let sub: str = s[0:5]
    print(sub)

    // string equality
    if sub == "hello" {
        print("eq ok")
    }
    if sub != "world" {
        print("ne ok")
    }

    return 0
}

// expected status:
// 0
// expected output:
// char ok
// hello
// eq ok
// ne ok


// expected selfhosted:
// skip
