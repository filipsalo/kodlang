type IntMap = Map[str, int64]
type S2S = Map[str, str]

func make_empty() -> IntMap {
    return IntMap()
}

test "empty map: get returns none" {
    let m: IntMap = make_empty()
    assert m.get("nope") is none
}

test "empty map: contains returns false" {
    let m: IntMap = make_empty()
    assert m.contains("nope") == false
}

test "empty map: len is zero" {
    let m: IntMap = make_empty()
    assert len(m) == 0
}

test "set then get round-trips" {
    let m: IntMap = make_empty()
    m.set("a", 1)
    assert m.get("a") is Some(_v)
    if m.get("a") is Some(v) {
        assert v == 1
    }
}

test "set multiple keys" {
    let m: IntMap = make_empty()
    m.set("x", 10)
    m.set("y", 20)
    m.set("z", 30)
    assert len(m) == 3
    if m.get("x") is Some(v) { assert v == 10 }
    if m.get("y") is Some(v) { assert v == 20 }
    if m.get("z") is Some(v) { assert v == 30 }
}

test "overwriting preserves len, replaces value" {
    let m: IntMap = make_empty()
    m.set("k", 1)
    m.set("k", 2)
    m.set("k", 3)
    assert len(m) == 1
    if m.get("k") is Some(v) { assert v == 3 }
}

test "contains tracks insertions" {
    let m: IntMap = make_empty()
    assert m.contains("a") == false
    m.set("a", 1)
    assert m.contains("a") == true
    assert m.contains("b") == false
}

test "op_index_set and op_index work" {
    let m: IntMap = make_empty()
    m["foo"] = 42
    match m["foo"] {
        Some(v) -> assert v == 42
        none -> fail("op_index miss after op_index_set")
    }
}

test "growth: many entries trigger resize without losing data" {
    let m: IntMap = make_empty()
    let i: int64 = 0
    for i < 100 {
        m.set(i.to_str(), i * 7)
        i = i + 1
    }
    assert len(m) == 100
    // Spot-check a few keys after the table has resized multiple times.
    if m.get("0") is Some(v) { assert v == 0 }
    if m.get("50") is Some(v) { assert v == 350 }
    if m.get("99") is Some(v) { assert v == 693 }
    assert m.contains("100") == false
}

test "key lookup uses content equality (not pointer identity)" {
    let m: IntMap = make_empty()
    let a: str = "hello"
    let b: str = "hel" + "lo"
    m.set(a, 1)
    // `b` is a freshly concatenated string; the lookup should still hit.
    match m.get(b) {
        Some(v) -> assert v == 1
        none -> fail("content-equal key missed")
    }
}

test "lookup of an absent key returns none" {
    let m: IntMap = make_empty()
    m["x"] = 10
    assert m["missing"] is none
}

test "string-keyed value (Map[str, str])" {
    let m: S2S = S2S()
    m.set("a", "apple")
    m.set("b", "banana")
    if m.get("a") is Some(v) { assert v == "apple" }
    if m.get("b") is Some(v) { assert v == "banana" }
    assert m.get("c") is none
}

test "20-key grow path with an in-place update" {
    // Exercises the resize threshold (initial table of 8 slots) plus an
    // overwrite of an existing key. Mirrors what was tests/map_grow.kod.
    let m: IntMap = make_empty()
    let keys: [str] = ["a", "b", "c", "d", "e", "f", "g", "h", "i", "j", "k", "l", "m", "n", "o", "p", "q", "r", "s", "t"]
    let i: int64 = 0
    for i < len(keys) {
        m[keys[i]] = i * 10
        i = i + 1
    }
    m["a"] = 999

    let sum: int64 = 0
    for k in keys {
        match m[k] {
            Some(v) -> sum = sum + v
            none -> fail("missing key after grow")
        }
    }
    // 999 + sum(10..200 step 10, skipping 0) = 999 + (10+20+...+190) = 999 + 1900
    assert sum == 2899
    assert m["missing"] is none
}
