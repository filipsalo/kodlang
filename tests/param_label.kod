// External argument label (for the caller) can differ from the
// binding name (inside the function).

func greet(who person: str) -> none {
	print(person)
}

// Single-name form still works: label and binding are the same.
func say(name: str) -> none {
	print(name)
}

// Anon params have no label regardless of the form.
func shout(anon msg: str) -> none {
	print(msg)
}

func main() -> int64 {
	greet(who: "kod")
	say(name: "world")
	shout("hi")
	return 0
}

// expected output:
// kod
// world
// hi
// expected status:
// 0
