func main() -> int64 {
    let a: str = "world"
    let b: str = "!"
    print(f"hello {a}{b}")
    let n: int64 = 42
    print(f"n = {int_to_str(n)}")
    print(f"a={a} b={b} n={int_to_str(n)}")
    return 0
}

// expected output:
// hello world!
// n = 42
// a=world b=! n=42

// expected status:
// 0
