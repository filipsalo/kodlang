// First-class functions: named functions are values that can be
// stored in variables, passed as arguments, and called indirectly.

func double(x: int64) -> int64 {
    return x * 2
}

func triple(x: int64) -> int64 {
    return x * 3
}

func apply(anon f: func(int64) -> int64, anon x: int64) -> int64 {
    return f(x)
}

func main() -> int64 {
    // Local var of function type — direct assignment, indirect call.
    let f: func(int64) -> int64 = double
    print_int(f(21))

    // Pass a function as an argument.
    print_int(apply(triple, 14))

    // Reassign and re-call.
    mut g: func(int64) -> int64 = double
    print_int(g(10))
    g = triple
    print_int(g(10))

    return 0
}

// expected output:
// 42
// 42
// 20
// 30

// expected status:
// 0
