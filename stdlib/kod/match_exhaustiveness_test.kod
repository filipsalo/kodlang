// Compiler tests for match exhaustiveness. Each test embeds a source
// snippet and runs it through the in-process dry-run codegen, then
// inspects the returned error list.

import "./test_support"

test "match on int64 requires an `else` arm" {
    let errs: [str] = test_support.try_compile("""
        func main() -> int64 {
            let n: int64 = 1
            match n {
                1 -> print("one")
            }
            return 0
        }
        """)
    assert test_support.any_contains(errs, needle: "match on int64 must include an `else` arm")
}

test "match on str requires an `else` arm" {
    let errs: [str] = test_support.try_compile("""
        func main() -> int64 {
            let s: str = "hello"
            match s {
                "a" -> print("a")
            }
            return 0
        }
        """)
    assert test_support.any_contains(errs, needle: "match on str must include an `else` arm")
}

test "match on enum: missing variant reported" {
    let errs: [str] = test_support.try_compile("""
        type Color = enum { Red, Green, Blue }
        func main() -> int64 {
            let c: Color = .Red
            match c {
                .Red -> print("red")
                .Green -> print("green")
            }
            return 0
        }
        """)
    assert test_support.any_contains(errs, needle: "doesn't cover variant `Blue`")
}

test "match with `else` catch-all is accepted" {
    let errs: [str] = test_support.try_compile("""
        func main() -> int64 {
            let n: int64 = 1
            match n {
                1 -> print("one")
                else -> print("other")
            }
            return 0
        }
        """)
    assert len(errs) == 0
}
