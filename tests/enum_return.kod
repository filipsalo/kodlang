type Color = enum {
    Red
    Green
    Blue
}

func pick(anon n: int64) -> Color {
    if n == 0 {
        return Color.Red
    }
    if n == 1 {
        return Color.Green
    }
    return Color.Blue
}

func name(anon c: Color) -> str {
    match c {
        Color.Red -> return "red"
        Color.Green -> return "green"
        Color.Blue -> return "blue"
    }
    return "unknown"
}

func main() -> int64 {
    print(name(pick(0)))
    print(name(pick(1)))
    print(name(pick(2)))
    return 0
}

// expected status:
// 0
// expected output:
// red
// green
// blue
