// Language-feature tests that don't have an obvious home in a
// primitive's *_test.kod. Each block here used to be a tests/*.kod
// example with a `// expected output:` block; assertions replace the
// print-and-compare pattern, which is faster (one binary for the
// whole suite instead of one per file) and tighter.

type Point = struct {
    x: int64
    y: int64
    func to_str(self) -> str {
        return f"({self.x}, {self.y})"
    }
}

// `//` comments interleaved with enum variants / struct fields used to
// break the parser. The regression test is the *parse* of these type
// definitions — if the parser regresses, the whole file fails to
// compile and `kod test` surfaces it as a build error before any
// assertion runs. The `Color` / `ColorPoint` test block below is just
// a runtime smoke-check that the types behave normally afterwards.
type Color = enum {
    // primary colors
    Red
    Green
    Blue
    // custom
    Custom(r: int64, g: int64, b: int64)
}

type PointHolder = struct {
    pts: [Point]
}

type ColorPoint = struct {
    // coordinates
    x: int64
    y: int64
}

test "comparison operators" {
    assert 1 != 2
    assert 2 <= 2
    assert 2 < 3
    assert 3 >= 2
    assert 3 > 2
    assert (1 < 2) == true
    assert (2 < 1) == false
}

test "logical operators short-circuit" {
    assert true and true
    assert (true and false) == false
    assert false or true
    assert (false or false) == false
}

test "arithmetic precedence: * binds tighter than +" {
    assert 1 + 2 * 3 == 7
    assert (1 + 2) * 3 == 9
    assert 10 - 2 - 3 == 5
    assert 10 - (2 - 3) == 11
}

test "negative array indexing" {
    let nums: [int64] = [10, 20, 30, 40, 50]
    assert nums[-1] == 50
    assert nums[-2] == 40
    assert nums[-5] == 10
}

test "f-string interpolates int / bool / str" {
    let n: int64 = 42
    let b: bool = true
    let s: str = "hi"
    assert f"int={n}" == "int=42"
    assert f"bool={b}" == "bool=true"
    assert f"bool={false}" == "bool=false"
    assert f"str={s}" == "str=hi"
    assert f"mix={n} {b} {s}" == "mix=42 true hi"
}

test "f-string concatenation across multiple interpolations" {
    let a: str = "world"
    let b: str = "!"
    assert f"hello {a}{b}" == "hello world!"
}

test "f-string calls user-defined to_str on struct values" {
    let p: Point = Point(x: 3, y: 4)
    assert f"point={p}" == "point=(3, 4)"
}

test "enum-with-comments and struct-with-comments are still usable" {
    // The comment regression is covered by the parse of the module-
    // level type definitions above. This block just confirms the
    // resulting types construct, match, and field-access normally.
    let c: Color = Color.Custom(r: 1, g: 2, b: 3)
    match c {
        .Red -> fail("expected Custom")
        .Green -> fail("expected Custom")
        .Blue -> fail("expected Custom")
        .Custom(r, g, b) -> {
            assert r == 1
            assert g == 2
            assert b == 3
        }
    }
    let pt: ColorPoint = ColorPoint(x: 1, y: 2)
    assert pt.x + pt.y == 3
}

test "two foreach loops sharing an element name pin per-loop kinds" {
    // Regression: reusing the element name `f` across two foreach loops
    // with differently-typed iterators used to leave both bodies seeing
    // the first loop's struct kind, so `f.x` in the second loop read the
    // wrong byte offset.
    let pts: [Point] = [Point(x: 1, y: 2), Point(x: 3, y: 4)]
    let cps: [ColorPoint] = [ColorPoint(x: 10, y: 20)]
    let total: int64 = 0
    for f in pts {
        total = total + f.x + f.y
    }
    for f in cps {
        total = total + f.x + f.y
    }
    assert total == (1 + 2) + (3 + 4) + (10 + 20)
}

test "foreach over an array literal infers the element struct kind" {
    // Regression: `for p in [pt]` used to fall back to KInt64 for `p`
    // (ArrayLit's infer_kind returned a bare KArray), so `p.x` read
    // from offset 0 of the int64-typed slot.
    let pt: Point = Point(x: 7, y: 9)
    let sum: int64 = 0
    for p in [pt] {
        sum = sum + p.x + p.y
    }
    assert sum == 16
}

test "non-Ident lhs in indexed assignment stores correctly" {
    // Regression: `obj.field[idx] = expr` (and any other non-Ident
    // array LHS) used to silently emit nothing because
    // compile_index_assign required the LHS to be a bare Ident.
    let outer: PointHolder = PointHolder(pts: [Point(x: 1, y: 2), Point(x: 3, y: 4)])
    outer.pts[0] = Point(x: 99, y: 100)
    assert outer.pts[0].x == 99
    assert outer.pts[0].y == 100
    assert outer.pts[1].x == 3
}
