// Regression test for `continue` inside a `for cond { ... }` loop.
// compile_for used to set incr_lbl to the loop's end label, so
// `continue` actually broke out of the loop instead of jumping back
// to the condition check. The lexer.lex_fstring path hit this when
// it tried to use `continue` to skip past `\X` escape pairs.
func main() -> int64 {
    mut i: int64 = 0
    mut n: int64 = 0
    for i < 5 {
        i = i + 1
        if i == 3 {
            continue
        }
        n = n + i
    }
    // Should be 1 + 2 + 4 + 5 = 12 (skips i==3).
    print_int(n)
    return 0
}

// expected status:
// 0
// expected output:
// 12
