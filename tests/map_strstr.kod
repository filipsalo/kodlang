type StrStrMap = Map[str, str]

func main() -> int64 {
	let m: StrStrMap = StrStrMap(keys: [], values: [], indices: [])
	m.set("a", "apple")
	m.set("b", "banana")
	m.set("c", "cherry")

	let va: str? = m.get("a")
	let vb: str? = m.get("b")
	let vc: str? = m.get("c")

	match va {
		Some(v) -> print(v)
		none -> print("missing a")
	}
	match vb {
		Some(v) -> print(v)
		none -> print("missing b")
	}
	match vc {
		Some(v) -> print(v)
		none -> print("missing c")
	}
	return 0
}

// expected output:
// apple
// banana
// cherry
// expected status:
// 0
