func main() -> int64 {
	let zero: int64 = 0
	let n: int64 = 42
	let neg: int64 = -7
	let big: int64 = 100
	print(zero.to_str())
	print(n.to_str())
	print(neg.to_str())
	let s: str = "value: " + big.to_str()
	print(s)
	return 0
}

// expected output:
// 0
// 42
// -7
// value: 100

// expected status:
// 0
