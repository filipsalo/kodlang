// `is not Pat` — the negated `is`. Reads as one operator; works
// anywhere `is Pat` does (expression context + `if … is` form).

func main() -> int64 {
    let a: int64? = none
    let b: int64? = 42

    // Expression-position predicate.
    let a_has: bool = a is not none
    let b_has: bool = b is not none
    if a_has {
        print("a_has unexpectedly true")
    }
    if b_has {
        print("b_has")
    }

    // `if … is not` — body runs when the pattern does NOT match.
    if a is not none {
        print("a is not none unexpectedly")
    } else {
        print("a is none branch")
    }
    if b is not none {
        print("b is not none branch")
    } else {
        print("b unexpectedly none")
    }

    return 0
}

// expected output:
// b_has
// a is none branch
// b is not none branch

// expected status:
// 0
