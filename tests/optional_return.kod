func maybe(anon x: int64) -> int64? {
    if x > 0 {
        return x
    }
    return none
}

func main() -> int64 {
    let a: int64? = maybe(5)
    match a {
        none -> print("none")
        Some(v) -> print_int(v)
    }
    let b: int64? = maybe(-1)
    match b {
        none -> print("none")
        Some(v) -> print_int(v)
    }
    return 0
}

// expected status:
// 0
// expected output:
// 5
// none
