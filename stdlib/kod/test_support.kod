// Helpers for compiler tests written in Kod. Two layers:
//
//  - `try_compile(src)` runs lexer + parser + dry-run codegen
//    in-process and returns the codegen's accumulated error list.
//    Fast (no subprocess); limited to single-file snippets (no
//    imports). Use for typecheck-style tests.
//
//  - `compile_source(src)` writes `src` to a scratch file and spawns
//    sh_kodc on it, returning the captured ProcessResult. Slower,
//    but supports the full compile pipeline including codegen for
//    multi-module setups. Use when `try_compile` isn't enough.

import "io"
import "process"
import "fs"
import "kod/lexing"
import "kod/parsing"
import "kod/ast"
import "kod/codegen"

func parse_kod(anon path: str) -> parsing.Parser {
    let source: str = io.read_file(path)
    let lxr: lexing.Lexer = lexing.Lexer(:source, pos: 0, start: 0)
    let tokens: [lexing.Token] = lxr.lex()
    return parsing.make_parser(tokens, :path, :source)
}

// Lex + parse + run a dry-run codegen over `src`. Returns the
// codegen's error list — empty when the snippet compiled cleanly.
// Only suitable for single-file snippets; cross-module behaviour needs
// `compile_source` (subprocess + temp file).
func try_compile(anon src: str) -> [codegen.Error] {
    let builtins_parser: parsing.Parser = parse_kod("stdlib/builtins.kod")
    let builtins_module: ast.Module = builtins_parser.parse_module()
    let int64_parser: parsing.Parser = parse_kod("stdlib/primitives/int64.kod")
    let int64_module: ast.Module = int64_parser.parse_module()
    let str_parser: parsing.Parser = parse_kod("stdlib/primitives/str.kod")
    let str_module: ast.Module = str_parser.parse_module()
    let bool_parser: parsing.Parser = parse_kod("stdlib/primitives/bool.kod")
    let bool_module: ast.Module = bool_parser.parse_module()

    let lxr: lexing.Lexer = lexing.Lexer(source: src, pos: 0, start: 0)
    let tokens: [lexing.Token] = lxr.lex()
    let p: parsing.Parser = parsing.make_parser(tokens, path: "<test>", source: src)
    let module: ast.Module = p.parse_module()

    let cg: codegen.Codegen = codegen.make_codegen(:p, path_prefix: "test")
    cg.dry_run = true
    cg.register_module_funcs(builtins_module, prefix: "builtins", p: builtins_parser)
    cg.register_module_types(builtins_module, prefix: "builtins", p: builtins_parser)
    cg.register_primitive_module(int64_module, kind: .KInt64, prefix: "primitives$int64", p: int64_parser)
    cg.register_primitive_module(str_module, kind: .KStr, prefix: "primitives$str", p: str_parser)
    cg.register_primitive_module(bool_module, kind: .KBool, prefix: "primitives$bool", p: bool_parser)
    cg.resolve_field_kinds()
    cg.resolve_variant_field_kinds()
    cg.compile_module(module)
    // Fold parser errors into the returned list — callers don't care
    // which stage of the pipeline produced the diagnostic, just that
    // the snippet had a problem.
    for pe in p.errors {
        cg.errors += [codegen.Error(path: pe.path, line: pe.line, col: pe.col, end_col: pe.end_col, message: pe.message, source_line: pe.source_line, caret: pe.caret)]
    }
    return cg.errors
}

// True if any error's `message` field contains `needle`.
func any_message_contains(anon errs: [codegen.Error], needle: str) -> bool {
    for e in errs {
        if e.message.contains(needle) {
            return true
        }
    }
    return false
}

// Subprocess path: write `src` to a scratch file at the project root
// and invoke sh_kodc on it. Returns the captured ProcessResult so
// tests can inspect status / stdout / stderr. Use when `try_compile`
// is not enough (e.g. cross-module).
func compile_source(anon src: str) -> process.ProcessResult {
    let scratch: str = ".kod_compile_test.kod"
    io.write_file(scratch, src)
    return process.run(["build/stage1/sh_kodc", scratch])
}

// Stage0 stdlib modules whose .o lives at build/stage0/_<basename>.o.
// Must stay in sync with the same list in tools/kod.kod and the
// Makefile's STAGE0_OBJS. Kod doesn't support module-level lets, so
// this is a nullary function returning the list each call.
func _stage0_module_paths() -> [str] {
    return ["stdlib/builtins.kod", "stdlib/primitives/int64.kod", "stdlib/primitives/str.kod", "stdlib/primitives/bool.kod", "stdlib/io.kod", "stdlib/process.kod", "stdlib/time.kod"]
}

// Strip directory + `.kod` suffix from a path: "tests/foo.kod" → "foo".
// Used to derive the .o name and the build/apps/<stem>/ directory.
func _basename_no_ext(anon path: str) -> str {
    mut last_slash: int64 = -1
    mut i: int64 = 0
    for i < len(path) {
        if path[i] == '/' {
            last_slash = i
        }
        i = i + 1
    }
    let after: int64 = last_slash + 1
    mut end: int64 = len(path)
    if end - after >= 4 and path[end-4:end] == ".kod" {
        end = end - 4
    }
    return path[after:end]
}

func _macos_version() -> str {
    let r: process.ProcessResult = process.run(["sw_vers", "-productVersion"])
    mut v: str = r.stdout
    let n: int64 = len(v)
    if n > 0 and v[n-1] == '\n' {
        v = v[0:n-1]
    }
    return v
}

// Full compile + link + run pipeline, kod-side. Writes `src` to a
// scratch file, drives sh_kodc + `as` + `ld` with the same stage0
// .o set tools/kod.kod uses, runs the result, returns the captured
// ProcessResult. Mirrors tools/kod.kod's `build_executable` —
// duplicated rather than shared so test_support stays a single
// self-contained module that any *_test.kod can import without
// pulling tools/kod.kod into the test program.
//
// Returns the build's ProcessResult on a build/link failure (status
// non-zero, stderr carries the compiler's diagnostic); otherwise the
// child program's ProcessResult.
//
// Best-effort cleanup: scratch files removed at the end even when
// the build or the run failed.
// Multi-file variant. Materialises every path in `files` to a
// scratch directory, then delegates the full build to the native
// `kod` driver (`./build/apps/kod/kod build <entry>`) and runs the
// resulting executable. Use for tests that need transitive imports
// or any other cross-file behaviour the single-string
// `build_and_run` can't express.
//
// `entry` is the path *within* the FileSystem of the file with
// `func main`. The scratch directory is the same `.kod_test_build`
// stub the single-file form uses, just populated with a tree
// instead of one file.
func build_and_run_files(files: fs.FileSystem, entry: str) -> process.ProcessResult {
    let dir: str = ".kod_test_build_dir"
    process.run(["rm", "-rf", dir])
    process.run(["mkdir", "-p", dir])
    for p in files.paths() {
        let full: str = f"{dir}/{p}"
        let parent: str = _dirname(full)
        if len(parent) > 0 {
            process.run(["mkdir", "-p", parent])
        }
        if io.write_file(full, files.read_file(p)) != 0 {
            process.run(["rm", "-rf", dir])
            return process.ProcessResult(status: 1, stdout: "", stderr: f"build_and_run_files: failed to write {full}\n")
        }
    }
    let entry_path: str = f"{dir}/{entry}"
    let build_r: process.ProcessResult = process.run(["./build/apps/kod/kod", "build", entry_path])
    if build_r.status != 0 {
        process.run(["rm", "-rf", dir])
        return build_r
    }
    let stem: str = _basename_no_ext(entry_path)
    let exe: str = f"build/apps/{stem}/{stem}"
    let run_r: process.ProcessResult = process.run([exe])
    process.run(["rm", "-rf", dir])
    return run_r
}

func _dirname(anon path: str) -> str {
    mut last_slash: int64 = -1
    mut i: int64 = 0
    for i < len(path) {
        if path[i] == '/' {
            last_slash = i
        }
        i = i + 1
    }
    if last_slash < 0 {
        return ""
    }
    return path[0:last_slash]
}

func build_and_run(anon src: str) -> process.ProcessResult {
    let stem: str = ".kod_test_build"
    let scratch: str = f"{stem}.kod"
    if io.write_file(scratch, src) != 0 {
        return process.ProcessResult(status: 1, stdout: "", stderr: f"build_and_run: failed to write {scratch}\n")
    }
    let app_dir: str = f"build/apps/{stem}"
    process.run(["mkdir", "-p", app_dir])
    let sh_kodc: str = "build/stage1/sh_kodc"

    let scratch_o: str = f"{app_dir}/_{stem}.o"
    let compile_r: process.ProcessResult = process.run([sh_kodc, "_compile", scratch, scratch_o])
    if compile_r.status != 0 {
        process.run(["rm", "-f", scratch])
        return compile_r
    }
    let main_s: str = f"{app_dir}/runtime_main.s"
    let main_o: str = f"{app_dir}/runtime_main.o"
    let main_r: process.ProcessResult = process.run([sh_kodc, "_emit-runtime-main", scratch, main_s])
    if main_r.status != 0 {
        process.run(["rm", "-f", scratch])
        return main_r
    }
    let as_r: process.ProcessResult = process.run(["as", "-target", "arm64-apple-darwin", "-o", main_o, main_s])
    if as_r.status != 0 {
        process.run(["rm", "-f", scratch])
        return as_r
    }
    let exe: str = f"{app_dir}/{stem}"
    mut link_argv: [str] = ["ld", "-macos_version_min", _macos_version(), "-lc", "-L", "/Library/Developer/CommandLineTools/SDKs/MacOSX.sdk/usr/lib", "-dead_strip", "-o", exe]
    for s in _stage0_module_paths() {
        link_argv += [f"build/stage0/_{_basename_no_ext(s)}.o"]
    }
    link_argv += ["build/stage0/arena.o"]
    link_argv += ["build/stage0/runtime.o"]
    link_argv += [scratch_o]
    link_argv += [main_o]
    let link_r: process.ProcessResult = process.run(link_argv)
    if link_r.status != 0 {
        process.run(["rm", "-f", scratch])
        return link_r
    }
    let run_r: process.ProcessResult = process.run([exe])
    process.run(["rm", "-f", scratch])
    return run_r
}
