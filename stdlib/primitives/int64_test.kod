test "to_str: zero" {
    assert 0.to_str() == "0"
}

test "to_str: small positive" {
    assert 1.to_str() == "1"
    assert 7.to_str() == "7"
    assert 9.to_str() == "9"
}

test "to_str: multi-digit positive" {
    assert 10.to_str() == "10"
    assert 42.to_str() == "42"
    assert 1234567.to_str() == "1234567"
    assert 1000000000000.to_str() == "1000000000000"
}

test "to_str: negative" {
    assert (-1).to_str() == "-1"
    assert (-7).to_str() == "-7"
    assert (-12345).to_str() == "-12345"
}

test "to_str round-trips through f-string interpolation" {
    let n: int64 = 42
    assert f"value={n}" == "value=42"
}

test "hash: identity" {
    // Per stdlib/primitives/int64.kod, int64.hash returns the value itself.
    assert 0.hash() == 0
    assert 1.hash() == 1
    assert (-99).hash() == -99
    assert 1234567.hash() == 1234567
    assert (-1000000000000).hash() == -1000000000000
}
