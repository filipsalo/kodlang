// Python-style chained comparisons. `a < b < c` is `(a < b) and
// (b < c)` with `b` computed once. Mixed-op chains (`a < b == c`)
// also work; each link short-circuits independently.
func main() -> int64 {
    // Basic 3-way chain.
    if 1 < 2 < 3 { print("1<2<3 true") } else { print("1<2<3 false (BUG)") }
    if 3 < 2 < 1 { print("3<2<1 true (BUG)") } else { print("3<2<1 false") }
    if 1 < 3 < 2 { print("1<3<2 true (BUG)") } else { print("1<3<2 false") }

    // 4-way chain.
    if 1 < 2 < 3 < 4 { print("1<2<3<4 true") } else { print("1<2<3<4 false (BUG)") }

    // Mixed operators.
    if 1 <= 1 == 1 { print("1<=1==1 true") } else { print("1<=1==1 false (BUG)") }
    if 5 > 3 >= 3 { print("5>3>=3 true") } else { print("5>3>=3 false (BUG)") }

    // Equality chain.
    let a: int64 = 42
    let b: int64 = 42
    let c: int64 = 42
    if a == b == c { print("a==b==c true") } else { print("a==b==c false (BUG)") }

    // Short-circuit: if the first link fails the rest don't run.
    if 1 > 2 < bang() { print("short-circuit BUG (should not run)") }
    print("done")
    return 0
}

func bang() -> int64 {
    print("bang() called (BUG)")
    return 0
}

// expected output:
// 1<2<3 true
// 3<2<1 false
// 1<3<2 false
// 1<2<3<4 true
// 1<=1==1 true
// 5>3>=3 true
// a==b==c true
// done
