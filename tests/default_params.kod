// Default values for function parameters: `name: T = expr`.
// Trailing params with defaults can be omitted at the call site,
// in which case the default expression is evaluated fresh in the
// function's defining-module scope.

func greet(name: str = "world") -> none {
    print(f"hello {name}")
}

func retry(anon n: int64, anon delay_ms: int64 = 100) -> int64 {
    return n * delay_ms
}

type Counter = struct {
    value: int64

    func bump(self, anon by: int64 = 1) -> int64 {
        self.value = self.value + by
        return self.value
    }
}

func compute_default() -> int64 {
    // Module-level helper referenced by a default expression below
    // — proves defaults can resolve to other top-level functions
    // (and would still work if the call site lived in another
    // module, since defaults compile in the function's own parser).
    return 42
}

func with_call_default(x: int64 = compute_default()) -> int64 {
    return x
}

func main() -> int64 {
    greet()                    // hello world
    greet(name: "Alice")       // hello Alice
    print_int(retry(3))        // 300
    print_int(retry(3, 500))   // 1500

    mut c: Counter = Counter(value: 0)
    print_int(c.bump())        // 1
    print_int(c.bump(5))       // 6

    print_int(with_call_default())       // 42 — default evaluated
    print_int(with_call_default(x: 99))  // 99 — explicit overrides

    return 0
}

// expected output:
// hello world
// hello Alice
// 300
// 1500
// 1
// 6
// 42
// 99

// expected status:
// 0
