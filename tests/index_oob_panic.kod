// Reading past the end of an array used to silently return whatever
// memory followed the buf — most often a wild value the program then
// kept using. The codegen now bounds-checks every array index and
// panics through `_kod_index_oob`, so the failure surfaces at the
// exact use site instead of corrupting downstream computation.

func main() -> int64 {
	let xs: [int64] = [10, 20, 30]
	return xs[5]
}

// expected mode:
// run
// expected status:
// 1
// expected stderr:
// panic: index 5 out of bounds for array of length 3
