// Regression for transitive-import resolution. We import `parsing` and
// `lexing` but NOT `ast`. `parsing.Parser` has a field
// `func_decls: [ast.FuncDecl]`; resolving the field's element kind
// requires `ast` to be loaded for the build. Before the transitive
// walk, that field came out as a plain `KArray`, and the comparison
// below mis-compiled to an integer compare (it would silently print
// "MISSED").

import "kod/parsing"
import "kod/lexing"

func main() -> int64 {
    let source: str = "func foo() -> int64 { return 0 }\n"
    let lxr: lexing.Lexer = lexing.Lexer(source: source, pos: 0, start: 0)
    let tokens: [lexing.Token] = lxr.lex()
    let p: parsing.Parser = parsing.make_parser(tokens, path: "x.kod", source: source)
    let _module = p.parse_module()
    // index 1: make_parser reserves index 0 as a null sentinel
    if p.func_decls[1].name == "foo" {
        print("ok")
    } else {
        print("MISSED")
    }
    return 0
}

// expected output:
// ok

// expected status:
// 0

// expected mode:
// run
