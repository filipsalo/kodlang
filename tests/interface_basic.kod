interface Printable {
    func print(self) -> none
}

type Point = struct {
    x: int64
    y: int64
    func print(self) -> none {
        print(f"Point({int_to_str(self.x)}, {int_to_str(self.y)})")
    }
}

type Name = struct {
    value: str
    func print(self) -> none {
        print(self.value)
    }
}

func show(anon p: Printable) -> none {
    p.print()
}

func main() -> int64 {
    let pt: Point = Point(x: 3, y: 4)
    let n: Name = Name(value: "hi")
    show(pt)
    show(n)
    return 0
}

// expected status:
// 0
// expected output:
// Point(3, 4)
// hi
