func get(anon flag: bool) -> int64? {
    if flag {
        return 42
    }
    return none
}

func main() -> int64 {
    if get(true) is Some(v) {
        print_int(v)
    }
    if get(false) is Some(v) {
        print("should not print")
    }
    // Still works as bool:
    let x: int64? = none
    if x is none {
        print("is none")
    }
    return 0
}

// expected output:
// 42
// is none
// expected status:
// 0
