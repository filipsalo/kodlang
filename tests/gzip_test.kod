// Stored-only gzip writer — produces a `.gz` blob, writes it through
// `gunzip`, and prints whatever comes back out. A successful
// round-trip means the framing (header + stored block + CRC + ISIZE)
// is well-formed.

import "gzip"
import "io"
import "process"

func main() -> int64 {
    let input: str = "The quick brown fox jumps over the lazy dog."
    let compressed: str = gzip.compress(input)
    let rc: int64 = io.write_file("/tmp/kod_gzip_test.gz", compressed)
    if rc != 0 {
        print("write failed")
        return 1
    }
    let r: process.ProcessResult = process.run(["gunzip", "-c", "/tmp/kod_gzip_test.gz"])
    if r.status != 0 {
        print("gunzip failed")
        print(r.stderr)
        return 1
    }
    if r.stdout == input {
        print("ok")
    } else {
        print(f"mismatch: got {r.stdout}")
    }
    return 0
}

// expected output:
// ok
// expected status:
// 0
// expected mode:
// run
