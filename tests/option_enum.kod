// Use the stdlib Option[T] enum directly (not via `T?` sugar).
// Proves the unified enum-shaped Option is constructible, matchable, and
// carries the substituted payload kind per instantiation.
func first_positive(anon xs: [int64]) -> Option[int64] {
    for x in xs {
        if x > 0 {
            return .Some(value: x)
        }
    }
    return .None
}

func describe(anon o: Option[int64]) -> str {
    match o {
        .Some(value) -> return f"some {value}"
        .None -> return "none"
    }
}

func main() -> int64 {
    print(describe(first_positive([-1, -2, 3, 4])))
    print(describe(first_positive([-1, -2])))
    return 0
}

// expected output:
// some 3
// none
