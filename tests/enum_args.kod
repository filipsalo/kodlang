type Direction = enum {
	North
	South
}

type Message = enum {
	Text(content: str)
	Number(value: int64)
}

func which_dir(anon d: Direction) -> none {
	if d == Direction.North {
		print("north")
	} else {
		print("south")
	}
}

func describe(anon m: Message) -> none {
	match m {
		Message.Text(content) -> print(content)
		Message.Number(value) -> print_int(value)
	}
}

func main() -> int64 {
	let d1: Direction = Direction.North
	let d2: Direction = Direction.South
	which_dir(d1)
	which_dir(d2)
	let m1: Message = Message.Text(content: "hello")
	let m2: Message = Message.Number(value: 42)
	describe(m1)
	describe(m2)
	return 0
}

// expected output:
// north
// south
// hello
// 42

// expected status:
// 0

// expected selfhosted:
// skip
