// Regression: `arr[i] = SomeStruct(...)` used to clobber the index
// register across the constructor's `_arena_alloc` call, so the write
// landed at a random offset inside the array buf. Each slot should
// receive the value computed from its own loop index, not some other.

type Box = struct { x: int64 }

func main() -> int64 {
	let arr: [Box] = [Box(x: 0), Box(x: 0), Box(x: 0)]
	mut i: int64 = 0
	for i < 3 {
		arr[i] = Box(x: i * 100 + 7)
		i = i + 1
	}
	mut j: int64 = 0
	for j < 3 {
		print(arr[j].x.to_str())
		j = j + 1
	}
	return 0
}

// expected output:
// 7
// 107
// 207
// expected status:
// 0
