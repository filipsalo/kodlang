func main() -> int64 {
    let n: int64 = 42
    let b: bool = true
    let nb: bool = false
    let s: str = "hi"
    print(f"int={n}")
    print(f"bool={b}")
    print(f"bool={nb}")
    print(f"str={s}")
    print(f"mix={n} {b} {s}")
    return 0
}

// expected status:
// 0
// expected output:
// int=42
// bool=true
// bool=false
// str=hi
// mix=42 true hi
