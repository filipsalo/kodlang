// String literals are UTF-8 bytes. `len` returns the byte length, not a
// code-point count, in both the interpreter and compiled code. The Python
// frontend previously double-encoded non-ASCII via `unicode-escape` and
// disagreed with the compiled (raw-bytes) representation; this pins them.
func main() -> int64 {
    print_int(len("héllo"))      // 6 — `é` is 2 UTF-8 bytes
    print_int(len("wörld"))      // 6
    print_int(len("ascii"))      // 5 — ASCII unchanged
    print_int(len("a\tb"))       // 3 — escapes still process
    let name = "wörld"
    print_int(len(f"{name}"))    // 6 — f-string preserves bytes
    return 0
}

// expected output:
// 6
// 6
// 5
// 3
// 6
