import "kod/ast"
import "kod/parsing"
import "kod/lexing"

// Concrete instantiation of the builtin Map used for string interning.
// Declared here so resolve_type registers the monomorphised entry early,
// before any field of Codegen references it.
type StrMap = Map[str, str]

// ── Type kind (must precede uses in FieldInfo/VarSlot) ───────────────────────

type TypeKind = enum {
    KVoid
    KInt64
    KBool
    KStr
    KArray
    // The inner type of an optional. KVoid means "unknown" (e.g. a bare
    // `none` literal — its inner is fixed up by the surrounding context).
    KOptional(inner: TypeKind)
    KEnum(idx: int64)
    // type_args carries the concrete type parameters when the struct is a
    // generic instantiation (e.g. `Map[str, str]`). Empty for non-generic
    // structs and for the template struct itself.
    KStruct(idx: int64, type_args: [TypeKind])
    KArrayStruct(elem_idx: int64)
    KArrayEnum(elem_idx: int64)
    KArrayStr
    KInterface(idx: int64)
    // Fallible result `T or Error`. Runtime cell is 16 bytes:
    //   {discriminant: 0=Ok|1=Err, payload: inner value or Error iface ptr}.
    // Variables of this type hold an arena pointer to that cell.
    KResult(inner: TypeKind)
}

// ── Type layout structures ────────────────────────────────────────────────────

// Pre-resolved function signature. Filled in once at registration time
// against the owning module's parser, so call sites never need to look at
// raw type_expr arena ids again. `param_labels[i]` is the call-site
// label for parameter i, or empty string when the parameter is anon.
// `param_names[i]` is the parameter's binding name (used by the LSP to
// render a hover signature with a useful name even for anon params —
// `anon path: str` instead of just `anon: str`).
type SigInfo = struct {
    param_kinds: [TypeKind]
    param_labels: [str]
    param_names: [str]
    return_kind: TypeKind
}

// Name → entry-index map for the parallel `func_names` / `func_labels`
// / `func_sigs` arrays. Keys are function names, values are indices
// into those arrays. Using a primitive int64 value keeps the type
// resolvable during early registration (no forward reference to a
// local struct).
type FuncIdx = Map[str, int64]

type VariantInfo = struct {
    name: str
    discriminant: int64
    field_names: [str]
    field_offsets: [int64]
    field_kinds: [TypeKind]
    // Raw AST type-expression ids for each field, parallel to
    // `field_kinds`. Kept so resolve_variant_field_kinds can re-resolve
    // after all imports are registered — captures the self-recursive
    // case where a variant field refers to its own enum, which isn't
    // in the registry yet at register_enum time.
    field_type_exprs: [int64]
}

type EnumInfo = struct {
    name: str
    variants: [VariantInfo]
    data_width: int64
    // Module prefix used to mangle this enum's method/value labels.
    // Local enums use the current module's prefix; imported ones use
    // the source module's prefix (e.g. "builtins").
    module_prefix: str
    // Parser that owns the variant field type_exprs. Same role as
    // StructInfo.src_p: needed so resolve_variant_field_kinds can swap
    // in the right parser when re-resolving the type ids.
    src_p: parsing.Parser
    // Source path + name-identifier span — see StructInfo.def_path.
    def_path: str
    def_span: ast.Span
}

type FieldInfo = struct {
    name: str
    offset: int64
    kind: TypeKind
    // Raw AST type-expression id for this field. Preserved alongside
    // the resolved `kind` so generic instantiations can re-resolve the
    // expression in a substitution context (e.g. `K` → `str`).
    type_expr: int64
}

// One method on a struct (or interface — `decl_id` is -1 for interfaces,
// which don't carry the source FuncDecl id).
type MethodInfo = struct {
    name: str
    decl_id: int64
    sig: SigInfo
}

type StructInfo = struct {
    name: str
    fields: [FieldInfo]
    methods: [MethodInfo]
    // Side index: method name → position in `methods`. Built alongside
    // it so dispatch lookups don't have to scan ~100 entries for every
    // `obj.method()` call (Codegen has ~100). Iteration sites use
    // `methods` directly.
    method_idx: FuncIdx
    data_width: int64
    // See EnumInfo.module_prefix.
    module_prefix: str
    // Parser that owns this struct's method func_decls. Needed to
    // monomorphise the methods into the consuming module's object file
    // when a type alias instantiates a generic struct.
    src_p: parsing.Parser
    // Template type parameter names (e.g. ["K", "V"] for Map[K, V]).
    // Empty for non-generic structs and for monomorphised instantiations.
    type_param_names: [str]
    // -1 if this struct is the template (or non-generic); otherwise the
    // index of the template struct this entry was monomorphised from.
    template_idx: int64
    // The concrete type arguments used to monomorphise this struct.
    // Empty for templates and non-generic structs.
    template_args: [TypeKind]
    // Source path + name-identifier span for go-to-definition / hover.
    // Empty path for monomorphised instances (the template carries the
    // original location).
    def_path: str
    def_span: ast.Span
}

// Interface metadata. Interface values are an 8-byte pointer to an arena
// cell {data_ptr, vtable_ptr}.
type IfaceInfo = struct {
    name: str
    methods: [MethodInfo]
    module_prefix: str
    def_path: str
    def_span: ast.Span
}

// One method on a primitive type (int64.to_str, str.hash, etc.).
// Held in a single `prim_methods: [PrimMethodInfo]` keyed by (kind, name);
// the lookup is a short linear scan (N ≈ 20), so a map would lose to
// the strcmp / cache-locality of the array.
type PrimMethodInfo = struct {
    kind: TypeKind
    name: str
    label: str
    sig: SigInfo
}

// One function exported by an imported module. `module` is the local
// alias the call site uses (`json` in `json.parse(...)`). `label` is the
// mangled symbol the call lowers to. `def_path`/`def_span` point at the
// function's name in its source file — used by go-to-definition.
type ImportFn = struct {
    module: str
    name: str
    label: str
    sig: SigInfo
    def_path: str
    def_span: ast.Span
}

// ── Per-variable stack slot ───────────────────────────────────────────────────

type VarSlot = struct {
    name: str
    offset: int64
    kind: TypeKind
}

// ── Expression result (what compile_expr returns) ─────────────────────────────

type Val = enum {
    VReg(name: str)
    VImm(value: int64)
    VStack(offset: int64)
    VStrLbl(page: str)
}

// ── Loop label stack entry ────────────────────────────────────────────────────

type LoopLbl = struct {
    start_lbl: str
    end_lbl: str
    incr_lbl: str
}

// A single compiler diagnostic. `path`/`line`/`col`/`message` is the
// structural part — tests assert on these directly. `source_line` and
// `caret` are pre-rendered at report time (tabs already expanded) so
// they can survive past changes to the parser's current source pointer
// and so print_errors stays a straight write-loop.
type Error = struct {
    path: str
    line: int64
    col: int64
    // Column AFTER the last char of the offending token. Same line as
    // `col` unless the token straddles a newline (which we don't try to
    // detect — most diagnostics target identifiers or single tokens).
    // `end_col == col + 1` means we couldn't widen past one character;
    // the LSP server still shows a squiggly, just narrower.
    end_col: int64
    message: str
    source_line: str
    caret: str

    func to_str(self) -> str {
        return f"{self.path}:{self.line.to_str()}:{self.col.to_str()}: {self.message}"
    }
}

// ── Codegen struct ────────────────────────────────────────────────────────────

type Codegen = struct {
    p: parsing.Parser
    path_prefix: str

    enums: [EnumInfo]
    structs: [StructInfo]
    interfaces: [IfaceInfo]

    // Pending vtables to emit at end of compile_module. Each (s, i) pair
    // means "struct s conforms to interface i and has been observed in an
    // upcast"; we emit one vtable per unique pair.
    vtable_struct_idx: [int64]
    vtable_iface_idx: [int64]
    // Same idea for primitives: each (kind, iface) means "kind conforms
    // to iface and was observed in an upcast". One vtable per unique pair.
    prim_vtable_kinds: [TypeKind]
    prim_vtable_iface_idx: [int64]

    // Type-alias maps: `type X = Y` adds an entry pointing X's name to
    // Y's struct/enum index. find_struct_idx / find_enum_idx consult
    // these before searching the main lists.
    // Name → position in `structs` / `enums` / `interfaces`. Includes
    // alias names (each maps to its target's real index) and generic
    // monomorphisation canonical names. Built alongside the arrays
    // themselves; lookups go through these instead of scanning.
    struct_idx: FuncIdx
    enum_idx: FuncIdx
    iface_idx: FuncIdx

    import_local: [str]
    import_prefix: [str]

    // Functions exported by imported modules. Used to resolve `mod.func()`
    // calls to their exact labels (externs get `_name`, regular functions
    // get `$prefix$name`). `sig` is pre-resolved at registration time.
    import_fns: [ImportFn]

    vars: [VarSlot]
    frame_slots: int64
    ret_lbl: str
    return_kind: TypeKind

    free_regs: [str]

    loop_stack: [LoopLbl]

    str_labels: [str]
    str_values: [str]
    // Map from string value to its already-emitted label, mirroring the
    // parallel str_values / str_labels arrays for O(1) intern lookups.
    interned: StrMap

    label_count: int64

    func_names: [str]
    func_labels: [str]
    // Parallel to func_names: pre-resolved param + return kinds. Empty
    // SigInfo (zero-length param_kinds, .KVoid return_kind) for externs
    // that haven't been registered with full signature info.
    func_sigs: [SigInfo]
    // Parallel to func_names: the source path and span of the function's
    // name identifier in its declaration. Used by go-to-definition.
    // Extern functions, primitives, and other registrations without a
    // user-visible source location get an empty path; the LSP filters
    // those out before responding.
    func_def_paths: [str]
    func_def_spans: [ast.Span]
    // Parallel to func_names: the function's leading `//` doc comment
    // text. Empty for declarations without docs (externs are usually
    // documented, free functions sometimes; methods on structs carry
    // their doc on the FuncDecl itself and are looked up there).
    func_docs: [str]
    // Name → index into the parallel func_* arrays. Replaces what would
    // otherwise be an O(n) linear scan per call-site lookup.
    func_idx: FuncIdx

    // Methods registered against primitive types via stdlib/primitives/
    // modules. Parallel arrays: kind, name, label, sig. Method dispatch
    // on a primitive receiver finds the entry whose kind + name match.
    // Methods on primitive types, one entry per (kind, name). See
    // PrimMethodInfo. Was four parallel arrays.
    prim_methods: [PrimMethodInfo]

    // Active type-parameter substitution. While compiling a specialised
    // method (e.g. Map[str, str].get) `subst_names` holds the template's
    // type-parameter names and `subst_args` the concrete types. `resolve_type`
    // consults these on `.Named` to substitute K→str, V→str, etc. Both
    // are empty outside specialised contexts.
    subst_names: [str]
    subst_args: [TypeKind]

    // User-facing errors accumulated during compile_module. Reported via
    // `report_error` at sites that used to `kod_panic`. Callers check
    // `had_errors()` after compile_module to decide whether to fail the
    // build; the errors themselves are written to stderr at that point.
    errors: [Error]

    // True while compiling the body of a `test "..." { ... }` block. The
    // codegen for `assert` switches on this: inside a test, a failed
    // assertion calls `_kod_test_fail` (flag the test, keep going);
    // outside a test, it calls `_kod_panic` (print + exit 1).
    in_test: bool

    // When true, codegen runs all its checks but skips actually emitting
    // assembly. Used by test_support.try_compile so test code can run
    // typechecking on a source string and inspect errors in-process
    // without polluting stdout with .s output.
    dry_run: bool


    // Accumulate a user-facing error. Unlike `kod_panic`, this does not
    // abort — the rest of the module is still walked so a single run
    // surfaces every error rather than stopping at the first.
    //
    // Formats as `path:L:C: msg`, followed by the offending source line
    // and a caret pointing at the column. Walks the source once per call
    // to compute line, column, and the surrounding line text — cheap
    // enough for the handful of errors we'd ever report in a single
    // compile.
    func report_error(self, anon msg: str, span: ast.Span) -> none {
        let source: str = self.p.source
        let offset: int64 = span.start
        let line: int64 = 1
        let col: int64 = 1
        let line_start: int64 = 0
        let i: int64 = 0
        for i < offset and i < len(source) {
            if source[i] == '\n' {
                line = line + 1
                col = 1
                line_start = i + 1
            } else {
                col = col + 1
            }
            i = i + 1
        }
        let line_end: int64 = line_start
        for line_end < len(source) and source[line_end] != '\n' {
            line_end = line_end + 1
        }
        // Normalise tabs to four spaces in both the source line and the
        // pre-caret indent so the caret aligns visually with the column
        // we report.
        let raw_line: str = source[line_start:line_end]
        let line_text: str = ""
        let li: int64 = 0
        for li < len(raw_line) {
            if raw_line[li] == '\t' {
                line_text = line_text + "    "
            } else {
                line_text = line_text + raw_line[li:li+1]
            }
            li = li + 1
        }
        // Widen the squiggly: if the start offset lands on an identifier
        // char (letter / digit / underscore), scan forward through more
        // identifier chars to get the token's end. Otherwise fall back
        // to a one-character range. Doesn't handle multi-line tokens —
        // those aren't a thing in Kod outside triple-quoted strings,
        // which we don't tend to report errors on anyway.
        let end_col: int64 = col + 1
        if offset < len(source) and ident_char(source[offset]) {
            let scan: int64 = offset
            for scan < len(source) and ident_char(source[scan]) {
                scan = scan + 1
            }
            end_col = col + (scan - offset)
        }
        // Pre-caret indent mirrors the tab expansion: any tab among the
        // bytes before the column counts as four spaces; everything else
        // counts as one. Then `^^^…^` spans the full token width so the
        // squiggly visually covers the offending range rather than
        // pointing at a single column.
        let caret: str = ""
        let s: int64 = 0
        for s < col - 1 {
            if line_start + s < len(source) and source[line_start + s] == '\t' {
                caret = caret + "    "
            } else {
                caret = caret + " "
            }
            s = s + 1
        }
        let span_width: int64 = end_col - col
        if span_width < 1 {
            span_width = 1
        }
        let k: int64 = 0
        for k < span_width {
            caret = caret + "^"
            k = k + 1
        }
        self.errors += [Error(path: self.p.path, :line, :col, :end_col, message: msg, source_line: line_text, :caret)]
    }

    func had_errors(self) -> bool {
        return len(self.errors) > 0
    }

    // Write every accumulated error to stderr. Three lines per error:
    // `path:line:col: message`, the source line, and a caret pointing
    // at the column.
    func print_errors(self) -> none {
        for e in self.errors {
            kod_eprint(f"{e.to_str()}\n{e.source_line}\n{e.caret}")
        }
    }

    // Verify call-site arguments line up with a declared parameter list.
    // `param_labels[i]` is "" for an anon parameter, otherwise the
    // expected label. Reports one error per mismatch and keeps going so
    // a wrong call produces all its errors in a single compile.
    //
    // `skip` is the number of leading param_labels entries to ignore —
    // 1 for method calls (skip self), 0 for free functions.
    func check_call_args(self, anon args: [ast.CallArg], param_labels: [str], skip: int64, call_name: str, call_span: ast.Span) -> none {
        let expected_count: int64 = len(param_labels) - skip
        if len(args) != expected_count {
            self.report_error(f"error: `{call_name}` takes {self.itos(expected_count)} arguments, got {self.itos(len(args))}", span: call_span)
            return none
        }
        let i: int64 = 0
        for i < len(args) {
            let arg = args[i]
            let expected = param_labels[i + skip]
            if len(expected) == 0 {
                if len(arg.label) > 0 {
                    self.report_error(f"error: parameter {self.itos(i)} of `{call_name}` is anon; remove label `{arg.label}`", span: arg.label_span)
                }
            } else {
                if len(arg.label) == 0 {
                    self.report_error(f"error: parameter {self.itos(i)} of `{call_name}` requires label `{expected}` (use `{expected}:` or `:{expected}` shorthand)", span: self.p.expr_spans[arg.value])
                } else if arg.label != expected {
                    self.report_error(f"error: parameter {self.itos(i)} of `{call_name}` expected label `{expected}`, got `{arg.label}`", span: arg.label_span)
                }
            }
            i = i + 1
        }
    }

    // If any arm of a match statement uses NonePat or SomePat, the
    // subject must have an optional type — `none`/`Some` aren't
    // meaningful patterns on a non-optional value. Same intent as
    // the Python typechecker's "Cannot use 'is' on non-optional" rule,
    // since `if x is none {...}` lowers to a MatchStmt.
    func check_match_subject(self, anon subject_id: int64, arms: [int64]) -> none {
        let needs_optional: bool = false
        for arm_id in arms {
            let arm = self.p.match_arms[arm_id]
            let pat = self.p.patterns[arm.pattern]
            if pat is .NonePat {
                needs_optional = true
            }
            if pat is .SomePat(_binding) {
                needs_optional = true
            }
        }
        if needs_optional == false {
            return none
        }
        let subj_kind = self.infer_kind(subject_id)
        let is_optional: bool = false
        if subj_kind is .KOptional(_inner) {
            is_optional = true
        }
        if is_optional == false {
            self.report_error("error: `is` / `match` with none/Some requires an optional value", span: self.p.expr_spans[subject_id])
        }
    }

    // Exhaustiveness check for matches whose subject is an enum,
    // optional, or bool. A wildcard arm satisfies coverage; otherwise
    // every variant (or both `Some` and `none` for optionals, or both
    // `true` and `false` for bool) must appear in at least one arm.
    // Reports one error per uncovered variant so a partial match
    // surfaces every gap in a single pass. Matches on int64 and str
    // require an explicit `else` arm.
    func check_match_exhaustive(self, anon subject_id: int64, pattern_ids: [int64]) -> none {
        let has_wildcard: bool = false
        for pid in pattern_ids {
            if self.p.patterns[pid] is .Wildcard {
                has_wildcard = true
            }
        }
        if has_wildcard {
            return none
        }
        let subj_kind = self.infer_kind(subject_id)
        if subj_kind is .KEnum(enum_idx) {
            let enum_info = self.enums[enum_idx]
            for variant in enum_info.variants {
                let covered: bool = false
                for pid in pattern_ids {
                    match self.p.patterns[pid] {
                        .EnumPat(_enum_name, variant_name, _bindings) -> {
                            if variant_name == variant.name {
                                covered = true
                            }
                        }
                        .ImplicitEnumPat(variant_name, _bindings) -> {
                            if variant_name == variant.name {
                                covered = true
                            }
                        }
                        else none
                    }
                }
                if covered == false {
                    self.report_error(f"error: match on `{enum_info.name}` doesn't cover variant `{variant.name}`", span: self.p.expr_spans[subject_id])
                }
            }
        }
        if subj_kind is .KOptional(_inner) {
            let has_some: bool = false
            let has_none: bool = false
            for pid in pattern_ids {
                let pat = self.p.patterns[pid]
                if pat is .SomePat(_b) {
                    has_some = true
                }
                if pat is .NonePat {
                    has_none = true
                }
            }
            if has_some == false {
                self.report_error("error: match on optional doesn't cover `Some(_)`", span: self.p.expr_spans[subject_id])
            }
            if has_none == false {
                self.report_error("error: match on optional doesn't cover `none`", span: self.p.expr_spans[subject_id])
            }
        }
        if subj_kind is .KBool {
            let has_true: bool = false
            let has_false: bool = false
            for pid in pattern_ids {
                if self.p.patterns[pid] is .BoolPat(value) {
                    if value {
                        has_true = true
                    } else {
                        has_false = true
                    }
                }
            }
            if has_true == false {
                self.report_error("error: match on bool doesn't cover `true`", span: self.p.expr_spans[subject_id])
            }
            if has_false == false {
                self.report_error("error: match on bool doesn't cover `false`", span: self.p.expr_spans[subject_id])
            }
        }
        // int64 and str matches can't be enumerated exhaustively, so
        // we require an `else` catch-all to make the fall-through explicit.
        if subj_kind is .KInt64 {
            self.report_error("error: match on int64 must include an `else` arm", span: self.p.expr_spans[subject_id])
        }
        if subj_kind is .KStr {
            self.report_error("error: match on str must include an `else` arm", span: self.p.expr_spans[subject_id])
        }
    }

    // Check that a function declaration's parameter list places anon
    // parameters before any labeled ones. Reports one error per
    // out-of-order anon param. The implicit `self` receiver of a method
    // doesn't count as a labeled parameter for ordering purposes.
    func check_param_order(self, anon func_decl: ast.FuncDecl, anon name: str) -> none {
        let seen_labeled: bool = false
        for param in func_decl.params {
            if param.name == "self" {
                continue
            }
            if param.anonymous {
                if seen_labeled {
                    self.report_error(f"error: in `{name}`, anon parameter `{param.name}` cannot follow a labeled parameter", span: param.span)
                }
            } else {
                seen_labeled = true
            }
        }
    }


    func itos(self, anon n: int64) -> str {
        return n.to_str()
    }

    // Load an integer constant into a register. ARM64's `mov xN, #imm`
    // accepts only encodings the assembler can prove are 16-bit-immediate
    // shaped (and a few special forms); anything else gets a real
    // assemble-time error. For values outside the safe `mov` range we
    // fall back to `ldr xN, =N`, the GAS pseudo-instruction that parks
    // the constant in a literal pool. Slightly less efficient than the
    // best-case movz/movk sequence but always correct.
    func emit_load_imm(self, anon dest: str, value: int64) -> none {
        if value >= -65535 and value <= 65535 {
            self.emit(f"mov {dest}, #{self.itos(value)}")
        } else {
            self.emit(f"ldr {dest}, ={self.itos(value)}")
        }
    }

    func fresh(self, anon prefix: str) -> str {
        self.label_count = self.label_count + 1
        return f"{prefix}${self.itos(self.label_count)}"
    }

    // Single output gate. In dry-run mode (test_support.try_compile),
    // this becomes a no-op so codegen can run all its checks without
    // polluting stdout with the generated .s.
    func println(self, anon line: str) -> none {
        if self.dry_run {
            return none
        }
        print(line)
    }

    func emit(self, anon line: str) -> none {
        self.println(f"\t{line}")
    }

    func emit_label(self, anon lbl: str) -> none {
        self.println(f"{lbl}:")
    }

    func emit_globl(self, anon lbl: str) -> none {
        self.println(f"\t.globl {lbl}")
    }

    func emit_asciz(self, anon value: str) -> none {
        if self.dry_run {
            return none
        }
        putchar(9)   // \t
        let i = 0
        let prefix = ".asciz "
        for i < len(prefix) {
            putchar(prefix[i])
            i = i + 1
        }
        putchar('"')
        let j = 0
        for j < len(value) {
            let char = value[j]
            let escaped = false
            if char == '\n' {
                putchar('\\')
                putchar('n')
                escaped = true
            }
            if char == '\t' {
                putchar('\\')
                putchar('t')
                escaped = true
            }
            if char == '\r' {
                putchar('\\')
                putchar('r')
                escaped = true
            }
            if char == '\\' {
                putchar('\\')
                putchar('\\')
                escaped = true
            }
            if char == '"' {
                putchar('\\')
                putchar('"')
                escaped = true
            }
            if escaped == false {
                putchar(char)
            }
            j = j + 1
        }
        putchar('"')
        putchar(10)
    }


    func alloc_reg(self) -> str {
        let n = len(self.free_regs)
        let reg = self.free_regs[-1]
        let new_regs: [str] = []
        let i = 0
        for i < n - 1 {
            new_regs += [self.free_regs[i]]
            i = i + 1
        }
        self.free_regs = new_regs
        return reg
    }

    func free_reg(self, anon reg: str) -> none {
        // Only return pool registers (x8-x15, x19-x27) to the free list.
        // Argument registers (x0-x7) hold call results/args and must not be pooled.
        if reg == "x0" or reg == "x1" or reg == "x2" or reg == "x3" or reg == "x4" or reg == "x5" or reg == "x6" or reg == "x7" {
            return
        }
        self.free_regs += [reg]
    }

    func free_val(self, anon val: Val) -> none {
        if val is .VReg(name) {
            self.free_reg(name)
        }
    }


    func load(self, anon val: Val) -> str {
        match val {
            .VReg(name) -> return name
            .VImm(value) -> {
                let reg = self.alloc_reg()
                self.emit_load_imm(reg, :value)
                return reg
            }
            .VStack(offset) -> {
                let reg = self.alloc_reg()
                self.emit_ldr(offset, :reg)
                return reg
            }
            .VStrLbl(page) -> {
                let reg = self.alloc_reg()
                self.emit(f"adrp {reg}, {page}@PAGE")
                self.emit(f"add {reg}, {reg}, {page}@PAGEOFF")
                return reg
            }
        }
    }

    func mov_to(self, anon val: Val, dest: str) -> str {
        match val {
            .VReg(name) -> {
                if name != dest {
                    self.emit(f"mov {dest}, {name}")
                    self.free_reg(name)
                }
                return dest
            }
            .VImm(value) -> {
                self.emit_load_imm(dest, :value)
                return dest
            }
            .VStack(offset) -> {
                self.emit_ldr(offset, reg: dest)
                return dest
            }
            .VStrLbl(page) -> {
                self.emit(f"adrp {dest}, {page}@PAGE")
                self.emit(f"add {dest}, {dest}, {page}@PAGEOFF")
                return dest
            }
        }
    }


    func intern_str(self, anon value: str) -> str {
        // Bind `interned` to a local so method calls go through a single
        // dotted callee (`m.get(...)`) — the codegen does not currently
        // support three-part dotted call syntax like `self.interned.get`.
        // Map is a reference type so `m` shares state with `self.interned`.
        let m = self.interned
        if m.get(value) is Some(existing) {
            return existing
        }
        let lbl = self.fresh("Lstr")
        m.set(value, lbl)
        self.str_labels += [lbl]
        self.str_values += [value]
        return lbl
    }


    func alloc_var(self, name: str, kind: TypeKind) -> int64 {
        self.frame_slots = self.frame_slots + 1
        let offset = 0 - self.frame_slots * 8
        self.vars += [VarSlot(:name, :offset, :kind)]
        return offset
    }

    func find_var_offset(self, anon name: str) -> int64 {
        let i = len(self.vars) - 1
        for i >= 0 {
            if self.vars[i].name == name {
                return self.vars[i].offset
            }
            i = i - 1
        }
        return -9999
    }

    func find_var_kind(self, anon name: str) -> TypeKind {
        let i = len(self.vars) - 1
        for i >= 0 {
            if self.vars[i].name == name {
                return self.vars[i].kind
            }
            i = i - 1
        }
        return .KVoid
    }

    func var_declared(self, anon name: str) -> bool {
        let i = 0
        for i < len(self.vars) {
            if self.vars[i].name == name {
                return true
            }
            i = i + 1
        }
        return false
    }


    func find_enum_idx(self, anon name: str) -> int64 {
        if self.enum_idx.get(name) is Some(i) {
            return i
        }
        return -1
    }

    func find_struct_idx(self, anon name: str) -> int64 {
        if self.struct_idx.get(name) is Some(i) {
            return i
        }
        return -1
    }

    func find_iface_idx(self, anon name: str) -> int64 {
        if self.iface_idx.get(name) is Some(i) {
            return i
        }
        return -1
    }

    // The label of the vtable for a struct acting as an interface.
    func vtable_label(self, anon struct_idx: int64, anon iface_idx: int64) -> str {
        let struct_info = self.structs[struct_idx]
        let iface_info = self.interfaces[iface_idx]
        return f"${iface_info.module_prefix}${iface_info.name}$for${struct_info.module_prefix}${struct_info.name}$vtable"
    }

    // Register a (struct, interface) pair so its vtable is emitted at the
    // end of compile_module. Idempotent: subsequent calls for the same
    // pair do nothing. Returns the vtable label.
    func register_vtable(self, anon struct_idx: int64, anon iface_idx: int64) -> str {
        let k = 0
        for k < len(self.vtable_struct_idx) {
            if self.vtable_struct_idx[k] == struct_idx and self.vtable_iface_idx[k] == iface_idx {
                return self.vtable_label(struct_idx, iface_idx)
            }
            k = k + 1
        }
        self.vtable_struct_idx += [struct_idx]
        self.vtable_iface_idx += [iface_idx]
        return self.vtable_label(struct_idx, iface_idx)
    }

    // Hardcoded module prefix for each primitive type. Used to compose
    // primitive vtable labels and to mangle primitive method symbols.
    func prim_module_prefix(self, kind: TypeKind) -> str {
        match kind {
            .KInt64 -> return "primitives$int64"
            .KStr -> return "primitives$str"
            .KBool -> return "primitives$bool"
            else return ""
        }
    }

    // The label of the vtable for a primitive type acting as an interface.
    func prim_vtable_label(self, anon iface_idx: int64, kind: TypeKind) -> str {
        let iface_info = self.interfaces[iface_idx]
        let prim_prefix = self.prim_module_prefix(:kind)
        return f"${iface_info.module_prefix}${iface_info.name}$for${prim_prefix}$vtable"
    }

    // Register a (primitive_kind, interface) pair so its vtable is emitted
    // at the end of compile_module. Returns the vtable label.
    func register_prim_vtable(self, anon iface_idx: int64, kind: TypeKind) -> str {
        let k = 0
        for k < len(self.prim_vtable_kinds) {
            if self.prim_vtable_iface_idx[k] == iface_idx {
                let stored = self.prim_vtable_kinds[k]
                let matches = false
                match kind {
                    .KInt64 -> if stored is .KInt64 { matches = true }
                    .KStr -> if stored is .KStr { matches = true }
                    .KBool -> if stored is .KBool { matches = true }
                    else none
                }
                if matches {
                    return self.prim_vtable_label(iface_idx, :kind)
                }
            }
            k = k + 1
        }
        self.prim_vtable_kinds += [kind]
        self.prim_vtable_iface_idx += [iface_idx]
        return self.prim_vtable_label(iface_idx, :kind)
    }

    // Find the cached signature for a function by name. Returns an empty
    // SigInfo (no params, void return) if the name isn't registered or
    // wasn't resolved with full signature info.
    // Return the closest name in `candidates` to `typo` within
    // `max_distance` Levenshtein edits, or "" if none qualifies.
    // Used to attach "did you mean X?" hints to unknown-identifier
    // diagnostics — small candidate lists (a few hundred entries at
    // most), tiny inputs (identifier-length), so the O(n*m) DP cost
    // is irrelevant for the handful of errors a single compile reports.
    func find_closest(self, anon typo: str, candidates: [str], max_distance: int64) -> str {
        let best: str = ""
        let best_dist: int64 = max_distance + 1
        let i: int64 = 0
        for i < len(candidates) {
            let d: int64 = typo.distance(candidates[i])
            if d < best_dist {
                best_dist = d
                best = candidates[i]
            }
            i = i + 1
        }
        return best
    }

    // Build an `error: <msg>. did you mean `<X>`?` message when a
    // near-match exists in `candidates`, or just `error: <msg>` when
    // it doesn't. Centralises the suggestion-or-not branch so each
    // call site stays a one-liner.
    func with_suggestion(self, anon msg: str, typo: str, candidates: [str]) -> str {
        let s: str = self.find_closest(typo, :candidates, max_distance: 2)
        if len(s) > 0 {
            return f"{msg}. did you mean `{s}`?"
        }
        return msg
    }

    func find_func_sig(self, anon name: str) -> SigInfo {
        let m = self.func_idx
        if m.get(name) is Some(idx) {
            return self.func_sigs[idx]
        }
        let empty_kinds: [TypeKind] = []
        let empty_strs: [str] = []
        return SigInfo(param_kinds: empty_kinds, param_labels: empty_strs, param_names: empty_strs, return_kind: .KVoid)
    }

    func find_import_fn_sig(self, anon local_mod: str, anon name: str) -> SigInfo {
        let i = 0
        for i < len(self.import_fns) {
            let f = self.import_fns[i]
            if f.module == local_mod and f.name == name {
                return f.sig
            }
            i = i + 1
        }
        let empty_kinds: [TypeKind] = []
        let empty_strs: [str] = []
        return SigInfo(param_kinds: empty_kinds, param_labels: empty_strs, param_names: empty_strs, return_kind: .KVoid)
    }

    func find_enum_with_variant(self, anon variant_name: str) -> int64 {
        let i = 0
        for i < len(self.enums) {
            let j = 0
            for j < len(self.enums[i].variants) {
                if self.enums[i].variants[j].name == variant_name {
                    return i
                }
                j = j + 1
            }
            i = i + 1
        }
        return -1
    }

    func find_variant_idx(self, anon variant_name: str, enum_idx: int64) -> int64 {
        let j = 0
        for j < len(self.enums[enum_idx].variants) {
            if self.enums[enum_idx].variants[j].name == variant_name {
                return j
            }
            j = j + 1
        }
        return -1
    }

    func find_field_offset(self, anon field_name: str, struct_idx: int64) -> int64 {
        let j = 0
        for j < len(self.structs[struct_idx].fields) {
            if self.structs[struct_idx].fields[j].name == field_name {
                return self.structs[struct_idx].fields[j].offset
            }
            j = j + 1
        }
        return 0
    }

    func has_field(self, anon field_name: str, struct_idx: int64) -> bool {
        for f in self.structs[struct_idx].fields {
            if f.name == field_name {
                return true
            }
        }
        return false
    }


    // Canonical, label-safe string representation of a TypeKind. Used to
    // build mangled names for monomorphised structs and their methods so
    // that e.g. Map[str, str] becomes the struct/label suffix `Map$str$str`.
    // Human-readable rendering of a TypeKind for user-facing output
    // (hover, error messages). Inverse of how the source-side syntax
    // declares the type — `[str]` for KArrayStr, `T?` for KOptional, etc.
    // Distinct from `canonical_kind_name`, which uses `$`-separated
    // mangled forms for assembly symbol names.
    func kind_display(self, anon kind: TypeKind) -> str {
        match kind {
            .KVoid -> return "none"
            .KInt64 -> return "int64"
            .KBool -> return "bool"
            .KStr -> return "str"
            .KArray -> return "[?]"
            .KArrayStr -> return "[str]"
            .KArrayStruct(elem_idx) -> return f"[{self.structs[elem_idx].name}]"
            .KArrayEnum(elem_idx) -> return f"[{self.enums[elem_idx].name}]"
            .KEnum(idx) -> return self.enums[idx].name
            .KInterface(idx) -> return self.interfaces[idx].name
            .KOptional(inner) -> return f"{self.kind_display(inner)}?"
            .KResult(inner) -> return f"{self.kind_display(inner)} or Error"
            .KStruct(idx, type_args) -> {
                let base: str = self.structs[idx].name
                if len(type_args) == 0 {
                    return base
                }
                let result: str = f"{base}["
                let i: int64 = 0
                for i < len(type_args) {
                    if i > 0 {
                        result = result + ", "
                    }
                    result = result + self.kind_display(type_args[i])
                    i = i + 1
                }
                return f"{result}]"
            }
        }
    }

    // `type Name = struct { field: kind, ... }` — for hover on a
    // struct type name. Methods are intentionally elided to keep the
    // tooltip short; users can jump to the source for the full body.
    func struct_display(self, anon idx: int64) -> str {
        let s: StructInfo = self.structs[idx]
        // Concatenate the `{` rather than embed in an f-string —
        // Kod's f-string parser has no brace escape today.
        let result: str = f"type {s.name} = struct " + "{"
        let i: int64 = 0
        for i < len(s.fields) {
            if i == 0 {
                result = result + " "
            } else {
                result = result + ", "
            }
            result = result + f"{s.fields[i].name}: {self.kind_display(s.fields[i].kind)}"
            i = i + 1
        }
        if len(s.fields) > 0 {
            result = result + " "
        }
        return result + "}"
    }

    // `type Name = enum { Variant, Variant(field: kind), ... }`.
    func enum_display(self, anon idx: int64) -> str {
        let e: EnumInfo = self.enums[idx]
        let result: str = f"type {e.name} = enum " + "{"
        let i: int64 = 0
        for i < len(e.variants) {
            let v: VariantInfo = e.variants[i]
            if i == 0 {
                result = result + " "
            } else {
                result = result + ", "
            }
            result = result + v.name
            if len(v.field_names) > 0 {
                result = result + "("
                let j: int64 = 0
                for j < len(v.field_names) {
                    if j > 0 {
                        result = result + ", "
                    }
                    result = result + f"{v.field_names[j]}: {self.kind_display(v.field_kinds[j])}"
                    j = j + 1
                }
                result = result + ")"
            }
            i = i + 1
        }
        if len(e.variants) > 0 {
            result = result + " "
        }
        return result + "}"
    }

    // `func name(label: T, anon name: T, ...) -> Ret` — for hover.
    // Mirrors the Kod source syntax so an `anon` param shows its
    // binding name (`anon path: str`), not just its position.
    func func_signature_display(self, name: str, sig: SigInfo) -> str {
        let result: str = f"func {name}("
        let i: int64 = 0
        for i < len(sig.param_labels) {
            if i > 0 {
                result = result + ", "
            }
            let label: str = sig.param_labels[i]
            let pname: str = ""
            if i < len(sig.param_names) {
                pname = sig.param_names[i]
            }
            if len(label) == 0 {
                if len(pname) > 0 {
                    result = result + f"anon {pname}: {self.kind_display(sig.param_kinds[i])}"
                } else {
                    result = result + f"anon: {self.kind_display(sig.param_kinds[i])}"
                }
            } else {
                result = result + f"{label}: {self.kind_display(sig.param_kinds[i])}"
            }
            i = i + 1
        }
        return f"{result}) -> {self.kind_display(sig.return_kind)}"
    }

    func canonical_kind_name(self, anon kind: TypeKind) -> str {
        match kind {
            .KVoid -> return "void"
            .KInt64 -> return "int64"
            .KBool -> return "bool"
            .KStr -> return "str"
            .KArray -> return "arr"
            .KArrayStr -> return "arrstr"
            .KArrayStruct(elem_idx) -> return f"arrstruct${self.structs[elem_idx].name}"
            .KArrayEnum(elem_idx) -> return f"arrenum${self.enums[elem_idx].name}"
            .KEnum(idx) -> return self.enums[idx].name
            .KInterface(idx) -> return self.interfaces[idx].name
            .KOptional(inner) -> return f"opt${self.canonical_kind_name(inner)}"
            .KResult(inner) -> return f"res${self.canonical_kind_name(inner)}"
            .KStruct(idx, type_args) -> {
                let name = self.structs[idx].name
                for ta in type_args {
                    name = f"{name}${self.canonical_kind_name(ta)}"
                }
                return name
            }
        }
    }

    // Return the struct_idx for a concrete instantiation of `template_idx`
    // with `type_args`, creating a new monomorphised struct entry if it
    // doesn't already exist. The new entry shares the template's method
    // func_decls but has substituted field kinds and method sigs.
    func instantiate_struct(self, anon type_args: [TypeKind], template_idx: int64) -> int64 {
        let template = self.structs[template_idx]
        let canonical = template.name
        for ta in type_args {
            canonical = f"{canonical}${self.canonical_kind_name(ta)}"
        }
        let existing = self.find_struct_idx(canonical)
        if existing >= 0 {
            return existing
        }
        let saved_names = self.subst_names
        let saved_args = self.subst_args
        let saved_p = self.p
        self.subst_names = template.type_param_names
        self.subst_args = type_args
        self.p = template.src_p
        let cloned_fields: [FieldInfo] = []
        for field in template.fields {
            let new_kind = self.resolve_type(field.type_expr)
            cloned_fields += [FieldInfo(name: field.name, offset: field.offset, kind: new_kind, type_expr: field.type_expr)]
        }
        // Re-resolve each method's sig with the new substitution context;
        // names + decl_ids stay the same as the template, so we build
        // fresh MethodInfo entries that copy those across.
        let cloned_methods: [MethodInfo] = []
        for m in template.methods {
            let fd = template.src_p.func_decls[m.decl_id]
            let pk: [TypeKind] = []
            let pl: [str] = []
            let pn: [str] = []
            for param in fd.params {
                pk += [self.resolve_type(param.typ)]
                if param.anonymous {
                    pl += [""]
                } else {
                    pl += [param.label]
                }
                pn += [param.name]
            }
            let rk = self.resolve_type(fd.return_typ)
            let sig: SigInfo = SigInfo(param_kinds: pk, param_labels: pl, param_names: pn, return_kind: rk)
            cloned_methods += [MethodInfo(name: m.name, decl_id: m.decl_id, :sig)]
        }
        self.p = saved_p
        self.subst_names = saved_names
        self.subst_args = saved_args
        let empty_params: [str] = []
        // Monomorphised instance: method names + positions match the template,
        // so share its name → index map directly.
        self.structs += [StructInfo(name: canonical, fields: cloned_fields, methods: cloned_methods, method_idx: template.method_idx, data_width: template.data_width, module_prefix: self.path_prefix, src_p: template.src_p, type_param_names: empty_params, :template_idx, template_args: type_args, def_path: "", def_span: ast.Span(start: 0))]
        let new_idx: int64 = len(self.structs) - 1
        self.struct_idx.set(canonical, new_idx)
        return new_idx
    }


    func resolve_type(self, anon type_id: int64) -> TypeKind {
        if type_id == 0 {
            return .KVoid
        }
        match self.p.type_exprs[type_id] {
            .Named(name) -> {
                // If we are inside a specialised method, type-parameter
                // names (e.g. K, V) map to concrete TypeKinds via the
                // active substitution context.
                let si = 0
                for si < len(self.subst_names) {
                    if self.subst_names[si] == name {
                        return self.subst_args[si]
                    }
                    si = si + 1
                }
                if name == "int64" {
                    return .KInt64
                }
                if name == "bool" {
                    return .KBool
                }
                if name == "str" {
                    return .KStr
                }
                if name == "none" {
                    return .KVoid
                }
                let enum_idx = self.find_enum_idx(name)
                if enum_idx >= 0 {
                    return .KEnum(idx: enum_idx)
                }
                let struct_idx = self.find_struct_idx(name)
                if struct_idx >= 0 {
                    return .KStruct(idx: struct_idx, type_args: [])
                }
                let iface_idx = self.find_iface_idx(name)
                if iface_idx >= 0 {
                    return .KInterface(idx: iface_idx)
                }
                return .KInt64
            }
            .Array(inner) -> {
                let ek = self.resolve_type(inner)
                match ek {
                    .KStruct(struct_idx, _struct_type_args) -> return .KArrayStruct(elem_idx: struct_idx)
                    .KEnum(enum_idx) -> return .KArrayEnum(elem_idx: enum_idx)
                    .KStr -> return .KArrayStr
                    else return .KArray
                }
            }
            .Optional(inner) -> return .KOptional(inner: self.resolve_type(inner))
            .Throws(inner) -> return .KResult(inner: self.resolve_type(inner))
            .Generic(name, args) -> {
                // Generic instantiation. Monomorphise the template struct
                // into a fresh concrete entry (Map[str, str] → struct
                // `Map$str$str`) so all downstream lookups read substituted
                // types directly from the new entry.
                let struct_idx = self.find_struct_idx(name)
                if struct_idx >= 0 {
                    let resolved: [TypeKind] = []
                    for arg in args {
                        resolved += [self.resolve_type(arg)]
                    }
                    let inst_idx = self.instantiate_struct(resolved, template_idx: struct_idx)
                    return .KStruct(idx: inst_idx, type_args: [])
                }
                let enum_idx = self.find_enum_idx(name)
                if enum_idx >= 0 {
                    return .KEnum(idx: enum_idx)
                }
                return .KInt64
            }
        }
    }


    // Resolve a FuncDecl's params and return type into a SigInfo, using p
    // as the owning parser (the type_expr arena ids in the FuncDecl point
    // into p.type_exprs). Type *names* are still looked up in self's own
    // registered tables — they must have been registered via
    // register_module_types beforehand.
    func resolve_sig(self, anon func_decl: ast.FuncDecl, p: parsing.Parser) -> SigInfo {
        let saved_p = self.p
        self.p = p
        let param_kinds: [TypeKind] = []
        let param_labels: [str] = []
        let param_names: [str] = []
        for param in func_decl.params {
            param_kinds += [self.resolve_type(param.typ)]
            if param.anonymous {
                param_labels += [""]
            } else {
                param_labels += [param.label]
            }
            param_names += [param.name]
        }
        let return_kind = self.resolve_type(func_decl.return_typ)
        self.p = saved_p
        return SigInfo(:param_kinds, :param_labels, :param_names, :return_kind)
    }

    // Same as resolve_sig but for an Extern decl, whose params/return_typ
    // are inlined in the Decl variant rather than wrapped in a FuncDecl.
    func resolve_extern_sig(self, anon params: [ast.Param], return_typ: int64, p: parsing.Parser) -> SigInfo {
        let saved_p = self.p
        self.p = p
        let param_kinds: [TypeKind] = []
        let param_labels: [str] = []
        let param_names: [str] = []
        for param in params {
            param_kinds += [self.resolve_type(param.typ)]
            if param.anonymous {
                param_labels += [""]
            } else {
                param_labels += [param.label]
            }
            param_names += [param.name]
        }
        let return_kind = self.resolve_type(return_typ)
        self.p = saved_p
        return SigInfo(:param_kinds, :param_labels, :param_names, :return_kind)
    }

    func func_label(self, anon name: str) -> str {
        let m = self.func_idx
        if m.get(name) is Some(idx) {
            return self.func_labels[idx]
        }
        return f"$builtins${name}"
    }

    func import_func_label(self, anon func_name: str, local_mod: str) -> str {
        // Prefer the exact label recorded by register_import_module
        // (extern names map to _name, regular functions map to $prefix$name).
        let j = 0
        for j < len(self.import_fns) {
            let f = self.import_fns[j]
            if f.module == local_mod and f.name == func_name {
                return f.label
            }
            j = j + 1
        }
        // Fallback: synthesize a label from the registered prefix.
        let i = 0
        for i < len(self.import_local) {
            if self.import_local[i] == local_mod {
                return f"${self.import_prefix[i]}${func_name}"
            }
            i = i + 1
        }
        return f"_{func_name}"
    }


    func emit_ldr(self, anon offset: int64, reg: str) -> none {
        if offset >= 0 {
            self.emit(f"ldr {reg}, [fp]")
            return
        }
        if offset >= -256 {
            self.emit(f"ldr {reg}, [fp, #{self.itos(offset)}]")
            return
        }
        // Out of immediate range — materialise the negative offset first.
        self.emit_load_imm("x16", value: 0 - offset)
        self.emit(f"sub x16, fp, x16")
        self.emit(f"ldr {reg}, [x16]")
    }

    func emit_str(self, anon offset: int64, reg: str) -> none {
        if offset >= 0 {
            self.emit(f"str {reg}, [fp]")
            return
        }
        if offset >= -256 {
            self.emit(f"str {reg}, [fp, #{self.itos(offset)}]")
            return
        }
        self.emit_load_imm("x16", value: 0 - offset)
        self.emit(f"sub x16, fp, x16")
        self.emit(f"str {reg}, [x16]")
    }


    func register_enum(self, anon decl: ast.Decl, prefix: str, p: parsing.Parser) -> none {
        match decl {
            .Enum(name, name_span, variants) -> {
                let saved_p = self.p
                self.p = p
                let variant_infos: [VariantInfo] = []
                let disc = 0
                let max_payload = 0
                for variant in variants {
                    let field_names: [str] = []
                    let field_offsets: [int64] = []
                    let field_kinds: [TypeKind] = []
                    let field_type_exprs: [int64] = []
                    let j = 0
                    for j < len(variant.fields) {
                        field_names += [variant.fields[j].name]
                        field_offsets += [j * 8]
                        field_kinds += [self.resolve_type(variant.fields[j].typ)]
                        field_type_exprs += [variant.fields[j].typ]
                        j = j + 1
                    }
                    let payload = len(variant.fields) * 8
                    if payload > max_payload {
                        max_payload = payload
                    }
                    variant_infos += [VariantInfo(name: variant.name, discriminant: disc, :field_names, :field_offsets, :field_kinds, :field_type_exprs)]
                    disc = disc + 1
                }
                self.p = saved_p
                let data_width = 8 + max_payload
                self.enums += [EnumInfo(:name, variants: variant_infos, :data_width, module_prefix: prefix, src_p: p, def_path: p.path, def_span: name_span)]
                self.enum_idx.set(name, len(self.enums) - 1)
            }
            else none
        }
    }

    func register_struct(self, anon decl: ast.Decl, prefix: str, p: parsing.Parser) -> none {
        match decl {
            .Struct(name, name_span, type_params, fields, methods) -> {
                let field_infos: [FieldInfo] = []
                let offset = 0
                // Temporarily swap parser so resolve_type reads field type
                // expressions from p (the source module's parser), not self.p.
                let saved_p = self.p
                self.p = p
                for field in fields {
                    let field_kind = self.resolve_type(field.typ)
                    field_infos += [FieldInfo(name: field.name, :offset, kind: field_kind, type_expr: field.typ)]
                    offset = offset + 8
                }
                // Restore parser before resolve_sig (which swaps to p
                // internally). One pass: append the fully-built MethodInfo
                // and record its position in method_idx in the same step.
                self.p = saved_p
                let method_idx: FuncIdx = FuncIdx(keys: [], values: [], indices: [])
                let method_infos: [MethodInfo] = []
                let mi: int64 = 0
                for method_id in methods {
                    let func_decl = p.func_decls[method_id]
                    let sig = self.resolve_sig(func_decl, :p)
                    method_infos += [MethodInfo(name: func_decl.name, decl_id: method_id, :sig)]
                    method_idx.set(func_decl.name, mi)
                    mi = mi + 1
                }
                let no_template_args: [TypeKind] = []
                self.structs += [StructInfo(:name, fields: field_infos, methods: method_infos, :method_idx, data_width: offset, module_prefix: prefix, src_p: p, type_param_names: type_params, template_idx: -1, template_args: no_template_args, def_path: p.path, def_span: name_span)]
                self.struct_idx.set(name, len(self.structs) - 1)
            }
            else none
        }
    }

    // First pass: register interface NAME so it's findable by name during
    // struct method sig resolution. Method sigs are left empty for now; a
    // second pass (resolve_interface_methods) fills them in once all types
    // are registered.
    func register_interface(self, anon decl: ast.Decl, prefix: str, p: parsing.Parser) -> none {
        match decl {
            .Interface(name, name_span, methods) -> {
                let empty_kinds: [TypeKind] = []
                let empty_strs: [str] = []
                let empty_sig: SigInfo = SigInfo(param_kinds: empty_kinds, param_labels: empty_strs, param_names: empty_strs, return_kind: .KVoid)
                let method_infos: [MethodInfo] = []
                for method_id in methods {
                    let func_decl = p.func_decls[method_id]
                    // decl_id is -1 for interface methods (they don't carry
                    // a concrete FuncDecl id beyond the parse). Sig is left
                    // empty here; resolve_interface_methods fills it in a
                    // second pass once all types are registered.
                    method_infos += [MethodInfo(name: func_decl.name, decl_id: -1, sig: empty_sig)]
                }
                self.interfaces += [IfaceInfo(:name, methods: method_infos, module_prefix: prefix, def_path: p.path, def_span: name_span)]
                self.iface_idx.set(name, len(self.interfaces) - 1)
            }
            else none
        }
    }

    // Second pass: resolve method signatures for an interface declaration
    // once all types are registered, then write the fully-populated
    // MethodInfo array onto the existing IfaceInfo.
    func resolve_interface_methods(self, anon decl: ast.Decl, p: parsing.Parser) -> none {
        match decl {
            .Interface(name, name_span, methods) -> {
                let iface_idx = self.find_iface_idx(name)
                if iface_idx >= 0 {
                    let new_methods: [MethodInfo] = []
                    for method_id in methods {
                        let func_decl = p.func_decls[method_id]
                        let sig = self.resolve_sig(func_decl, :p)
                        new_methods += [MethodInfo(name: func_decl.name, decl_id: -1, :sig)]
                    }
                    self.interfaces[iface_idx].methods = new_methods
                }
            }
            else none
        }
    }

    // Register all struct and enum declarations from another module under the
    // given prefix (e.g. "builtins"). Doesn't emit any code for them — just
    // makes their names and methods visible for label resolution. Interfaces
    // are registered before structs so struct method signatures can reference
    // interface types.
    // Register a `type Name = OtherType` alias. The target type must
    // already be known (typically an import or an earlier enum). `p`
    // is the parser that owns the type_expr arena entry for `target`;
    // we swap self.p so resolve_type indexes into the right arena.
    func register_type_alias(self, anon decl: ast.Decl, p: parsing.Parser) -> none {
        match decl {
            .TypeAlias(name, target) -> {
                let saved_p = self.p
                self.p = p
                let kind = self.resolve_type(target)
                self.p = saved_p
                match kind {
                    .KStruct(idx, _struct_type_args) -> {
                        self.struct_idx.set(name, idx)
                    }
                    .KEnum(idx) -> {
                        self.enum_idx.set(name, idx)
                    }
                    else none
                }
            }
            else none
        }
    }

    func register_module_types(self, anon module: ast.Module, prefix: str, p: parsing.Parser) -> none {
        // Phase 1: register interface NAMES (with empty sigs) so they're
        // findable when struct method signatures reference them.
        for decl in module.decls {
            self.register_interface(decl, :prefix, :p)
        }
        // Phase 2: register type aliases targeting *already-registered*
        // types (e.g. `type StrMap = Map[str, str]` where Map came from
        // an imported module). Aliases targeting local enums or structs
        // would also work as long as they appear after the target in the
        // source, but in practice this pass handles import aliases.
        for decl in module.decls {
            self.register_type_alias(decl, :p)
        }
        // Phase 3: register enums and structs in source order. Order
        // matters here: ast.kod's `Decl` enum has a variant with a
        // `[StructField]` payload, and StructField is a struct defined
        // earlier — so we need the struct registered before the enum
        // that references it. Interleaving in source order preserves
        // that natural dependency.
        for decl in module.decls {
            self.register_enum(decl, :prefix, :p)
            self.register_struct(decl, :prefix, :p)
        }
        // Phase 4: now that structs are also registered, resolve the
        // interface method signatures (which may reference struct types).
        for decl in module.decls {
            self.resolve_interface_methods(decl, :p)
        }
    }

    // Re-resolve every registered struct's field kinds. Used after all
    // imported modules have been registered to fix up references to
    // types defined in modules that hadn't yet been loaded at the time
    // the holding struct was first registered. Without this, a field
    // like `[ast.FuncDecl]` ends up as a plain KArray (no element kind)
    // when `parsing` is registered before `ast`, and downstream chained
    // access like `p.func_decls[0].name` mis-infers as KInt64.
    func resolve_field_kinds(self) -> none {
        let i: int64 = 0
        for i < len(self.structs) {
            let s: StructInfo = self.structs[i]
            let saved_p = self.p
            let saved_names = self.subst_names
            let saved_args = self.subst_args
            self.p = s.src_p
            // Monomorphised structs need the template's substitution context
            // restored before re-resolving — otherwise a field like `[K]`
            // sees K as an unbound name, falls back to KArray (no element
            // kind), and downstream `self.keys[i]` mis-infers as KInt64.
            // That in turn makes `K == K` inside the method lower to a
            // bit-identical pointer compare instead of the kind-specific
            // path (e.g. `$primitives$str$equals` for K = str).
            if s.template_idx >= 0 {
                let template = self.structs[s.template_idx]
                self.subst_names = template.type_param_names
                self.subst_args = s.template_args
            }
            let new_fields: [FieldInfo] = []
            for f in s.fields {
                let new_kind: TypeKind = self.resolve_type(f.type_expr)
                new_fields += [FieldInfo(name: f.name, offset: f.offset, kind: new_kind, type_expr: f.type_expr)]
            }
            self.structs[i].fields = new_fields
            self.p = saved_p
            self.subst_names = saved_names
            self.subst_args = saved_args
            i = i + 1
        }
    }

    // Mirror of resolve_field_kinds for enum variant fields. Self-
    // recursive enums (e.g. `Value = enum { Array(items: [Value]) }`)
    // capture plain KArray at register_enum time because Value isn't
    // in self.enums yet. Re-resolving once every type is registered
    // pins the right kind (KArrayEnum) so downstream `items[i]` infers
    // correctly instead of falling back to KInt64.
    func resolve_variant_field_kinds(self) -> none {
        let i: int64 = 0
        for i < len(self.enums) {
            let saved_p = self.p
            self.p = self.enums[i].src_p
            let new_variants: [VariantInfo] = []
            for v in self.enums[i].variants {
                let new_kinds: [TypeKind] = []
                let j: int64 = 0
                for j < len(v.field_type_exprs) {
                    new_kinds += [self.resolve_type(v.field_type_exprs[j])]
                    j = j + 1
                }
                new_variants += [VariantInfo(name: v.name, discriminant: v.discriminant, field_names: v.field_names, field_offsets: v.field_offsets, field_kinds: new_kinds, field_type_exprs: v.field_type_exprs)]
            }
            self.enums[i].variants = new_variants
            self.p = saved_p
            i = i + 1
        }
    }


    // Walk an expression and allocate stack slots for any bindings that
    // appear in nested match expressions. Without this, 'Some(x) -> x'
    // inside a match expression returns 'x' as an unknown var.
    func collect_expr_vars(self, anon expr_id: int64) -> none {
        match self.p.exprs[expr_id] {
            .Binary(lhs, op, rhs) -> {
                self.collect_expr_vars(lhs)
                self.collect_expr_vars(rhs)
            }
            .Call(callee, args) -> {
                self.collect_expr_vars(callee)
                let i = 0
                for i < len(args) {
                    self.collect_expr_vars(args[i].value)
                    i = i + 1
                }
            }
            .ArrayLit(elements) -> {
                let i = 0
                for i < len(elements) {
                    self.collect_expr_vars(elements[i])
                    i = i + 1
                }
            }
            .Slice(s, lo, hi) -> {
                self.collect_expr_vars(s)
                self.collect_expr_vars(lo)
                if hi != 0 {
                    self.collect_expr_vars(hi)
                }
            }
            .Try(inner) -> self.collect_expr_vars(inner)
            .Must(inner) -> self.collect_expr_vars(inner)
            .MatchExpr(subject, arms) -> {
                self.collect_expr_vars(subject)
                let subj_inner: TypeKind = .KInt64
                if self.infer_kind(subject) is .KOptional(inner) {
                    subj_inner = inner
                }
                let i = 0
                for i < len(arms) {
                    let arm = self.p.match_expr_arms[arms[i]]
                    match self.p.patterns[arm.pattern] {
                        .SomePat(binding) -> {
                            if len(binding) > 0 and self.var_declared(binding) == false {
                                self.alloc_var(name: binding, kind: subj_inner)
                            }
                        }
                        .EnumPat(enum_name, variant_name, bindings) -> {
                            let enum_idx = self.find_enum_idx(enum_name)
                            let variant_idx = -1
                            if enum_idx >= 0 {
                                variant_idx = self.find_variant_idx(variant_name, :enum_idx)
                            }
                            let j = 0
                            for j < len(bindings) {
                                if self.var_declared(bindings[j]) == false {
                                    let binding_kind = .KInt64
                                    if variant_idx >= 0 and j < len(self.enums[enum_idx].variants[variant_idx].field_kinds) {
                                        binding_kind = self.enums[enum_idx].variants[variant_idx].field_kinds[j]
                                    }
                                    self.alloc_var(name: bindings[j], kind: binding_kind)
                                }
                                j = j + 1
                            }
                        }
                        .ImplicitEnumPat(variant_name, bindings) -> {
                            let enum_idx = self.find_enum_with_variant(variant_name)
                            let variant_idx = -1
                            if enum_idx >= 0 {
                                variant_idx = self.find_variant_idx(variant_name, :enum_idx)
                            }
                            let j = 0
                            for j < len(bindings) {
                                if self.var_declared(bindings[j]) == false {
                                    let binding_kind = .KInt64
                                    if variant_idx >= 0 and j < len(self.enums[enum_idx].variants[variant_idx].field_kinds) {
                                        binding_kind = self.enums[enum_idx].variants[variant_idx].field_kinds[j]
                                    }
                                    self.alloc_var(name: bindings[j], kind: binding_kind)
                                }
                                j = j + 1
                            }
                        }
                        else none
                    }
                    self.collect_expr_vars(arm.body)
                    i = i + 1
                }
            }
            else none
        }
    }

    func collect_stmt_vars(self, stmt_id: int64) -> none {
        match self.p.stmts[stmt_id] {
            .Let(name, typ, value) -> {
                if self.var_declared(name) == false {
                    let kind = self.resolve_type(typ)
                    // No annotation: infer the kind now so downstream
                    // collect calls (e.g. a foreach over `name.field`) can
                    // resolve correctly. compile_let does this too, but
                    // that only runs after collection.
                    if kind is .KVoid {
                        kind = self.infer_kind(value)
                    }
                    self.alloc_var(:name, :kind)
                }
                self.collect_expr_vars(value)
            }
            .Assign(lhs, rhs) -> self.collect_expr_vars(rhs)
            .PlusAssign(lhs, rhs) -> self.collect_expr_vars(rhs)
            .Return(value) -> {
                if value != 0 {
                    self.collect_expr_vars(value)
                }
            }
            .Throw(value) -> self.collect_expr_vars(value)
            .Assert(expr, _source_text, _span) -> self.collect_expr_vars(expr)
            .ExprStmt(expr) -> self.collect_expr_vars(expr)
            .If(cond, then_body, else_body) -> {
                self.collect_expr_vars(cond)
                let i = 0
                for i < len(then_body) {
                    self.collect_stmt_vars(stmt_id: then_body[i])
                    i = i + 1
                }
                let j = 0
                for j < len(else_body) {
                    self.collect_stmt_vars(stmt_id: else_body[j])
                    j = j + 1
                }
            }
            .For(cond, body) -> {
                let i = 0
                for i < len(body) {
                    self.collect_stmt_vars(stmt_id: body[i])
                    i = i + 1
                }
            }
            .ForEach(name, iter, body) -> {
                if self.var_declared(name) == false {
                    let elem_kind = .KInt64
                    match self.infer_kind(iter) {
                        .KArrayStruct(elem_idx) -> elem_kind = .KStruct(idx: elem_idx, type_args: [])
                        .KArrayEnum(elem_idx) -> elem_kind = .KEnum(idx: elem_idx)
                        .KArrayStr -> elem_kind = .KStr
                        else none
                    }
                    self.alloc_var(:name, kind: elem_kind)
                }
                let idx_name = f"__fi_{name}"
                if self.var_declared(idx_name) == false {
                    self.alloc_var(name: idx_name, kind: .KInt64)
                }
                // Persistent slot for the array header pointer so we can
                // reload it each iteration (bl calls in the body would
                // clobber a register-resident copy).
                let hdr_name = f"__fh_{name}"
                if self.var_declared(hdr_name) == false {
                    self.alloc_var(name: hdr_name, kind: .KInt64)
                }
                let i = 0
                for i < len(body) {
                    self.collect_stmt_vars(stmt_id: body[i])
                    i = i + 1
                }
            }
            .MatchStmt(subject, arms) -> {
                let subj_inner: TypeKind = .KInt64
                if self.infer_kind(subject) is .KOptional(inner) {
                    subj_inner = inner
                }
                let i = 0
                for i < len(arms) {
                    let arm = self.p.match_arms[arms[i]]
                    match self.p.patterns[arm.pattern] {
                        .SomePat(binding) -> {
                            if len(binding) > 0 and self.var_declared(binding) == false {
                                self.alloc_var(name: binding, kind: subj_inner)
                            }
                        }
                        .EnumPat(enum_name, variant_name, bindings) -> {
                            let enum_idx = self.find_enum_idx(enum_name)
                            let variant_idx = -1
                            if enum_idx >= 0 {
                                variant_idx = self.find_variant_idx(variant_name, :enum_idx)
                            }
                            let j = 0
                            for j < len(bindings) {
                                if self.var_declared(bindings[j]) == false {
                                    let binding_kind = .KInt64
                                    if variant_idx >= 0 and j < len(self.enums[enum_idx].variants[variant_idx].field_kinds) {
                                        binding_kind = self.enums[enum_idx].variants[variant_idx].field_kinds[j]
                                    }
                                    self.alloc_var(name: bindings[j], kind: binding_kind)
                                }
                                j = j + 1
                            }
                        }
                        .ImplicitEnumPat(variant_name, bindings) -> {
                            let enum_idx = self.find_enum_with_variant(variant_name)
                            let variant_idx = -1
                            if enum_idx >= 0 {
                                variant_idx = self.find_variant_idx(variant_name, :enum_idx)
                            }
                            let j = 0
                            for j < len(bindings) {
                                if self.var_declared(bindings[j]) == false {
                                    let binding_kind = .KInt64
                                    if variant_idx >= 0 and j < len(self.enums[enum_idx].variants[variant_idx].field_kinds) {
                                        binding_kind = self.enums[enum_idx].variants[variant_idx].field_kinds[j]
                                    }
                                    self.alloc_var(name: bindings[j], kind: binding_kind)
                                }
                                j = j + 1
                            }
                        }
                        else none
                    }
                    for stmt_id in arm.body {
                        self.collect_stmt_vars(:stmt_id)
                    }
                    i = i + 1
                }
            }
            .LetElse(pattern, value, else_body) -> {
                // Allocate bindings introduced by the pattern (same shape as
                // a match arm) so the rest of the surrounding block can use
                // them.
                match self.p.patterns[pattern] {
                    .EnumPat(enum_name, variant_name, bindings) -> {
                        let enum_idx = self.find_enum_idx(enum_name)
                        let variant_idx = -1
                        if enum_idx >= 0 {
                            variant_idx = self.find_variant_idx(variant_name, :enum_idx)
                        }
                        let j = 0
                        for j < len(bindings) {
                            if self.var_declared(bindings[j]) == false {
                                let binding_kind = .KInt64
                                if variant_idx >= 0 and j < len(self.enums[enum_idx].variants[variant_idx].field_kinds) {
                                    binding_kind = self.enums[enum_idx].variants[variant_idx].field_kinds[j]
                                }
                                self.alloc_var(name: bindings[j], kind: binding_kind)
                            }
                            j = j + 1
                        }
                    }
                    .ImplicitEnumPat(variant_name, bindings) -> {
                        let enum_idx = self.find_enum_with_variant(variant_name)
                        let variant_idx = -1
                        if enum_idx >= 0 {
                            variant_idx = self.find_variant_idx(variant_name, :enum_idx)
                        }
                        let j = 0
                        for j < len(bindings) {
                            if self.var_declared(bindings[j]) == false {
                                let binding_kind = .KInt64
                                if variant_idx >= 0 and j < len(self.enums[enum_idx].variants[variant_idx].field_kinds) {
                                    binding_kind = self.enums[enum_idx].variants[variant_idx].field_kinds[j]
                                }
                                self.alloc_var(name: bindings[j], kind: binding_kind)
                            }
                            j = j + 1
                        }
                    }
                    .SomePat(binding) -> {
                        if len(binding) > 0 and self.var_declared(binding) == false {
                            let inner_kind: TypeKind = .KInt64
                            if self.infer_kind(value) is .KOptional(inner) {
                                inner_kind = inner
                            }
                            self.alloc_var(name: binding, kind: inner_kind)
                        }
                    }
                    else none
                }
                self.collect_expr_vars(value)
                let e = 0
                for e < len(else_body) {
                    self.collect_stmt_vars(stmt_id: else_body[e])
                    e = e + 1
                }
            }
            else none
        }
    }


    func compile_expr(self, anon expr_id: int64) -> Val {
        match self.p.exprs[expr_id] {
            .IntLit(value) -> return .VImm(:value)
            .BoolLit(value) -> {
                if value {
                    return .VImm(value: 1)
                }
                return .VImm(value: 0)
            }
            .NoneLit -> return .VImm(value: 0)
            .StrLit(value) -> {
                let lbl = self.intern_str(value)
                return .VStrLbl(page: lbl)
            }
            .Ident(name) -> {
                if self.var_declared(name) == false {
                    // Candidates for the typo hint: in-scope variables
                    // plus visible function names. Type and import
                    // names also live in the global namespace but
                    // can't appear in a value position, so leaving
                    // them out keeps the suggestions relevant.
                    let cands: [str] = []
                    for v in self.vars {
                        cands += [v.name]
                    }
                    for n in self.func_names {
                        cands += [n]
                    }
                    let msg: str = self.with_suggestion(f"error: unknown name `{name}`", typo: name, candidates: cands)
                    self.report_error(msg, span: self.p.expr_spans[expr_id])
                    return .VImm(value: 0)
                }
                let off = self.find_var_offset(name)
                return .VStack(offset: off)
            }
            .ImplicitVariant(name) -> {
                let enum_idx = self.find_enum_with_variant(name)
                if enum_idx < 0 {
                    let variant_names: [str] = []
                    for e in self.enums {
                        for v in e.variants {
                            variant_names += [v.name]
                        }
                    }
                    let msg: str = self.with_suggestion(f"error: unknown implicit variant `.{name}`", typo: name, candidates: variant_names)
                    self.report_error(msg, span: self.p.expr_spans[expr_id])
                    return .VImm(value: 0)
                }
                let variant_idx = self.find_variant_idx(name, :enum_idx)
                let empty: [ast.CallArg] = []
                return self.compile_enum_construct(empty, :enum_idx, :variant_idx)
            }
            .Binary(lhs, op, rhs) -> return self.compile_binary(:lhs, :op, :rhs)
            .Call(callee, args) -> return self.compile_call(args, callee_id: callee)
            .ArrayLit(elements) -> return self.compile_array_lit(elements)
            .MatchExpr(subject, arms) -> return self.compile_match_expr(arms, subject_id: subject)
            .Slice(s, lo, hi) -> return self.compile_slice(s_id: s, lo_id: lo, hi_id: hi)
            .Try(inner) -> return self.compile_try(inner)
            .Must(inner) -> return self.compile_must(inner)
        }
    }

    func compile_binary(self, lhs: int64, op: ast.Op, rhs: int64) -> Val {
        match op {
            .Dot -> return self.compile_dot(:lhs, :rhs)
            .Index -> return self.compile_index(:lhs, :rhs)
            .And -> return self.compile_and(:lhs, :rhs)
            .Or -> return self.compile_or(:lhs, :rhs)
            .Is -> return self.compile_is(:lhs, :rhs)
            else return self.compile_arith_cmp(lhs_id: lhs, :op, rhs_id: rhs)
        }
    }

    // Try `module.Enum.Variant` — bare three-part unit-variant access.
    // Drops the module qualifier (types are global in the codegen).
    func try_three_part_unit_variant(self, dot_lhs: int64, dot_rhs: int64) -> Val? {
        let .Binary(inner_lhs, inner_op, inner_rhs) = self.p.exprs[dot_lhs] else { return none }
        let .Dot = inner_op else { return none }
        let .Ident(enum_name) = self.p.exprs[inner_rhs] else { return none }
        let .Ident(variant_name) = self.p.exprs[dot_rhs] else { return none }
        let ei3 = self.find_enum_idx(enum_name)
        if ei3 < 0 { return none }
        let vi3 = self.find_variant_idx(variant_name, enum_idx: ei3)
        if vi3 < 0 { return none }
        let empty: [ast.CallArg] = []
        return self.compile_enum_construct(empty, enum_idx: ei3, variant_idx: vi3)
    }

    // Try `EnumName.Variant` — bare two-part unit-variant access.
    func try_two_part_unit_variant(self, dot_lhs: int64, dot_rhs: int64) -> Val? {
        let .Ident(type_name) = self.p.exprs[dot_lhs] else { return none }
        let enum_idx = self.find_enum_idx(type_name)
        if enum_idx < 0 { return none }
        let .Ident(variant_name) = self.p.exprs[dot_rhs] else { return none }
        let variant_idx = self.find_variant_idx(variant_name, :enum_idx)
        let empty: [ast.CallArg] = []
        return self.compile_enum_construct(empty, :enum_idx, :variant_idx)
    }

    func compile_dot(self, lhs: int64, rhs: int64) -> Val {
        if self.try_three_part_unit_variant(dot_lhs: lhs, dot_rhs: rhs) is Some(val) {
            return val
        }
        if self.try_two_part_unit_variant(dot_lhs: lhs, dot_rhs: rhs) is Some(val) {
            return val
        }
        let ptr_v = self.compile_expr(lhs)
        let ptr_r = self.load(ptr_v)
        match self.p.exprs[rhs] {
            .Ident(field_name) -> {
                // Resolve the struct via infer_kind so chained accesses
                // (e.g. obj.field, arr[i].field) work, not just Ident lhs.
                let struct_idx = -1
                if self.infer_kind(lhs) is .KStruct(idx, _struct_type_args) {
                    struct_idx = idx
                }
                let field_off = 0
                if struct_idx >= 0 {
                    field_off = self.find_field_offset(field_name, :struct_idx)
                }
                let result = self.alloc_reg()
                self.emit(f"ldr {result}, [{ptr_r}, #{self.itos(field_off)}]")
                self.free_reg(ptr_r)
                return .VReg(name: result)
            }
            else none
        }
        self.free_reg(ptr_r)
        return .VImm(value: 0)
    }

    func find_var_offset_by_lhs(self, anon expr_id: int64) -> int64 {
        match self.p.exprs[expr_id] {
            .Ident(name) -> return self.find_var_offset(name)
            else return -8
        }
    }

    func compile_index(self, lhs: int64, rhs: int64) -> Val {
        let lhs_kind = self.infer_kind(lhs)
        // Struct with op_index — dispatch as a method call.
        match lhs_kind {
            .KStruct(idx, _struct_type_args) -> {
                if self.structs[idx].method_idx.get("op_index") is Some(_mi) {
                    let key_val = self.compile_expr(rhs)
                    let key_reg = self.alloc_reg()
                    self.mov_to(key_val, dest: key_reg)
                    let ov = self.compile_expr(lhs)
                    self.mov_to(ov, dest: "x0")
                    self.emit(f"mov x1, {key_reg}")
                    self.free_reg(key_reg)
                    let method_lbl = f"${self.structs[idx].module_prefix}${self.structs[idx].name}$op_index"
                    self.emit(f"bl {method_lbl}")
                    return .VReg(name: "x0")
                }
            }
            else none
        }
        let ptr_v = self.compile_expr(lhs)
        let idx_v = self.compile_expr(rhs)
        let ptr_r = self.load(ptr_v)
        let idx_r = self.load(idx_v)
        let result = self.alloc_reg()
        let array_like = false
        match lhs_kind {
            .KArray -> array_like = true
            .KArrayStruct(elem_idx) -> array_like = true
            .KArrayEnum(elem_idx) -> array_like = true
            .KArrayStr -> array_like = true
            else none
        }
        if array_like {
            // Normalise negative index: if idx < 0, idx += len.
            let pos_lbl = self.fresh("Lidx_pos")
            let len_r = self.alloc_reg()
            self.emit(f"ldr {len_r}, [{ptr_r}, #8]")
            self.emit(f"cmp {idx_r}, #0")
            self.emit(f"bge {pos_lbl}")
            self.emit(f"add {idx_r}, {idx_r}, {len_r}")
            self.emit_label(pos_lbl)
            // Bounds check via unsigned compare: catches both idx >= len
            // and idx < 0 (negative signed → huge unsigned), and skips
            // ahead to load on success. Forward branch to the panic
            // call to keep the hot path (no panic) straight-line.
            let ok_lbl = self.fresh("Lidx_ok")
            let oob_lbl = self.fresh("Lidx_oob")
            self.emit(f"cmp {idx_r}, {len_r}")
            self.emit(f"b.hs {oob_lbl}")
            self.emit(f"b {ok_lbl}")
            self.emit_label(oob_lbl)
            self.emit(f"mov x0, {idx_r}")
            self.emit(f"mov x1, {len_r}")
            self.emit("bl _kod_index_oob")
            self.emit_label(ok_lbl)
            self.free_reg(len_r)

            let hdr = self.alloc_reg()
            self.emit(f"ldr {hdr}, [{ptr_r}]")
            self.emit(f"lsl {idx_r}, {idx_r}, #3")
            self.emit(f"ldr {result}, [{hdr}, {idx_r}]")
            self.free_reg(hdr)
        } else {
            // KStr indexing. ptr_r is the `{ buf, len }` struct pointer.
            // Load buf and len, normalise negative, bounds-check, then
            // a one-byte read from buf — same shape as the array path.
            let len_r = self.alloc_reg()
            self.emit(f"ldr {len_r}, [{ptr_r}, #8]")
            let buf_r = self.alloc_reg()
            self.emit(f"ldr {buf_r}, [{ptr_r}]")
            let pos_lbl = self.fresh("Lidx_pos")
            self.emit(f"cmp {idx_r}, #0")
            self.emit(f"bge {pos_lbl}")
            self.emit(f"add {idx_r}, {idx_r}, {len_r}")
            self.emit_label(pos_lbl)
            let ok_lbl = self.fresh("Lidx_ok")
            let oob_lbl = self.fresh("Lidx_oob")
            self.emit(f"cmp {idx_r}, {len_r}")
            self.emit(f"b.hs {oob_lbl}")
            self.emit(f"b {ok_lbl}")
            self.emit_label(oob_lbl)
            self.emit(f"mov x0, {idx_r}")
            self.emit(f"mov x1, {len_r}")
            self.emit("bl _kod_index_oob")
            self.emit_label(ok_lbl)
            self.free_reg(len_r)
            self.emit(f"ldrb w{result[1:len(result)]}, [{buf_r}, {idx_r}]")
            self.free_reg(buf_r)
        }
        self.free_reg(ptr_r)
        self.free_reg(idx_r)
        return .VReg(name: result)
    }

    func compile_and(self, lhs: int64, rhs: int64) -> Val {
        let done = self.fresh("Land")
        let result = self.alloc_reg()
        let lhs_val = self.compile_expr(lhs)
        self.mov_to(lhs_val, dest: result)
        self.emit(f"cmp {result}, #0")
        self.emit(f"cset {result}, ne")
        self.emit(f"beq {done}")
        let rhs_val = self.compile_expr(rhs)
        self.mov_to(rhs_val, dest: result)
        self.emit(f"cmp {result}, #0")
        self.emit(f"cset {result}, ne")
        self.emit_label(done)
        return .VReg(name: result)
    }

    func compile_or(self, lhs: int64, rhs: int64) -> Val {
        let done = self.fresh("Lor")
        let result = self.alloc_reg()
        let lhs_val = self.compile_expr(lhs)
        self.mov_to(lhs_val, dest: result)
        self.emit(f"cmp {result}, #0")
        self.emit(f"cset {result}, ne")
        self.emit(f"bne {done}")
        let rhs_val = self.compile_expr(rhs)
        self.mov_to(rhs_val, dest: result)
        self.emit(f"cmp {result}, #0")
        self.emit(f"cset {result}, ne")
        self.emit_label(done)
        return .VReg(name: result)
    }

    func compile_is(self, lhs: int64, rhs: int64) -> Val {
        let lhs_kind = self.infer_kind(lhs)
        let is_optional: bool = false
        if lhs_kind is .KOptional(_inner) {
            is_optional = true
        }
        if is_optional == false {
            self.report_error("error: `is` requires an optional value", span: self.p.expr_spans[lhs])
        }
        let ptr_v = self.compile_expr(lhs)
        let reg = self.load(ptr_v)
        self.emit(f"cmp {reg}, #0")
        match self.p.exprs[rhs] {
            .NoneLit -> self.emit(f"cset {reg}, eq")
            else self.emit(f"cset {reg}, ne")
        }
        return .VReg(name: reg)
    }

    func compile_arith_cmp(self, lhs_id: int64, op: ast.Op, rhs_id: int64) -> Val {
        let lhs_kind = self.infer_kind(lhs_id)
        // Comparing against `none` only makes sense for optional types;
        // for other kinds it would silently compile to `x == 0`.
        let is_eq_or_ne: bool = false
        if op is .Eq {
            is_eq_or_ne = true
        }
        if op is .Ne {
            is_eq_or_ne = true
        }
        if is_eq_or_ne {
            let lhs_is_none: bool = false
            if self.p.exprs[lhs_id] is .NoneLit {
                lhs_is_none = true
            }
            let rhs_is_none: bool = false
            if self.p.exprs[rhs_id] is .NoneLit {
                rhs_is_none = true
            }
            if lhs_is_none and rhs_is_none == false {
                let rhs_kind = self.infer_kind(rhs_id)
                let rhs_is_opt: bool = false
                if rhs_kind is .KOptional(_inner) {
                    rhs_is_opt = true
                }
                if rhs_is_opt == false {
                    self.report_error("error: cannot compare non-optional value with `none`", span: self.p.expr_spans[rhs_id])
                }
            }
            if rhs_is_none and lhs_is_none == false {
                let lhs_is_opt: bool = false
                if lhs_kind is .KOptional(_inner) {
                    lhs_is_opt = true
                }
                if lhs_is_opt == false {
                    self.report_error("error: cannot compare non-optional value with `none`", span: self.p.expr_spans[lhs_id])
                }
            }
        }
        match lhs_kind {
            .KStr -> {
                match op {
                    .Eq -> return self.compile_str_eq(:lhs_id, :rhs_id, negate: false)
                    .Ne -> return self.compile_str_eq(:lhs_id, :rhs_id, negate: true)
                    else none
                }
            }
            else none
        }
        match op {
            .Add -> {
                match lhs_kind {
                    .KStr -> return self.compile_str_concat(:lhs_id, :rhs_id)
                    .KArray -> return self.compile_arr_concat(:lhs_id, :rhs_id)
                    .KArrayStruct(elem_idx) -> return self.compile_arr_concat(:lhs_id, :rhs_id)
                    .KArrayEnum(elem_idx) -> return self.compile_arr_concat(:lhs_id, :rhs_id)
                    .KArrayStr -> return self.compile_arr_concat(:lhs_id, :rhs_id)
                    else none
                }
            }
            else none
        }

        // Compile both sides, stashing the lhs on the stack across the rhs
        // compilation so its value survives any bl calls in rhs.
        let lhs_val = self.compile_expr(lhs_id)
        let lv_r = self.load_enum_or_val(lhs_val, expr_id: lhs_id)
        let lhs_reg = self.alloc_reg()
        if lv_r != lhs_reg {
            self.emit(f"mov {lhs_reg}, {lv_r}")
        }
        self.free_reg(lv_r)
        self.emit("sub sp, sp, #16")
        self.emit(f"str {lhs_reg}, [sp]")
        let rhs_val = self.compile_expr(rhs_id)
        let rhs_reg = self.load_enum_or_val(rhs_val, expr_id: rhs_id)
        self.emit(f"ldr {lhs_reg}, [sp]")
        self.emit("add sp, sp, #16")
        let result = self.alloc_reg()
        match op {
            .Eq -> {
                self.emit(f"cmp {lhs_reg}, {rhs_reg}")
                self.emit(f"cset {result}, eq")
            }
            .Ne -> {
                self.emit(f"cmp {lhs_reg}, {rhs_reg}")
                self.emit(f"cset {result}, ne")
            }
            .Lt -> {
                self.emit(f"cmp {lhs_reg}, {rhs_reg}")
                self.emit(f"cset {result}, lt")
            }
            .Le -> {
                self.emit(f"cmp {lhs_reg}, {rhs_reg}")
                self.emit(f"cset {result}, le")
            }
            .Gt -> {
                self.emit(f"cmp {lhs_reg}, {rhs_reg}")
                self.emit(f"cset {result}, gt")
            }
            .Ge -> {
                self.emit(f"cmp {lhs_reg}, {rhs_reg}")
                self.emit(f"cset {result}, ge")
            }
            .Add -> {
                self.emit(f"add {result}, {lhs_reg}, {rhs_reg}")
            }
            .Sub -> {
                self.emit(f"sub {result}, {lhs_reg}, {rhs_reg}")
            }
            .Mul -> {
                self.emit(f"mul {result}, {lhs_reg}, {rhs_reg}")
            }
            .Div -> {
                self.emit(f"sdiv {result}, {lhs_reg}, {rhs_reg}")
            }
            .Mod -> {
                let tmp2 = self.alloc_reg()
                self.emit(f"sdiv {result}, {lhs_reg}, {rhs_reg}")
                self.emit(f"mul {tmp2}, {result}, {rhs_reg}")
                self.emit(f"sub {result}, {lhs_reg}, {tmp2}")
                self.free_reg(tmp2)
            }
            else {
                self.emit(f"cmp {lhs_reg}, {rhs_reg}")
                self.emit(f"cset {result}, eq")
            }
        }
        self.free_reg(lhs_reg)
        self.free_reg(rhs_reg)
        return .VReg(name: result)
    }

    func load_enum_or_val(self, anon val: Val, expr_id: int64) -> str {
        match self.infer_kind(expr_id) {
            .KEnum(idx) -> {
                let reg = self.load(val)
                self.emit(f"ldr {reg}, [{reg}]")
                return reg
            }
            else return self.load(val)
        }
    }

    func compile_str_eq(self, lhs_id: int64, rhs_id: int64, negate: bool) -> Val {
        let rhs_val = self.compile_expr(rhs_id)
        let rhs_reg = self.alloc_reg()
        self.mov_to(rhs_val, dest: rhs_reg)
        // Stash rhs to the stack so the lhs compilation (which may bl)
        // doesn't clobber rr's pool register.
        self.emit("sub sp, sp, #16")
        self.emit(f"str {rhs_reg}, [sp]")
        let lhs_val = self.compile_expr(lhs_id)
        self.mov_to(lhs_val, dest: "x0")
        self.emit(f"ldr {rhs_reg}, [sp]")
        self.emit("add sp, sp, #16")
        self.emit(f"mov x1, {rhs_reg}")
        self.free_reg(rhs_reg)
        // `kod_str_cmp` takes two KodStr pointers and returns 0 / ±n
        // like memcmp. Replaces the previous `_strcmp` call, which
        // would have compared struct headers byte-by-byte (and stopped
        // at the first 0 in the embedded len field).
        self.emit("bl _kod_str_cmp")
        let result = self.alloc_reg()
        self.emit("cmp x0, #0")
        if negate {
            self.emit(f"cset {result}, ne")
        } else {
            self.emit(f"cset {result}, eq")
        }
        return .VReg(name: result)
    }

    // Compile `expr_id` and coerce the result to a `str` value. Used for
    // f-string interpolations and `str + X` concatenation so that non-string
    // values are rendered before being passed to _kod_str_concat. Lowering
    // matches the Stringable interface from stdlib/builtins.kod:
    //   - KStr        : already a string, pass through
    //   - KInt64      : bl $primitives$int64$to_str
    //   - KBool       : bl $primitives$bool$to_str
    //   - KStruct(si) : if the struct defines a `to_str` method, call it
    //   - anything else: best-effort pass-through (likely garbage, but
    //                    we don't have a string representation for it yet)
    func compile_as_str(self, anon expr_id: int64) -> Val {
        let k = self.infer_kind(expr_id)
        match k {
            .KStr -> return self.compile_expr(expr_id)
            .KInt64 -> {
                let val = self.compile_expr(expr_id)
                self.mov_to(val, dest: "x0")
                self.emit("bl $primitives$int64$to_str")
                return .VReg(name: "x0")
            }
            .KBool -> {
                let val = self.compile_expr(expr_id)
                self.mov_to(val, dest: "x0")
                self.emit("bl $primitives$bool$to_str")
                return .VReg(name: "x0")
            }
            .KStruct(struct_idx, _struct_type_args) -> {
                if self.structs[struct_idx].method_idx.get("to_str") is Some(_mi) {
                    let val = self.compile_expr(expr_id)
                    self.mov_to(val, dest: "x0")
                    let struct_info = self.structs[struct_idx]
                    self.emit(f"bl ${struct_info.module_prefix}${struct_info.name}$to_str")
                    return .VReg(name: "x0")
                }
                return self.compile_expr(expr_id)
            }
            else return self.compile_expr(expr_id)
        }
    }

    func compile_str_concat(self, lhs_id: int64, rhs_id: int64) -> Val {
        // Both operands must already be `str`. Non-string operands need an
        // explicit conversion (`one + str(other)` or, equivalently, an
        // f-string `f"{one}{other}"`).
        let rhs_val = self.compile_expr(rhs_id)
        let rhs_reg = self.alloc_reg()
        self.mov_to(rhs_val, dest: rhs_reg)
        // Save rhs to the stack so it survives any bl calls inside lhs
        // compilation (pool registers x8-x15 are caller-saved and would
        // be clobbered by an inner _kod_str_concat for chained concats).
        self.emit("sub sp, sp, #16")
        self.emit(f"str {rhs_reg}, [sp]")
        let lhs_val = self.compile_expr(lhs_id)
        self.mov_to(lhs_val, dest: "x0")
        self.emit(f"ldr {rhs_reg}, [sp]")
        self.emit("add sp, sp, #16")
        self.emit(f"mov x1, {rhs_reg}")
        self.free_reg(rhs_reg)
        self.emit("bl _kod_str_concat")
        return .VReg(name: "x0")
    }

    func compile_arr_concat(self, lhs_id: int64, rhs_id: int64) -> Val {
        let rhs_val = self.compile_expr(rhs_id)
        let rhs_reg = self.load(rhs_val)
        let lhs_val = self.compile_expr(lhs_id)
        self.mov_to(lhs_val, dest: "x0")
        self.emit(f"mov x1, {rhs_reg}")
        self.free_reg(rhs_reg)
        self.emit("bl _kod_array_concat")
        return .VReg(name: "x0")
    }

    func compile_slice(self, s_id: int64, lo_id: int64, hi_id: int64) -> Val {
        // Stash each value on the stack so that compile_expr calls (which can
        // issue bl into len/strlen/etc.) don't clobber prior args still held
        // in caller-saved pool registers or in x0.
        self.emit("sub sp, sp, #32")
        let hi_v = self.compile_expr(hi_id)
        let hi_r = self.load(hi_v)
        self.emit(f"str {hi_r}, [sp, #16]")
        self.free_reg(hi_r)
        let lo_v = self.compile_expr(lo_id)
        let lo_r = self.load(lo_v)
        self.emit(f"str {lo_r}, [sp, #8]")
        self.free_reg(lo_r)
        let subj_val = self.compile_expr(s_id)
        let s_r = self.load(subj_val)
        self.emit(f"str {s_r}, [sp]")
        self.free_reg(s_r)
        self.emit("ldr x0, [sp]")
        self.emit("ldr x1, [sp, #8]")
        self.emit("ldr x2, [sp, #16]")
        self.emit("add sp, sp, #32")
        self.emit("bl _kod_str_slice")
        return .VReg(name: "x0")
    }

    func compile_array_lit(self, anon elements: [int64]) -> Val {
        let n = len(elements)
        let item_sz = 8
        // Allocate header (24 bytes) and buf, saving both pointers on
        // the stack so element compilation (which may bl) doesn't
        // clobber them via pool-register reuse.
        self.emit("sub sp, sp, #16")
        self.emit("mov x0, #24")
        self.emit("bl _arena_alloc")
        self.emit("str x0, [sp]")
        let buf_sz = n * item_sz
        if buf_sz < 8 {
            buf_sz = 8
        }
        self.emit_load_imm("x0", value: buf_sz)
        self.emit("bl _arena_alloc")
        self.emit("str x0, [sp, #8]")
        let i = 0
        for i < n {
            let elem_val = self.compile_expr(elements[i])
            let elem_reg = self.load(elem_val)
            // Reload buf from stack — any bl in compile_expr above would
            // have clobbered a pool-register copy.
            let buf_r = self.alloc_reg()
            self.emit(f"ldr {buf_r}, [sp, #8]")
            self.emit(f"str {elem_reg}, [{buf_r}, #{self.itos(i * item_sz)}]")
            self.free_reg(buf_r)
            self.free_reg(elem_reg)
            i = i + 1
        }
        let hdr_r = self.alloc_reg()
        let buf_r = self.alloc_reg()
        self.emit(f"ldr {hdr_r}, [sp]")
        self.emit(f"ldr {buf_r}, [sp, #8]")
        self.emit("add sp, sp, #16")
        self.emit(f"str {buf_r}, [{hdr_r}]")
        let len_r = self.alloc_reg()
        self.emit_load_imm(len_r, value: n)
        self.emit(f"str {len_r}, [{hdr_r}, #8]")
        self.emit(f"str {len_r}, [{hdr_r}, #16]")
        self.free_reg(len_r)
        self.free_reg(buf_r)
        return .VReg(name: hdr_r)
    }

    // Try `mod.Enum.Variant(args)` — succeed iff the callee shape is
    // Binary(Binary(Ident(mod), Dot, Ident(enum)), Dot, Ident(variant))
    // and Enum/Variant resolve.
    func try_three_part_construct(self, anon args: [ast.CallArg], callee_lhs: int64, callee_rhs: int64) -> Val? {
        let .Binary(inner_lhs, inner_op, inner_rhs) = self.p.exprs[callee_lhs] else { return none }
        let .Dot = inner_op else { return none }
        let .Ident(mod_name) = self.p.exprs[inner_lhs] else { return none }
        let .Ident(enum_name) = self.p.exprs[inner_rhs] else { return none }
        let .Ident(variant_name) = self.p.exprs[callee_rhs] else { return none }
        let enum_idx = self.find_enum_idx(enum_name)
        if enum_idx < 0 { return none }
        let variant_idx = self.find_variant_idx(variant_name, :enum_idx)
        if variant_idx < 0 { return none }
        return self.compile_enum_construct(args, :enum_idx, :variant_idx)
    }

    // Try `EnumName.Variant(args)` or `module.thing(args)` two-part forms.
    func try_two_part_call(self, anon args: [ast.CallArg], callee_lhs: int64, callee_rhs: int64) -> Val? {
        let .Ident(mod_or_obj) = self.p.exprs[callee_lhs] else { return none }
        let .Ident(method_name) = self.p.exprs[callee_rhs] else { return none }
        let enum_idx = self.find_enum_idx(mod_or_obj)
        if enum_idx >= 0 {
            let variant_idx = self.find_variant_idx(method_name, :enum_idx)
            if variant_idx >= 0 {
                return self.compile_enum_construct(args, :enum_idx, :variant_idx)
            }
        }
        let is_import = false
        let i = 0
        for i < len(self.import_local) {
            if self.import_local[i] == mod_or_obj {
                is_import = true
                i = len(self.import_local)
            } else {
                i = i + 1
            }
        }
        if is_import {
            let s_idx = self.find_struct_idx(method_name)
            if s_idx >= 0 {
                return self.compile_struct_construct(args, struct_idx: s_idx)
            }
            let sig = self.find_import_fn_sig(mod_or_obj, method_name)
            self.check_call_args(args, param_labels: sig.param_labels, skip: 0, call_name: f"{mod_or_obj}.{method_name}", call_span: self.p.expr_spans[callee_lhs])
            self.prepare_args_with_kinds(args, expected_kinds: sig.param_kinds)
            let lbl = self.import_func_label(method_name, local_mod: mod_or_obj)
            self.emit(f"bl {lbl}")
            return .VReg(name: "x0")
        }
        return self.compile_method_call(args, receiver_id: callee_lhs, :method_name, span: self.p.expr_spans[callee_lhs])
    }

    func compile_call(self, anon args: [ast.CallArg], callee_id: int64) -> Val {
        match self.p.exprs[callee_id] {
            .Ident(name) -> {
                if name == "len" and len(args) == 1 {
                    return self.compile_len(args[0].value)
                }
                // `str(x)` — explicit conversion intrinsic. Dispatches by
                // kind to the appropriate to_str (int_to_str, bool_to_str,
                // struct.to_str). Used by f-strings and any explicit cast.
                if name == "str" and len(args) == 1 {
                    return self.compile_as_str(args[0].value)
                }
                // `hash(x)` — produce an int64 hash. Primitives hash to
                // their bit pattern (identity). Strings hash by content
                // via the builtins `str_hash` so Map[str, V] finds keys
                // by content rather than pointer identity.
                if name == "hash" and len(args) == 1 {
                    let arg_kind = self.infer_kind(args[0].value)
                    if arg_kind is .KStr {
                        let val = self.compile_expr(args[0].value)
                        self.mov_to(val, dest: "x0")
                        self.emit("bl $primitives$str$hash")
                        return .VReg(name: "x0")
                    }
                    return self.compile_expr(args[0].value)
                }
                // Struct constructor: StructName(field1: v1, ...)
                let struct_idx = self.find_struct_idx(name)
                if struct_idx >= 0 {
                    return self.compile_struct_construct(args, :struct_idx)
                }
                let func_lookup = self.func_idx
                if func_lookup.get(name) is Some(idx) {
                    self.check_call_args(args, param_labels: self.func_sigs[idx].param_labels, skip: 0, call_name: name, call_span: self.p.expr_spans[callee_id])
                    self.prepare_args_with_kinds(args, expected_kinds: self.func_sigs[idx].param_kinds)
                    self.emit(f"bl {self.func_labels[idx]}")
                    return .VReg(name: "x0")
                }
                let msg: str = self.with_suggestion(f"error: unknown function `{name}`", typo: name, candidates: self.func_names)
                self.report_error(msg, span: self.p.expr_spans[callee_id])
                return .VImm(value: 0)
            }
            .Binary(lhs, op, rhs) -> {
                match op {
                    .Dot -> {
                        if self.try_three_part_construct(args, callee_lhs: lhs, callee_rhs: rhs) is Some(val) {
                            return val
                        }
                        if self.try_two_part_call(args, callee_lhs: lhs, callee_rhs: rhs) is Some(val) {
                            return val
                        }
                        // Fallback: receiver is a non-Ident expression
                        // (literal, field access, call result, ...). Dispatch
                        // via the general method-call path using the receiver
                        // expression directly.
                        if self.p.exprs[rhs] is .Ident(method_name) {
                            return self.compile_method_call(args, receiver_id: lhs, :method_name, span: self.p.expr_spans[lhs])
                        }
                    }
                    else none
                }
                self.report_error("error: unresolved call on dotted callee", span: self.p.expr_spans[callee_id])
                return .VReg(name: "x0")
            }
            .ImplicitVariant(variant_name) -> {
                // .Variant(args) constructor — payload form of implicit variant.
                let enum_idx = self.find_enum_with_variant(variant_name)
                if enum_idx >= 0 {
                    let variant_idx = self.find_variant_idx(variant_name, :enum_idx)
                    if variant_idx >= 0 {
                        return self.compile_enum_construct(args, :enum_idx, :variant_idx)
                    }
                }
                // Candidates for the typo hint: every variant of every
                // registered enum. An implicit `.X` has no enum context
                // to narrow against, so the suggestion pool is wide.
                let variant_names: [str] = []
                for e in self.enums {
                    for v in e.variants {
                        variant_names += [v.name]
                    }
                }
                let msg: str = self.with_suggestion(f"error: unknown implicit variant `.{variant_name}` in call position", typo: variant_name, candidates: variant_names)
                self.report_error(msg, span: self.p.expr_spans[callee_id])
                return .VReg(name: "x0")
            }
            else {
                self.report_error("error: call with non-callable expression", span: self.p.expr_spans[callee_id])
                return .VReg(name: "x0")
            }
        }
    }

    func compile_len(self, anon arg_id: int64) -> Val {
        let kind = self.infer_kind(arg_id)
        let arg_val = self.compile_expr(arg_id)
        match kind {
            .KArray -> {
                let reg = self.load(arg_val)
                self.emit(f"ldr {reg}, [{reg}, #8]")
                return .VReg(name: reg)
            }
            .KArrayStruct(elem_idx) -> {
                let reg = self.load(arg_val)
                self.emit(f"ldr {reg}, [{reg}, #8]")
                return .VReg(name: reg)
            }
            .KArrayEnum(elem_idx) -> {
                let reg = self.load(arg_val)
                self.emit(f"ldr {reg}, [{reg}, #8]")
                return .VReg(name: reg)
            }
            .KArrayStr -> {
                let reg = self.load(arg_val)
                self.emit(f"ldr {reg}, [{reg}, #8]")
                return .VReg(name: reg)
            }
            .KStr -> {
                // A str is a `{ buf, len }` struct pointer; len lives
                // at offset 8. One load — no `bl _strlen` walk.
                let reg = self.load(arg_val)
                self.emit(f"ldr {reg}, [{reg}, #8]")
                return .VReg(name: reg)
            }
            .KStruct(struct_idx, _struct_type_args) -> {
                // Look for a `len(self) -> int64` method on the struct;
                // if one exists, dispatch to it. Lets `len(map)` work the
                // same way `len(array)` and `len(str)` do.
                let s = self.structs[struct_idx]
                if s.method_idx.get("len") is Some(_mi) {
                    self.mov_to(arg_val, dest: "x0")
                    self.emit(f"bl ${s.module_prefix}${s.name}$len")
                    return .VReg(name: "x0")
                }
                self.report_error(f"error: len() not defined for struct `{s.name}` (no `len` method)", span: self.p.expr_spans[arg_id])
                return .VImm(value: 0)
            }
            else {
                self.report_error("error: len() not defined for this type", span: self.p.expr_spans[arg_id])
                return .VImm(value: 0)
            }
        }
    }

    // Dispatch on an interface value: the variable holds a pointer to an
    // arena cell {data_ptr at 0, vtable_ptr at 8}. The method index in the
    // vtable matches its order in the interface declaration.
    func compile_iface_method_call(self, anon args: [ast.CallArg], receiver_id: int64, iface_idx: int64, method_name: str) -> Val {
        let i = 0
        let method_idx = -1
        for i < len(self.interfaces[iface_idx].methods) {
            if self.interfaces[iface_idx].methods[i].name == method_name {
                method_idx = i
                i = len(self.interfaces[iface_idx].methods)
            } else {
                i = i + 1
            }
        }
        let sig_params: [TypeKind] = []
        if method_idx >= 0 {
            sig_params = self.interfaces[iface_idx].methods[method_idx].sig.param_kinds
        }
        // Stash self (data_ptr) and each compiled arg, plus the method ptr,
        // so arg compilation doesn't clobber x0..x7. Layout in the spill
        // area: [data_ptr, arg0, arg1, ..., method_ptr].
        let arg_regs: [str] = ["x0", "x1", "x2", "x3", "x4", "x5", "x6", "x7"]
        let n = len(args) + 1
        let padded = (n + 1) * 8
        if padded % 16 != 0 {
            padded = padded + 8
        }
        self.emit(f"sub sp, sp, #{self.itos(padded)}")
        // Load cell ptr -> x0; data_ptr -> sp[0]; vtable -> x1; method ptr -> sp[n*8].
        let recv_val = self.compile_expr(receiver_id)
        self.mov_to(recv_val, dest: "x0")
        let cell_r = self.alloc_reg()
        let tmp_r = self.alloc_reg()
        // Use two distinct pool regs: hard-coding x9 here would clobber
        // cell_r when alloc_reg happens to hand back x9.
        self.emit(f"mov {cell_r}, x0")
        self.emit(f"ldr {tmp_r}, [{cell_r}]")
        self.emit(f"str {tmp_r}, [sp]")
        self.emit(f"ldr {tmp_r}, [{cell_r}, #8]")
        self.emit(f"ldr {tmp_r}, [{tmp_r}, #{self.itos(method_idx * 8)}]")
        self.emit(f"str {tmp_r}, [sp, #{self.itos(n * 8)}]")
        self.free_reg(tmp_r)
        self.free_reg(cell_r)
        let i = 0
        for i < len(args) {
            let arg_val = self.compile_expr(args[i].value)
            let arg_reg = self.load(arg_val)
            // Method param 0 is self; caller arg i maps to param i+1.
            let param_idx = i + 1
            if param_idx < len(sig_params) {
                let actual = self.infer_kind(args[i].value)
                arg_reg = self.maybe_box_for_iface(arg_reg, :actual, expected: sig_params[param_idx])
            }
            self.emit(f"str {arg_reg}, [sp, #{self.itos((i + 1) * 8)}]")
            self.free_reg(arg_reg)
            i = i + 1
        }
        let k = 0
        for k < n {
            self.emit(f"ldr {arg_regs[k]}, [sp, #{self.itos(k * 8)}]")
            k = k + 1
        }
        self.emit(f"ldr x9, [sp, #{self.itos(n * 8)}]")
        self.emit(f"add sp, sp, #{self.itos(padded)}")
        self.emit("blr x9")
        return .VReg(name: "x0")
    }

    // Find a primitive method registered via `register_primitive_module`.
    // Returns the entry index, or -1 if `kind` is not primitive or has no
    // method named `name`.
    func find_prim_method(self, anon name: str, kind: TypeKind) -> int64 {
        let i = 0
        for i < len(self.prim_methods) {
            let pm = self.prim_methods[i]
            if pm.name == name {
                let matches: bool = false
                match kind {
                    .KInt64 -> if pm.kind is .KInt64 { matches = true }
                    .KStr -> if pm.kind is .KStr { matches = true }
                    .KBool -> if pm.kind is .KBool { matches = true }
                    else none
                }
                if matches {
                    return i
                }
            }
            i = i + 1
        }
        return -1
    }

    func compile_method_call(self, anon args: [ast.CallArg], receiver_id: int64, method_name: str, span: ast.Span) -> Val {
        let recv_kind = self.infer_kind(receiver_id)

        // Interface dispatch: load vtable from the cell, then indirect call.
        if recv_kind is .KInterface(iface_idx) {
            return self.compile_iface_method_call(args, :receiver_id, :iface_idx, :method_name)
        }

        let method_lbl = ""
        let sig_params: [TypeKind] = []
        let sig_labels: [str] = []
        match recv_kind {
            .KStruct(idx, _struct_type_args) -> {
                if self.structs[idx].method_idx.get(method_name) is Some(mi) {
                    method_lbl = f"${self.structs[idx].module_prefix}${self.structs[idx].name}${method_name}"
                    sig_params = self.structs[idx].methods[mi].sig.param_kinds
                    sig_labels = self.structs[idx].methods[mi].sig.param_labels
                }
            }
            else none
        }
        // Primitive method dispatch (int64.to_str etc.) for non-struct
        // receivers — looked up against stdlib/primitives/<kind>.kod.
        if len(method_lbl) == 0 {
            let prim_idx = self.find_prim_method(method_name, kind: recv_kind)
            if prim_idx >= 0 {
                let pm = self.prim_methods[prim_idx]
                method_lbl = pm.label
                sig_params = pm.sig.param_kinds
                sig_labels = pm.sig.param_labels
            }
        }
        if len(method_lbl) == 0 {
            let recv_desc: str = "receiver"
            if self.p.exprs[receiver_id] is .Ident(recv_name) {
                recv_desc = recv_name
            }
            // Collect candidate method names for the typo hint: the
            // receiver's struct methods (if any) plus the primitive
            // methods registered for its kind.
            let cands: [str] = []
            match recv_kind {
                .KStruct(idx, _ta) -> {
                    for m in self.structs[idx].methods {
                        cands += [m.name]
                    }
                }
                else none
            }
            // Inline the (kind, kind) match — TypeKind is an enum and
            // pairwise comparison needs a destructure of both sides.
            for pm in self.prim_methods {
                let same: bool = false
                match recv_kind {
                    .KInt64 -> if pm.kind is .KInt64 { same = true }
                    .KStr -> if pm.kind is .KStr { same = true }
                    .KBool -> if pm.kind is .KBool { same = true }
                    else none
                }
                if same {
                    cands += [pm.name]
                }
            }
            let msg: str = self.with_suggestion(f"error: unknown method `{method_name}` on `{recv_desc}`", typo: method_name, candidates: cands)
            self.report_error(msg, :span)
            return .VImm(value: 0)
        }
        self.check_call_args(args, param_labels: sig_labels, skip: 1, call_name: method_name, call_span: span)

        // Stash self and each compiled arg on the stack so that arg
        // expressions (which may issue bl calls) don't clobber preceding
        // values held in x0..x7.
        let arg_regs: [str] = ["x0", "x1", "x2", "x3", "x4", "x5", "x6", "x7"]
        let n = len(args) + 1
        let padded = n * 8
        if padded % 16 != 0 {
            padded = padded + 8
        }
        self.emit(f"sub sp, sp, #{self.itos(padded)}")
        let recv_val = self.compile_expr(receiver_id)
        self.mov_to(recv_val, dest: "x0")
        self.emit("str x0, [sp]")
        let i = 0
        for i < len(args) {
            let arg_val = self.compile_expr(args[i].value)
            let arg_reg = self.load(arg_val)
            // Method param 0 is self; caller arg i maps to param i+1.
            let param_idx = i + 1
            if param_idx < len(sig_params) {
                let actual = self.infer_kind(args[i].value)
                arg_reg = self.maybe_box_for_iface(arg_reg, :actual, expected: sig_params[param_idx])
            }
            self.emit(f"str {arg_reg}, [sp, #{self.itos((i + 1) * 8)}]")
            self.free_reg(arg_reg)
            i = i + 1
        }
        let k = 0
        for k < n {
            self.emit(f"ldr {arg_regs[k]}, [sp, #{self.itos(k * 8)}]")
            k = k + 1
        }
        self.emit(f"add sp, sp, #{self.itos(padded)}")
        self.emit(f"bl {method_lbl}")
        return .VReg(name: "x0")
    }

    // Box `arg_reg` (an arena pointer to a struct of kind .KStruct(si, _struct_type_args))
    // into an arena-allocated {data_ptr, vtable_ptr} cell for interface
    // ii. Returns a fresh register holding the cell pointer. Frees the
    // input register.
    func emit_iface_box(self, anon arg_reg: str, struct_idx: int64, iface_idx: int64) -> str {
        let vt_lbl = self.register_vtable(struct_idx, iface_idx)
        self.emit("sub sp, sp, #16")
        self.emit(f"str {arg_reg}, [sp]")
        self.free_reg(arg_reg)
        self.emit("mov x0, #16")
        self.emit("bl _arena_alloc")
        let data_r = self.alloc_reg()
        self.emit(f"ldr {data_r}, [sp]")
        self.emit("add sp, sp, #16")
        self.emit(f"str {data_r}, [x0]")
        self.free_reg(data_r)
        let vt_r = self.alloc_reg()
        self.emit(f"adrp {vt_r}, {vt_lbl}@PAGE")
        self.emit(f"add {vt_r}, {vt_r}, {vt_lbl}@PAGEOFF")
        self.emit(f"str {vt_r}, [x0, #8]")
        self.free_reg(vt_r)
        let cell_r = self.alloc_reg()
        self.emit(f"mov {cell_r}, x0")
        return cell_r
    }

    // If expected kind is KInterface and actual is KStruct, perform an
    // implicit upcast: box the struct pointer in a {data, vtable} cell
    // and return the new register. Otherwise returns the input register.
    func maybe_box_for_iface(self, anon arg_reg: str, actual: TypeKind, expected: TypeKind) -> str {
        let .KInterface(iface_idx) = expected else { return arg_reg }
        match actual {
            .KStruct(struct_idx, _struct_type_args) -> return self.emit_iface_box(arg_reg, :struct_idx, :iface_idx)
            .KInt64 -> return self.emit_prim_iface_box(arg_reg, kind: .KInt64, :iface_idx)
            .KStr -> return self.emit_prim_iface_box(arg_reg, kind: .KStr, :iface_idx)
            .KBool -> return self.emit_prim_iface_box(arg_reg, kind: .KBool, :iface_idx)
            else return arg_reg
        }
    }

    // Box a primitive value (int64 / str / bool) into a {data, vtable}
    // iface cell. The primitive value is stored *directly* in the data
    // slot — vtable methods receive it as `self` in x0. Mirrors
    // emit_iface_box but reaches a primitive's vtable.
    func emit_prim_iface_box(self, anon arg_reg: str, kind: TypeKind, iface_idx: int64) -> str {
        let vt_lbl = self.register_prim_vtable(iface_idx, :kind)
        self.emit("sub sp, sp, #16")
        self.emit(f"str {arg_reg}, [sp]")
        self.free_reg(arg_reg)
        self.emit("mov x0, #16")
        self.emit("bl _arena_alloc")
        let data_r = self.alloc_reg()
        self.emit(f"ldr {data_r}, [sp]")
        self.emit("add sp, sp, #16")
        self.emit(f"str {data_r}, [x0]")
        self.free_reg(data_r)
        let vt_r = self.alloc_reg()
        self.emit(f"adrp {vt_r}, {vt_lbl}@PAGE")
        self.emit(f"add {vt_r}, {vt_r}, {vt_lbl}@PAGEOFF")
        self.emit(f"str {vt_r}, [x0, #8]")
        self.free_reg(vt_r)
        let cell_r = self.alloc_reg()
        self.emit(f"mov {cell_r}, x0")
        return cell_r
    }

    func prepare_args(self, anon args: [ast.CallArg]) -> none {
        let empty: [TypeKind] = []
        self.prepare_args_with_kinds(args, expected_kinds: empty)
    }

    func prepare_args_with_kinds(self, anon args: [ast.CallArg], expected_kinds: [TypeKind]) -> none {
        let arg_regs: [str] = ["x0", "x1", "x2", "x3", "x4", "x5", "x6", "x7"]
        let n = len(args)
        if n == 0 {
            return none
        }
        // Reserve 16-byte aligned stack space and stash each compiled arg
        // there. Compiling an arg may issue bl calls (e.g. into match
        // expressions, struct/enum construction, array concat) which would
        // clobber any earlier args we'd already placed into x0..x7.
        let padded = n * 8
        if padded % 16 != 0 {
            padded = padded + 8
        }
        self.emit(f"sub sp, sp, #{self.itos(padded)}")
        let i = 0
        for i < n {
            let arg_val = self.compile_expr(args[i].value)
            let arg_reg = self.load(arg_val)
            if i < len(expected_kinds) {
                let actual = self.infer_kind(args[i].value)
                arg_reg = self.maybe_box_for_iface(arg_reg, :actual, expected: expected_kinds[i])
            }
            self.emit(f"str {arg_reg}, [sp, #{self.itos(i * 8)}]")
            self.free_reg(arg_reg)
            i = i + 1
        }
        let k = 0
        for k < n {
            self.emit(f"ldr {arg_regs[k]}, [sp, #{self.itos(k * 8)}]")
            k = k + 1
        }
        self.emit(f"add sp, sp, #{self.itos(padded)}")
    }

    func compile_match_expr(self, anon arms: [int64], subject_id: int64) -> Val {
        let expr_patterns: [int64] = []
        for arm_id in arms {
            expr_patterns += [self.p.match_expr_arms[arm_id].pattern]
        }
        self.check_match_exhaustive(subject_id, pattern_ids: expr_patterns)
        let done_lbl = self.fresh("Lmexpr_done")
        let subj_val = self.compile_expr(subject_id)
        let sptr_r = self.load(subj_val)
        let subj_slot = self.alloc_var(name: self.fresh("__msubj"), kind: .KInt64)
        self.emit_str(subj_slot, reg: sptr_r)
        self.free_reg(sptr_r)
        let disc_val = .VStack(offset: subj_slot)
        let disc_r = self.load_enum_or_val(disc_val, expr_id: subject_id)
        let result_r = self.alloc_reg()
        let i = 0
        for i < len(arms) {
            let arm = self.p.match_expr_arms[arms[i]]
            let skip_lbl = self.fresh("Lmexpr_skip")
            match self.p.patterns[arm.pattern] {
                .Wildcard -> {
                    let body_val = self.compile_expr(arm.body)
                    self.mov_to(body_val, dest: result_r)
                    self.emit(f"b {done_lbl}")
                }
                .IntPat(value) -> {
                    self.emit(f"cmp {disc_r}, #{self.itos(value)}")
                    self.emit(f"bne {skip_lbl}")
                    let body_val = self.compile_expr(arm.body)
                    self.mov_to(body_val, dest: result_r)
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .BoolPat(value) -> {
                    let lit = 0
                    if value {
                        lit = 1
                    }
                    self.emit(f"cmp {disc_r}, #{self.itos(lit)}")
                    self.emit(f"bne {skip_lbl}")
                    let body_val = self.compile_expr(arm.body)
                    self.mov_to(body_val, dest: result_r)
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .StrPat(value) -> {
                    let slbl = self.intern_str(value)
                    self.emit(f"adrp x0, {slbl}@PAGE")
                    self.emit(f"add x0, x0, {slbl}@PAGEOFF")
                    // Reload from subj_slot — disc_r may have been clobbered
                    // by a prior arm's `bl _kod_str_cmp`.
                    self.emit_ldr(subj_slot, reg: "x1")
                    self.emit("bl _kod_str_cmp")
                    self.emit("cmp x0, #0")
                    self.emit(f"bne {skip_lbl}")
                    let body_val = self.compile_expr(arm.body)
                    self.mov_to(body_val, dest: result_r)
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .EnumPat(enum_name, variant_name, bindings) -> {
                    let enum_idx = self.find_enum_idx(enum_name)
                    let variant_idx = self.find_variant_idx(variant_name, :enum_idx)
                    let disc = self.enums[enum_idx].variants[variant_idx].discriminant
                    self.emit(f"cmp {disc_r}, #{self.itos(disc)}")
                    self.emit(f"bne {skip_lbl}")
                    let body_val = self.compile_expr(arm.body)
                    self.mov_to(body_val, dest: result_r)
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .ImplicitEnumPat(variant_name, bindings) -> {
                    let enum_idx = self.find_enum_with_variant(variant_name)
                    let variant_idx = self.find_variant_idx(variant_name, :enum_idx)
                    let disc = self.enums[enum_idx].variants[variant_idx].discriminant
                    self.emit(f"cmp {disc_r}, #{self.itos(disc)}")
                    self.emit(f"bne {skip_lbl}")
                    let body_val = self.compile_expr(arm.body)
                    self.mov_to(body_val, dest: result_r)
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .NonePat -> {
                    self.emit(f"cmp {disc_r}, #0")
                    self.emit(f"bne {skip_lbl}")
                    let body_val = self.compile_expr(arm.body)
                    self.mov_to(body_val, dest: result_r)
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .SomePat(binding) -> {
                    self.emit(f"cmp {disc_r}, #0")
                    self.emit(f"beq {skip_lbl}")
                    if len(binding) > 0 {
                        let boff = self.find_var_offset(binding)
                        let ptr_r = self.alloc_reg()
                        self.emit_ldr(subj_slot, reg: ptr_r)
                        let val_r = self.alloc_reg()
                        self.emit(f"ldr {val_r}, [{ptr_r}]")
                        self.emit_str(boff, reg: val_r)
                        self.free_reg(val_r)
                        self.free_reg(ptr_r)
                    }
                    let body_val = self.compile_expr(arm.body)
                    self.mov_to(body_val, dest: result_r)
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                else {
                    let body_val = self.compile_expr(arm.body)
                    self.mov_to(body_val, dest: result_r)
                    self.emit(f"b {done_lbl}")
                }
            }
            i = i + 1
        }
        self.emit_label(done_lbl)
        self.free_reg(disc_r)
        return .VReg(name: result_r)
    }


    // For `obj.method()` where obj is a known struct, return the method's
    // recorded return kind. Returns none if anything about the shape doesn't
    // match (callee not Ident.Ident, obj not a struct, method not found).
    func method_call_return_kind(self, callee_lhs: int64, callee_rhs: int64) -> TypeKind? {
        let .Ident(method_name) = self.p.exprs[callee_rhs] else { return none }
        // Recurse via infer_kind so receivers like `0.to_str()` (IntLit
        // receiver) or `p.field.to_str()` (Binary.Dot receiver) get the
        // right kind, not just bare `var.method()`.
        let obj_kind = self.infer_kind(callee_lhs)
        if obj_kind is .KInterface(iidx) {
            let method_idx = 0
            for method_idx < len(self.interfaces[iidx].methods) {
                if self.interfaces[iidx].methods[method_idx].name == method_name {
                    return self.interfaces[iidx].methods[method_idx].sig.return_kind
                }
                method_idx = method_idx + 1
            }
            return none
        }
        if obj_kind is .KStruct(sidx, _struct_type_args) {
            if self.structs[sidx].method_idx.get(method_name) is Some(mi) {
                return self.structs[sidx].methods[mi].sig.return_kind
            }
            return none
        }
        // Primitive receivers (int64.to_str, str.hash, etc.) go through
        // the primitive method table.
        let prim_idx = self.find_prim_method(method_name, kind: obj_kind)
        if prim_idx >= 0 {
            return self.prim_methods[prim_idx].sig.return_kind
        }
        // Module-qualified call `mod.func(...)`: the lhs is an import alias,
        // not a value-typed receiver. Run last so a struct/iface/primitive
        // method on the same name (none in tree today, but plausible)
        // takes precedence.
        match self.p.exprs[callee_lhs] {
            .Ident(maybe_mod) -> {
                let i = 0
                for i < len(self.import_local) {
                    if self.import_local[i] == maybe_mod {
                        return self.find_import_fn_sig(maybe_mod, method_name).return_kind
                    }
                    i = i + 1
                }
            }
            else none
        }
        return none
    }

    // For an expression of shape `mod.Enum.Variant`, return KEnum(idx).
    func three_part_enum_kind(self, dot_lhs: int64) -> TypeKind? {
        let .Binary(inner_lhs, inner_op, inner_rhs) = self.p.exprs[dot_lhs] else { return none }
        let .Dot = inner_op else { return none }
        let .Ident(enum_name) = self.p.exprs[inner_rhs] else { return none }
        let enum_idx = self.find_enum_idx(enum_name)
        if enum_idx < 0 { return none }
        return .KEnum(idx: enum_idx)
    }

    // For `EnumName.X`, return KEnum(idx). (X is checked at the call site.)
    func two_part_enum_kind(self, dot_lhs: int64) -> TypeKind? {
        let .Ident(type_name) = self.p.exprs[dot_lhs] else { return none }
        let enum_idx = self.find_enum_idx(type_name)
        if enum_idx < 0 { return none }
        return .KEnum(idx: enum_idx)
    }

    // Look up a struct field's kind by name. Returns none if absent.
    func struct_field_kind(self, struct_idx: int64, field_name: str) -> TypeKind? {
        let field_idx = 0
        for field_idx < len(self.structs[struct_idx].fields) {
            if self.structs[struct_idx].fields[field_idx].name == field_name {
                return self.structs[struct_idx].fields[field_idx].kind
            }
            field_idx = field_idx + 1
        }
        return none
    }

    func infer_kind(self, anon expr_id: int64) -> TypeKind {
        match self.p.exprs[expr_id] {
            .IntLit(value) -> return .KInt64
            .BoolLit(value) -> return .KBool
            .StrLit(value) -> return .KStr
            .NoneLit -> return .KOptional(inner: .KVoid)
            .Ident(name) -> return self.find_var_kind(name)
            .ArrayLit(elements) -> return .KArray
            .Slice(s, lo, hi) -> return .KStr
            .ImplicitVariant(name) -> {
                let enum_idx = self.find_enum_with_variant(name)
                if enum_idx >= 0 {
                    return .KEnum(idx: enum_idx)
                }
                return .KInt64
            }
            .Call(callee, args) -> {
                match self.p.exprs[callee] {
                    .Ident(name) -> {
                        // `str(x)` intrinsic always yields a string.
                        if name == "str" {
                            return .KStr
                        }
                        // `hash(x)` intrinsic always yields an int64.
                        if name == "hash" {
                            return .KInt64
                        }
                        // Struct or enum constructor: TypeName(...)
                        let struct_idx = self.find_struct_idx(name)
                        if struct_idx >= 0 {
                            return .KStruct(idx: struct_idx, type_args: [])
                        }
                        let enum_idx = self.find_enum_idx(name)
                        if enum_idx >= 0 {
                            return .KEnum(idx: enum_idx)
                        }
                        // Free function call: use the cached return kind.
                        let idx_m = self.func_idx
                        if idx_m.get(name) is Some(idx) {
                            return self.func_sigs[idx].return_kind
                        }
                    }
                    .Binary(call_lhs, call_op, call_rhs) -> {
                        let .Dot = call_op else { return .KInt64 }
                        if self.method_call_return_kind(callee_lhs: call_lhs, callee_rhs: call_rhs) is Some(k) {
                            return k
                        }
                    }
                    .ImplicitVariant(variant_name) -> {
                        // .Variant(args) — constructor for an enum.
                        let ei2 = self.find_enum_with_variant(variant_name)
                        if ei2 >= 0 {
                            return .KEnum(idx: ei2)
                        }
                    }
                    else none
                }
                return .KInt64
            }
            .Binary(lhs, op, rhs) -> {
                match op {
                    .Dot -> {
                        // `mod.Enum.Variant` or `Enum.Variant` — unit-variant ref.
                        if self.three_part_enum_kind(dot_lhs: lhs) is Some(k) {
                            return k
                        }
                        if self.two_part_enum_kind(dot_lhs: lhs) is Some(k) {
                            return k
                        }
                        // Field access on any struct-valued expression.
                        let .KStruct(struct_idx, _struct_type_args) = self.infer_kind(lhs) else { return .KInt64 }
                        let .Ident(field_name) = self.p.exprs[rhs] else { return .KInt64 }
                        match self.struct_field_kind(:struct_idx, :field_name) {
                            Some(k) -> return k
                            none -> return .KInt64
                        }
                    }
                    .Add -> return self.infer_kind(lhs)
                    .Index -> {
                        match self.infer_kind(lhs) {
                            .KArrayStruct(elem_idx) -> return .KStruct(idx: elem_idx, type_args: [])
                            .KArrayEnum(elem_idx) -> return .KEnum(idx: elem_idx)
                            .KArrayStr -> return .KStr
                            .KStruct(sidx, _struct_type_args) -> {
                                // Struct with op_index — return its return kind.
                                if self.structs[sidx].method_idx.get("op_index") is Some(mi) {
                                    return self.structs[sidx].methods[mi].sig.return_kind
                                }
                                return .KInt64
                            }
                            else return .KInt64
                        }
                    }
                    else return .KInt64
                }
            }
            .Try(inner) -> {
                let k = self.infer_kind(inner)
                if k is .KResult(inner_kind) {
                    return inner_kind
                }
                return k
            }
            .Must(inner) -> {
                let k = self.infer_kind(inner)
                if k is .KResult(inner_kind) {
                    return inner_kind
                }
                return k
            }
            else return .KInt64
        }
    }


    func compile_stmt(self, anon stmt_id: int64) -> none {
        match self.p.stmts[stmt_id] {
            .Let(name, typ, value) -> self.compile_let(:name, :typ, :value)
            .Assign(lhs, rhs) -> self.compile_assign(lhs_id: lhs, rhs_id: rhs)
            .PlusAssign(lhs, rhs) -> self.compile_plus_assign(lhs_id: lhs, rhs_id: rhs)
            .Return(value) -> self.compile_return(value)
            .If(cond, then_body, else_body) -> self.compile_if(cond_id: cond, :then_body, :else_body)
            .For(cond, body) -> self.compile_for(body, cond_id: cond)
            .ForEach(name, iter, body) -> self.compile_foreach(body, :name, iter_id: iter)
            .Break -> self.compile_break()
            .Continue -> self.compile_continue()
            .ExprStmt(expr) -> {
                let val = self.compile_expr(expr)
                self.free_val(val)
            }
            .MatchStmt(subject, arms) -> self.compile_match_stmt(arms, subject_id: subject)
            .LetElse(pattern, value, else_body) -> self.compile_let_else(else_body, pattern_id: pattern, value_id: value)
            .Throw(value) -> self.compile_throw(value)
            .Assert(expr, source_text, span) -> self.compile_assert(expr, :source_text, :span)
        }
    }

    func compile_let(self, name: str, typ: int64, value: int64) -> none {
        let off = self.find_var_offset(name)
        let kind = self.resolve_type(typ)
        if kind is .KVoid {
            kind = self.infer_kind(value)
        }
        let i = 0
        for i < len(self.vars) {
            if self.vars[i].name == name {
                self.vars[i].kind = kind
                i = len(self.vars)
            } else {
                i = i + 1
            }
        }
        self.compile_store(dest_off: off, :kind, value_id: value)
    }

    func compile_store(self, dest_off: int64, kind: TypeKind, value_id: int64) -> none {
        match kind {
            .KEnum(idx) -> {
                self.emit_enum_alloc(enum_idx: idx, :value_id, :dest_off)
            }
            .KStruct(idx, _struct_type_args) -> {
                // If the source is a value already producing a struct pointer
                // (variable alias, call result, or constructor expression),
                // just store the pointer — preserve reference semantics.
                let alias = false
                match self.p.exprs[value_id] {
                    .Ident(name) -> {
                        if self.find_var_kind(name) is .KStruct(other, _struct_type_args) {
                            alias = true
                        }
                    }
                    .Call(callee, args) -> alias = true
                    .Binary(blhs, bop, brhs) -> {
                        match bop {
                            .Index -> alias = true
                            .Dot -> alias = true
                            else none
                        }
                    }
                    else none
                }
                if alias {
                    let val = self.compile_expr(value_id)
                    let reg = self.load(val)
                    self.emit_str(dest_off, :reg)
                    self.free_reg(reg)
                } else {
                    self.emit_struct_alloc(struct_idx: idx, :value_id, :dest_off)
                }
            }
            .KArray -> {
                let val = self.compile_expr(value_id)
                let reg = self.load(val)
                self.emit_str(dest_off, :reg)
                self.free_reg(reg)
            }
            .KArrayStruct(elem_idx) -> {
                let val = self.compile_expr(value_id)
                let reg = self.load(val)
                self.emit_str(dest_off, :reg)
                self.free_reg(reg)
            }
            .KArrayEnum(elem_idx) -> {
                let val = self.compile_expr(value_id)
                let reg = self.load(val)
                self.emit_str(dest_off, :reg)
                self.free_reg(reg)
            }
            .KArrayStr -> {
                let val = self.compile_expr(value_id)
                let reg = self.load(val)
                self.emit_str(dest_off, :reg)
                self.free_reg(reg)
            }
            .KInterface(iface_idx) -> {
                // Box a struct into a {data, vtable} iface cell when the
                // declared type is an interface; passing a struct value to
                // an iface-typed binding otherwise stores the raw struct
                // pointer, and the next method call would treat it as a
                // cell and load garbage from offset 8.
                let val = self.compile_expr(value_id)
                let reg = self.load(val)
                let actual = self.infer_kind(value_id)
                reg = self.maybe_box_for_iface(reg, :actual, expected: .KInterface(idx: iface_idx))
                self.emit_str(dest_off, :reg)
                self.free_reg(reg)
            }
            .KOptional(inner) -> {
                // Wrap into an Optional cell unless the value is already an
                // Optional (NoneLit, Call return, or an inferred-Optional expr).
                let needs_wrap = true
                match self.p.exprs[value_id] {
                    .NoneLit -> needs_wrap = false
                    .Call(callee, args) -> needs_wrap = false
                    else none
                }
                if needs_wrap {
                    if self.infer_kind(value_id) is .KOptional(inner2) {
                        needs_wrap = false
                    }
                }
                if needs_wrap == false {
                    let wrapped_val = self.compile_expr(value_id)
                    let val_reg = self.load(wrapped_val)
                    self.emit_str(dest_off, reg: val_reg)
                    self.free_reg(val_reg)
                } else {
                    let wrapped_val = self.compile_expr(value_id)
                    let val_reg = self.load(wrapped_val)
                    self.emit("sub sp, sp, #16")
                    self.emit(f"str {val_reg}, [sp]")
                    self.free_reg(val_reg)
                    self.emit("mov x0, #8")
                    self.emit("bl _arena_alloc")
                    let ptr_reg = self.alloc_reg()
                    self.emit(f"mov {ptr_reg}, x0")
                    self.emit_str(dest_off, reg: ptr_reg)
                    let tmp = self.alloc_reg()
                    self.emit(f"ldr {tmp}, [sp]")
                    self.emit("add sp, sp, #16")
                    self.emit(f"str {tmp}, [{ptr_reg}]")
                    self.free_reg(tmp)
                    self.free_reg(ptr_reg)
                }
            }
            else {
                let val = self.compile_expr(value_id)
                let reg = self.load(val)
                self.emit_str(dest_off, :reg)
                self.free_reg(reg)
            }
        }
    }

    // Allocate a struct value on the arena and return its pointer in x0.
    // field_args supplies the labelled field values.
    func compile_struct_construct(self, anon field_args: [ast.CallArg], struct_idx: int64) -> Val {
        let data_width = self.structs[struct_idx].data_width
        self.emit_load_imm("x0", value: data_width)
        self.emit("bl _arena_alloc")
        let ptr_r = self.alloc_reg()
        self.emit(f"mov {ptr_r}, x0")
        for arg in field_args {
            if self.has_field(arg.label, :struct_idx) == false {
                let field_names: [str] = []
                for f in self.structs[struct_idx].fields {
                    field_names += [f.name]
                }
                let msg: str = self.with_suggestion(f"error: struct `{self.structs[struct_idx].name}` has no field `{arg.label}`", typo: arg.label, candidates: field_names)
                self.report_error(msg, span: arg.label_span)
            }
            let foff = self.find_field_offset(arg.label, :struct_idx)
            // Stash ptr_r across the call so it survives any bl in the
            // field expression.
            self.emit("sub sp, sp, #16")
            self.emit(f"str {ptr_r}, [sp]")
            let field_val = self.compile_expr(arg.value)
            let field_reg = self.load(field_val)
            self.emit(f"ldr {ptr_r}, [sp]")
            self.emit("add sp, sp, #16")
            self.emit(f"str {field_reg}, [{ptr_r}, #{self.itos(foff)}]")
            self.free_reg(field_reg)
        }
        self.emit(f"mov x0, {ptr_r}")
        self.free_reg(ptr_r)
        return .VReg(name: "x0")
    }

    // Allocate an enum value on the arena and return its pointer in x0.
    // field_args supplies payload values (empty for unit variants).
    func compile_enum_construct(self, anon field_args: [ast.CallArg], enum_idx: int64, variant_idx: int64) -> Val {
        let data_width = self.enums[enum_idx].data_width
        let disc = self.enums[enum_idx].variants[variant_idx].discriminant
        self.emit_load_imm("x0", value: data_width)
        self.emit("bl _arena_alloc")
        let ptr_r = self.alloc_reg()
        self.emit(f"mov {ptr_r}, x0")
        let disc_r = self.alloc_reg()
        self.emit_load_imm(disc_r, value: disc)
        self.emit(f"str {disc_r}, [{ptr_r}]")
        self.free_reg(disc_r)
        if len(field_args) > 0 {
            let vinfo = self.enums[enum_idx].variants[variant_idx]
            let i = 0
            for i < len(field_args) {
                let foff = vinfo.field_offsets[i]
                // Stash ptr_r across the call so it survives any bl in the
                // field expression.
                self.emit("sub sp, sp, #16")
                self.emit(f"str {ptr_r}, [sp]")
                let field_val = self.compile_expr(field_args[i].value)
                let field_reg = self.load(field_val)
                self.emit(f"ldr {ptr_r}, [sp]")
                self.emit("add sp, sp, #16")
                self.emit(f"str {field_reg}, [{ptr_r}, #{self.itos(8 + foff)}]")
                self.free_reg(field_reg)
                i = i + 1
            }
        }
        self.emit(f"mov x0, {ptr_r}")
        self.free_reg(ptr_r)
        return .VReg(name: "x0")
    }

    // For an expression that looks like a dotted variant reference, return
    // the variant name. Handles `.Variant`, `Enum.Variant`, and the Dot side
    // of `Enum.Variant(args)`.
    func dotted_variant_name(self, expr_id: int64) -> str? {
        if self.p.exprs[expr_id] is .ImplicitVariant(variant_name) {
            return variant_name
        }
        let .Binary(lhs, op, rhs) = self.p.exprs[expr_id] else { return none }
        let .Dot = op else { return none }
        let .Ident(variant_name) = self.p.exprs[rhs] else { return none }
        return variant_name
    }

    func emit_enum_alloc(self, enum_idx: int64, value_id: int64, dest_off: int64) -> none {
        // Detect direct enum construction patterns and route through
        // compile_enum_construct; otherwise compile the expression and store
        // its (pointer) result.
        let variant_idx = -1
        let field_args: [ast.CallArg] = []
        // Bare-variant cases: .Variant or Enum.Variant
        if self.dotted_variant_name(expr_id: value_id) is Some(name) {
            variant_idx = self.find_variant_idx(name, :enum_idx)
        }
        // Variant-with-args case: <dotted>(args)
        match self.p.exprs[value_id] {
            .Call(callee_id, call_args) -> {
                match self.dotted_variant_name(expr_id: callee_id) {
                    Some(name) -> {
                        variant_idx = self.find_variant_idx(name, :enum_idx)
                        field_args = call_args
                    }
                    none -> {}
                }
            }
            else none
        }
        if variant_idx >= 0 {
            let val = self.compile_enum_construct(field_args, :enum_idx, :variant_idx)
            self.emit_str(dest_off, reg: "x0")
        } else {
            let val = self.compile_expr(value_id)
            let reg = self.load(val)
            self.emit_str(dest_off, :reg)
            self.free_reg(reg)
        }
    }

    func emit_struct_alloc(self, struct_idx: int64, value_id: int64, dest_off: int64) -> none {
        let data_width = self.structs[struct_idx].data_width
        self.emit_load_imm("x0", value: data_width)
        self.emit("bl _arena_alloc")
        let ptr_r = self.alloc_reg()
        self.emit(f"mov {ptr_r}, x0")
        self.emit_str(dest_off, reg: ptr_r)
        self.free_reg(ptr_r)
        match self.p.exprs[value_id] {
            .Call(callee_id, args) -> {
                let i = 0
                for i < len(args) {
                    let arg = args[i]
                    let foff = self.find_field_offset(arg.label, :struct_idx)
                    let field_val = self.compile_expr(arg.value)
                    let field_reg = self.load(field_val)
                    let ptr_reg = self.alloc_reg()
                    self.emit_ldr(dest_off, reg: ptr_reg)
                    self.emit(f"str {field_reg}, [{ptr_reg}, #{self.itos(foff)}]")
                    self.free_reg(field_reg)
                    self.free_reg(ptr_reg)
                    i = i + 1
                }
            }
            else none
        }
    }

    // Compile `<lhs>.<field> = <rhs>` for any lhs expression that yields a
    // struct pointer.
    func compile_field_assign(self, lhs: int64, rhs: int64, rhs_id: int64) -> none {
        let .Ident(field_name) = self.p.exprs[rhs] else { return }
        let struct_idx = -1
        if self.infer_kind(lhs) is .KStruct(idx, _struct_type_args) {
            struct_idx = idx
        }
        let foff = 0
        if struct_idx >= 0 {
            foff = self.find_field_offset(field_name, :struct_idx)
        }
        // Compute rhs first, stash on stack, then compute the lhs pointer.
        let rhs_val = self.compile_expr(rhs_id)
        let rhs_reg = self.load(rhs_val)
        self.emit("sub sp, sp, #16")
        self.emit(f"str {rhs_reg}, [sp]")
        self.free_reg(rhs_reg)
        let ptr_val = self.compile_expr(lhs)
        let ptr_reg = self.load(ptr_val)
        let tmp_reg = self.alloc_reg()
        self.emit(f"ldr {tmp_reg}, [sp]")
        self.emit("add sp, sp, #16")
        self.emit(f"str {tmp_reg}, [{ptr_reg}, #{self.itos(foff)}]")
        self.free_reg(tmp_reg)
        self.free_reg(ptr_reg)
    }

    // Look up `op_index_set` on a struct, returning its mangled label.
    func struct_index_setter_label(self, struct_idx: int64) -> str? {
        if self.structs[struct_idx].method_idx.get("op_index_set") is Some(_mi) {
            return f"${self.structs[struct_idx].module_prefix}${self.structs[struct_idx].name}$op_index_set"
        }
        return none
    }

    // Compile `<arr>[<key>] = <rhs>` for Ident-named arr. Dispatches to
    // op_index_set when available; otherwise plain array indexed store.
    func compile_index_assign(self, lhs: int64, rhs: int64, rhs_id: int64) -> none {
        let .Ident(arr_name) = self.p.exprs[lhs] else { return }
        let struct_idx = -1
        if self.find_var_kind(arr_name) is .KStruct(struct_idx, _struct_type_args) {
            struct_idx = struct_idx
        }
        let setter: str? = none
        if struct_idx >= 0 {
            setter = self.struct_index_setter_label(:struct_idx)
        }
        match setter {
            Some(method_lbl) -> {
                // Compile rhs first (clean register state), stash, then key,
                // then load the array and call.
                let rhs_v = self.compile_expr(rhs_id)
                let rhs_r = self.alloc_reg()
                self.mov_to(rhs_v, dest: rhs_r)
                self.emit("sub sp, sp, #16")
                self.emit(f"str {rhs_r}, [sp]")
                self.free_reg(rhs_r)
                let key_val = self.compile_expr(rhs)
                let key_reg = self.alloc_reg()
                self.mov_to(key_val, dest: key_reg)
                let arr_off = self.find_var_offset(arr_name)
                self.emit_ldr(arr_off, reg: "x0")
                self.emit(f"mov x1, {key_reg}")
                self.free_reg(key_reg)
                self.emit("ldr x2, [sp]")
                self.emit("add sp, sp, #16")
                self.emit(f"bl {method_lbl}")
            }
            none -> {
                let arr_off = self.find_var_offset(arr_name)
                let idx_v = self.compile_expr(rhs)
                let idx_r = self.load(idx_v)
                // Spill the index to the stack before evaluating the RHS.
                // If the RHS includes a `bl` (e.g. a struct constructor
                // calling _arena_alloc) it would clobber whichever reg
                // idx_r happens to live in, sending the str below to a
                // wild offset. Reload after the RHS is in hand.
                self.emit("sub sp, sp, #16")
                self.emit(f"str {idx_r}, [sp]")
                self.free_reg(idx_r)
                let rhs_v = self.compile_expr(rhs_id)
                let rhs_r = self.load(rhs_v)
                let arr_ptr_r = self.alloc_reg()
                self.emit_ldr(arr_off, reg: arr_ptr_r)
                let buf_r = self.alloc_reg()
                self.emit(f"ldr {buf_r}, [{arr_ptr_r}]")
                let len_r = self.alloc_reg()
                self.emit(f"ldr {len_r}, [{arr_ptr_r}, #8]")
                self.free_reg(arr_ptr_r)
                let reloaded_idx_r = self.alloc_reg()
                self.emit(f"ldr {reloaded_idx_r}, [sp]")
                self.emit("add sp, sp, #16")
                // Normalise negative index: if idx < 0, idx += len.
                // Then bounds-check via unsigned compare. Mirrors the
                // read path in compile_index — without the check a
                // `buf[oob_idx] = ...` silently wrote into whatever
                // memory followed the array's buf.
                let pos_lbl = self.fresh("Lidx_pos")
                self.emit(f"cmp {reloaded_idx_r}, #0")
                self.emit(f"bge {pos_lbl}")
                self.emit(f"add {reloaded_idx_r}, {reloaded_idx_r}, {len_r}")
                self.emit_label(pos_lbl)
                let ok_lbl = self.fresh("Lidx_ok")
                let oob_lbl = self.fresh("Lidx_oob")
                self.emit(f"cmp {reloaded_idx_r}, {len_r}")
                self.emit(f"b.hs {oob_lbl}")
                self.emit(f"b {ok_lbl}")
                self.emit_label(oob_lbl)
                self.emit(f"mov x0, {reloaded_idx_r}")
                self.emit(f"mov x1, {len_r}")
                self.emit("bl _kod_index_oob")
                self.emit_label(ok_lbl)
                self.free_reg(len_r)
                self.emit(f"lsl {reloaded_idx_r}, {reloaded_idx_r}, #3")
                self.emit(f"str {rhs_r}, [{buf_r}, {reloaded_idx_r}]")
                self.free_reg(buf_r)
                self.free_reg(reloaded_idx_r)
                self.free_reg(rhs_r)
            }
        }
    }

    func compile_assign(self, lhs_id: int64, rhs_id: int64) -> none {
        match self.p.exprs[lhs_id] {
            .Ident(name) -> {
                let off = self.find_var_offset(name)
                let kind = self.find_var_kind(name)
                self.compile_store(dest_off: off, :kind, value_id: rhs_id)
            }
            .Binary(lhs2, op, rhs2) -> {
                match op {
                    .Dot -> self.compile_field_assign(lhs: lhs2, rhs: rhs2, :rhs_id)
                    .Index -> self.compile_index_assign(lhs: lhs2, rhs: rhs2, :rhs_id)
                    else none
                }
            }
            else none
        }
    }

    func find_field_kind(self, anon field_name: str, struct_idx: int64) -> TypeKind {
        let field_idx = 0
        for field_idx < len(self.structs[struct_idx].fields) {
            if self.structs[struct_idx].fields[field_idx].name == field_name {
                return self.structs[struct_idx].fields[field_idx].kind
            }
            field_idx = field_idx + 1
        }
        return .KInt64
    }

    func compile_plus_assign(self, lhs_id: int64, rhs_id: int64) -> none {
        match self.p.exprs[lhs_id] {
            .Binary(lhs2, op, rhs2) -> {
                match op {
                    .Dot -> {
                        match self.p.exprs[lhs2] {
                            .Ident(obj_name) -> {
                                match self.p.exprs[rhs2] {
                                    .Ident(field_name) -> {
                                        let obj_off = self.find_var_offset(obj_name)
                                        let struct_idx = -1
                                        if self.find_var_kind(obj_name) is .KStruct(idx, _struct_type_args) {
                                            struct_idx = idx
                                        }
                                        let foff = 0
                                        let field_kind = .KInt64
                                        if struct_idx >= 0 {
                                            foff = self.find_field_offset(field_name, :struct_idx)
                                            field_kind = self.find_field_kind(field_name, :struct_idx)
                                        }
                                        let is_arr = false
                                        let is_str = false
                                        match field_kind {
                                            .KArray -> is_arr = true
                                            .KArrayStruct(elem_idx) -> is_arr = true
                                            .KArrayEnum(elem_idx) -> is_arr = true
                                            .KArrayStr -> is_arr = true
                                            .KStr -> is_str = true
                                            else none
                                        }
                                        if is_arr {
                                            let rhs_val = self.compile_expr(rhs_id)
                                            let rhs_reg = self.load(rhs_val)
                                            self.emit("sub sp, sp, #16")
                                            self.emit(f"str {rhs_reg}, [sp]")
                                            self.free_reg(rhs_reg)
                                            let ptr_reg = self.alloc_reg()
                                            self.emit_ldr(obj_off, reg: ptr_reg)
                                            self.emit(f"ldr x0, [{ptr_reg}, #{self.itos(foff)}]")
                                            self.emit("ldr x1, [sp]")
                                            self.emit("add sp, sp, #16")
                                            self.emit("bl _kod_array_concat")
                                            self.emit_ldr(obj_off, reg: ptr_reg)
                                            self.emit(f"str x0, [{ptr_reg}, #{self.itos(foff)}]")
                                            self.free_reg(ptr_reg)
                                        } else {
                                            if is_str {
                                                let rhs_val = self.compile_expr(rhs_id)
                                                let rhs_reg = self.load(rhs_val)
                                                self.emit("sub sp, sp, #16")
                                                self.emit(f"str {rhs_reg}, [sp]")
                                                self.free_reg(rhs_reg)
                                                let ptr_reg = self.alloc_reg()
                                                self.emit_ldr(obj_off, reg: ptr_reg)
                                                self.emit(f"ldr x0, [{ptr_reg}, #{self.itos(foff)}]")
                                                self.emit("ldr x1, [sp]")
                                                self.emit("add sp, sp, #16")
                                                self.emit("bl _kod_str_concat")
                                                self.emit_ldr(obj_off, reg: ptr_reg)
                                                self.emit(f"str x0, [{ptr_reg}, #{self.itos(foff)}]")
                                                self.free_reg(ptr_reg)
                                            } else {
                                                let rhs_val = self.compile_expr(rhs_id)
                                                let rhs_reg = self.load(rhs_val)
                                                let ptr_reg = self.alloc_reg()
                                                self.emit_ldr(obj_off, reg: ptr_reg)
                                                let lhs_reg = self.alloc_reg()
                                                self.emit(f"ldr {lhs_reg}, [{ptr_reg}, #{self.itos(foff)}]")
                                                self.emit(f"add {lhs_reg}, {lhs_reg}, {rhs_reg}")
                                                self.emit(f"str {lhs_reg}, [{ptr_reg}, #{self.itos(foff)}]")
                                                self.free_reg(lhs_reg)
                                                self.free_reg(rhs_reg)
                                                self.free_reg(ptr_reg)
                                            }
                                        }
                                    }
                                    else none
                                }
                            }
                            else none
                        }
                    }
                    else none
                }
            }
            .Ident(name) -> {
                let off = self.find_var_offset(name)
                let kind = self.find_var_kind(name)
                match kind {
                    .KArray -> {
                        let rhs_val = self.compile_expr(rhs_id)
                        let rhs_reg = self.load(rhs_val)
                        let lhs_reg = self.alloc_reg()
                        self.emit_ldr(off, reg: lhs_reg)
                        self.emit(f"mov x0, {lhs_reg}")
                        self.emit(f"mov x1, {rhs_reg}")
                        self.free_reg(lhs_reg)
                        self.free_reg(rhs_reg)
                        self.emit("bl _kod_array_concat")
                        self.emit_str(off, reg: "x0")
                    }
                    .KArrayStruct(elem_idx) -> {
                        let rhs_val = self.compile_expr(rhs_id)
                        let rhs_reg = self.load(rhs_val)
                        let lhs_reg = self.alloc_reg()
                        self.emit_ldr(off, reg: lhs_reg)
                        self.emit(f"mov x0, {lhs_reg}")
                        self.emit(f"mov x1, {rhs_reg}")
                        self.free_reg(lhs_reg)
                        self.free_reg(rhs_reg)
                        self.emit("bl _kod_array_concat")
                        self.emit_str(off, reg: "x0")
                    }
                    .KArrayEnum(elem_idx) -> {
                        let rhs_val = self.compile_expr(rhs_id)
                        let rhs_reg = self.load(rhs_val)
                        let lhs_reg = self.alloc_reg()
                        self.emit_ldr(off, reg: lhs_reg)
                        self.emit(f"mov x0, {lhs_reg}")
                        self.emit(f"mov x1, {rhs_reg}")
                        self.free_reg(lhs_reg)
                        self.free_reg(rhs_reg)
                        self.emit("bl _kod_array_concat")
                        self.emit_str(off, reg: "x0")
                    }
                    .KArrayStr -> {
                        let rhs_val = self.compile_expr(rhs_id)
                        let rhs_reg = self.load(rhs_val)
                        let lhs_reg = self.alloc_reg()
                        self.emit_ldr(off, reg: lhs_reg)
                        self.emit(f"mov x0, {lhs_reg}")
                        self.emit(f"mov x1, {rhs_reg}")
                        self.free_reg(lhs_reg)
                        self.free_reg(rhs_reg)
                        self.emit("bl _kod_array_concat")
                        self.emit_str(off, reg: "x0")
                    }
                    .KStr -> {
                        let rhs_val = self.compile_expr(rhs_id)
                        let rhs_reg = self.load(rhs_val)
                        let lhs_reg = self.alloc_reg()
                        self.emit_ldr(off, reg: lhs_reg)
                        self.emit(f"mov x0, {lhs_reg}")
                        self.emit(f"mov x1, {rhs_reg}")
                        self.free_reg(lhs_reg)
                        self.free_reg(rhs_reg)
                        self.emit("bl _kod_str_concat")
                        self.emit_str(off, reg: "x0")
                    }
                    else {
                        let rhs_val = self.compile_expr(rhs_id)
                        let rhs_reg = self.load(rhs_val)
                        let lhs_reg = self.alloc_reg()
                        self.emit_ldr(off, reg: lhs_reg)
                        self.emit(f"add {lhs_reg}, {lhs_reg}, {rhs_reg}")
                        self.emit_str(off, reg: lhs_reg)
                        self.free_reg(lhs_reg)
                        self.free_reg(rhs_reg)
                    }
                }
            }
            else none
        }
    }

    func compile_return(self, anon value_id: int64) -> none {
        if value_id == 0 {
            self.emit("mov x0, #0")
            self.emit(f"b {self.ret_lbl}")
            return
        }
        // If returning into a Result and the value isn't already a Result,
        // wrap it as .Ok(value) — a 16-byte arena cell {0, value}.
        if self.return_kind is .KResult(inner) {
            let already = false
            if self.infer_kind(value_id) is .KResult(inner2) {
                already = true
            }
            if already {
                let val = self.compile_expr(value_id)
                self.mov_to(val, dest: "x0")
            } else {
                self.compile_wrap_ok(value_id)
            }
            self.emit(f"b {self.ret_lbl}")
            return
        }
        // If returning into an optional and the value isn't already optional,
        // wrap it in an arena allocation. NoneLit is always Optional. For Call,
        // trust free-function returns (we don't track free-fn return kinds);
        // for method calls, infer_kind looks up the method's return type.
        let needs_wrap = false
        match self.return_kind {
            .KOptional(inner) -> {
                let assume_optional = false
                match self.p.exprs[value_id] {
                    .NoneLit -> assume_optional = true
                    .Call(callee, args) -> {
                        if self.p.exprs[callee] is .Ident(name) {
                            assume_optional = true
                        }
                    }
                    else none
                }
                if assume_optional == false {
                    match self.infer_kind(value_id) {
                        .KOptional(inner2) -> {}
                        else needs_wrap = true
                    }
                }
            }
            else none
        }
        if needs_wrap {
            // A match expression whose arms include `else -> none` produces
            // a 0 value that we must NOT re-wrap (would yield Some(NULL)).
            // For any other expression, infer_kind already established this
            // is a concrete non-optional value (bool/int/etc.) — a literal 0
            // or `false` MUST still wrap, or `return 0` from an `int64?`
            // function silently becomes `none` (the same bug used to bite
            // `as_int(.Number(0))` and `Map[K, int64].get` on its first entry).
            let conditional: bool = false
            match self.p.exprs[value_id] {
                .MatchExpr(_subject, _arms) -> conditional = true
                else none
            }
            let val = self.compile_expr(value_id)
            let reg = self.load(val)
            let skip_lbl = self.fresh("Lwrap_skip")
            let done_lbl = self.fresh("Lwrap_done")
            if conditional {
                self.emit(f"cmp {reg}, #0")
                self.emit(f"beq {skip_lbl}")
            }
            self.emit("sub sp, sp, #16")
            self.emit(f"str {reg}, [sp]")
            self.free_reg(reg)
            self.emit("mov x0, #8")
            self.emit("bl _arena_alloc")
            let tmp = self.alloc_reg()
            self.emit(f"ldr {tmp}, [sp]")
            self.emit("add sp, sp, #16")
            self.emit(f"str {tmp}, [x0]")
            self.free_reg(tmp)
            if conditional {
                self.emit(f"b {done_lbl}")
                self.emit_label(skip_lbl)
                self.emit("mov x0, #0")
                self.emit_label(done_lbl)
            }
        } else {
            let val = self.compile_expr(value_id)
            self.mov_to(val, dest: "x0")
        }
        self.emit(f"b {self.ret_lbl}")
    }

    // Compile `value_id` and wrap the result in a Result.Ok cell. Leaves
    // the cell pointer in x0. Used for implicit `return v` in Result-typed
    // functions and for the Ok arm of try/must.
    func compile_wrap_ok(self, anon value_id: int64) -> none {
        let val = self.compile_expr(value_id)
        let reg = self.alloc_reg()
        self.mov_to(val, dest: reg)
        self.emit("sub sp, sp, #16")
        self.emit(f"str {reg}, [sp]")
        self.free_reg(reg)
        self.emit("mov x0, #16")
        self.emit("bl _arena_alloc")
        let payload = self.alloc_reg()
        self.emit(f"ldr {payload}, [sp]")
        self.emit("add sp, sp, #16")
        self.emit("str xzr, [x0]")              // discriminant = 0 (Ok)
        self.emit(f"str {payload}, [x0, #8]")   // payload
        self.free_reg(payload)
    }

    // `throw expr` — box `expr` as an Error (fat pointer with vtable) and
    // return a Result.Err cell {1, error_ptr} from the enclosing function.
    // Compute `path:line:col` for an error message from a byte offset
    // into self.p.source.
    func format_position(self, anon offset: int64) -> str {
        let source = self.p.source
        let line = 1
        let col = 1
        let i = 0
        for i < offset and i < len(source) {
            if source[i] == '\n' {
                line = line + 1
                col = 1
            } else {
                col = col + 1
            }
            i = i + 1
        }
        return f"{self.p.path}:{line.to_str()}:{col.to_str()}"
    }

    // `assert <expr>` — runtime check. When the expression evaluates to
    // false, emit a call carrying a message that pins down both the source
    // location and the original expression text (captured by the parser).
    // Inside a `test "..." {}` block: `_kod_test_fail` (flag the test and
    // keep going, so multiple asserts surface in one run). Outside: a
    // straight `_kod_panic` (print + exit 1). Same syntax, intent matches
    // the surrounding context.
    func compile_assert(self, anon expr_id: int64, source_text: str, span: ast.Span) -> none {
        let val = self.compile_expr(expr_id)
        let reg = self.load(val)
        let ok_lbl = self.fresh("Lassert_ok")
        self.emit(f"cbnz {reg}, {ok_lbl}")
        self.free_reg(reg)
        let pos = self.format_position(span.start)
        let msg = f"{pos}: assertion failed: {source_text}"
        let msg_lbl = self.intern_str(msg)
        self.emit(f"adrp x0, {msg_lbl}@PAGE")
        self.emit(f"add x0, x0, {msg_lbl}@PAGEOFF")
        if self.in_test {
            self.emit("bl _kod_test_fail")
        } else {
            self.emit("bl _kod_panic")
        }
        self.emit_label(ok_lbl)
    }

    func compile_throw(self, anon value_id: int64) -> none {
        let iface_idx = self.find_iface_idx("Error")
        let actual = self.infer_kind(value_id)
        let val = self.compile_expr(value_id)
        let reg = self.alloc_reg()
        self.mov_to(val, dest: reg)
        // Box into the Error interface if the source is a concrete struct.
        if iface_idx >= 0 {
            reg = self.maybe_box_for_iface(reg, :actual, expected: .KInterface(idx: iface_idx))
        }
        // Build the Result.Err cell.
        self.emit("sub sp, sp, #16")
        self.emit(f"str {reg}, [sp]")
        self.free_reg(reg)
        self.emit("mov x0, #16")
        self.emit("bl _arena_alloc")
        let payload = self.alloc_reg()
        self.emit(f"ldr {payload}, [sp]")
        self.emit("add sp, sp, #16")
        self.emit("mov x9, #1")
        self.emit("str x9, [x0]")               // discriminant = 1 (Err)
        self.emit(f"str {payload}, [x0, #8]")   // error iface ptr
        self.free_reg(payload)
        self.emit(f"b {self.ret_lbl}")
    }

    // `try expr` / `must expr` — evaluate `expr` (yielding a Result cell
    // pointer in x0), then branch on the discriminant. The Ok arm yields
    // the unwrapped inner value as this expression's value. The Err arm
    // either returns the same cell from the enclosing function (try) or
    // calls _kod_panic_error and aborts (must).
    func compile_try_or_must(self, anon inner_id: int64, is_must: bool) -> Val {
        let val = self.compile_expr(inner_id)
        self.mov_to(val, dest: "x0")
        let disc = self.alloc_reg()
        self.emit(f"ldr {disc}, [x0]")
        let ok_lbl = self.fresh("Lresult_ok")
        let done_lbl = self.fresh("Lresult_done")
        self.emit(f"cmp {disc}, #0")
        self.free_reg(disc)
        self.emit(f"beq {ok_lbl}")
        // Err path.
        if is_must {
            // Load the Error interface cell, then dispatch its to_str
            // method to render a panic message. Layout:
            //   result cell:    [disc, error_iface_ptr]
            //   error iface:    [data_ptr, vtable_ptr]
            //   vtable[0]:      to_str method (only entry on Error)
            self.emit("ldr x0, [x0, #8]")    // x0 = error iface cell ptr
            self.emit("ldr x1, [x0, #8]")    // x1 = vtable ptr
            self.emit("ldr x9, [x1, #0]")    // x9 = to_str method
            self.emit("ldr x0, [x0, #0]")    // x0 = self (data ptr)
            self.emit("blr x9")              // x0 = str
            self.emit("bl _kod_panic")
        } else {
            // Propagate: the cell ptr is already in x0; just return it.
            self.emit(f"b {self.ret_lbl}")
        }
        self.emit_label(ok_lbl)
        let result_r = self.alloc_reg()
        self.emit(f"ldr {result_r}, [x0, #8]")
        self.emit_label(done_lbl)
        return .VReg(name: result_r)
    }

    func compile_try(self, anon inner_id: int64) -> Val {
        return self.compile_try_or_must(inner_id, is_must: false)
    }

    func compile_must(self, anon inner_id: int64) -> Val {
        return self.compile_try_or_must(inner_id, is_must: true)
    }

    func compile_if(self, cond_id: int64, then_body: [int64], else_body: [int64]) -> none {
        let lbl = self.fresh("Lif")
        let false_lbl = f"{lbl}_false"
        let end_lbl = f"{lbl}_end"
        let cond_val = self.compile_expr(cond_id)
        let cond_reg = self.load(cond_val)
        self.emit(f"cmp {cond_reg}, #0")
        self.free_reg(cond_reg)
        self.emit(f"beq {false_lbl}")
        let i = 0
        for i < len(then_body) {
            self.compile_stmt(then_body[i])
            i = i + 1
        }
        self.emit(f"b {end_lbl}")
        self.emit_label(false_lbl)
        let j = 0
        for j < len(else_body) {
            self.compile_stmt(else_body[j])
            j = j + 1
        }
        self.emit_label(end_lbl)
    }

    func compile_for(self, anon body: [int64], cond_id: int64) -> none {
        let lbl = self.fresh("Lfor")
        let start_lbl = f"{lbl}_start"
        let end_lbl = f"{lbl}_end"
        // `continue` lands here — re-check the loop condition. Previously
        // pointed at end_lbl, which made `continue` behave as `break`.
        self.loop_stack += [LoopLbl(:start_lbl, :end_lbl, incr_lbl: start_lbl)]
        self.emit_label(start_lbl)
        let cond_val = self.compile_expr(cond_id)
        let cond_reg = self.load(cond_val)
        self.emit(f"cmp {cond_reg}, #0")
        self.free_reg(cond_reg)
        self.emit(f"beq {end_lbl}")
        let i = 0
        for i < len(body) {
            self.compile_stmt(body[i])
            i = i + 1
        }
        self.emit(f"b {start_lbl}")
        self.emit_label(end_lbl)
        let n = len(self.loop_stack)
        let new_stack: [LoopLbl] = []
        let j = 0
        for j < n - 1 {
            new_stack += [self.loop_stack[j]]
            j = j + 1
        }
        self.loop_stack = new_stack
    }

    func compile_foreach(self, anon body: [int64], name: str, iter_id: int64) -> none {
        let lbl = self.fresh("Lfe")
        let start_lbl = f"{lbl}_start"
        let incr_lbl = f"{lbl}_incr"
        let end_lbl = f"{lbl}_end"
        self.loop_stack += [LoopLbl(start_lbl: incr_lbl, :end_lbl, :incr_lbl)]

        let idx_name = f"__fi_{name}"
        let idx_off = self.find_var_offset(idx_name)
        let elem_off = self.find_var_offset(name)
        // Pre-allocated by collect_stmt_vars: stash the array header here
        // so the body can issue `bl` calls without clobbering data/len regs.
        let hdr_name = f"__fh_{name}"
        let hdr_off = self.find_var_offset(hdr_name)

        let arr_val = self.compile_expr(iter_id)
        let hdr_r = self.load(arr_val)
        self.emit_str(hdr_off, reg: hdr_r)
        self.free_reg(hdr_r)

        let idx_r = self.alloc_reg()
        self.emit(f"mov {idx_r}, #0")
        self.emit_str(idx_off, reg: idx_r)
        self.free_reg(idx_r)

        self.emit_label(start_lbl)
        let hdr_reg = self.alloc_reg()
        let len_reg = self.alloc_reg()
        let idx_reg = self.alloc_reg()
        self.emit_ldr(hdr_off, reg: hdr_reg)
        self.emit(f"ldr {len_reg}, [{hdr_reg}, #8]")
        self.emit_ldr(idx_off, reg: idx_reg)
        self.emit(f"cmp {idx_reg}, {len_reg}")
        self.emit(f"bge {end_lbl}")
        self.free_reg(len_reg)

        let elem_reg = self.alloc_reg()
        self.emit(f"ldr {elem_reg}, [{hdr_reg}]")
        self.emit(f"lsl {idx_reg}, {idx_reg}, #3")
        self.emit(f"ldr {elem_reg}, [{elem_reg}, {idx_reg}]")
        self.emit_str(elem_off, reg: elem_reg)
        self.free_reg(elem_reg)
        self.free_reg(idx_reg)
        self.free_reg(hdr_reg)

        let i = 0
        for i < len(body) {
            self.compile_stmt(body[i])
            i = i + 1
        }

        self.emit_label(incr_lbl)
        let bump_reg = self.alloc_reg()
        self.emit_ldr(idx_off, reg: bump_reg)
        self.emit(f"add {bump_reg}, {bump_reg}, #1")
        self.emit_str(idx_off, reg: bump_reg)
        self.free_reg(bump_reg)
        self.emit(f"b {start_lbl}")
        self.emit_label(end_lbl)

        let n = len(self.loop_stack)
        let new_stack: [LoopLbl] = []
        let j = 0
        for j < n - 1 {
            new_stack += [self.loop_stack[j]]
            j = j + 1
        }
        self.loop_stack = new_stack
    }

    func compile_break(self) -> none {
        self.emit(f"b {self.loop_stack[-1].end_lbl}")
    }

    func compile_continue(self) -> none {
        self.emit(f"b {self.loop_stack[-1].incr_lbl}")
    }

    // Refutable `let .Pat(...) = expr else { ... }`. On a successful pattern
    // match, the bindings receive the variant's payload fields and execution
    // falls through; on mismatch, the else-block runs (and must diverge).
    func compile_let_else(self, anon else_body: [int64], pattern_id: int64, value_id: int64) -> none {
        let else_lbl = self.fresh("Llet_else")
        let done_lbl = self.fresh("Llet_done")
        let subj_val = self.compile_expr(value_id)
        let sptr_r = self.load(subj_val)
        let subj_slot = self.alloc_var(name: self.fresh("__lsubj"), kind: .KInt64)
        self.emit_str(subj_slot, reg: sptr_r)
        self.free_reg(sptr_r)
        match self.p.patterns[pattern_id] {
            .EnumPat(enum_name, variant_name, bindings) -> {
                let enum_idx = self.find_enum_idx(enum_name)
                let variant_idx = self.find_variant_idx(variant_name, :enum_idx)
                let disc = self.enums[enum_idx].variants[variant_idx].discriminant
                let disc_r = self.alloc_reg()
                let ptr_r = self.alloc_reg()
                self.emit_ldr(subj_slot, reg: ptr_r)
                self.emit(f"ldr {disc_r}, [{ptr_r}]")
                self.emit(f"cmp {disc_r}, #{self.itos(disc)}")
                self.emit(f"bne {else_lbl}")
                self.free_reg(disc_r)
                self.free_reg(ptr_r)
                let vinfo = self.enums[enum_idx].variants[variant_idx]
                let key_idx = 0
                for key_idx < len(bindings) {
                    let foff = vinfo.field_offsets[key_idx]
                    let binding_off = self.find_var_offset(bindings[key_idx])
                    let ptr_r2 = self.alloc_reg()
                    self.emit_ldr(subj_slot, reg: ptr_r2)
                    let fv_r = self.alloc_reg()
                    self.emit(f"ldr {fv_r}, [{ptr_r2}, #{self.itos(8 + foff)}]")
                    self.emit_str(binding_off, reg: fv_r)
                    self.free_reg(fv_r)
                    self.free_reg(ptr_r2)
                    key_idx = key_idx + 1
                }
            }
            .ImplicitEnumPat(variant_name, bindings) -> {
                let enum_idx = self.find_enum_with_variant(variant_name)
                let variant_idx = self.find_variant_idx(variant_name, :enum_idx)
                let disc = self.enums[enum_idx].variants[variant_idx].discriminant
                let disc_r = self.alloc_reg()
                let ptr_r = self.alloc_reg()
                self.emit_ldr(subj_slot, reg: ptr_r)
                self.emit(f"ldr {disc_r}, [{ptr_r}]")
                self.emit(f"cmp {disc_r}, #{self.itos(disc)}")
                self.emit(f"bne {else_lbl}")
                self.free_reg(disc_r)
                self.free_reg(ptr_r)
                let vinfo2 = self.enums[enum_idx].variants[variant_idx]
                let key_idx = 0
                for key_idx < len(bindings) {
                    let foff = vinfo2.field_offsets[key_idx]
                    let binding_off = self.find_var_offset(bindings[key_idx])
                    let ptr_r2 = self.alloc_reg()
                    self.emit_ldr(subj_slot, reg: ptr_r2)
                    let fv_r = self.alloc_reg()
                    self.emit(f"ldr {fv_r}, [{ptr_r2}, #{self.itos(8 + foff)}]")
                    self.emit_str(binding_off, reg: fv_r)
                    self.free_reg(fv_r)
                    self.free_reg(ptr_r2)
                    key_idx = key_idx + 1
                }
            }
            .SomePat(binding) -> {
                let disc_r = self.alloc_reg()
                self.emit_ldr(subj_slot, reg: disc_r)
                self.emit(f"cmp {disc_r}, #0")
                self.emit(f"beq {else_lbl}")
                self.free_reg(disc_r)
                if len(binding) > 0 {
                    let boff = self.find_var_offset(binding)
                    let ptr_r = self.alloc_reg()
                    self.emit_ldr(subj_slot, reg: ptr_r)
                    let val_r = self.alloc_reg()
                    self.emit(f"ldr {val_r}, [{ptr_r}]")
                    self.emit_str(boff, reg: val_r)
                    self.free_reg(val_r)
                    self.free_reg(ptr_r)
                }
            }
            .NonePat -> {
                let disc_r = self.alloc_reg()
                self.emit_ldr(subj_slot, reg: disc_r)
                self.emit(f"cmp {disc_r}, #0")
                self.emit(f"bne {else_lbl}")
                self.free_reg(disc_r)
            }
            else {
                // Other patterns are not supported here yet.
                self.emit(f"b {else_lbl}")
            }
        }
        self.emit(f"b {done_lbl}")
        self.emit_label(else_lbl)
        let i = 0
        for i < len(else_body) {
            self.compile_stmt(else_body[i])
            i = i + 1
        }
        self.emit_label(done_lbl)
    }

    func compile_match_stmt(self, anon arms: [int64], subject_id: int64) -> none {
        self.check_match_subject(subject_id, :arms)
        let stmt_patterns: [int64] = []
        for arm_id in arms {
            stmt_patterns += [self.p.match_arms[arm_id].pattern]
        }
        self.check_match_exhaustive(subject_id, pattern_ids: stmt_patterns)
        let done_lbl = self.fresh("Lmatch_done")
        // Evaluate subject once; stash its pointer on the stack so pattern
        // bindings can read fields off the subject after disc_r is consumed.
        let subj_val = self.compile_expr(subject_id)
        let sptr_r = self.load(subj_val)
        let subj_slot = self.alloc_var(name: self.fresh("__msubj"), kind: .KInt64)
        self.emit_str(subj_slot, reg: sptr_r)
        self.free_reg(sptr_r)
        let disc_val = .VStack(offset: subj_slot)
        let disc_r = self.load_enum_or_val(disc_val, expr_id: subject_id)
        let i = 0
        for i < len(arms) {
            let arm = self.p.match_arms[arms[i]]
            let skip_lbl = self.fresh("Lmatch_skip")
            match self.p.patterns[arm.pattern] {
                .Wildcard -> {
                    for stmt_id in arm.body {
                        self.compile_stmt(stmt_id)
                    }
                    self.emit(f"b {done_lbl}")
                }
                .IntPat(value) -> {
                    self.emit(f"cmp {disc_r}, #{self.itos(value)}")
                    self.emit(f"bne {skip_lbl}")
                    for stmt_id in arm.body {
                        self.compile_stmt(stmt_id)
                    }
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .BoolPat(value) -> {
                    let lit = 0
                    if value {
                        lit = 1
                    }
                    self.emit(f"cmp {disc_r}, #{self.itos(lit)}")
                    self.emit(f"bne {skip_lbl}")
                    for stmt_id in arm.body {
                        self.compile_stmt(stmt_id)
                    }
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .StrPat(value) -> {
                    let slbl = self.intern_str(value)
                    // Reload from subj_slot — disc_r may have been clobbered
                    // by a prior arm's `bl _kod_str_cmp`.
                    self.emit_ldr(subj_slot, reg: "x0")
                    self.emit(f"adrp x1, {slbl}@PAGE")
                    self.emit(f"add x1, x1, {slbl}@PAGEOFF")
                    self.emit("bl _kod_str_cmp")
                    self.emit("cmp x0, #0")
                    self.emit(f"bne {skip_lbl}")
                    for stmt_id in arm.body {
                        self.compile_stmt(stmt_id)
                    }
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .EnumPat(enum_name, variant_name, bindings) -> {
                    let enum_idx = self.find_enum_idx(enum_name)
                    let variant_idx = self.find_variant_idx(variant_name, :enum_idx)
                    let disc = self.enums[enum_idx].variants[variant_idx].discriminant
                    self.emit(f"cmp {disc_r}, #{self.itos(disc)}")
                    self.emit(f"bne {skip_lbl}")
                    let vinfo = self.enums[enum_idx].variants[variant_idx]
                    let key_idx = 0
                    for key_idx < len(bindings) {
                        let foff = vinfo.field_offsets[key_idx]
                        let binding_off = self.find_var_offset(bindings[key_idx])
                        let ptr_r = self.alloc_reg()
                        self.emit_ldr(subj_slot, reg: ptr_r)
                        let fv_r = self.alloc_reg()
                        self.emit(f"ldr {fv_r}, [{ptr_r}, #{self.itos(8 + foff)}]")
                        self.emit_str(binding_off, reg: fv_r)
                        self.free_reg(fv_r)
                        self.free_reg(ptr_r)
                        key_idx = key_idx + 1
                    }
                    for stmt_id in arm.body {
                        self.compile_stmt(stmt_id)
                    }
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .ImplicitEnumPat(variant_name, bindings) -> {
                    let enum_idx = self.find_enum_with_variant(variant_name)
                    let variant_idx = self.find_variant_idx(variant_name, :enum_idx)
                    let disc = self.enums[enum_idx].variants[variant_idx].discriminant
                    self.emit(f"cmp {disc_r}, #{self.itos(disc)}")
                    self.emit(f"bne {skip_lbl}")
                    let vinfo2 = self.enums[enum_idx].variants[variant_idx]
                    let key_idx = 0
                    for key_idx < len(bindings) {
                        let foff = vinfo2.field_offsets[key_idx]
                        let binding_off = self.find_var_offset(bindings[key_idx])
                        let ptr_r = self.alloc_reg()
                        self.emit_ldr(subj_slot, reg: ptr_r)
                        let fv_r = self.alloc_reg()
                        self.emit(f"ldr {fv_r}, [{ptr_r}, #{self.itos(8 + foff)}]")
                        self.emit_str(binding_off, reg: fv_r)
                        self.free_reg(fv_r)
                        self.free_reg(ptr_r)
                        key_idx = key_idx + 1
                    }
                    for stmt_id in arm.body {
                        self.compile_stmt(stmt_id)
                    }
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .NonePat -> {
                    self.emit(f"cmp {disc_r}, #0")
                    self.emit(f"bne {skip_lbl}")
                    for stmt_id in arm.body {
                        self.compile_stmt(stmt_id)
                    }
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
                .SomePat(binding) -> {
                    self.emit(f"cmp {disc_r}, #0")
                    self.emit(f"beq {skip_lbl}")
                    if len(binding) > 0 {
                        let boff = self.find_var_offset(binding)
                        let ptr_r = self.alloc_reg()
                        self.emit_ldr(subj_slot, reg: ptr_r)
                        let val_r = self.alloc_reg()
                        self.emit(f"ldr {val_r}, [{ptr_r}]")
                        self.emit_str(boff, reg: val_r)
                        self.free_reg(val_r)
                        self.free_reg(ptr_r)
                    }
                    for stmt_id in arm.body {
                        self.compile_stmt(stmt_id)
                    }
                    self.emit(f"b {done_lbl}")
                    self.emit_label(skip_lbl)
                }
            }
            i = i + 1
        }
        self.emit_label(done_lbl)
        self.free_reg(disc_r)
    }


    func compile_func(self, fd_id: int64, struct_name: str, override_lbl: str) -> none {
        let func_decl = self.p.func_decls[fd_id]
        self.check_param_order(func_decl, func_decl.name)
        self.vars = []
        self.frame_slots = 0
        self.free_regs = ["x27", "x26", "x25", "x24", "x23", "x22", "x21", "x20", "x19", "x15", "x14", "x13", "x12", "x11", "x10", "x9", "x8"]
        self.loop_stack = []

        for param in func_decl.params {
            let kind = self.resolve_type(param.typ)
            // The method receiver `self` has no type annotation; give it
            // the kind of the enclosing struct so field/method access works.
            if param.name == "self" and len(struct_name) > 0 {
                let struct_idx = self.find_struct_idx(struct_name)
                if struct_idx >= 0 {
                    kind = .KStruct(idx: struct_idx, type_args: [])
                }
            }
            self.alloc_var(name: param.name, :kind)
        }

        for stmt_id in func_decl.body {
            self.collect_stmt_vars(:stmt_id)
        }

        let raw_sz = self.frame_slots * 8
        let aligned = raw_sz + 16 - raw_sz % 16

        let func_lbl = f"${self.path_prefix}${func_decl.name}"
        if len(struct_name) > 0 {
            func_lbl = f"${self.path_prefix}${struct_name}${func_decl.name}"
        }
        if len(override_lbl) > 0 {
            func_lbl = override_lbl
        }
        // L-prefix the function-end label so the assembler keeps it
        // file-local and out of the symbol table. With
        // `.subsections_via_symbols` set, every symbol becomes a
        // subsection boundary — and our epilogue falls through from
        // the function body into `…$end:`, so if `$end` got its own
        // subsection the linker could place it anywhere, and `ret`
        // would end up in the wrong code.
        self.ret_lbl = f"L{func_lbl}$end"
        self.return_kind = self.resolve_type(func_decl.return_typ)

        self.emit_globl(func_lbl)
        self.emit_label(func_lbl)
        self.emit(f"sub sp, sp, #{self.itos(aligned + 16)}")
        self.emit(f"stp fp, lr, [sp, #{self.itos(aligned)}]")
        self.emit(f"add fp, sp, #{self.itos(aligned)}")

        let arg_regs: [str] = ["x0", "x1", "x2", "x3", "x4", "x5", "x6", "x7"]
        let k = 0
        for param in func_decl.params {
            let off = self.find_var_offset(param.name)
            self.emit_str(off, reg: arg_regs[k])
            k = k + 1
        }

        for stmt_id in func_decl.body {
            self.compile_stmt(stmt_id)
        }

        self.emit("mov x0, #0")

        self.emit_label(self.ret_lbl)
        self.emit(f"ldp fp, lr, [sp, #{self.itos(aligned)}]")
        self.emit(f"add sp, sp, #{self.itos(aligned + 16)}")
        self.emit("ret")
    }


    func compile_module(self, anon module: ast.Module) -> none {
        self.println("\t.text")

        // Three-phase registration to handle struct ⇄ interface refs:
        // 1) interface names, 2) enums + structs, 3) interface method sigs.
        for decl in module.decls {
            self.register_interface(decl, prefix: self.path_prefix, p: self.p)
        }
        // Type aliases come before enum/struct registration so struct
        // fields and enum variant payload types can use them. Aliases
        // targeting *local* structs/enums aren't supported here, but we
        // don't have any such cases in-tree.
        for decl in module.decls {
            self.register_type_alias(decl, p: self.p)
        }
        // Interleave enums and structs in source order: a later enum's
        // variant payload may reference an earlier struct (see ast.kod's
        // `Decl.Struct(... fields: [StructField] ...)`), and an earlier
        // struct's field/method sig can reference a later struct only
        // if that struct already exists as an import — which is fine.
        for decl in module.decls {
            self.register_enum(decl, prefix: self.path_prefix, p: self.p)
            self.register_struct(decl, prefix: self.path_prefix, p: self.p)
        }
        for decl in module.decls {
            self.resolve_interface_methods(decl, p: self.p)
        }

        for decl in module.decls {
            let idx_m = self.func_idx
            match decl {
                .Func(decl_id) -> {
                    let func_decl = self.p.func_decls[decl_id]
                    idx_m.set(func_decl.name, len(self.func_names))
                    self.func_names += [func_decl.name]
                    self.func_labels += [f"${self.path_prefix}${func_decl.name}"]
                    self.func_sigs += [self.resolve_sig(func_decl, p: self.p)]
                    self.func_def_paths += [self.p.path]
                    self.func_def_spans += [func_decl.name_span]
                    self.func_docs += [func_decl.doc]
                }
                .Extern(name, name_span, params, return_typ) -> {
                    idx_m.set(name, len(self.func_names))
                    self.func_names += [name]
                    self.func_labels += [f"_{name}"]
                    self.func_sigs += [self.resolve_extern_sig(params, :return_typ, p: self.p)]
                    self.func_def_paths += [self.p.path]
                    self.func_def_spans += [name_span]
                    self.func_docs += [""]
                }
                else none
            }
        }

        for decl in module.decls {
            match decl {
                .Func(decl_id) -> self.compile_func(fd_id: decl_id, struct_name: "", override_lbl: "")
                .Struct(name, _name_span, _struct_type_params, fields, methods) -> {
                    for method_id in methods {
                        self.compile_func(fd_id: method_id, struct_name: name, override_lbl: "")
                    }
                }
                else none
            }
        }

        // Compile any `test "..." { ... }` blocks. Each becomes a normal
        // function with a synthesized label `<prefix>$__test_N`, plus a
        // per-module dispatcher `<prefix>$__run_tests` that resets the
        // failure flag, calls each test, reports the outcome, and finally
        // prints a summary. The dispatcher is what `kod test` links its
        // runtime_main against.
        let test_displays: [str] = []
        let test_labels: [str] = []
        for decl in module.decls {
            if decl is .Test(display, test_decl_id) {
                let lbl: str = f"${self.path_prefix}$__test_{len(test_labels).to_str()}"
                self.in_test = true
                self.compile_func(fd_id: test_decl_id, struct_name: "", override_lbl: lbl)
                self.in_test = false
                test_displays += [display]
                test_labels += [lbl]
            }
        }
        if len(test_labels) > 0 {
            // Per-module dispatcher. Just runs this module's tests and
            // returns. The summary call is hoisted out into the runtime
            // _main so multiple modules' dispatchers can contribute to a
            // single aggregate result. A `kod_test_module_begin` call
            // at the top prints the module's source path so the test
            // runner's output reads as one group per file.
            let run_lbl: str = f"${self.path_prefix}$__run_tests"
            let path_lbl: str = self.intern_str(self.p.path)
            self.emit_globl(run_lbl)
            self.emit_label(run_lbl)
            self.emit("sub sp, sp, #16")
            self.emit("stp fp, lr, [sp]")
            self.emit("add fp, sp, #0")
            self.emit(f"adrp x0, {path_lbl}@PAGE")
            self.emit(f"add x0, x0, {path_lbl}@PAGEOFF")
            self.emit("bl _kod_test_module_begin")
            let i: int64 = 0
            for i < len(test_labels) {
                let name_lbl: str = self.intern_str(test_displays[i])
                self.emit("bl _kod_test_reset")
                self.emit(f"bl {test_labels[i]}")
                self.emit(f"adrp x0, {name_lbl}@PAGE")
                self.emit(f"add x0, x0, {name_lbl}@PAGEOFF")
                self.emit("bl _kod_test_report")
                i = i + 1
            }
            self.emit("ldp fp, lr, [sp]")
            self.emit("add sp, sp, #16")
            self.emit("ret")
        }

        // Emit method bodies for every monomorphised struct instantiation
        // (e.g. Map[str, int64]). We walk the structs list with a cursor
        // that re-checks the length each step so any further instantiations
        // discovered while compiling a specialised body get picked up too.
        let cursor = 0
        for cursor < len(self.structs) {
            let s = self.structs[cursor]
            if s.template_idx >= 0 {
                let template = self.structs[s.template_idx]
                let saved_p = self.p
                let saved_names = self.subst_names
                let saved_args = self.subst_args
                self.p = s.src_p
                self.subst_names = template.type_param_names
                self.subst_args = s.template_args
                for m in s.methods {
                    self.compile_func(fd_id: m.decl_id, struct_name: s.name, override_lbl: "")
                }
                self.p = saved_p
                self.subst_names = saved_names
                self.subst_args = saved_args
            }
            cursor = cursor + 1
        }

        if len(self.str_labels) > 0 or len(self.vtable_struct_idx) > 0 {
            self.println(".data")
            // Each `str` literal is a KodStr struct (`{ buf, len }`) plus
            // a byte buffer. The 8-aligned struct header is what the
            // label points at — adrp / add returns the struct pointer.
            let i = 0
            for i < len(self.str_labels) {
                let lbl: str = self.str_labels[i]
                let value: str = self.str_values[i]
                self.println("\t.p2align 3")
                self.println(f"{lbl}:")
                self.println(f"\t.quad {lbl}$buf")
                self.println(f"\t.quad {len(value).to_str()}")
                self.println(f"{lbl}$buf:")
                self.emit_asciz(value)
                i = i + 1
            }
            self.emit_vtables()
        }
        // Tell the Mach-O linker that each labelled definition is its own
        // subsection — `ld -dead_strip` then drops any function/vtable
        // nothing reachable refers to. Without this directive, every .o
        // contributes its entire __text/__data wholesale.
        self.println(".subsections_via_symbols")
    }

    // Emit one row per registered (struct, interface) pair. Methods are
    // listed in the order they appear in the interface declaration; for
    // each, look up the matching method on the struct and emit a .quad
    // pointing at its mangled label.
    func emit_vtables(self) -> none {
        let i = 0
        for i < len(self.vtable_struct_idx) {
            let struct_idx = self.vtable_struct_idx[i]
            let iface_idx = self.vtable_iface_idx[i]
            let struct_info = self.structs[struct_idx]
            let iface_info = self.interfaces[iface_idx]
            self.println("\t.p2align 3")
            self.println(f"{self.vtable_label(struct_idx, iface_idx)}:")
            for m in iface_info.methods {
                match struct_info.method_idx.get(m.name) {
                    Some(_mi) -> self.println(f"\t.quad ${struct_info.module_prefix}${struct_info.name}${m.name}")
                    none -> self.println(f"\t.quad 0")
                }
            }
            i = i + 1
        }
        // Primitive vtables: same layout, but methods come from the
        // primitive method table populated by register_primitive_module.
        let pi = 0
        for pi < len(self.prim_vtable_kinds) {
            let kind = self.prim_vtable_kinds[pi]
            let iface_idx = self.prim_vtable_iface_idx[pi]
            let iface_info = self.interfaces[iface_idx]
            self.println("\t.p2align 3")
            self.println(f"{self.prim_vtable_label(iface_idx, :kind)}:")
            for m in iface_info.methods {
                let pm_idx = self.find_prim_method(m.name, :kind)
                if pm_idx >= 0 {
                    self.println(f"\t.quad {self.prim_methods[pm_idx].label}")
                } else {
                    self.println(f"\t.quad 0")
                }
            }
            pi = pi + 1
        }
    }

    // Register all functions and externs from a dependency module without compiling it.
    // Call this for each imported module (e.g. builtins) before compile_module.
    func register_module_funcs(self, anon module: ast.Module, prefix: str, p: parsing.Parser) -> none {
        let idx_m = self.func_idx
        for decl in module.decls {
            match decl {
                .Func(decl_id) -> {
                    let func_decl = p.func_decls[decl_id]
                    idx_m.set(func_decl.name, len(self.func_names))
                    self.func_names += [func_decl.name]
                    self.func_labels += [f"${prefix}${func_decl.name}"]
                    self.func_sigs += [self.resolve_sig(func_decl, :p)]
                    self.func_def_paths += [p.path]
                    self.func_def_spans += [func_decl.name_span]
                    self.func_docs += [func_decl.doc]
                }
                .Extern(name, name_span, params, return_typ) -> {
                    idx_m.set(name, len(self.func_names))
                    self.func_names += [name]
                    self.func_labels += [f"_{name}"]
                    self.func_sigs += [self.resolve_extern_sig(params, :return_typ, :p)]
                    self.func_def_paths += [p.path]
                    self.func_def_spans += [name_span]
                    self.func_docs += [""]
                }
                else none
            }
        }
    }

    // Register every function in a primitive's module (e.g. stdlib/primitives/int64.kod)
    // as a method on that primitive `kind`. Method dispatch on a receiver
    // of this kind will look up `name` and emit `bl $prefix$name`.
    func register_primitive_module(self, anon module: ast.Module, kind: TypeKind, prefix: str, p: parsing.Parser) -> none {
        for decl in module.decls {
            match decl {
                .Func(decl_id) -> {
                    let func_decl = p.func_decls[decl_id]
                    let lbl = f"${prefix}${func_decl.name}"
                    let sig = self.resolve_sig(func_decl, :p)
                    self.prim_methods += [PrimMethodInfo(:kind, name: func_decl.name, label: lbl, :sig)]
                }
                else none
            }
        }
    }

    // Register selected items from an imported module into the local
    // namespace so they can be referenced without the module prefix.
    // For functions/externs this appends to func_names/func_labels/func_sigs.
    // Types (struct/enum) are already global-by-name, so they need no entry.
    func register_imported_items(self, anon items: [str], anon module: ast.Module, prefix: str, p: parsing.Parser) -> none {
        let idx_m = self.func_idx
        for want in items {
            for decl in module.decls {
                match decl {
                    .Func(decl_id) -> {
                        let func_decl = p.func_decls[decl_id]
                        if func_decl.name == want {
                            idx_m.set(func_decl.name, len(self.func_names))
                            self.func_names += [func_decl.name]
                            self.func_labels += [f"${prefix}${func_decl.name}"]
                            self.func_sigs += [self.resolve_sig(func_decl, :p)]
                            self.func_def_paths += [p.path]
                            self.func_def_spans += [func_decl.name_span]
                            self.func_docs += [func_decl.doc]
                        }
                    }
                    .Extern(name, name_span, params, return_typ) -> {
                        if name == want {
                            idx_m.set(name, len(self.func_names))
                            self.func_names += [name]
                            self.func_labels += [f"_{name}"]
                            self.func_sigs += [self.resolve_extern_sig(params, :return_typ, :p)]
                            self.func_def_paths += [p.path]
                            self.func_def_spans += [name_span]
                            self.func_docs += [""]
                        }
                    }
                    else none
                }
            }
        }
    }

    // Record an import alias only. Must run before any sig resolution
    // that might reference an enum or struct from this module, because
    // resolve_type's KEnum/KStruct lookup goes through self.struct_idx /
    // self.enum_idx, which are populated by register_module_types — not
    // by this. Call register_import_module_funcs in a second pass once
    // every imported module's types are registered.
    func register_import_module_alias(self, anon local_mod: str, prefix: str) -> none {
        self.import_local += [local_mod]
        self.import_prefix += [prefix]
    }

    // Resolve and store sigs for each function / extern exported by
    // `module`. Run AFTER every imported module's types are registered
    // so a sig whose return type references an imported enum/struct
    // doesn't fall back to KInt64.
    func register_import_module_funcs(self, anon module: ast.Module, local_mod: str, prefix: str, p: parsing.Parser) -> none {
        for decl in module.decls {
            match decl {
                .Func(decl_id) -> {
                    let func_decl = p.func_decls[decl_id]
                    let sig = self.resolve_sig(func_decl, :p)
                    self.import_fns += [ImportFn(module: local_mod, name: func_decl.name, label: f"${prefix}${func_decl.name}", :sig, def_path: p.path, def_span: func_decl.name_span)]
                }
                .Extern(name, name_span, params, return_typ) -> {
                    let sig = self.resolve_extern_sig(params, :return_typ, :p)
                    self.import_fns += [ImportFn(module: local_mod, :name, label: f"_{name}", :sig, def_path: p.path, def_span: name_span)]
                }
                else none
            }
        }
    }

    // One-shot convenience for callers that don't need the two-step
    // ordering — used by code paths that register a module after the
    // full type registry already exists.
    func register_import_module(self, anon module: ast.Module, local_mod: str, prefix: str, p: parsing.Parser) -> none {
        self.register_import_module_alias(local_mod, :prefix)
        self.register_import_module_funcs(module, :local_mod, :prefix, :p)
    }
}

// True if `c` (as a byte) is a Kod identifier char — used by
// report_error to widen the diagnostic span past the start of the
// offending token. Duplicates lexing.is_alnum so codegen doesn't have
// to import lexing just for one helper.
func ident_char(anon c: int64) -> bool {
    if c >= 'a' and c <= 'z' { return true }
    if c >= 'A' and c <= 'Z' { return true }
    if c >= '0' and c <= '9' { return true }
    if c == '_' { return true }
    return false
}

func make_codegen(p: parsing.Parser, path_prefix: str) -> Codegen {
    let enums: [EnumInfo] = []
    let structs: [StructInfo] = []
    let interfaces: [IfaceInfo] = []
    let vtable_struct_idx: [int64] = []
    let vtable_iface_idx: [int64] = []
    let prim_vtable_kinds: [TypeKind] = []
    let prim_vtable_iface_idx: [int64] = []
    let import_local: [str] = []
    let import_prefix: [str] = []
    let import_fns: [ImportFn] = []
    let vars: [VarSlot] = []
    let loop_stack: [LoopLbl] = []
    let str_labels: [str] = []
    let str_values: [str] = []
    let func_names: [str] = []
    let func_labels: [str] = []
    let func_sigs: [SigInfo] = []
    let func_def_paths: [str] = []
    let func_def_spans: [ast.Span] = []
    let func_docs: [str] = []
    let func_idx: FuncIdx = FuncIdx(keys: [], values: [], indices: [])
    let struct_idx: FuncIdx = FuncIdx(keys: [], values: [], indices: [])
    let enum_idx: FuncIdx = FuncIdx(keys: [], values: [], indices: [])
    let iface_idx: FuncIdx = FuncIdx(keys: [], values: [], indices: [])
    let prim_methods: [PrimMethodInfo] = []
    let free_regs: [str] = ["x27", "x26", "x25", "x24", "x23", "x22", "x21", "x20", "x19", "x15", "x14", "x13", "x12", "x11", "x10", "x9", "x8"]
    let subst_names: [str] = []
    let subst_args: [TypeKind] = []
    let interned: StrMap = StrMap(keys: [], values: [], indices: [])
    let errors: [Error] = []
    return Codegen(:p, :path_prefix, :enums, :structs, :interfaces, :vtable_struct_idx, :vtable_iface_idx, :prim_vtable_kinds, :prim_vtable_iface_idx, :struct_idx, :enum_idx, :iface_idx, :import_local, :import_prefix, :import_fns, :vars, frame_slots: 0, ret_lbl: "", return_kind: .KVoid, :free_regs, :loop_stack, :str_labels, :str_values, :interned, label_count: 0, :func_names, :func_labels, :func_sigs, :func_def_paths, :func_def_spans, :func_docs, :func_idx, :prim_methods, :subst_names, :subst_args, :errors, in_test: false, dry_run: false)
}
