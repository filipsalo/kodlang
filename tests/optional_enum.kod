// `T?` where T is an enum: the cell should reuse T's layout (disc 0 = none),
// not allocate a separate wrapper cell. Verifies behaviour via pattern
// matching; the layout optimisation itself is internal but the test
// exercises the same paths.
type Color = enum {
    Red
    Green
    Blue
}

func first_color(anon n: int64) -> Color? {
    if n == 0 { return .Red }
    if n == 1 { return .Green }
    return none
}

func main() -> int64 {
    let a: Color? = first_color(0)
    if a is none { print("a none") } else { print("a some") }
    match a {
        none -> print("a match none")
        Some(c) -> {
            if c is .Red { print("a Red") }
            if c is .Green { print("a Green") }
            if c is .Blue { print("a Blue") }
        }
    }
    let b: Color? = first_color(99)
    if b is none { print("b none") } else { print("b some") }
    match b {
        none -> print("b match none")
        Some(c) -> print("b match some")
    }
    return 0
}

// expected output:
// a some
// a Red
// b none
// b match none
