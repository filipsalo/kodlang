// CRC-32 against known reference values (matches Python's
// `zlib.crc32` / the gzip polynomial).

import "hash/crc32"

func main() -> int64 {
    print_int(crc32.compute(""))                                       // 0
    print_int(crc32.compute("a"))                                      // 3904355907
    print_int(crc32.compute("hello"))                                  // 907060870
    print_int(crc32.compute("The quick brown fox jumps over the lazy dog"))   // 1095738169

    // Streaming: feeding the same bytes split arbitrarily yields the
    // same CRC as one-shot.
    mut c: crc32.Crc32 = crc32.make_crc32()
    c.update_bytes("The quick brown fox")
    c.update_bytes(" jumps over the lazy dog")
    print_int(c.final())                                               // 1095738169

    return 0
}

// expected output:
// 0
// 3904355907
// 907060870
// 1095738169
// 1095738169
// expected status:
// 0
