func classify(anon n: int64) -> str {
	if n < 0 {
		return "negative"
	} else if n == 0 {
		return "zero"
	} else if n < 10 {
		return "small"
	} else {
		return "big"
	}
}

func main() -> int64 {
	print(classify(-3))
	print(classify(0))
	print(classify(5))
	print(classify(100))
	return 0
}

// expected output:
// negative
// zero
// small
// big
// expected status:
// 0
