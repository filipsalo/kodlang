test "to_str: true and false" {
    assert true.to_str() == "true"
    assert false.to_str() == "false"
}

test "to_str round-trips through f-string" {
    let b: bool = true
    assert f"flag={b}" == "flag=true"
    let b2: bool = false
    assert f"flag={b2}" == "flag=false"
}

test "hash: 1 and 0" {
    assert true.hash() == 1
    assert false.hash() == 0
}

test "hash is deterministic" {
    assert true.hash() == true.hash()
    assert false.hash() == false.hash()
}
