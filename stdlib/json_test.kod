import "json"

// These tests are deliberately verbose: the compiler doesn't yet
// track cross-module function return kinds, so a direct
// `match json.parse(...)` would treat the subject as int64 and fail
// to dereference, and `json.emit(...) == "literal"` would compile as a
// pointer compare. Every cross-module call is therefore funneled
// through a typed local — `let v: json.Value = ...` or
// `let s: str = ...` — so the var's declared kind drives the match /
// comparison correctly. Self-recursive enum element kinds aren't
// re-resolved either, so `items[i]` reads as int64; the same typed-
// local trick bridges that.

test "parse: null" {
    let v: json.Value = json.parse("null")
    match v {
        .Null -> {}
        else -> fail("expected Null")
    }
}

test "parse: true" {
    let v: json.Value = json.parse("true")
    match v {
        .Bool(b) -> assert b == true
        else -> fail("expected Bool")
    }
}

test "parse: false" {
    let v: json.Value = json.parse("false")
    match v {
        .Bool(b) -> assert b == false
        else -> fail("expected Bool")
    }
}

test "parse: positive integer" {
    let v: json.Value = json.parse("42")
    match v {
        .Number(n) -> assert n == 42
        else -> fail("expected Number")
    }
}

test "parse: negative integer" {
    let v: json.Value = json.parse("-7")
    match v {
        .Number(n) -> assert n == -7
        else -> fail("expected Number")
    }
}

test "parse: zero" {
    let v: json.Value = json.parse("0")
    match v {
        .Number(n) -> assert n == 0
        else -> fail("expected Number")
    }
}

test "parse: simple string" {
    let v: json.Value = json.parse("\"hello\"")
    match v {
        .Str(s) -> assert s == "hello"
        else -> fail("expected Str")
    }
}

test "parse: string with escapes" {
    let v: json.Value = json.parse("\"a\\nb\\tc\\\"d\"")
    match v {
        .Str(s) -> assert s == "a\nb\tc\"d"
        else -> fail("expected Str")
    }
}

test "parse: empty array" {
    let v: json.Value = json.parse("[]")
    match v {
        .Array(items) -> assert len(items) == 0
        else -> fail("expected Array")
    }
}

test "parse: array of numbers" {
    let v: json.Value = json.parse("[1, 2, 3]")
    match v {
        .Array(items) -> {
            assert len(items) == 3
            let item0: json.Value = items[0]
            match item0 {
                .Number(n) -> assert n == 1
                else -> fail("expected Number at [0]")
            }
            let item1: json.Value = items[1]
            match item1 {
                .Number(n) -> assert n == 2
                else -> fail("expected Number at [1]")
            }
            let item2: json.Value = items[2]
            match item2 {
                .Number(n) -> assert n == 3
                else -> fail("expected Number at [2]")
            }
        }
        else -> fail("expected Array")
    }
}

test "parse: empty object" {
    let v: json.Value = json.parse("{}")
    match v {
        .Object(keys, _values) -> assert len(keys) == 0
        else -> fail("expected Object")
    }
}

test "parse: object" {
    let v: json.Value = json.parse("{\"name\": \"alice\", \"age\": 30}")
    let name: json.Value = json.get(v, key: "name")
    match name {
        .Str(s) -> assert s == "alice"
        else -> fail("expected Str for name")
    }
    let age: json.Value = json.get(v, key: "age")
    match age {
        .Number(n) -> assert n == 30
        else -> fail("expected Number for age")
    }
    let missing: json.Value = json.get(v, key: "missing")
    match missing {
        .Null -> {}
        else -> fail("expected Null for missing key")
    }
}

test "parse: nested" {
    let v: json.Value = json.parse("{\"items\": [1, 2, {\"k\": true}]}")
    let items_v: json.Value = json.get(v, key: "items")
    match items_v {
        .Array(items) -> {
            assert len(items) == 3
            let item0: json.Value = items[0]
            match item0 {
                .Number(n) -> assert n == 1
                else -> fail("expected Number at [0]")
            }
            let item2: json.Value = items[2]
            let inner: json.Value = json.get(item2, key: "k")
            match inner {
                .Bool(b) -> assert b == true
                else -> fail("expected Bool for k")
            }
        }
        else -> fail("expected Array")
    }
}

// Accessor coverage — the optional-wrap-on-zero codegen bug used to make
// `Some(0)` and `Some(false)` round-trip to `none`, so these cases stayed
// uncovered until ea0a0e9. The `match … { Some(v) -> …; none -> fail }`
// shape is used instead of `if … is Some(v) { … } else { … }` because the
// parser lowers an `if is` into a one-arm match and doesn't attach the
// trailing `else`.

test "as_int: positive" {
    let pos: int64? = json.as_int(json.parse("42"))
    match pos {
        Some(p) -> assert p == 42
        none -> fail("expected Some")
    }
}

test "as_int: negative" {
    let neg: int64? = json.as_int(json.parse("-7"))
    match neg {
        Some(n) -> assert n == -7
        none -> fail("expected Some")
    }
}

test "as_int: zero (regression: optional-wrap-on-zero)" {
    let zero: int64? = json.as_int(json.parse("0"))
    match zero {
        Some(z) -> assert z == 0
        none -> fail("as_int(0) round-tripped to none")
    }
}

test "as_bool: true" {
    let t: bool? = json.as_bool(json.parse("true"))
    match t {
        Some(tv) -> assert tv == true
        none -> fail("expected Some")
    }
}

test "as_bool: false (regression: optional-wrap-on-zero)" {
    let f: bool? = json.as_bool(json.parse("false"))
    match f {
        Some(fv) -> assert fv == false
        none -> fail("as_bool(false) round-tripped to none")
    }
}

test "as_int / as_bool: wrong type returns none" {
    let not_int: int64? = json.as_int(json.parse("\"hi\""))
    assert not_int is none
    let not_bool: bool? = json.as_bool(json.parse("0"))
    assert not_bool is none
}

test "as_str: returns string" {
    let s: str? = json.as_str(json.parse("\"hi\""))
    match s {
        Some(sv) -> assert sv == "hi"
        none -> fail("expected Some")
    }
}

test "emit: null" {
    let s: str = json.emit(json.Value.Null)
    assert s == "null"
}

test "emit: true / false" {
    let t: str = json.emit(json.Value.Bool(value: true))
    assert t == "true"
    let f: str = json.emit(json.Value.Bool(value: false))
    assert f == "false"
}

test "emit: integers" {
    let pos: str = json.emit(json.Value.Number(value: 42))
    assert pos == "42"
    let neg: str = json.emit(json.Value.Number(value: -7))
    assert neg == "-7"
}

test "emit: simple string" {
    let s: str = json.emit(json.Value.Str(value: "hi"))
    assert s == "\"hi\""
}

test "emit: string escapes" {
    let nl: str = json.emit(json.Value.Str(value: "a\nb"))
    assert nl == "\"a\\nb\""
    let quoted: str = json.emit(json.Value.Str(value: "x\"y"))
    assert quoted == "\"x\\\"y\""
}

test "emit: array" {
    let items: [json.Value] = [json.Value.Number(value: 1), json.Value.Number(value: 2)]
    let s: str = json.emit(json.Value.Array(items: items))
    assert s == "[1,2]"
}

test "emit: object" {
    let keys: [str] = ["a"]
    let values: [json.Value] = [json.Value.Number(value: 1)]
    let s: str = json.emit(json.Value.Object(keys: keys, values: values))
    assert s == "{\"a\":1}"
}

test "round-trip: nested structure" {
    let src: str = "{\"name\":\"alice\",\"tags\":[\"a\",\"b\"],\"meta\":{\"n\":42}}"
    let out: str = json.emit(json.parse(src))
    assert out == src
}
