// Filesystem operations. Backed by C in stdlib/runtime.c.

// Read the file at `path` and return its contents. Returns the empty
// string if the file can't be opened.
extern func read_file(anon path: str) -> str

// Write `content` to a file at `path`, replacing it if it exists.
// Returns 0 on success, -1 on failure. The parent directory must
// already exist (no mkdir -p; caller's responsibility).
extern func write_file(anon path: str, anon content: str) -> int64
