type IoError = struct {
    message: str

    func to_str(self) -> str {
        return self.message
    }
}

func read_size(anon path: str) -> int64 or Error {
    if path == "missing.txt" {
        throw IoError(message: f"file not found: {path}")
    }
    if path == "forbidden.txt" {
        throw IoError(message: "permission denied")
    }
    return 42
}

func use_must() -> int64 {
    let n: int64 = must read_size("ok.txt")
    return n
}

func use_try() -> int64 or Error {
    let n: int64 = try read_size("ok.txt")
    return n + 1
}

func main() -> int64 {
    let a: int64 = use_must()
    let b: int64 = must use_try()
    print(f"a={a} b={b}")
    return 0
}

// expected status:
// 0
// expected output:
// a=42 b=43
