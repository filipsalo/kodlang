import "set"

// Type aliases instead of inline `Set[int64]` at each use site —
// reads better and keeps the verbose constructor in one place.
type IntSet = Set[int64]
type StrSet = Set[str]

func empty_int_set() -> IntSet {
    return IntSet(items: Map[int64, bool](keys: [], values: [], indices: []))
}

func empty_str_set() -> StrSet {
    return StrSet(items: Map[str, bool](keys: [], values: [], indices: []))
}

test "empty: len 0, contains nothing" {
    let s: IntSet = empty_int_set()
    assert len(s) == 0
    assert s.contains(42) == false
}

test "add then contains" {
    let s: IntSet = empty_int_set()
    s.add(7)
    assert s.contains(7)
    assert s.contains(8) == false
    assert len(s) == 1
}

test "adding the same element twice is idempotent" {
    let s: IntSet = empty_int_set()
    s.add(7)
    s.add(7)
    s.add(7)
    assert len(s) == 1
    assert s.contains(7)
}

test "many adds grow the underlying table" {
    let s: IntSet = empty_int_set()
    let i: int64 = 0
    for i < 50 {
        s.add(i * 3)
        i = i + 1
    }
    assert len(s) == 50
    assert s.contains(0)
    assert s.contains(49 * 3)
    assert s.contains(1) == false
}

test "Set[str] uses content equality, not pointer identity" {
    let s: StrSet = empty_str_set()
    s.add("hello")
    let lookup: str = "hel" + "lo"
    // Distinct buffer, same bytes — should still hit.
    assert s.contains(lookup)
    assert s.contains("world") == false
}
