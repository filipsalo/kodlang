// Round-trip stdin through both readers. Reads two lines (greeting,
// then "Content-Length: N"), then exactly N bytes of body, then echoes
// what we got back to stdout. Used by the LSP-framing groundwork.
import "io"

func main() -> int64 {
    let greet: str = io.read_stdin_line()
    let hdr: str = io.read_stdin_line()
    // hdr is "Content-Length: N" (no trailing CR — read_stdin_line strips it).
    mut n: int64 = parse_content_length(hdr)
    let _blank: str = io.read_stdin_line()
    let body: str = io.read_stdin_exact(n)
    print(f"greet={greet}")
    print(f"n={n.to_str()}")
    print(f"body={body}")
    return 0
}

func parse_content_length(anon line: str) -> int64 {
    // Skip "Content-Length: " (16 chars).
    let prefix_len: int64 = 16
    mut n: int64 = 0
    mut i: int64 = prefix_len
    for i < len(line) {
        let c: int64 = line[i]
        if c >= '0' and c <= '9' {
            n = n * 10 + (c - '0')
        }
        i = i + 1
    }
    return n
}

// expected status:
// 0
// expected output:
// greet=
// n=0
// body=
