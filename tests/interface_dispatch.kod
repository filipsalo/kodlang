interface Named {
    func display(self) -> none
}

type A = struct {
    label: str
    func display(self) -> none {
        print(self.label)
    }
}

type B = struct {
    label: str
    func display(self) -> none {
        print(f"B:{self.label}")
    }

    // Method taking an interface arg — exercises upcast inside
    // compile_method_call (caller arg → interface param).
    func render(self, n: Named) -> none {
        n.display()
    }
}

func main() -> int64 {
    let a: A = A(label: "alpha")
    let b: B = B(label: "beta")
    b.render(n: a)
    b.render(n: b)
    return 0
}

// expected status:
// 0
// expected output:
// alpha
// B:beta
