func other_func(msg: str) -> none {
	print(msg)
}

func main() -> int64 {
	other_func(msg: 123)
	other_func("hello")
	other_func()
	other_func("hello", 123)
}

// expected errors:
// 7:13: error: parameter 0 of `other_func` requires label `msg`
// 8:2: error: `other_func` takes 1 arguments, got 0
// 9:2: error: `other_func` takes 1 arguments, got 2
