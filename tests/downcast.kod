// Interface downcasting: recover a thrown error's concrete type from the
// boxed `Error`, via `match` and the `is` operator. Runs under both frontends.

type DiskFull = struct {
    bytes: int64
    func to_str(self) -> str { return "disk full" }
}

type NotFound = struct {
    path: str
    func to_str(self) -> str { return "not found" }
}

func open_(anon which: int64) -> int64 or Error {
    if which == 1 {
        throw DiskFull(bytes: 100)
    }
    throw NotFound(path: "/etc/x")
}

func main() -> int64 {
    match open_(1) {
        Ok(_v) -> print("ok")
        Err(e) -> {
            if e is DiskFull(d) {
                print_int(d.bytes)
            }
            if e is NotFound {
                print("unexpected")
            }
        }
    }
    match open_(2) {
        Ok(_v) -> print("ok")
        Err(e) -> {
            match e {
                NotFound(n) -> print(n.path)
                else -> print("?")
            }
        }
    }
    return 0
}

// expected output:
// 100
// /etc/x
